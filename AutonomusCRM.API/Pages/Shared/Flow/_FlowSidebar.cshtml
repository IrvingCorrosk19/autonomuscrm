    </a>

    <div class="flow-nav-section">@L["Nav_Section_Admin"]</div>
    <a href="/Users" class="flow-nav-item @(Active("/Users") ? "is-active" : "")">
      <span class="flow-nav-icon" aria-hidden="true">👤</span>
      <span class="flow-nav-text">@L["Nav_Users"]</span>
    </a>
    <a href="/Policies" class="flow-nav-item @(Active("/Policies") ? "is-active" : "")">
      <span class="flow-nav-icon" aria-hidden="true">⚖</span>
      <span class="flow-nav-text">@L["Nav_Policies"]</span>
    </a>
    <a href="/Audit" class="flow-nav-item @(Active("/Audit") ? "is-active" : "")">
      <span class="flow-nav-icon" aria-hidden="true">📋</span>
      <span class="flow-nav-text">@L["Nav_Audit"]</span>
    </a>
    <a href="/Settings" class="flow-nav-item @(Active("/Settings") ? "is-active" : "")">
      <span class="flow-nav-icon" aria-hidden="true">⚙</span>
      <span class="flow-nav-text">@L["Nav_Settings"]</span>
    </a>
    <a href="/billing" class="flow-nav-item @(Active("/Billing") ? "is-active" : "")">
      <span class="flow-nav-icon" aria-hidden="true">💳</span>
      <span class="flow-nav-text">@L["Nav_Billing"]</span>
    </a>
  </nav>
</aside>
