@{
    var ctx = ViewData["RuntimeContextLabel"] as string ?? L["Nav_Runtime_Operation"].Value;
}
<div class="crm-runtime-bar" id="crm-runtime-bar" role="navigation" aria-label="@L["Nav_Runtime_AriaLabel"]">
  <span class="crm-runtime-context">
    <i class="fas fa-layer-group mr-1" aria-hidden="true"></i>
    <span id="crm-runtime-context-label">@ctx</span>
  </span>
  <div class="crm-runtime-links">
    <a class="btn btn-xs btn-outline-secondary" href="/" data-crm-module="dashboard">@L["Nav_Runtime_Dashboard"]</a>
    <a class="btn btn-xs btn-outline-secondary" href="/Leads" data-crm-module="leads">@L["Nav_Runtime_Leads"]</a>
    <a class="btn btn-xs btn-outline-secondary" href="/Deals" data-crm-module="deals">@L["Nav_Runtime_Pipeline"]</a>
    <a class="btn btn-xs btn-outline-secondary" href="/Customers" data-crm-module="customers">@L["Nav_Runtime_Customers"]</a>
    <a class="btn btn-xs btn-outline-secondary" href="/Workflows" data-crm-module="workflows">@L["Nav_Runtime_Workflows"]</a>
    <a class="btn btn-xs btn-outline-secondary" href="/Agents" data-crm-module="agents">@L["Nav_Runtime_Agents"]</a>
    <a class="btn btn-xs btn-outline-secondary" href="/Tasks" data-crm-module="tasks">@L["Nav_Runtime_Tasks"]</a>
    <a class="btn btn-xs btn-outline-secondary" href="/Audit" data-crm-module="audit">@L["Nav_Runtime_Audit"]</a>
  </div>
  <a href="#" class="crm-runtime-resume crm-hidden" id="crm-runtime-resume" title="@L["Nav_Runtime_ResumeTitle"]">
  <i class="fas fa-history mr-1" aria-hidden="true"></i>@L["Nav_Runtime_Continue"] <span id="crm-runtime-resume-label"></span>
  </a>
</div>
