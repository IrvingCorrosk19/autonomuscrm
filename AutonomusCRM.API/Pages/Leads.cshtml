@page
@model AutonomusCRM.API.Pages.LeadsModel
@using AutonomusCRM.Domain.Leads
@{
    ViewData["Title"] = "Leads";
    ViewData["PageTitle"] = "Leads";
    ViewData["PageKicker"] = "Comercial";
    ViewData["PageSubtitle"] = "Lista de prospectos, filtros y acciones sobre tu cartera.";
    ViewData["PageActionsHtml"] = @"<button type=""button"" class=""btn btn-outline-secondary"" onclick=""showBulkActionsModal()""><i class=""fas fa-tasks mr-1""></i>Masivas</button>
        <a href=""/Leads/Import"" class=""btn btn-outline-secondary"" onclick=""event.preventDefault(); showImportModal();""><i class=""fas fa-file-import mr-1""></i>Importar</a>
        <a href=""/Leads/Create"" class=""btn btn-primary""><i class=""fas fa-plus mr-1""></i>Nuevo lead</a>";

    var avgScore = Model.Leads.Any(l => l.Score.HasValue)
        ? Model.Leads.Where(l => l.Score.HasValue).Average(l => l.Score!.Value)
        : (double?)null;
    var conversionPct = Model.Leads.Any()
        ? Model.Leads.Count(l => l.Status == LeadStatus.Qualified) * 100.0 / Model.Leads.Count
        : 0;
    var sourceStats = Model.Leads
        .GroupBy(l => l.Source)
        .Select(g => new {
            Source = g.Key,
            Count = g.Count(),
            Qualified = g.Count(l => l.Status == LeadStatus.Qualified)
        })
        .OrderByDescending(x => x.Count)
        .ToList();
}

<partial name="Flow/_FlowPageHeader" />

@if (Model.Created == true)
{
  <div class="alert alert-success alert-dismissible fade show" role="alert">
    <i class="fas fa-check mr-1"></i> El lead ha sido creado correctamente.
    <button type="button" class="close" data-dismiss="alert"><span>&times;</span></button>
  </div>
}

<!-- Filtros -->
<div class="crm-filter-card">
  <form method="get" class="crm-filter-form">
    <div class="form-group" style="flex: 2 1 220px;">
      <label for="search">Buscar</label>
      <input type="text" id="search" name="search" class="form-control" value="@Model.SearchTerm" placeholder="Nombre, empresa o email..." />
    </div>
    <div class="form-group">
      <label for="status">Estado</label>
      <select id="status" name="status" class="form-control">
        <option value="">Todos</option>
        @foreach (var status in Enum.GetValues<LeadStatus>())
        {
          <option value="@((int)status)" selected="@(Model.FilterStatus == status)">@status</option>
        }
      </select>
    </div>
    <div class="form-group">
      <label for="source">Fuente</label>
      <select id="source" name="source" class="form-control">
        <option value="">Todas</option>
        @foreach (var source in Enum.GetValues<LeadSource>())
        {
          <option value="@((int)source)" selected="@(Model.FilterSource == source)">@source</option>
        }
      </select>
    </div>
    <div class="crm-filter-actions">
      <button type="submit" class="btn btn-primary"><i class="fas fa-filter mr-1"></i>Filtrar</button>
      @if (!string.IsNullOrWhiteSpace(Model.SearchTerm) || Model.FilterStatus.HasValue || Model.FilterSource.HasValue)
      {
        <a href="/Leads" class="btn btn-outline-secondary">Limpiar</a>
      }
    </div>
  </form>
</div>

<section class="flow-metric-grid" aria-label="Métricas de leads">
  @{ ViewData["FlowMetricLabel"] = "Total leads"; ViewData["FlowMetricValue"] = Model.Leads.Count.ToString(); ViewData["FlowMetricHint"] = $"{Model.FilteredLeads.Count} mostrados"; ViewData["FlowMetricVariant"] = "info"; }
  <partial name="Flow/_FlowMetricCard" />
  @{ ViewData["FlowMetricLabel"] = "Score promedio"; ViewData["FlowMetricValue"] = avgScore.HasValue ? avgScore.Value.ToString("F0") : "—"; ViewData["FlowMetricHint"] = $"{Model.Leads.Count(l => l.Score > 70)} con score alto"; ViewData["FlowMetricVariant"] = "success"; }
  <partial name="Flow/_FlowMetricCard" />
  @{ ViewData["FlowMetricLabel"] = "Conversión"; ViewData["FlowMetricValue"] = conversionPct.ToString("F1") + "%"; ViewData["FlowMetricHint"] = $"{Model.Leads.Count(l => l.Status == LeadStatus.Qualified)} calificados"; ViewData["FlowMetricVariant"] = "ai"; }
  <partial name="Flow/_FlowMetricCard" />
  @{ ViewData["FlowMetricLabel"] = "Pendientes"; ViewData["FlowMetricValue"] = Model.Leads.Count(l => l.Status == LeadStatus.New).ToString(); ViewData["FlowMetricHint"] = "Estado: New"; ViewData["FlowMetricVariant"] = "warning"; }
  <partial name="Flow/_FlowMetricCard" />
</section>

<section class="flow-card mt-4" data-flow-datatable>
  <header class="flow-card-header">
    <div>
      <h3 class="flow-card-title">Listado de leads</h3>
      <p class="text-muted mb-0" style="font-size:13px;">@Model.FilteredLeads.Count de @Model.Leads.Count registros</p>
    </div>
  </header>
  <div class="flow-datatable-toolbar">
    <input type="search" class="flow-datatable-search" placeholder="Buscar leads…" aria-label="Buscar leads" />
  </div>
  <div class="flow-card-body flow-crm-table-wrap" style="padding:0;">
      <table class="flow-table-minimal flow-datatable" aria-label="Lista de leads">
        <thead>
          <tr>
            <th style="width:36px;"><input type="checkbox" id="selectAll" onclick="toggleSelectAll()" aria-label="Seleccionar todos" /></th>
            <th>Lead</th>
            <th>Score</th>
            <th>Estado</th>
            <th>Fuente</th>
            <th style="width:100px;">Acciones</th>
          </tr>
        </thead>
        <tbody>
          @if (Model.FilteredLeads.Any())
          {
            @foreach (var lead in Model.FilteredLeads)
            {
              var statusClass = lead.Status switch {
                LeadStatus.New => "status-new",
                LeadStatus.Contacted => "status-contacted",
                LeadStatus.Qualified => "status-qualified",
                LeadStatus.Converted => "status-converted",
                LeadStatus.Lost => "status-lost",
                _ => "status-unqualified"
              };
              var search = $"{lead.Name} {lead.Company} {lead.Email} {lead.Status} {lead.Source}".ToLowerInvariant();
              var drawerBody = $"{lead.Company ?? "—"} · {lead.Email ?? ""} · Score {(lead.Score?.ToString() ?? "—")} · {lead.Status}";
              <tr data-search="@search" data-drawer-title="@lead.Name" data-drawer-body="@drawerBody" data-drawer-href="/Leads/Details/@lead.Id">
                <td><input type="checkbox" name="leadIds" value="@lead.Id" onclick="event.stopPropagation();" /></td>
                <td>
                  <div style="font-weight:600;font-size:13px;"><a href="/Leads/Details/@lead.Id">@lead.Name</a></div>
                  <div style="font-size:12px;color:var(--flow-text-muted);">@(lead.Company ?? "—")@(string.IsNullOrEmpty(lead.Email) ? "" : " · " + lead.Email)</div>
                </td>
                <td>
                  @if (lead.Score.HasValue)
                  {
                    <span class="flow-score-pill @(lead.Score >= 70 ? "flow-score-pill--ok" : lead.Score >= 50 ? "flow-score-pill--warn" : "flow-score-pill--danger")">@lead.Score</span>
                  }
                  else { <span class="flow-score-pill">—</span> }
                </td>
                <td>@lead.Status</td>
                <td>@lead.Source</td>
                <td class="flow-row-actions">
                  <a href="/Leads/Details/@lead.Id" class="flow-btn flow-btn-secondary" style="font-size:11px;padding:4px 8px;" onclick="event.stopPropagation();">Ver</a>
                  <a href="/Leads/Edit/@lead.Id" class="flow-btn flow-btn-secondary" style="font-size:11px;padding:4px 8px;" onclick="event.stopPropagation();">Editar</a>
                </td>
              </tr>
            }
          }
          else
          {
            <tr>
              <td colspan="6" class="table-empty">
                @if (!string.IsNullOrWhiteSpace(Model.SearchTerm) || Model.FilterStatus.HasValue || Model.FilterSource.HasValue)
                {
                  <text>No hay resultados. <a href="/Leads">Limpiar filtros</a></text>
                }
                else
                {
                  <text>No hay leads. <a href="/Leads/Create">Crear el primero</a></text>
                }
              </td>
            </tr>
          }
        </tbody>
      </table>
  </div>
  <footer class="flow-card-body" style="border-top:1px solid var(--flow-border-default); display:flex; gap:8px; flex-wrap:wrap;">
    <button class="flow-btn flow-btn-secondary" type="button" onclick="exportLeads()">Exportar JSON</button>
    <button class="flow-btn flow-btn-secondary" type="button" onclick="showBulkActionsModal()">Acciones masivas</button>
  </footer>
</section>

<!-- Análisis (colapsable) -->
<div class="card crm-collapse-card">
  <div class="card-header" data-toggle="collapse" data-target="#leadsAnalytics" aria-expanded="false">
    <div class="d-flex justify-content-between align-items-center w-100">
      <div>
        <h3><i class="fas fa-chart-pie text-muted mr-2"></i>Análisis y distribución</h3>
        <span class="text-muted">Fuentes y resumen — no es necesario para el día a día</span>
      </div>
      <i class="fas fa-chevron-down text-muted"></i>
    </div>
  </div>
  <div id="leadsAnalytics" class="collapse">
    <div class="card-b">
      <div class="row">
        <div class="col-md-6">
          <h4 class="crm-section-title">Por fuente (datos reales)</h4>
          @if (sourceStats.Any())
          {
            <table class="table table-sm">
              <thead><tr><th>Fuente</th><th>Cantidad</th><th>Calificados</th></tr></thead>
              <tbody>
                @foreach (var s in sourceStats)
                {
                  var rate = s.Count > 0 ? (s.Qualified * 100.0 / s.Count) : 0;
                  <tr>
                    <td>@s.Source</td>
                    <td>@s.Count</td>
                    <td><span class="badge @(rate >= 20 ? "ok" : "warn")">@rate.ToString("F0")%</span></td>
                  </tr>
                }
              </tbody>
            </table>
          }
          else
          {
            <p class="text-muted">Sin datos de fuentes.</p>
          }
        </div>
        <div class="col-md-6">
          <h4 class="crm-section-title">Sugerencias</h4>
          <ul class="text-muted mb-0 pl-3">
            @if (Model.Leads.Any(l => l.Status == LeadStatus.New))
            {
              <li>@Model.Leads.Count(l => l.Status == LeadStatus.New) lead(s) nuevos pendientes de calificar.</li>
            }
            @if (Model.Leads.Any(l => !l.Score.HasValue))
            {
              <li>@Model.Leads.Count(l => !l.Score.HasValue) sin score (activa agentes IA o califica manualmente).</li>
            }
            @if (!Model.Leads.Any(l => l.Status == LeadStatus.New) && Model.Leads.Any())
            {
              <li>No hay leads nuevos sin revisar.</li>
            }
          </ul>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Modales -->
<div id="importModal" class="crm-modal-backdrop">
  <div class="crm-modal">
    <div class="crm-modal-header"><h3>Importar leads</h3></div>
    <div class="crm-modal-body">
      <form method="post" action="/Leads/Import" enctype="multipart/form-data">
        <label class="form-label-crm">Archivo JSON o CSV *</label>
        <input type="file" name="file" class="form-control" accept=".json,.csv" required />
        <small class="text-muted d-block mt-2">CSV: Name,Email,Phone,Company,Source</small>
        <div class="crm-modal-footer px-0 pb-0">
          <button type="button" class="btn btn-outline-secondary" onclick="closeImportModal()">Cancelar</button>
          <button type="submit" class="btn btn-primary">Importar</button>
        </div>
      </form>
    </div>
  </div>
</div>

<div id="bulkActionsModal" class="crm-modal-backdrop">
  <div class="crm-modal">
    <div class="crm-modal-header"><h3>Acciones masivas</h3></div>
    <div class="crm-modal-body">
      <form method="post" action="/Leads/BulkActions">
        <input type="hidden" id="selectedLeadIds" name="leadIds" />
        <input type="hidden" name="action" value="updateStatus" />
        <label class="form-label-crm">Cambiar estado a</label>
        <select name="status" class="form-control" required>
          @foreach (var status in Enum.GetValues<LeadStatus>())
          {
            <option value="@status">@status</option>
          }
        </select>
        <div class="crm-modal-footer px-0 pb-0">
          <button type="button" class="btn btn-outline-secondary" onclick="closeBulkActionsModal()">Cancelar</button>
          <button type="submit" class="btn btn-primary">Aplicar</button>
        </div>
      </form>
    </div>
  </div>
</div>

<partial name="Flow/_FlowDrawer" />

@section Scripts {
<script src="~/js/flow-worldclass.js" asp-append-version="true"></script>
<script>
function exportLeads() {
  const leads = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.FilteredLeads.Select(l => new { l.Id, l.Name, l.Email, l.Phone, l.Company, Source = l.Source.ToString(), Status = l.Status.ToString(), l.Score, CreatedAt = l.CreatedAt.ToString("yyyy-MM-dd HH:mm") })));
  const blob = new Blob([JSON.stringify(leads, null, 2)], { type: 'application/json' });
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = 'leads-' + new Date().toISOString().split('T')[0] + '.json';
  a.click();
  URL.revokeObjectURL(a.href);
}
function showBulkActionsModal() {
  const selected = Array.from(document.querySelectorAll('input[name="leadIds"]:checked')).map(cb => cb.value);
  if (!selected.length) { alert('Selecciona al menos un lead'); return; }
  document.getElementById('selectedLeadIds').value = selected.join(',');
  document.getElementById('bulkActionsModal').classList.add('show');
}
function closeBulkActionsModal() { document.getElementById('bulkActionsModal').classList.remove('show'); }
function showImportModal() { document.getElementById('importModal').classList.add('show'); }
function closeImportModal() { document.getElementById('importModal').classList.remove('show'); }
function toggleSelectAll() {
  const on = document.getElementById('selectAll').checked;
  document.querySelectorAll('input[name="leadIds"]').forEach(cb => cb.checked = on);
}
document.querySelectorAll('.crm-modal-backdrop').forEach(el => {
  el.addEventListener('click', e => { if (e.target === el) el.classList.remove('show'); });
});
</script>
}
