@page "/Memory"
@model AutonomusCRM.API.Pages.MemoryModel
@{
    ViewData["Title"] = L["Memory_PageTitle"].Value;
    ViewData["PageTitle"] = L["Memory_BusinessMemory"].Value;
    ViewData["PageKicker"] = L["Nav_Section_Intelligence"].Value;
    ViewData["PageSubtitle"] = L["Memory_BusinessMemory"].Value;
    var d = Model.Dashboard;
}
<partial name="Flow/_FlowPageHeader" />

@if (d == null)
{
  <partial name="Flow/_FlowEmptyState" />
}
else
{
  @if (Model.EmbeddingStatus != null)
  {
    <div class="alert alert-info" role="status" style="margin-bottom:16px;">
      <strong>@L["Memory_Embeddings"]:</strong> @Model.EmbeddingStatus.ActiveProvider
      @if (!Model.EmbeddingStatus.IsProductionProvider)
      {
        <span class="flow-revenue-priority">@Model.EmbeddingStatus.Badge</span>
      }
    </div>
  }

  <section class="flow-metric-grid" style="margin-bottom:24px;">
    @{ ViewData["FlowMetricLabel"] = L["Memory_TotalMemories"].Value; ViewData["FlowMetricValue"] = d.TotalMemories.ToString("N0"); ViewData["FlowMetricVariant"] = "ai"; }
    <partial name="Flow/_FlowMetricCard" />
    @{ ViewData["FlowMetricLabel"] = L["Memory_LearnedPatterns"].Value; ViewData["FlowMetricValue"] = d.LearnedPatterns.ToString("N0"); ViewData["FlowMetricVariant"] = "success"; }
    <partial name="Flow/_FlowMetricCard" />
    @{ ViewData["FlowMetricLabel"] = L["Revenue_Insights"].Value; ViewData["FlowMetricValue"] = d.TopInsights.Count.ToString(); ViewData["FlowMetricVariant"] = "info"; }
    <partial name="Flow/_FlowMetricCard" />
  </section>

  <div class="flow-revenue-grid">
    <section class="flow-card">
      <header class="flow-card-header"><h3 class="flow-card-title">@L["Memory_SuccessfulDecisions"]</h3></header>
      <div class="flow-card-body">
        @if (d.MostSuccessfulDecisions.Count == 0)
        {
          <p class="text-muted">@L["Memory_NoDecisionsIndexed"]</p>
        }
        else
        {
          <ul class="flow-list-minimal">
            @foreach (var item in d.MostSuccessfulDecisions)
            {
              <li><strong>@item.SourceType</strong> — @item.Text</li>
            }
          </ul>
        }
      </div>
    </section>

    <section class="flow-card">
      <header class="flow-card-header"><h3 class="flow-card-title">@L["Route_Playbooks"]</h3></header>
      <div class="flow-card-body">
        @if (d.MostEffectivePlaybooks.Count == 0)
        {
          <p class="text-muted">@L["Common_NoData"]</p>
        }
        else
        {
          <ul class="flow-list-minimal">
            @foreach (var item in d.MostEffectivePlaybooks)
            {
              <li><strong>@item.SourceType</strong> — @item.Text</li>
            }
          </ul>
        }
      </div>
    </section>
  </div>

  <section class="flow-card" style="margin-top:24px;">
    <header class="flow-card-header"><h3 class="flow-card-title">@L["Memory_BusinessMemory"]</h3></header>
    <div class="flow-card-body">
      <table class="flow-table-minimal">
        <thead><tr><th>@L["Executive_Date"]</th><th>@L["Common_Type"]</th><th>@L["Common_Summary"]</th></tr></thead>
        <tbody>
          @foreach (var t in Model.Timeline)
          {
            <tr>
              <td>@t.OccurredAt.ToString("g")</td>
              <td>@t.ItemType</td>
              <td>@(t.Summary.Length > 120 ? t.Summary[..120] + "…" : t.Summary)</td>
            </tr>
          }
        </tbody>
      </table>
    </div>
  </section>
}

