@page
@model AutonomusCRM.API.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Iniciar sesión";
    Layout = null;
}
<!doctype html>
<html lang="es">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Iniciar sesión - AUTONOMUS CRM</title>
  <link rel="stylesheet" href="~/css/site.css" />
  <style>
    .login-wrap { min-height: 100vh; display: grid; place-items: center; padding: 2rem; }
    .login-card { width: min(420px, 100%); background: var(--card, #111); border: 1px solid var(--border, #2a2a2a); border-radius: 16px; padding: 2rem; }
    .login-card h1 { margin: 0 0 .5rem; font-size: 1.5rem; }
    .login-card p { margin: 0 0 1.5rem; opacity: .75; }
    .login-card label { display: block; margin-bottom: .35rem; font-size: .85rem; }
    .login-card input { width: 100%; margin-bottom: 1rem; padding: .65rem .75rem; border-radius: 8px; border: 1px solid var(--border, #333); background: #0a0a0a; color: #fff; }
    .login-card button { width: 100%; padding: .75rem; border: 0; border-radius: 8px; background: #3b82f6; color: #fff; font-weight: 600; cursor: pointer; }
    .error { color: #f87171; margin-bottom: 1rem; }
    .hint { font-size: .8rem; opacity: .65; margin-top: 1rem; }
  </style>
</head>
<body>
  <div class="login-wrap">
    <div class="login-card">
      <h1>AUTONOMUS CRM</h1>
      <p>Acceso seguro al sistema</p>
      @if (!string.IsNullOrEmpty(Model.ErrorMessage))
      {
        <div class="error">@Model.ErrorMessage</div>
      }
      <form method="post">
        <label for="TenantId">Tenant ID</label>
        <input asp-for="TenantId" id="TenantId" placeholder="GUID del tenant" required />
        <label for="Email">Email</label>
        <input asp-for="Email" id="Email" type="email" required />
        <label for="Password">Contraseña</label>
        <input asp-for="Password" id="Password" type="password" required />
        <button type="submit">Entrar</button>
      </form>
      <p class="hint">Demo local: admin@autonomuscrm.local / Admin123! (tras seed)</p>
    </div>
  </div>
</body>
</html>
