@page
@model AutonomusCRM.API.Pages.UsersModel
@{
    ViewData["Title"] = "Usuarios y Roles - AUTONOMUS CRM";
}

<!-- TOPBAR -->
<header class="topbar">
  <div class="topbar-left">
    <div class="kicker">Gestión de usuarios</div>
    <h2 class="headline">Usuarios, roles y permisos</h2>
  </div>

  <div class="topbar-center">
    <form method="get" class="crm-filter-bar crm-filter-bar-full">
      <div class="search crm-grow" role="search">
        <input type="text" name="search" value="@Model.SearchTerm" placeholder="Buscar usuarios por email, nombre, rol..." aria-label="Buscar" />
      </div>
      <button type="submit" class="btn crm-text-nowrap">Buscar</button>
      @if (!string.IsNullOrWhiteSpace(Model.SearchTerm))
      {
        <a href="/Users" class="btn crm-text-nowrap crm-link-btn">Limpiar</a>
      }
    </form>
  </div>

  <div class="topbar-right">
    <button class="btn mobile-toggle" type="button" onclick="toggleSidebar()">Menú</button>
    <button class="btn" type="button" onclick="showImportModal()">Importar</button>
    <a href="/Users/Create" class="btn primary crm-link-btn">Nuevo Usuario</a>
  </div>
</header>

<!-- STATS -->
<section class="stats" aria-label="Métricas de usuarios">
  <div class="stat">
    <div class="label">Total usuarios</div>
    <div class="value">@Model.Users.Count</div>
    <div class="hint">
      <span>Registrados</span>
      <span class="delta up">@Model.Users.Count(u => u.IsActive) activos</span>
    </div>
  </div>

  <div class="stat">
    <div class="label">MFA activado</div>
    <div class="value">@Model.Users.Count(u => u.MfaEnabled)</div>
    <div class="hint">
      <span>@(Model.Users.Any() ? (Model.Users.Count(u => u.MfaEnabled) * 100 / Model.Users.Count) : 0)% cobertura</span>
      <span class="delta up">@Model.Users.Count(u => u.MfaEnabled) usuarios</span>
    </div>
  </div>

  <div class="stat">
    <div class="label">Usuarios activos</div>
    <div class="value">@Model.Users.Count(u => u.IsActive)</div>
    <div class="hint">
      <span>En el sistema</span>
      <span class="delta up">@Model.Users.Count total</span>
    </div>
  </div>

  <div class="stat">
    <div class="label">Con roles</div>
    <div class="value">@Model.Users.Count(u => u.Roles != null && u.Roles.Any())</div>
    <div class="hint">
      <span>Asignados</span>
      <span class="delta ok">✓</span>
    </div>
  </div>
</section>

<section class="grid">
  <!-- LEFT: Users Table -->
  <div class="card">
    <div class="card-h">
      <div>
        <h3 class="title">Usuarios del sistema</h3>
        <p class="subtitle">
          Gestión de usuarios, roles, permisos y configuración de seguridad.
        </p>
      </div>
      <span class="pill">@Model.FilteredUsers.Count de @Model.Users.Count usuarios</span>
    </div>

    <div class="card-b">
      <table class="table" aria-label="Lista de usuarios">
        <thead>
          <tr>
            <th><input type="checkbox" id="selectAll" onclick="toggleSelectAll()" /></th>
            <th>Usuario</th>
            <th>Rol</th>
            <th>MFA</th>
            <th>Estado</th>
            <th>Acciones</th>
          </tr>
        </thead>
        <tbody>
          @if (Model.FilteredUsers.Any())
          {
            @foreach (var user in Model.FilteredUsers)
            {
              <tr>
                <td><input type="checkbox" name="userIds" value="@user.Id" /></td>
                <td>
                  <div class="crm-meta-strong">@user.Email</div>
                  <div class="crm-meta-muted">
                    @if (!string.IsNullOrEmpty(user.FirstName) || !string.IsNullOrEmpty(user.LastName))
                    {
                      <text>@($"{user.FirstName} {user.LastName}".Trim())</text>
                    }
                    else
                    {
                      <text>Usuario</text>
                    }
                  </div>
                </td>
                <td>
                  @if (user.Roles != null && user.Roles.Any())
                  {
                    <span class="badge @(user.Roles.Contains("Admin") ? "danger" : user.Roles.Contains("Manager") ? "warn" : "")">@string.Join(", ", user.Roles)</span>
                  }
                  else
                  {
                    <span class="badge">Sin rol</span>
                  }
                </td>
                <td>
                  @if (user.MfaEnabled)
                  {
                    <span class="badge ok">Activo</span>
                  }
                  else
                  {
                    <span class="badge warn">Inactivo</span>
                  }
                </td>
                <td>
                  @if (user.IsActive)
                  {
                    <span class="badge ok">Activo</span>
                  }
                  else
                  {
                    <span class="badge">Inactivo</span>
                  }
                </td>
                <td>
                  <a href="/Users/Edit/@user.Id" class="btn crm-btn-compact crm-link-btn">Editar</a>
                </td>
              </tr>
            }
          }
          else
          {
            <tr>
              <td colspan="5" class="crm-empty-cell">
                @if (!string.IsNullOrWhiteSpace(Model.SearchTerm))
                {
                  <text>No se encontraron usuarios con la búsqueda. <a href="/Users">Limpiar búsqueda</a></text>
                }
                else
                {
                  <text>No hay usuarios registrados. <a href="/Users/Create">Crea tu primer usuario</a></text>
                }
              </td>
            </tr>
          }
        </tbody>
      </table>

      <div class="crm-toolbar-spacer"></div>

      <div class="crm-toolbar">
        <button class="btn" type="button" onclick="exportUsers()">Exportar</button>
        <button class="btn" type="button" onclick="showBulkActionsModal()">Bulk actions</button>
        <a href="/Users/Create" class="btn primary crm-link-btn">Crear usuario</a>
      </div>
    </div>
  </div>

  <!-- RIGHT: Roles & Permissions -->
  <aside class="stack">
    <div class="card">
      <div class="card-h">
        <div>
          <h3 class="title">Roles y permisos</h3>
          <p class="subtitle">Configuración de roles y sus permisos asociados.</p>
        </div>
        <span class="pill">RBAC + ABAC</span>
      </div>
      <div class="card-b">
        <table class="table" aria-label="Roles del sistema">
          <thead>
            <tr>
              <th>Rol</th>
              <th>Usuarios</th>
              <th>Permisos</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>Admin</td>
              <td>3</td>
              <td><span class="badge ok">Completo</span></td>
            </tr>
            <tr>
              <td>Manager</td>
              <td>8</td>
              <td><span class="badge warn">Gestión</span></td>
            </tr>
            <tr>
              <td>Sales</td>
              <td>24</td>
              <td><span class="badge">Ventas</span></td>
            </tr>
            <tr>
              <td>Viewer</td>
              <td>12</td>
              <td><span class="badge">Solo lectura</span></td>
            </tr>
          </tbody>
        </table>

        <div class="crm-toolbar-spacer"></div>

        <a href="/Users/Roles" class="btn primary crm-btn-block">Gestionar roles</a>
      </div>
    </div>

    <div class="card">
      <div class="card-h">
        <div>
          <h3 class="title">Actividad reciente</h3>
          <p class="subtitle">Últimos accesos y acciones de usuarios.</p>
        </div>
        <span class="pill">Últimas 24h</span>
      </div>
      <div class="card-b">
        <div class="feed">
          <div class="item">
            <div class="itop">
              <div class="itag">ACCESO</div>
              <div class="itime">Hace 2 min</div>
            </div>
            <div class="ibody">
              admin@autonomuscrm.com inició sesión desde IP 192.168.1.100
            </div>
            <div class="ifooter">
              <span class="pill">MFA: ✓</span>
              <span class="pill">Estado: OK</span>
            </div>
          </div>

          <div class="item">
            <div class="itop">
              <div class="itag">ACCIÓN</div>
              <div class="itime">Hace 8 min</div>
            </div>
            <div class="ibody">
              manager@autonomuscrm.com creó nuevo lead #342
            </div>
            <div class="ifooter">
              <span class="pill">Permiso: ✓</span>
              <span class="pill">Auditado</span>
            </div>
          </div>
        </div>

        <div class="crm-toolbar-spacer"></div>

        <a href="/Audit" class="btn primary crm-btn-block crm-link-btn">Ver auditoría completa</a>
      </div>
    </div>
  </aside>
</section>

<div class="crm-section-gap"></div>

<footer class="crm-footer-note">
  AUTONOMUS CRM · Gestión de usuarios con Zero Trust y RBAC/ABAC.
</footer>

<div id="importModal" class="crm-overlay-modal">
    <div class="card crm-overlay-card">
        <div class="card-h">
            <div>
                <h3 class="title">Importar Usuarios</h3>
            </div>
        </div>
        <div class="card-b">
            <form method="post" action="/Users/Import" enctype="multipart/form-data">
                <div class="crm-form-field">
                    <label>Archivo JSON o CSV *</label>
                    <input type="file" name="file" accept=".json,.csv" required class="crm-form-control" />
                    <div class="crm-form-help">
                        Formato CSV: Email,FirstName,LastName,Password<br/>
                        Formato JSON: Array de objetos con email, firstName, lastName, password
                    </div>
                </div>
                <div class="crm-split-actions">
                    <button type="submit" class="btn primary">Importar</button>
                    <button type="button" class="btn" onclick="closeImportModal()">Cancelar</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
function exportUsers() {
    const users = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Users.Select(u => new { u.Id, u.Email, u.FirstName, u.LastName, Roles = u.Roles != null ? string.Join(", ", u.Roles) : "", u.MfaEnabled, u.IsActive })));
    const json = JSON.stringify(users, null, 2);
    const blob = new Blob([json], { type: 'application/json' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = 'users-' + new Date().toISOString().split('T')[0] + '.json';
    a.click();
    URL.revokeObjectURL(url);
}
function showImportModal() {
    document.getElementById('importModal').style.display = 'flex';
}
function closeImportModal() {
    document.getElementById('importModal').style.display = 'none';
}
function showBulkActionsModal() {
    const selected = Array.from(document.querySelectorAll('input[type="checkbox"][name="userIds"]:checked')).map(cb => cb.value);
    if (selected.length === 0) {
        alert('Por favor selecciona al menos un usuario');
        return;
    }
    document.getElementById('bulkActionsModal').style.display = 'flex';
    document.getElementById('selectedUserIds').value = selected.join(',');
}
function closeBulkActionsModal() {
    document.getElementById('bulkActionsModal').style.display = 'none';
}
function toggleSelectAll() {
    const selectAll = document.getElementById('selectAll');
    const checkboxes = document.querySelectorAll('input[type="checkbox"][name="userIds"]');
    checkboxes.forEach(cb => cb.checked = selectAll.checked);
}
</script>

<div id="bulkActionsModal" class="crm-overlay-modal">
    <div class="card crm-overlay-card">
        <div class="card-h">
            <div>
                <h3 class="title">Acciones Masivas</h3>
            </div>
        </div>
        <div class="card-b">
            <form method="post" action="/Users/BulkActions">
                <input type="hidden" id="selectedUserIds" name="userIds" />
                <div class="crm-form-field">
                    <label>Acción *</label>
                    <select name="action" required class="crm-form-control">
                        <option value="activate">Activar usuarios</option>
                        <option value="deactivate">Desactivar usuarios</option>
                    </select>
                </div>
                <div class="crm-split-actions">
                    <button type="submit" class="btn primary">Aplicar</button>
                    <button type="button" class="btn" onclick="closeBulkActionsModal()">Cancelar</button>
                </div>
            </form>
        </div>
    </div>
</div>

