@page "/Leads/Create"
@model AutonomusCRM.API.Pages.Leads.CreateModel
@{
    ViewData["Title"] = L["Leads_Create_Title"].Value;
    ViewData["PageTitle"] = L["Leads_Create_Title"].Value;
    ViewData["PageKicker"] = L["Leads_Create_Kicker"].Value;
    ViewData["PageSubtitle"] = L["Leads_Create_CardSubtitle"].Value;
    ViewData["PageActionsHtml"] = $"<a href=\"/Leads\" class=\"flow-btn flow-btn-secondary\">{L["Btn_Cancel"].Value}</a>";
    ViewData["FormErrorMessage"] = Model.ErrorMessage;
    ViewData["FormSuccessMessage"] = Model.SuccessMessage;
}

<partial name="Flow/_FlowPageHeader" />
<partial name="Shared/_FlowFormAlerts" />

<section class="flow-card flow-form-card">
  <header class="flow-card-header">
    <h2 class="flow-card-title" id="lead-create-title">@L["Leads_Create_CardTitle"]</h2>
    <p class="flow-page-subtitle mb-0">@L["Leads_Create_CardSubtitle"]</p>
  </header>
  <div class="flow-card-body">
    <form method="post" asp-page-handler="Create" class="flow-form" aria-labelledby="lead-create-title">
      <div class="flow-form-grid">
        <div class="flow-form-field">
          <label class="flow-form-label" for="lead-name">@L["Form_FullNameRequired"]</label>
          <input type="text" id="lead-name" name="name" class="flow-form-control" required value="@Model.Name" placeholder="@L["Leads_Create_PlaceholderName"]" autocomplete="name" />
        </div>
        <div class="flow-form-field">
          <label class="flow-form-label" for="lead-email">@L["Common_Email"]</label>
          <input type="email" id="lead-email" name="email" class="flow-form-control" value="@Model.Email" placeholder="@L["Leads_Create_PlaceholderEmail"]" autocomplete="email" />
        </div>
        <div class="flow-form-field">
          <label class="flow-form-label" for="lead-phone">@L["Common_Phone"]</label>
          <input type="tel" id="lead-phone" name="phone" class="flow-form-control" value="@Model.Phone" placeholder="@L["Leads_Create_PlaceholderPhone"]" autocomplete="tel" />
        </div>
        <div class="flow-form-field">
          <label class="flow-form-label" for="lead-company">@L["Form_Company"]</label>
          <input type="text" id="lead-company" name="company" class="flow-form-control" value="@Model.Company" placeholder="@L["Leads_Create_PlaceholderCompany"]" autocomplete="organization" />
        </div>
        <div class="flow-form-field flow-form-field--full">
          <label class="flow-form-label" for="lead-source">@L["Form_SourceRequired"]</label>
          <select id="lead-source" name="source" class="flow-form-control" required>
            <option value="">@L["Form_SelectSource"]</option>
            <option value="Website" selected="@(Model.Source == "Website")">@L["LeadSource_Website"]</option>
            <option value="Referral" selected="@(Model.Source == "Referral")">@L["LeadSource_Referral"]</option>
            <option value="SocialMedia" selected="@(Model.Source == "SocialMedia")">@L["LeadSource_SocialMedia"]</option>
            <option value="EmailCampaign" selected="@(Model.Source == "EmailCampaign")">@L["LeadSource_EmailCampaign"]</option>
            <option value="ColdCall" selected="@(Model.Source == "ColdCall")">@L["LeadSource_ColdCall"]</option>
            <option value="Partner" selected="@(Model.Source == "Partner")">@L["LeadSource_Partner"]</option>
            <option value="Event" selected="@(Model.Source == "Event")">@L["LeadSource_Event"]</option>
            <option value="Other" selected="@(Model.Source == "Other")">@L["LeadSource_Other"]</option>
          </select>
        </div>
      </div>
      <div class="flow-form-actions">
        <button type="submit" class="flow-btn flow-btn-primary">@L["Leads_Create_Submit"]</button>
        <a href="/Leads" class="flow-btn flow-btn-secondary">@L["Btn_Cancel"]</a>
      </div>
    </form>
  </div>
</section>

<p class="flow-form-footer">@L["Leads_Create_Footer"]</p>
