@page "/command/outcomes"
@model AutonomusCRM.API.Pages.Command.OutcomesModel
@{
    ViewData["Title"] = L["Command_OutcomesTitle"].Value;
    ViewData["PageTitle"] = L["Command_OutcomesTitle"].Value;
    ViewData["PageKicker"] = L["Nav_Section_Command"].Value;
    ViewData["PageSubtitle"] = L["Command_Subtitle"].Value;
    var s = Model.Summary;
}
<partial name="Flow/_FlowPageHeader" />

@if (s == null)
{
  <partial name="Flow/_FlowEmptyState" />
}
else
{
  <div class="flow-metric-grid mb-4">
    @{ ViewData["FlowMetricLabel"] = L["Command_OutcomesGenerated"].Value; ViewData["FlowMetricValue"] = "$" + s.RevenueGenerated.ToString("N0"); ViewData["FlowMetricVariant"] = "success"; ViewData["FlowMetricFooterHtml"] = null; }
    <partial name="Flow/_FlowMetricCard" />
    @{ ViewData["FlowMetricLabel"] = L["Command_OutcomesProtected"].Value; ViewData["FlowMetricValue"] = "$" + s.RevenueProtected.ToString("N0"); ViewData["FlowMetricVariant"] = "info"; }
    <partial name="Flow/_FlowMetricCard" />
    @{ ViewData["FlowMetricLabel"] = L["Command_OutcomesChains"].Value; ViewData["FlowMetricValue"] = s.CompleteChains.ToString(); ViewData["FlowMetricVariant"] = "ai"; }
    <partial name="Flow/_FlowMetricCard" />
    @{ ViewData["FlowMetricLabel"] = L["Common_Pending"].Value; ViewData["FlowMetricValue"] = s.IncompleteChains.ToString(); ViewData["FlowMetricVariant"] = "warning"; }
    <partial name="Flow/_FlowMetricCard" />
  </div>

  <section class="flow-card">
    <header class="flow-card-header"><h3 class="flow-card-title">@L["Command_OutcomesChains"]</h3></header>
    <div class="flow-card-body">
      @if (s.RecentChains.Count == 0)
      {
        ViewData["FlowEmptyTitle"] = L["Command_Outcomes"].Value;
        ViewData["FlowEmptyMessage"] = L["Command_MetricsWillAppear"].Value;
        <partial name="Flow/_FlowEmptyState" />
      }
      @foreach (var chain in s.RecentChains)
      {
        <partial name="Flow/_FlowOutcomeChain" model="chain" />
        <hr style="margin:16px 0;border:0;border-top:1px solid var(--flow-border-subtle);" />
      }
    </div>
  </section>
}
