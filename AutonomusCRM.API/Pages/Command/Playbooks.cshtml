@page "/command/playbooks"
@model AutonomusCRM.API.Pages.Command.PlaybooksModel
@{
    ViewData["Title"] = L["Command_PlaybooksTitle"].Value;
    ViewData["PageTitle"] = L["Command_PlaybooksTitle"].Value;
    ViewData["PageKicker"] = L["Nav_Section_Command"].Value;
    ViewData["PageSubtitle"] = L["Command_Subtitle"].Value;
}
<partial name="Flow/_FlowPageHeader" />

@if (Model.Playbooks.Count == 0)
{
  ViewData["FlowEmptyTitle"] = L["Command_PlaybooksEmpty"].Value;
  ViewData["FlowEmptyMessage"] = L["Command_MetricsWillAppear"].Value;
  <partial name="Flow/_FlowEmptyState" />
}
else
{
  <section class="flow-card">
    <div class="flow-card-body" style="padding:0;">
      <table class="flow-table-minimal">
        <thead><tr><th>@L["Common_Customer"]</th><th>@L["CustomerSuccess_Playbooks"]</th><th>@L["Common_Status"]</th><th>@L["Command_DecisionType"]</th><th>@L["Command_DecisionAction"]</th></tr></thead>
        <tbody>
          @foreach (var p in Model.Playbooks)
          {
            <tr>
              <td>@(p.CustomerName ?? p.CustomerId.ToString())</td>
              <td>@p.PlaybookType</td>
              <td>@p.Status</td>
              <td>@p.CurrentStep / @p.TotalSteps</td>
              <td>@(p.NextActionAt?.ToString("g") ?? "—")</td>
            </tr>
          }
        </tbody>
      </table>
    </div>
  </section>
}
