@page "/Policies/Create"
@model AutonomusCRM.API.Pages.Policies.CreateModel
@{
    ViewData["Title"] = L["Policies_Create_Title"].Value;
    ViewData["PageTitle"] = L["Policies_Create_Title"].Value;
    ViewData["PageKicker"] = L["Policies_Create_Kicker"].Value;
    ViewData["PageSubtitle"] = L["Policies_Create_CardSubtitle"].Value;
    ViewData["PageActionsHtml"] = $"<a href=\"/Policies\" class=\"flow-btn flow-btn-secondary\">{L["Btn_Cancel"].Value}</a>";
}

<partial name="Flow/_FlowPageHeader" />
<partial name="Shared/_FlowFormAlerts" />

<section class="flow-card flow-form-card">
    <header class="flow-card-header">
        <h2 class="flow-card-title" id="policy-create-title">@L["Policies_Create_CardTitle"]</h2>
        <p class="flow-page-subtitle mb-0">@L["Policies_Create_CardSubtitle"]</p>
    </header>
    <div class="flow-card-body">
        <form method="post" class="flow-form" aria-labelledby="policy-create-title">
            <div class="flow-form-grid">
                <div class="flow-form-field flow-form-field--full">
                    <label class="flow-form-label" for="policy-create-name">@L["Form_NameRequired"]</label>
                    <input type="text" id="policy-create-name" name="name" class="flow-form-control" required placeholder="@L["Policies_Create_PlaceholderName"]" />
                </div>
                <div class="flow-form-field flow-form-field--full">
                    <label class="flow-form-label" for="policy-create-expression">@L["Form_ExpressionRequired"]</label>
                    <textarea id="policy-create-expression" name="expression" class="flow-form-control flow-form-control--mono" rows="6" required placeholder="@L["Policies_Create_PlaceholderExpression"]" aria-describedby="policy-create-expression-hint"></textarea>
                    <span id="policy-create-expression-hint" class="flow-form-help">@L["Policies_Create_ExpressionHint"]</span>
                </div>
                <div class="flow-form-field flow-form-field--full">
                    <label class="flow-form-label" for="policy-create-description">@L["Form_Description"]</label>
                    <textarea id="policy-create-description" name="description" class="flow-form-control" rows="3" placeholder="@L["Policies_Create_PlaceholderDesc"]"></textarea>
                </div>
            </div>
            <div class="flow-form-actions">
                <button type="submit" class="flow-btn flow-btn-primary">@L["Policies_Create_Submit"]</button>
                <a href="/Policies" class="flow-btn flow-btn-secondary">@L["Btn_Cancel"]</a>
            </div>
        </form>
    </div>
</section>

<p class="flow-form-footer">@L["Policies_Create_Footer"]</p>
