@page "/Policies/Edit/{id:guid}"
@model AutonomusCRM.API.Pages.Policies.EditModel
@{
    ViewData["Title"] = L["Policies_Edit_Kicker"].Value;
}

@if (Model.Policy == null)
{
    ViewData["EmptyIcon"] = "fas fa-shield-alt";
    ViewData["EmptyTitle"] = L["Policies_Edit_NotFound"].Value;
    ViewData["EmptyMessage"] = L["Policies_Edit_NotFoundDesc"].Value;
    ViewData["EmptyActionHtml"] = $"<a href=\"/Policies\" class=\"flow-btn flow-btn-primary\">{L["Policies_Edit_BackTo"].Value}</a>";
    <partial name="Shared/_CrmEmptyState" />
}
else
{
    ViewData["PageTitle"] = Model.Policy.Name;
    ViewData["PageKicker"] = L["Policies_Edit_Kicker"].Value;
    ViewData["PageSubtitle"] = L["Policies_Edit_CardSubtitle"].Value;
    ViewData["PageActionsHtml"] = $"<a href=\"/Policies\" class=\"flow-btn flow-btn-secondary\">{L["Btn_Cancel"].Value}</a>";

    <partial name="Flow/_FlowPageHeader" />
    <partial name="Shared/_FlowFormAlerts" />

    <section class="flow-card flow-form-card">
        <header class="flow-card-header">
            <h2 class="flow-card-title" id="policy-edit-title">@L["Policies_Edit_CardTitle"]</h2>
            <p class="flow-page-subtitle mb-0">@L["Policies_Edit_CardSubtitle"]</p>
        </header>
        <div class="flow-card-body">
            <form method="post" class="flow-form" aria-labelledby="policy-edit-title">
                <div class="flow-form-grid">
                    <div class="flow-form-field flow-form-field--full">
                        <label class="flow-form-label" for="policy-edit-name">@L["Form_NameRequired"]</label>
                        <input type="text" id="policy-edit-name" name="name" class="flow-form-control" value="@Model.Policy.Name" required />
                    </div>
                    <div class="flow-form-field flow-form-field--full">
                        <label class="flow-form-label" for="policy-edit-expression">@L["Form_ExpressionRequired"]</label>
                        <textarea id="policy-edit-expression" name="expression" class="flow-form-control flow-form-control--mono" rows="6" required aria-describedby="policy-edit-expression-hint">@Model.Policy.Expression</textarea>
                        <span id="policy-edit-expression-hint" class="flow-form-help">@L["Policies_Edit_ExpressionHint"]</span>
                    </div>
                    <div class="flow-form-field flow-form-field--full">
                        <label class="flow-form-label" for="policy-edit-description">@L["Form_Description"]</label>
                        <textarea id="policy-edit-description" name="description" class="flow-form-control" rows="3">@Model.Policy.Description</textarea>
                    </div>
                    <div class="flow-form-field">
                        <label class="flow-form-label" for="policy-edit-status">@L["Common_Status"]</label>
                        <select id="policy-edit-status" name="isActive" class="flow-form-control">
                            <option value="true" selected="@Model.Policy.IsActive">@L["Common_Active"]</option>
                            <option value="false" selected="@(!Model.Policy.IsActive)">@L["Common_Inactive"]</option>
                        </select>
                    </div>
                </div>
                <div class="flow-form-actions">
                    <button type="submit" class="flow-btn flow-btn-primary">@L["Form_SaveChanges"]</button>
                    <a href="/Policies" class="flow-btn flow-btn-secondary">@L["Btn_Cancel"]</a>
                </div>
            </form>

            <div class="flow-form-divider" role="separator"></div>

            <div class="flow-form-actions flow-form-actions--stack">
                <form method="post" asp-page-handler="Duplicate">
                    <input type="hidden" name="id" value="@Model.Policy.Id" />
                    <button type="submit" class="flow-btn flow-btn-secondary flow-btn-block">@L["Policies_Edit_DuplicatePolicy"]</button>
                </form>
                <form method="post" asp-page-handler="Delete" onsubmit="return confirm(this.dataset.msg)" data-msg="@L["Common_DeleteConfirm"]">
                    <input type="hidden" name="id" value="@Model.Policy.Id" />
                    <button type="submit" class="flow-btn flow-btn-danger flow-btn-block">@L["Policies_Edit_DeletePolicy"]</button>
                </form>
            </div>
        </div>
    </section>

    <p class="flow-form-footer">@L["Policies_Edit_Footer"]</p>
}
