@page
@model AutonomusCRM.API.Pages.IntegrationsModel
@{
    ViewData["Title"] = "Integraciones";
    ViewData["PageTitle"] = "Integrations Hub";
    ViewData["PageKicker"] = "Platform";
    ViewData["PageSubtitle"] = "Marketplace de conexiones — estado, sync, tokens y salud por proveedor.";
}
<partial name="Flow/_FlowPageHeader" />

@if (!string.IsNullOrEmpty(Model.Message)) { <div class="flow-comms-banner flow-comms-banner--ok" role="status">@Model.Message</div> }
@if (!string.IsNullOrEmpty(Model.Error)) { <div class="flow-comms-banner flow-comms-banner--warn" role="alert">@Model.Error</div> }

<div class="flow-integration-grid">
  @foreach (var provider in IntegrationsModel.Providers)
  {
    var conn = Model.GetConnection(provider);
    var connected = conn?.IsEnabled == true;
    var health = conn?.LastSyncStatus switch
    {
      "success" or "ok" => "Saludable",
      "error" or "failed" => "Error",
      _ when connected => "Pendiente sync",
      _ => "Desconectado"
    };
    <article class="flow-integration-card @(connected ? "is-connected" : "")">
      <div class="d-flex justify-content-between align-items-start mb-2">
        <h3 style="font-size:15px;margin:0;font-weight:600;">@provider</h3>
        <span class="flow-integration-status">@(connected ? "Conectado" : "Off")</span>
      </div>
      <div class="flow-integration-health">
        @if (conn != null)
        {
          <div>Última sync: @(conn.LastSyncAt?.ToString("g") ?? "—")</div>
          <div>Estado: @(conn.LastSyncStatus ?? "—")</div>
          <div>Salud: @health</div>
          @if (conn.LastSyncStatus is "error" or "failed")
          {
            <div style="color:var(--flow-danger);margin-top:4px;">Revisar logs de sync</div>
          }
        }
        else
        {
          <div>Sin conexión activa para este tenant.</div>
        }
      </div>
      @if (Model.IsOAuthReady(provider))
      {
        <a asp-page="/Integrations" asp-page-handler="OAuth" asp-route-provider="@provider" class="flow-btn flow-btn-primary" style="width:100%;margin-bottom:8px;">Conectar OAuth</a>
      }
      <details style="font-size:12px;">
        <summary class="flow-btn flow-btn-secondary" style="width:100%;cursor:pointer;list-style:none;">Token manual</summary>
        <form method="post" asp-page-handler="Connect" class="mt-2">
          <input type="hidden" name="provider" value="@provider" />
          <input type="password" name="accessToken" class="form-control form-control-sm mb-1" placeholder="Access token" autocomplete="off" />
          <input type="password" name="refreshToken" class="form-control form-control-sm mb-1" placeholder="Refresh token" autocomplete="off" />
          <input type="text" name="instanceUrl" class="form-control form-control-sm mb-1" placeholder="Instance URL (SF)" />
          <input type="password" name="apiKey" class="form-control form-control-sm mb-1" placeholder="API key" autocomplete="off" />
          @Html.AntiForgeryToken()
          <button type="submit" class="flow-btn flow-btn-secondary" style="width:100%;">Guardar</button>
        </form>
      </details>
      <form method="post" asp-page-handler="Sync" class="mt-2">
        <input type="hidden" name="provider" value="@provider" />
        @Html.AntiForgeryToken()
        <button type="submit" class="flow-btn flow-btn-secondary" style="width:100%;" disabled="@(!connected)">Sincronizar</button>
      </form>
    </article>
  }
</div>
