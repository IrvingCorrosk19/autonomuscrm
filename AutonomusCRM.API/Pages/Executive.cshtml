@page "/executive"

@model AutonomusCRM.API.Pages.ExecutiveModel

@using AutonomusCRM.API.Infrastructure

@{

    var os = Model.Os;

    ViewData["Title"] = L["Executive_PageTitle"].Value;

    ViewData["PageTitle"] = L["Executive_OsTitle"].Value;

    ViewData["PageKicker"] = L["Executive_Kicker"].Value;

    ViewData["PageSubtitle"] = L["Executive_OsSubtitle"].Value;

    ViewData["PageActionsHtml"] =
        "<a href=\"/executive?handler=Export&amp;type=executive\" class=\"flow-btn flow-btn-secondary flow-btn-sm\">" + L["Executive_ExportSummary"].Value + "</a>" +
        "<a href=\"/executive?handler=Export&amp;type=board\" class=\"flow-btn flow-btn-secondary flow-btn-sm\">" + L["Executive_ExportBoard"].Value + "</a>";

}

<partial name="Flow/_FlowPageHeader" />



@if (os == null || !os.HasData)

{

  ViewData["FlowEmptyTitle"] = L["Executive_ReadyTitle"].Value;

  ViewData["FlowEmptyMessage"] = L["Executive_ReadyMessage"].Value;

  ViewData["FlowEmptyCta"] = L["Command_PageTitle"].Value;

  ViewData["FlowEmptyCtaHref"] = "/";

  <partial name="Flow/_FlowEmptyState" />

}

else

{

  var p = os.Pulse;

  var ai = os.AiImpact;

  var qbr = Model.QbrPeriod switch {

    "monthly" => os.Qbr.Monthly,

    "annual" => os.Qbr.Annual,

    _ => os.Qbr.Quarterly

  };



  <section class="flow-revenue-hero flow-exec-os-hero" aria-labelledby="exec-pulse-title">

    <div class="flow-exec-os-head">

      <h2 id="exec-pulse-title">@L["Executive_PulseTitle"]</h2>

      <nav class="flow-exec-os-nav" aria-label="@L["Executive_NavAria"]">

        <a href="/revenue" class="flow-btn flow-btn-secondary flow-btn-sm">@L["Revenue_PageTitle"]</a>

        <a href="/Customer360" class="flow-btn flow-btn-secondary flow-btn-sm">@L["Nav_Customer360"]</a>

        <a href="/TrustInbox" class="flow-btn flow-btn-secondary flow-btn-sm">@L["Trust_PageTitle"]</a>

        <a href="/" class="flow-btn flow-btn-secondary flow-btn-sm">@L["Command_PageTitle"]</a>

      </nav>

    </div>

    <div class="flow-metric-grid">

      @{ ViewData["FlowMetricLabel"] = L["Executive_RevenueGenerated"].Value; ViewData["FlowMetricValue"] = "$" + p.RevenueGenerated.ToString("N0"); ViewData["FlowMetricVariant"] = "success"; }

      <partial name="Flow/_FlowMetricCard" />

      @{ ViewData["FlowMetricLabel"] = L["Executive_RevenueProtected"].Value; ViewData["FlowMetricValue"] = "$" + p.RevenueProtected.ToString("N0"); ViewData["FlowMetricVariant"] = "ai"; }

      <partial name="Flow/_FlowMetricCard" />

      @{ ViewData["FlowMetricLabel"] = L["Executive_RevenueAtRisk"].Value; ViewData["FlowMetricValue"] = "$" + p.RevenueAtRisk.ToString("N0"); ViewData["FlowMetricVariant"] = "danger"; }

      <partial name="Flow/_FlowMetricCard" />

      @{ ViewData["FlowMetricLabel"] = L["Executive_AtRiskCustomers"].Value; ViewData["FlowMetricValue"] = p.AtRiskCustomers.ToString(); ViewData["FlowMetricVariant"] = "warning"; }

      <partial name="Flow/_FlowMetricCard" />

      @{ ViewData["FlowMetricLabel"] = L["Executive_ExpansionReady"].Value; ViewData["FlowMetricValue"] = p.ExpansionReady.ToString(); ViewData["FlowMetricVariant"] = "success"; }

      <partial name="Flow/_FlowMetricCard" />

      @{ ViewData["FlowMetricLabel"] = L["Executive_PendingDecisions"].Value; ViewData["FlowMetricValue"] = p.PendingDecisions.ToString(); ViewData["FlowMetricVariant"] = "danger"; }

      <partial name="Flow/_FlowMetricCard" />

      @{ ViewData["FlowMetricLabel"] = L["Executive_RecommendedActions"].Value; ViewData["FlowMetricValue"] = p.RecommendedActions.ToString(); ViewData["FlowMetricVariant"] = "ai"; }

      <partial name="Flow/_FlowMetricCard" />

    </div>

  </section>



  <div class="flow-revenue-grid mt-4">

    <section class="flow-card">

      <header class="flow-card-header"><h3 class="flow-card-title">@L["Executive_AiImpact"]</h3></header>

      <div class="flow-card-body">

        <div class="flow-exec-ai-grid">

          <div><span class="text-muted">@L["Executive_AiGenerated"]</span><strong>$@ai.RevenueGeneratedByAi.ToString("N0")</strong></div>

          <div><span class="text-muted">@L["Executive_AiProtected"]</span><strong>$@ai.RevenueProtectedByAi.ToString("N0")</strong></div>

          <div><span class="text-muted">@L["Executive_AiExecuted"]</span><strong>@ai.AiDecisionsExecuted</strong></div>

          <div><span class="text-muted">@L["Executive_AiPending"]</span><strong>@ai.AiDecisionsPending</strong></div>

          <div><span class="text-muted">@L["Executive_HumanApproved"]</span><strong>@ai.HumanApprovals</strong></div>

          <div><span class="text-muted">@L["Executive_HumanRejected"]</span><strong>@ai.HumanRejections</strong></div>

        </div>

        @if (os.TrustPendingApprovals > 0) {

          <p class="mt-3"><a href="/TrustInbox" class="flow-btn flow-btn-primary flow-btn-sm">@L["Executive_TrustPending", os.TrustPendingApprovals]</a></p>

        }

      </div>

    </section>



    <section class="flow-card">

      <header class="flow-card-header">

        <h3 class="flow-card-title">@L["Executive_QbrTitle"]</h3>

        <form method="get" class="flow-exec-qbr-tabs">

          @foreach (var tab in new[] { ("monthly", L["Executive_PeriodMonthly"].Value), ("quarterly", L["Executive_PeriodQuarterly"].Value), ("annual", L["Executive_PeriodAnnual"].Value) }) {

            <button type="submit" name="qbrPeriod" value="@tab.Item1" class="flow-btn flow-btn-sm @(Model.QbrPeriod == tab.Item1 ? "flow-btn-primary" : "flow-btn-secondary")">@tab.Item2</button>

          }

        </form>

      </header>

      <div class="flow-card-body">

        <p style="font-size:14px;margin:0 0 12px;"><strong>@qbr.Headline</strong></p>

        <div class="flow-exec-ai-grid">

          <div><span class="text-muted">@L["Executive_RevenueGenerated"] (@qbr.Days d)</span><strong>$@qbr.RevenueGenerated.ToString("N0")</strong></div>

          <div><span class="text-muted">@L["Executive_RevenueProtected"]</span><strong>$@qbr.RevenueProtected.ToString("N0")</strong></div>

          <div><span class="text-muted">@L["Executive_AiExecuted"]</span><strong>@qbr.AiDecisionsExecuted</strong></div>

          <div><span class="text-muted">@L["Executive_HumanApproved"]</span><strong>@qbr.HumanApprovals</strong></div>

        </div>

      </div>

    </section>

  </div>



  <section class="flow-card mt-4">

    <header class="flow-card-header"><h3 class="flow-card-title">@L["Revenue_Attribution"]</h3></header>

    <div class="flow-card-body">

      @if (os.OutcomeChains.Count == 0) {

        <p class="text-muted">@L["Common_NoData"]</p>

      } else {

        <table class="flow-table-minimal">

          <thead><tr><th>@L["Executive_Action"]</th><th>@L["Executive_Result"]</th><th>@L["Executive_Revenue"]</th><th>@L["Executive_State"]</th><th>@L["Executive_Date"]</th></tr></thead>

          <tbody>

            @foreach (var c in os.OutcomeChains) {

              <tr>

                <td>@c.Action</td>

                <td>@c.Outcome</td>

                <td>$@c.Revenue.ToString("N0")</td>

                <td>@c.Status</td>

                <td>@c.OccurredAt.ToString("d")</td>

              </tr>

            }

          </tbody>

        </table>

      }

    </div>

  </section>



  <div class="flow-revenue-grid mt-4">

    <section class="flow-card">

      <header class="flow-card-header"><h3 class="flow-card-title">@L["Executive_RecommendedActions"]</h3></header>

      <div class="flow-card-body">

        @foreach (var n in os.Ai.NextBestActions.Take(6)) {

          var insightType = FlowInsightMapper.FromNba(n);

          var customerId = n.EntityType == "Customer" ? n.EntityId : (Guid?)null;

          <div class="flow-insight-row">

            <div class="flow-insight-row-head">

              <span><strong>@n.EntityName</strong> — @n.RecommendedAction</span>

              <span class="flow-revenue-priority">@n.PriorityScore</span>

            </div>

            @if (customerId.HasValue) {

              ViewData["FlowInsightType"] = insightType;

              ViewData["FlowInsightCustomerId"] = customerId;

              ViewData["FlowInsightCustomerName"] = n.EntityName;

              ViewData["FlowInsightReturnUrl"] = "/executive";

              ViewData["FlowInsightCompact"] = true;

              <partial name="Flow/_FlowInsightActions" />

            }

          </div>

        }

      </div>

    </section>



    <section class="flow-card">

      <header class="flow-card-header"><h3 class="flow-card-title">@L["Executive_AiExecuted"]</h3></header>

      <div class="flow-card-body flow-decision-feed">

        @foreach (var dec in os.Ai.RecentDecisions.Take(6)) {

          ViewData["FlowDecisionType"] = dec.DecisionType;

          ViewData["FlowDecisionAction"] = dec.Action;

          ViewData["FlowDecisionScore"] = dec.Score;

          ViewData["FlowDecisionStatus"] = dec.Score >= 70 ? "executed" : "pending";

          ViewData["FlowDecisionAt"] = DateTime.UtcNow.AddHours(-(dec.Score % 48));

          <partial name="Flow/_FlowDecisionCard" />

        }

      </div>

    </section>



    <section class="flow-card">

      <header class="flow-card-header"><h3 class="flow-card-title">@L["Executive_RevenueAtRisk"]</h3></header>

      <div class="flow-card-body">

        @if (os.Revenue.WinLoss.Any()) {

          <ul class="flow-revenue-list">@foreach (var w in os.Revenue.WinLoss.Take(4)) { <li><span>@w.Key</span><span>$@w.TotalAmount.ToString("N0")</span></li> }</ul>

        }

        <p style="margin-top:12px;">@L["Executive_Revenue"]: <strong>$@os.Revenue.Kpis.RevenueClosed.ToString("N0")</strong></p>

      </div>

    </section>



    @if (os.Learning != null)

    {

      var l = os.Learning;

      <section class="flow-card">

        <header class="flow-card-header"><h3 class="flow-card-title">@L["Memory_LearnedPatterns"]</h3></header>

        <div class="flow-card-body">

          <p>@L["Executive_RevenueGenerated"]: <strong>$@l.RevenueGeneratedByActions.ToString("N0")</strong> · @L["Executive_RevenueProtected"]: <strong>$@l.RevenueProtected.ToString("N0")</strong></p>

          @if (l.TopActions.Any()) {

            <ul class="flow-list-minimal">

              @foreach (var a in l.TopActions.Take(4)) {

                <li>@a.Label — @a.SuccessRate.ToString("F0")% (@a.TotalAttempts)</li>

              }

            </ul>

          }

        </div>

      </section>

    }

  </div>

}


