@model (IReadOnlyList<AutonomusCRM.Application.DataPlatform.RelationshipNodeDto> Nodes, IReadOnlyList<AutonomusCRM.Application.DataPlatform.RelationshipEdgeDto> Edges)
@{
    var nodes = Model.Nodes ?? Array.Empty<AutonomusCRM.Application.DataPlatform.RelationshipNodeDto>();
    var edges = Model.Edges ?? Array.Empty<AutonomusCRM.Application.DataPlatform.RelationshipEdgeDto>();
}
@if (nodes.Count == 0)
{
  <p class="text-muted" style="font-size:13px;">Sin relaciones registradas para este cliente.</p>
}
else
{
  <div class="flow-rel-graph" role="img" aria-label="Grafo de relaciones del cliente">
    @foreach (var n in nodes)
    {
      var cls = n.Type switch
      {
        "customer" => "flow-rel-node flow-rel-node--hub",
        "deal-won" => "flow-rel-node flow-rel-node--revenue",
        "deal-open" => "flow-rel-node",
        "risk" => "flow-rel-node flow-rel-node--risk",
        _ => "flow-rel-node"
      };
      <div class="@cls" title="@n.Meta">
        <div>@n.Label</div>
        <small style="color:var(--flow-text-muted);">@n.Type</small>
      </div>
    }
  </div>
  @if (edges.Count > 0)
  {
    <ul class="text-muted" style="font-size:12px;margin-top:12px;padding-left:18px;">
      @foreach (var e in edges.Take(12))
      {
        <li>@e.Label</li>
      }
    </ul>
  }
}
