@page "/Deals/Edit/{id:guid}"
@model AutonomusCRM.API.Pages.Deals.EditModel
@using AutonomusCRM.Domain.Deals
@{
    ViewData["Title"] = L["Deals_Edit_Kicker"].Value;
}

@if (Model.Deal == null)
{
    ViewData["EmptyIcon"] = "fas fa-handshake";
    ViewData["EmptyTitle"] = L["Deals_Edit_NotFound"].Value;
    ViewData["EmptyMessage"] = L["Deals_Edit_NotFoundDesc"].Value;
    ViewData["EmptyActionHtml"] = $"<a href=\"/Deals\" class=\"flow-btn flow-btn-primary\">{L["Deals_Edit_BackTo"].Value}</a>";
    <partial name="Shared/_CrmEmptyState" />
}
else
{
    ViewData["PageTitle"] = Model.Deal.Title;
    ViewData["PageKicker"] = L["Deals_Edit_Kicker"].Value;
    ViewData["PageSubtitle"] = L["Deals_Edit_CardSubtitle"].Value;
    ViewData["PageActionsHtml"] = $"<a href=\"/Deals/Details/{Model.Deal.Id}\" class=\"flow-btn flow-btn-secondary\">{L["Btn_Cancel"].Value}</a>";

    <partial name="Flow/_FlowPageHeader" />
    <partial name="Shared/_FlowFormAlerts" />

    <section class="flow-card flow-form-card">
        <header class="flow-card-header">
            <h2 class="flow-card-title" id="deal-edit-title">@L["Deals_Edit_CardTitle"]</h2>
            <p class="flow-page-subtitle mb-0">@L["Deals_Edit_CardSubtitle"]</p>
        </header>
        <div class="flow-card-body">
            <form method="post" class="flow-form" aria-labelledby="deal-edit-title">
                <div class="flow-form-grid">
                    <div class="flow-form-field flow-form-field--full">
                        <label class="flow-form-label" for="deal-edit-title-input">@L["Form_TitleRequired"]</label>
                        <input type="text" id="deal-edit-title-input" name="title" class="flow-form-control" value="@Model.Deal.Title" required />
                    </div>
                    <div class="flow-form-field">
                        <label class="flow-form-label" for="deal-edit-customer">@L["Form_Customer"]</label>
                        <select id="deal-edit-customer" name="customerId" class="flow-form-control">
                            <option value="">@L["Form_NoChange"]</option>
                            @foreach (var customer in Model.Customers)
                            {
                                <option value="@customer.Id" selected="@(customer.Id == Model.Deal.CustomerId)">@customer.Name @(!string.IsNullOrEmpty(customer.Company) ? $"({customer.Company})" : "")</option>
                            }
                        </select>
                    </div>
                    <div class="flow-form-field">
                        <label class="flow-form-label" for="deal-edit-amount">@L["Form_Amount"]</label>
                        <input type="number" id="deal-edit-amount" name="amount" class="flow-form-control" value="@Model.Deal.Amount" step="0.01" min="0" />
                    </div>
                    <div class="flow-form-field">
                        <label class="flow-form-label" for="deal-edit-stage">@L["Form_Stage"]</label>
                        <select id="deal-edit-stage" name="stage" class="flow-form-control">
                            <option value="">@L["Form_NoChange"]</option>
                            @foreach (var stage in Model.Stages)
                            {
                                <option value="@stage.Value" selected="@stage.Selected">@stage.Text</option>
                            }
                        </select>
                    </div>
                    <div class="flow-form-field">
                        <label class="flow-form-label" for="deal-edit-probability">@L["Form_Probability"]</label>
                        <input type="number" id="deal-edit-probability" name="probability" class="flow-form-control" value="@Model.Deal.Probability" min="0" max="100" aria-describedby="deal-edit-probability-hint" />
                        <span id="deal-edit-probability-hint" class="flow-form-help">0–100</span>
                    </div>
                    <div class="flow-form-field">
                        <label class="flow-form-label" for="deal-edit-close-date">@L["Form_ExpectedCloseDate"]</label>
                        <input type="date" id="deal-edit-close-date" name="expectedCloseDate" class="flow-form-control" value="@(Model.Deal.ExpectedCloseDate?.ToString("yyyy-MM-dd"))" />
                    </div>
                </div>
                <div class="flow-form-actions">
                    <button type="submit" class="flow-btn flow-btn-primary">@L["Form_SaveChanges"]</button>
                    <a href="/Deals/Details/@Model.Deal.Id" class="flow-btn flow-btn-secondary">@L["Btn_Cancel"]</a>
                </div>
            </form>
        </div>
    </section>

    <p class="flow-form-footer">@L["Deals_Edit_Footer"]</p>
}
