<div class="flow-drawer-overlay" id="flow-drawer-overlay" aria-hidden="true"></div>
<aside class="flow-drawer" id="flow-drawer" aria-hidden="true" aria-label="Detalle">
  <header class="flow-drawer-header">
    <div>
      <h2 style="font-size:16px;margin:0;" data-drawer-title></h2>
    </div>
    <button type="button" class="flow-btn flow-btn-secondary" data-flow-drawer-close aria-label="@L["Shared_DrawerClose"]">✕</button>
  </header>
  <div class="flow-drawer-body" data-drawer-body></div>
  <footer class="flow-card-body" style="border-top:1px solid var(--flow-border-default);">
    <a class="flow-btn flow-btn-primary" data-drawer-link href="#">@L["Shared_DrawerOpenRecord"]</a>
  </footer>
</aside>
