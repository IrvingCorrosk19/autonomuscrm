@using System.Globalization
@using System.Security.Claims
@inject AutonomusCRM.Application.CustomerSuccess.ICommunicationStatusService CommsStatus
@inject AutonomusCRM.Application.Trust.ITrustMetricsService TrustMetrics
@inject AutonomusCRM.Application.Common.Tenancy.ITenantContext TenantContext
@inject Microsoft.Extensions.Configuration.IConfiguration Config
@{
    var comms = CommsStatus.GetStatus();
    var userEmail = User.FindFirst(ClaimTypes.Email)?.Value ?? User.Identity?.Name ?? L["Shell_DefaultUser"].Value;
    var userRoles = string.Join(", ", User.FindAll(ClaimTypes.Role).Select(c => c.Value));
    var envName = Environment.GetEnvironmentVariable("ASPNETCORE_ENVIRONMENT") ?? "Local";
    var aiEnabled = Config.GetValue<bool?>("AI:Enabled") ?? Config.GetValue<bool?>("AI__Enabled") ?? true;
    var uiCulture = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
    ViewData["FlowUserEmail"] = userEmail;
    ViewData["FlowUserRoles"] = userRoles;
    var trustPending = 0;
    if (User.Identity?.IsAuthenticated == true && TenantContext.TenantId is Guid tenantId)
    {
        try
        {
            var metrics = await TrustMetrics.GetMetricsAsync(tenantId);
            trustPending = metrics.PendingApprovals;
        }
        catch { trustPending = 0; }
    }
}
<!DOCTYPE html>
<html lang="@uiCulture">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>@ViewData["Title"] - @L["AppName"]</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/css/bootstrap.min.css" crossorigin="anonymous" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" crossorigin="anonymous" />
  <link rel="stylesheet" href="~/css/flow-tokens.css" asp-append-version="true" />
  <link rel="stylesheet" href="~/css/flow-shell.css" asp-append-version="true" />
  <link rel="stylesheet" href="~/css/flow-command.css" asp-append-version="true" />
  <link rel="stylesheet" href="~/css/flow-worldclass.css" asp-append-version="true" />
  <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="flow-app" id="flow-app">
<a class="flow-skip-link" href="#flow-main-content">@L["Shell_SkipToContent"]</a>

<div class="flow-app-shell">
  <div class="flow-sidebar-backdrop" id="flow-sidebar-backdrop" aria-hidden="true"></div>
  <partial name="Flow/_FlowSidebar" model="trustPending" />

  <div class="flow-main">
    <header class="flow-topbar" role="banner">
      <button type="button" class="flow-topbar-toggle" id="flow-sidebar-toggle" aria-label="@L["Shell_ToggleMenuAria"]" aria-expanded="true">
        <span aria-hidden="true">☰</span>
      </button>
      <button type="button" class="flow-topbar-search-trigger" id="flow-palette-open" aria-label="@L["Shell_SearchAria"]">
        <span>@L["Shell_SearchTrigger"]</span>
        <kbd>Ctrl+K</kbd>
      </button>
      <div class="flow-topbar-spacer"></div>
      <partial name="_LanguageSelector" />
      <button type="button" class="flow-theme-toggle" id="flow-theme-toggle" aria-label="@L["Shell_DarkModeAria"]">@L["Shell_DarkMode"]</button>
      @if (aiEnabled && User.Identity?.IsAuthenticated == true)
      {
        <span class="flow-status-pill" title="@L["Shell_AutonomousActiveTitle"]">@L["Shell_AutonomousActive"]</span>
      }
      @if (!string.Equals(envName, "Production", StringComparison.OrdinalIgnoreCase))
      {
        <span class="flow-topbar-env" aria-label="@L["Shell_EnvironmentAria"]">@envName</span>
      }
      <div class="flow-topbar-user" id="flow-topbar-user">
        <button type="button" class="flow-topbar-user-btn" aria-haspopup="true" aria-expanded="false" id="flow-user-menu-btn">
          @userEmail
        </button>
        <div class="flow-topbar-dropdown" role="menu">
          <div style="font-size:12px;color:var(--flow-text-muted);padding:4px 8px;">@userRoles</div>
          <a href="/Settings" class="flow-btn flow-btn-secondary" style="width:100%;margin-top:4px;">@L["Shell_Settings"]</a>
          <form method="post" asp-page="/Account/Logout">
            @Html.AntiForgeryToken()
            <button type="submit" class="flow-btn flow-btn-danger">@L["Shell_Logout"]</button>
          </form>
        </div>
      </div>
    </header>

    <main class="flow-content" id="flow-main-content" role="main">
      @if (!string.IsNullOrEmpty(comms.WarningMessage))
      {
        <div class="flow-comms-banner flow-comms-banner--warn" role="alert">
          <strong>@L["Shell_CommsWarningLabel"]</strong> @comms.WarningMessage
          <span style="display:block;margin-top:4px;font-size:12px;">Email: @comms.EmailMode · WhatsApp: @comms.WhatsAppMode · <a href="/Settings">@L["Shell_CommsConfigure"]</a></span>
        </div>
      }
      else if (comms.EmailIsLive || comms.WhatsAppIsLive)
      {
        <div class="flow-comms-banner flow-comms-banner--ok" role="status">
          @L["Shell_CommsActive", comms.EmailMode, comms.WhatsAppMode]
        </div>
      }
      <partial name="_FlashMessages" />
      <partial name="_CrmToastContainer" />
      <div class="flow-page-enter">
        @RenderBody()
      </div>
    </main>

    <footer class="flow-footer">
      <strong>@L["AppName"]</strong> — @L["AppTagline"]
    </footer>
  </div>
</div>

<partial name="Flow/_FlowDrawer" />

<div class="flow-palette-overlay" id="flow-palette" role="dialog" aria-modal="true" aria-label="@L["Shell_PaletteAria"]" hidden>
  <div class="flow-palette">
    <input type="text" class="flow-palette-input" id="flow-palette-input" placeholder="@L["Shell_PalettePlaceholder"]" autocomplete="off" aria-label="@L["Shell_PaletteSearchAria"]" />
    <div class="flow-palette-list" id="flow-palette-list" role="listbox"></div>
  </div>
</div>

<partial name="_FlowI18nScript" />
<script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js" crossorigin="anonymous"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>
<script src="~/js/flow-shell.js" asp-append-version="true"></script>
<script src="~/js/flow-worldclass.js" asp-append-version="true"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
