@page
@model AutonomusCRM.API.Pages.AuditModel
@{
    ViewData["Title"] = L["Audit_PageTitle"].Value;
}

<!-- TOPBAR -->
<header class="topbar">
  <div class="topbar-left">
    <div class="kicker">@L["Audit_Subtitle"]</div>
    <h2 class="headline">@L["Audit_PageTitle"]</h2>
  </div>

  <div class="topbar-center">
    <form method="get" class="crm-filter-bar">
      <select name="eventType" class="crm-filter-control">
        <option value="">@L["Common_All"]</option>
        @foreach (var eventType in Model.EventTypes)
        {
          <option value="@eventType.Value" selected="@eventType.Selected">@eventType.Text</option>
        }
      </select>
      <input type="date" name="from" value="@Model.FilterFrom?.ToString("yyyy-MM-dd")" placeholder="@L["Audit_From"]" class="crm-filter-control" />
      <input type="date" name="to" value="@Model.FilterTo?.ToString("yyyy-MM-dd")" placeholder="@L["Audit_To"]" class="crm-filter-control" />
      <button type="submit" class="btn crm-text-nowrap">@L["Btn_Filter"]</button>
    </form>
  </div>

  <div class="topbar-right">
    <button class="btn mobile-toggle" type="button" onclick="toggleSidebar()">@L["Shell_ToggleMenuAria"]</button>
    <form method="post" asp-page-handler="Export" class="crm-inline-form">
      <button type="submit" class="btn">@L["Btn_Export"]</button>
    </form>
    <button class="btn primary" type="button" disabled>@L["Audit_GenerateReport"]</button>
  </div>
</header>

<!-- STATS -->
<section class="stats" aria-label="@L["Audit_MetricsAria"]">
  <div class="stat">
    <div class="label">@L["Audit_EventsRegistered"]</div>
    <div class="value">@Model.TotalEventsCount.ToString("N0")</div>
    <div class="hint">
      <span>@L["Audit_CurrentTenantTotal"]</span>
    </div>
  </div>

  <div class="stat">
    <div class="label">@L["Audit_EventsTodayUtc"]</div>
    <div class="value">@Model.TodayEventsCount.ToString("N0")</div>
    <div class="hint">
      <span>@L["Audit_SinceMidnightUtc"]</span>
    </div>
  </div>

  <div class="stat">
    <div class="label">@L["Audit_InFilteredView"]</div>
    <div class="value">@Model.Events.Count.ToString("N0")</div>
    <div class="hint">
      <span>@L["Audit_MaxRowsHint"]</span>
    </div>
  </div>

  <div class="stat">
    <div class="label">@L["Audit_DistinctTypes"]</div>
    <div class="value">@Model.EventTypes.Count</div>
    <div class="hint">
      <span>@L["Audit_EventStoreHint"]</span>
    </div>
  </div>
</section>

<section class="grid">
  <!-- LEFT: Audit Log -->
  <div class="card">
    <div class="card-h">
      <div>
        <h3 class="title">@L["Audit_PageTitle"]</h3>
        <p class="subtitle">@L["Audit_Subtitle"]</p>
      </div>
      <span class="pill">@L["Audit_EventSourcing"]</span>
    </div>

    <div class="card-b">
      <table class="table" aria-label="@L["Audit_LogAria"]">
        <thead>
          <tr>
            <th>@L["Common_Timestamp"]</th>
            <th>@L["Audit_Event"]</th>
            <th>@L["Audit_UserAgent"]</th>
            <th>@L["Audit_Entity"]</th>
            <th>@L["Common_Actions"]</th>
          </tr>
        </thead>
        <tbody>
          @if (Model.Events.Any())
          {
            @foreach (var evt in Model.Events.OrderByDescending(e => e.OccurredOn).Take(100))
            {
              <tr>
                <td>@evt.OccurredOn.ToString("yyyy-MM-dd HH:mm:ss")</td>
                <td>
                  <div class="crm-meta-strong">@evt.EventType</div>
                  <div class="crm-meta-muted">@L["Common_IdLabel"] @evt.Id.ToString().Substring(0, 8)...</div>
                </td>
                <td>
                  @if (evt.CorrelationId.HasValue)
                  {
                    <span class="pill">@evt.CorrelationId.Value.ToString().Substring(0, 8)...</span>
                  }
                  else
                  {
                    <span class="pill">@L["Common_System"]</span>
                  }
                </td>
                <td><span class="badge">@evt.TenantId.ToString().Substring(0, 8)...</span></td>
                <td>
                  <button class="btn crm-btn-compact" type="button" onclick="showEventDetails('@evt.Id', '@evt.EventType', '@evt.OccurredOn', '@System.Text.Json.JsonSerializer.Serialize(evt).Replace("'", "\\'")');">@L["Btn_View"]</button>
                </td>
              </tr>
            }
          }
          else
          {
            <tr>
              <td colspan="5" class="crm-empty-cell">
                @L["Common_NoData"]
              </td>
            </tr>
          }
        </tbody>
      </table>

      <div class="crm-toolbar-spacer"></div>

      <div class="crm-toolbar">
        <button class="btn" type="button">@L["Btn_Export"]</button>
        <button class="btn" type="button">@L["Btn_Filter"]</button>
        <button class="btn primary" type="button">@L["Audit_GenerateReport"]</button>
      </div>
    </div>
  </div>

  <!-- RIGHT: Event Details -->
  <aside class="stack">
    <div class="card">
      <div class="card-h">
        <div>
          <h3 class="title">@L["Audit_EventsByType"]</h3>
          <p class="subtitle">@L["Audit_EventsByTypeSubtitle"]</p>
        </div>
        <span class="pill">@L["Audit_Last7Days"]</span>
      </div>
      <div class="card-b">
        <table class="table" aria-label="@L["Audit_EventsByTypeAria"]">
          <thead>
            <tr>
              <th>@L["Audit_EventType"]</th>
              <th>@L["Revenue_Count"]</th>
              <th>@L["Common_Trend"]</th>
            </tr>
          </thead>
          <tbody>
            @if (Model.EventsByType.Any())
            {
              @foreach (var kv in Model.EventsByType.OrderByDescending(x => x.Value).Take(15))
              {
                <tr>
                  <td>@kv.Key</td>
                  <td>@kv.Value</td>
                  <td><span class="badge ok">—</span></td>
                </tr>
              }
            }
            else
            {
              <tr>
                <td colspan="3" class="crm-empty-cell">@L["Audit_NoDataInFilter"]</td>
              </tr>
            }
          </tbody>
        </table>
      </div>
    </div>

    <div class="card">
      <div class="card-h">
        <div>
          <h3 class="title">@L["Audit_FullTraceability"]</h3>
          <p class="subtitle">@L["Audit_FullTraceabilitySubtitle"]</p>
        </div>
        <span class="pill">@L["Audit_EventSourcing"]</span>
      </div>
      <div class="card-b">
        <div class="feed">
          <div class="item">
            <div class="itop">
              <div class="itag">@L["Common_Info"]</div>
              <div class="itime">@L["Common_System"]</div>
            </div>
            <div class="ibody">
              @L["Audit_EventStoreDescription"]
            </div>
            <div class="ifooter">
              <span class="pill">@L["Audit_EventStoreHint"]</span>
              <span class="pill">@L["Audit_Snapshots"]</span>
            </div>
          </div>
        </div>

        <div class="crm-toolbar-spacer"></div>

        <button class="btn primary crm-btn-block" type="button">@L["Audit_ViewDocumentation"]</button>
      </div>
    </div>
  </aside>
</section>

<div class="crm-section-gap"></div>

<footer class="crm-footer-note">
  @L["Audit_FooterNote"]
</footer>

<div id="eventDetailsModal" class="crm-overlay-modal">
    <div class="card crm-overlay-card crm-overlay-card-lg">
        <div class="card-h">
            <div>
                <h3 class="title" id="eventDetailsTitle">@L["Audit_EventDetails"]</h3>
            </div>
        </div>
        <div class="card-b">
            <div id="eventDetailsContent" class="crm-json-preview"></div>
            <div class="crm-form-field">
                <button type="button" class="btn crm-btn-block" onclick="closeEventDetailsModal()">@L["Shared_DrawerClose"]</button>
            </div>
        </div>
    </div>
</div>

<script>
function showEventDetails(id, eventType, occurredOn, eventData) {
    document.getElementById('eventDetailsTitle').textContent = eventType;
    try {
        const data = JSON.parse(eventData);
        document.getElementById('eventDetailsContent').textContent = JSON.stringify(data, null, 2);
    } catch {
        document.getElementById('eventDetailsContent').textContent = eventData;
    }
    document.getElementById('eventDetailsModal').style.display = 'flex';
}
function closeEventDetailsModal() {
    document.getElementById('eventDetailsModal').style.display = 'none';
}
</script>

