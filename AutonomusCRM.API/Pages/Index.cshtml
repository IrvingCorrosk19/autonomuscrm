@page
@model IndexModel
@using AutonomusCRM.Domain.Leads
@using AutonomusCRM.Domain.Deals
@{
    ViewData["Title"] = "Dashboard";
    ViewData["PageTitle"] = "Dashboard";
    ViewData["PageKicker"] = "Resumen operativo";
    ViewData["PageSubtitle"] = "Métricas clave, pipeline y acciones pendientes.";
    ViewData["PageActionsHtml"] = @"<a href=""/Leads/Create"" class=""btn btn-primary""><i class=""fas fa-plus mr-1""></i>Nuevo lead</a>
        <a href=""/Deals/Create"" class=""btn btn-outline-secondary""><i class=""fas fa-handshake mr-1""></i>Nuevo deal</a>";
    var openDeals = Model.ViewModel.Deals.Where(d => d.Status == DealStatus.Open).ToList();
}

<partial name="_PageHeader" />

<!-- KPIs -->
<div class="row crm-kpi-row">
  <div class="col-6 col-lg-3 mb-3 mb-lg-0">
    <div class="small-box bg-info">
      <div class="inner">
        <h3>@Model.ViewModel.NewLeadsLast24h</h3>
        <p>Leads nuevos (24h)</p>
      </div>
      <div class="icon"><i class="fas fa-user-plus"></i></div>
      <a href="/Leads" class="small-box-footer">@Model.ViewModel.TotalLeads en total <i class="fas fa-arrow-circle-right"></i></a>
    </div>
  </div>
  <div class="col-6 col-lg-3 mb-3 mb-lg-0">
    <div class="small-box bg-success">
      <div class="inner">
        <h3>@Model.ViewModel.ConversionRate.ToString("F1")%</h3>
        <p>Tasa de conversión</p>
      </div>
      <div class="icon"><i class="fas fa-chart-line"></i></div>
      <a href="/Leads?status=@((int)LeadStatus.Qualified)" class="small-box-footer">Ver calificados <i class="fas fa-arrow-circle-right"></i></a>
    </div>
  </div>
  <div class="col-6 col-lg-3 mb-3 mb-lg-0">
    <div class="small-box bg-warning">
      <div class="inner">
        <h3>@Model.ViewModel.DealsAtRisk</h3>
        <p>Deals en riesgo</p>
      </div>
      <div class="icon"><i class="fas fa-exclamation-triangle"></i></div>
      <a href="/Deals" class="small-box-footer">Prob. &lt; 50% <i class="fas fa-arrow-circle-right"></i></a>
    </div>
  </div>
  <div class="col-6 col-lg-3">
    <div class="small-box bg-primary">
      <div class="inner">
        <h3>$@Model.ViewModel.EstimatedRevenue.ToString("N0")</h3>
        <p>Ingresos estimados</p>
      </div>
      <div class="icon"><i class="fas fa-dollar-sign"></i></div>
      <a href="/Deals" class="small-box-footer">@openDeals.Count deals abiertos <i class="fas fa-arrow-circle-right"></i></a>
    </div>
  </div>
</div>

<div class="row">
  <!-- Pipeline -->
  <div class="col-lg-8">
    <div class="card">
      <div class="card-h">
        <div>
          <h3 class="title">Pipeline de ventas</h3>
          <p class="subtitle">Oportunidades por etapa. Haz clic en un deal para ver el detalle.</p>
        </div>
        <a href="/Deals" class="btn btn-sm btn-outline-secondary">Ver pipeline completo</a>
      </div>
      <div class="card-b">
        @if (Model.ViewModel.HasData)
        {
          <div class="pipeline-scroll" aria-label="Etapas del pipeline">
            @{
              var stages = new[] {
                ("Prospección", DealStage.Prospecting, Model.ViewModel.PipelineProspecting),
                ("Calificación", DealStage.Qualification, Model.ViewModel.PipelineQualification),
                ("Propuesta", DealStage.Proposal, Model.ViewModel.PipelineProposal),
                ("Negociación", DealStage.Negotiation, Model.ViewModel.PipelineClosing)
              };
            }
            @foreach (var (stageName, stage, amount) in stages)
            {
              var stageDeals = Model.ViewModel.Deals.Where(d => d.Stage == stage).Take(3).ToList();
              <div class="pipeline-col">
                <h4>
                  <span>@stageName</span>
                  <span class="amount">$@amount.ToString("N0")</span>
                </h4>
                @if (stageDeals.Any())
                {
                  @foreach (var deal in stageDeals)
                  {
                    <div class="pipeline-deal">
                      <a href="/Deals/Details/@deal.Id">@deal.Title</a>
                      <div class="meta">@(deal.Probability ?? 0)% · $@deal.Amount.ToString("N0")</div>
                      <div class="progress crm-progress">
                        <div class="progress-bar bg-primary" style="width:@(deal.Probability ?? 0)%"></div>
                      </div>
                    </div>
                  }
                }
                else
                {
                  <p class="text-muted small mb-0">Sin deals en esta etapa</p>
                }
              </div>
            }
          </div>
        }
        else
        {
          <p class="text-muted mb-0">Crea leads y deals para visualizar el pipeline.</p>
        }
      </div>
    </div>
  </div>

  <!-- Acciones pendientes -->
  <div class="col-lg-4">
    <div class="card">
      <div class="card-h">
        <div>
          <h3 class="title">Acciones pendientes</h3>
          <p class="subtitle">Prioridad sugerida según tus datos actuales.</p>
        </div>
      </div>
      <div class="card-b p-0">
        <table class="table table-sm mb-0">
          <tbody>
            @{
              var riskDeals = Model.ViewModel.Deals.Where(d => d.Probability < 50 && d.Status == DealStatus.Open).Take(3).ToList();
              var newLeads = Model.ViewModel.Leads.Where(l => l.Status == LeadStatus.New).Take(3).ToList();
            }
            @if (riskDeals.Any() || newLeads.Any())
            {
              @foreach (var deal in riskDeals)
              {
                <tr>
                  <td>
                    <span class="badge danger">Deal</span>
                    <a href="/Deals/Details/@deal.Id" class="d-block mt-1">@deal.Title</a>
                    <small class="text-muted">Revisar probabilidad baja</small>
                  </td>
                </tr>
              }
              @foreach (var lead in newLeads)
              {
                <tr>
                  <td>
                    <span class="badge warn">Lead</span>
                    <a href="/Leads/Details/@lead.Id" class="d-block mt-1">@lead.Name</a>
                    <small class="text-muted">Calificar lead nuevo</small>
                  </td>
                </tr>
              }
            }
            else
            {
              <tr><td class="table-empty">No hay acciones urgentes</td></tr>
            }
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<!-- Sección secundaria colapsable -->
<div class="card crm-collapse-card">
  <div class="card-header" data-toggle="collapse" data-target="#dashboardExtra" aria-expanded="false">
    <div class="d-flex justify-content-between align-items-center">
      <div>
        <h3><i class="fas fa-robot text-muted mr-2"></i>Centro IA y experiencia del cliente</h3>
        <span class="text-muted">Información complementaria — expandir si la necesitas</span>
      </div>
      <i class="fas fa-chevron-down text-muted"></i>
    </div>
  </div>
  <div id="dashboardExtra" class="collapse">
    <div class="card-b">
      <div class="row">
        <div class="col-md-6">
          <h4 class="crm-section-title">Actividad IA (modo supervisado)</h4>
          <div class="feed">
            <div class="item">
              <div class="d-flex justify-content-between">
                <span class="itag">DECISIÓN</span>
                <span class="itime">Reciente</span>
              </div>
              <div class="ibody">Priorización automática de deals según probabilidad e historial.</div>
            </div>
            <div class="item">
              <div class="d-flex justify-content-between">
                <span class="itag">CALIDAD</span>
                <span class="itime">En cola</span>
              </div>
              <div class="ibody">Normalización de datos de contacto en leads incompletos.</div>
            </div>
          </div>
          <a href="/Agents" class="btn btn-sm btn-outline-secondary mt-2">Ir a agentes IA</a>
        </div>
        <div class="col-md-6">
          <h4 class="crm-section-title">Indicadores de experiencia</h4>
          <table class="table table-sm">
            <thead><tr><th>Indicador</th><th>Valor</th><th></th></tr></thead>
            <tbody>
              <tr><td>Tiempo de respuesta</td><td>12 min</td><td><span class="badge ok">Bueno</span></td></tr>
              <tr><td>Satisfacción</td><td>4.6 / 5</td><td><span class="badge ok">Bueno</span></td></tr>
              <tr><td>Tickets reabiertos</td><td>3</td><td><span class="badge warn">Atención</span></td></tr>
            </tbody>
          </table>
          <a href="/Support" class="btn btn-sm btn-outline-secondary">Ir a soporte</a>
        </div>
      </div>
    </div>
  </div>
</div>
