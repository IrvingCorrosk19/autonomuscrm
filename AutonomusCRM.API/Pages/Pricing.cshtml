@page "/pricing"
@model AutonomusCRM.API.Pages.PricingModel
@{
    Layout = "Shared/Marketing/_MarketingLayout";
    ViewData["Title"] = L["Marketing_Pricing_PageTitle"].Value;
}
<section class="marketing-hero" style="padding-bottom:24px;">
  <h1>@L["Marketing_Pricing_HeroTitle"]</h1>
  <p class="lead">@L["Marketing_Pricing_HeroLead"]</p>
</section>

<section class="marketing-section" style="padding-top:0;">
  <div class="marketing-pricing-grid">
    <article class="marketing-price-card">
      <h3 style="margin:0;">@L["Marketing_Pricing_PilotTitle"]</h3>
      <div class="price">@L["Marketing_Pricing_PilotPrice"]<small>@L["Marketing_Pricing_PeriodYear"]</small></div>
      <p style="font-size:13px;color:var(--flow-text-secondary);">@L["Marketing_Pricing_PilotSubtitle"]</p>
      <ul>
        <li>@L["Marketing_Pricing_PilotFeature1"]</li>
        <li>@L["Marketing_Pricing_PilotFeature2"]</li>
        <li>@L["Marketing_Pricing_PilotFeature3"]</li>
        <li>@L["Marketing_Pricing_PilotFeature4"]</li>
        <li>@L["Marketing_Pricing_PilotFeature5"]</li>
      </ul>
      <span class="marketing-readiness marketing-readiness--ready">@L["Marketing_Pricing_ReadinessReady"]</span>
      <p style="margin-top:16px;"><a href="/Account/Login" class="flow-btn flow-btn-secondary" style="width:100%;">@L["Marketing_Pricing_PilotCta"]</a></p>
    </article>

    <article class="marketing-price-card featured">
      <h3 style="margin:0;">@L["Marketing_Pricing_GrowthTitle"]</h3>
      <div class="price">@L["Marketing_Pricing_GrowthPrice"]<small>@L["Marketing_Pricing_PeriodYear"]</small></div>
      <p style="font-size:13px;color:var(--flow-text-secondary);">@L["Marketing_Pricing_GrowthSubtitle"]</p>
      <ul>
        <li>@L["Marketing_Pricing_GrowthFeature1"]</li>
        <li>@L["Marketing_Pricing_GrowthFeature2"]</li>
        <li>@L["Marketing_Pricing_GrowthFeature3"]</li>
        <li>@L["Marketing_Pricing_GrowthFeature4"]</li>
        <li>@L["Marketing_Pricing_GrowthFeature5"]</li>
      </ul>
      <span class="marketing-readiness marketing-readiness--partial">@L["Marketing_Pricing_ReadinessPartial"]</span>
      <p style="margin-top:16px;font-size:12px;color:var(--flow-text-muted);">@L["Marketing_Pricing_GrowthRequirements"]</p>
      <p style="margin-top:12px;"><a href="/demo" class="flow-btn flow-btn-primary" style="width:100%;">@L["Marketing_Pricing_GrowthCta"]</a></p>
    </article>

    <article class="marketing-price-card">
      <h3 style="margin:0;">@L["Marketing_Pricing_EnterpriseTitle"]</h3>
      <div class="price">@L["Marketing_Pricing_EnterprisePrice"]<small>@L["Marketing_Pricing_PeriodYear"]</small></div>
      <p style="font-size:13px;color:var(--flow-text-secondary);">@L["Marketing_Pricing_EnterpriseSubtitle"]</p>
      <ul>
        <li>@L["Marketing_Pricing_EnterpriseFeature1"]</li>
        <li>@L["Marketing_Pricing_EnterpriseFeature2"]</li>
        <li>@L["Marketing_Pricing_EnterpriseFeature3"]</li>
        <li>@L["Marketing_Pricing_EnterpriseFeature4"]</li>
        <li>@L["Marketing_Pricing_EnterpriseFeature5"]</li>
      </ul>
      <span class="marketing-readiness marketing-readiness--not">@L["Marketing_Pricing_ReadinessNot"]</span>
      <p style="margin-top:16px;font-size:12px;color:var(--flow-text-muted);">@L["Marketing_Pricing_EnterpriseBlockers"]</p>
    </article>
  </div>

  <div class="marketing-card" style="max-width:720px;margin:40px auto 0;">
    <h3 style="margin:0 0 12px;">@L["Marketing_Pricing_EvaluationTitle"]</h3>
    <table class="flow-table-minimal">
      <thead><tr><th>@L["Marketing_Pricing_TablePrice"]</th><th>@L["Marketing_Pricing_TableReadiness"]</th><th>@L["Marketing_Pricing_TableBuyer"]</th></tr></thead>
      <tbody>
        <tr><td><strong>@L["Marketing_Pricing_Row10kPrice"]</strong></td><td style="color:var(--flow-success);">@L["Marketing_Pricing_Row10kReadiness"]</td><td>@L["Marketing_Pricing_Row10kBuyer"]</td></tr>
        <tr><td><strong>@L["Marketing_Pricing_Row50kPrice"]</strong></td><td style="color:var(--flow-warning);">@L["Marketing_Pricing_Row50kReadiness"]</td><td>@L["Marketing_Pricing_Row50kBuyer"]</td></tr>
        <tr><td><strong>@L["Marketing_Pricing_Row100kPrice"]</strong></td><td style="color:var(--flow-danger);">@L["Marketing_Pricing_Row100kReadiness"]</td><td>@L["Marketing_Pricing_Row100kBuyer"]</td></tr>
      </tbody>
    </table>
  </div>
</section>
