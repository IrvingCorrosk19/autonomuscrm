@page "/Customers/Details/{id:guid}"
@model AutonomusCRM.API.Pages.Customers.DetailsModel
@using AutonomusCRM.Application.Customers.Queries
@using AutonomusCRM.Domain.Customers
@{
    ViewData["Title"] = L["Customers_Detail_Kicker"].Value;
}

@if (Model.Customer == null)
{
    <div style="padding: 40px; text-align: center;">
        <h2>@L["Customers_Detail_NotFound"]</h2>
        <p>@L["Customers_Edit_NotFoundDesc"]</p>
        <a href="/Customers" class="btn primary">@L["Customers_Edit_BackTo"]</a>
    </div>
}
else
{
    <header class="topbar">
        <div class="topbar-left">
            <div class="kicker">@L["Customers_Detail_Kicker"]</div>
            <h2 class="headline">@Model.Customer.Name</h2>
        </div>

        <div class="topbar-right">
            <button class="btn mobile-toggle" type="button" onclick="toggleSidebar()">@L["Common_Menu"]</button>
            <a href="/Customers" class="btn">@L["Customers_Detail_BackTo"]</a>
            <a href="/Customers/Create" class="btn primary">@L["Customers_Detail_NewCustomer"]</a>
        </div>
    </header>

    <section class="grid">
        <div class="card">
            <div class="card-h">
                <div>
                    <h3 class="title">@L["Customers_Detail_CardTitle"]</h3>
                    <p class="subtitle">@L["Customers_Detail_CardSubtitle"]</p>
                </div>
                <span class="pill">ID: @(Model.Customer.Id.ToString().Substring(0, 8))...</span>
            </div>

            <div class="card-b">
                <table class="table" aria-label="@L["Customers_Detail_CardTitle"]">
                    <tbody>
                        <tr>
                            <td style="font-weight: 600; width: 200px;">@L["Common_Name"]</td>
                            <td>@Model.Customer.Name</td>
                        </tr>
                        <tr>
                            <td style="font-weight: 600;">@L["Common_Email"]</td>
                            <td>@(Model.Customer.Email ?? L["Common_NA"].Value)</td>
                        </tr>
                        <tr>
                            <td style="font-weight: 600;">@L["Common_Phone"]</td>
                            <td>@(Model.Customer.Phone ?? L["Common_NA"].Value)</td>
                        </tr>
                        <tr>
                            <td style="font-weight: 600;">@L["Form_Company"]</td>
                            <td>@(Model.Customer.Company ?? L["Common_NA"].Value)</td>
                        </tr>
                        <tr>
                            <td style="font-weight: 600;">@L["Common_Status"]</td>
                            <td><span class="badge ok">@Model.Customer.Status</span></td>
                        </tr>
                        <tr>
                            <td style="font-weight: 600;">@L["Common_LTV"]</td>
                            <td>
                                @if (Model.Customer.LifetimeValue.HasValue)
                                {
                                    <span class="badge @(Model.Customer.LifetimeValue > 20000 ? "ok" : Model.Customer.LifetimeValue > 10000 ? "warn" : "")">$ @(Model.Customer.LifetimeValue.Value.ToString("N0"))</span>
                                }
                                else
                                {
                                    <span class="badge">@L["Common_NA"]</span>
                                }
                            </td>
                        </tr>
                        <tr>
                            <td style="font-weight: 600;">@L["Common_Risk"]</td>
                            <td>
                                @if (Model.Customer.RiskScore.HasValue)
                                {
                                    <span class="badge @(Model.Customer.RiskScore < 30 ? "ok" : Model.Customer.RiskScore < 70 ? "warn" : "danger")">@(Model.Customer.RiskScore < 30 ? L["Common_RiskLow"].Value : Model.Customer.RiskScore < 70 ? L["Common_RiskMedium"].Value : L["Common_RiskHigh"].Value)</span>
                                }
                                else
                                {
                                    <span class="badge">@L["Common_NA"]</span>
                                }
                            </td>
                        </tr>
                        <tr>
                            <td style="font-weight: 600;">@L["Common_Created"]</td>
                            <td>@(Model.Customer.CreatedAt.ToString("dd/MM/yyyy HH:mm"))</td>
                        </tr>
                    </tbody>
                </table>

                <div style="height:12px"></div>

                <div style="display:flex; gap:10px; flex-wrap:wrap;">
                    <a href="/Customers" class="btn">@L["Common_BackToList"]</a>
                    <a href="/Customers/Edit/@Model.Customer.Id" class="btn">@L["Btn_Edit"]</a>
                </div>
            </div>
        </div>

        <aside class="stack">
            <div class="card">
                <div class="card-h">
                    <div>
                        <h3 class="title">@L["Customers_Detail_QuickActions"]</h3>
                        <p class="subtitle">@L["Customers_Detail_QuickActionsSubtitle"]</p>
                    </div>
                </div>
                <div class="card-b">
                    <div style="display: flex; flex-direction: column; gap: 10px;">
                        <button class="btn" type="button" onclick="showCreateDealModal()" style="width: 100%;">@L["Customers_Detail_CreateDeal"]</button>
                        <button class="btn" type="button" onclick="showHistoryModal()" style="width: 100%;">@L["Customers_Detail_ViewHistory"]</button>
                        <form method="post" asp-page-handler="RecordContact" style="margin: 0;">
                            <input type="hidden" name="id" value="@Model.Customer.Id" />
                            <button class="btn" type="submit" style="width: 100%;">@L["Customers_Detail_Contact"]</button>
                        </form>
                    </div>
                </div>
                
                <div class="card" style="margin-top: 20px;">
                    <div class="card-h">
                        <div>
                            <h3 class="title">@L["Common_DangerZone"]</h3>
                        </div>
                    </div>
                    <div class="card-b">
                        <form method="post" asp-page-handler="Delete" onsubmit="return confirm(this.dataset.msg)" data-msg="@L["Customers_Detail_DeleteConfirm"]">
                            <input type="hidden" name="id" value="@Model.Customer.Id" />
                            <button type="submit" class="btn" style="background: rgba(255, 0, 0, 0.2); border-color: rgba(255, 0, 0, 0.5); color: #ff6b6b; width: 100%;">@L["Customers_Detail_DeleteCustomer"]</button>
                        </form>
                    </div>
                </div>
            </div>
        </aside>
    </section>
}

<div style="height:14px"></div>

<footer style="color:rgba(255,255,255,0.55); font-size:12px; padding:8px 2px;">
  @L["Customers_Detail_Footer"]
</footer>

<div id="createDealModal" style="display: none; position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.7); z-index: 1000; align-items: center; justify-content: center;">
    <div class="card" style="max-width: 500px; margin: auto; position: relative; top: 50%; transform: translateY(-50%);">
        <div class="card-h">
            <div>
                <h3 class="title">@L["Customers_Detail_CreateDealForCustomer"]</h3>
            </div>
        </div>
        <div class="card-b">
            <form method="post" asp-page-handler="CreateDeal">
                <input type="hidden" name="id" value="@Model.Customer.Id" />
                <div style="margin-bottom: 15px;">
                    <label style="display: block; margin-bottom: 5px; font-weight: 600;">@L["Form_TitleRequired"]</label>
                    <input type="text" name="title" required style="width: 100%; padding: 10px; border: 1px solid rgba(255,255,255,0.1); background: var(--bg); color: var(--text); border-radius: 4px;" />
                </div>
                <div style="margin-bottom: 15px;">
                    <label style="display: block; margin-bottom: 5px; font-weight: 600;">@L["Form_AmountRequired"]</label>
                    <input type="number" name="amount" required step="0.01" min="0" style="width: 100%; padding: 10px; border: 1px solid rgba(255,255,255,0.1); background: var(--bg); color: var(--text); border-radius: 4px;" />
                </div>
                <div style="margin-bottom: 15px;">
                    <label style="display: block; margin-bottom: 5px; font-weight: 600;">@L["Form_Description"]</label>
                    <textarea name="description" rows="3" style="width: 100%; padding: 10px; border: 1px solid rgba(255,255,255,0.1); background: var(--bg); color: var(--text); border-radius: 4px;"></textarea>
                </div>
                <div style="display: flex; gap: 10px;">
                    <button type="submit" class="btn primary" style="flex: 1;">@L["Customers_Detail_CreateDeal"]</button>
                    <button type="button" class="btn" onclick="closeCreateDealModal()" style="flex: 1;">@L["Btn_Cancel"]</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div id="historyModal" style="display: none; position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.7); z-index: 1000; align-items: center; justify-content: center;">
    <div class="card" style="max-width: 700px; margin: auto; position: relative; top: 50%; transform: translateY(-50%); max-height: 80vh; overflow-y: auto;">
        <div class="card-h">
            <div>
                <h3 class="title">@L["Customers_Detail_HistoryTitle"]</h3>
                <p class="subtitle">@Model.Customer.Name</p>
            </div>
        </div>
        <div class="card-b">
            <div style="margin-bottom: 15px;">
                <h4 style="margin-bottom: 10px;">@L["Customers_Detail_CardTitle"]</h4>
                <table class="table" style="margin-bottom: 20px;">
                    <tbody>
                        <tr>
                            <td style="font-weight: 600; width: 150px;">@L["Customers_Detail_CustomerSince"]</td>
                            <td>@(Model.Customer.CreatedAt.ToString("dd/MM/yyyy HH:mm"))</td>
                        </tr>
                        <tr>
                            <td style="font-weight: 600;">@L["Customers_Detail_CurrentStatus"]</td>
                            <td><span class="badge ok">@Model.Customer.Status</span></td>
                        </tr>
                        <tr>
                            <td style="font-weight: 600;">@L["Common_LTV"]</td>
                            <td>@(Model.Customer.LifetimeValue?.ToString("C") ?? L["Common_NA"].Value)</td>
                        </tr>
                        <tr>
                            <td style="font-weight: 600;">@L["Common_Risk"]</td>
                            <td>
                                @if (Model.Customer.RiskScore.HasValue)
                                {
                                    <span class="badge @(Model.Customer.RiskScore < 30 ? "ok" : Model.Customer.RiskScore < 70 ? "warn" : "danger")">
                                        @(Model.Customer.RiskScore < 30 ? L["Common_RiskLow"].Value : Model.Customer.RiskScore < 70 ? L["Common_RiskMedium"].Value : L["Common_RiskHigh"].Value)
                                    </span>
                                }
                                else
                                {
                                    <text>@L["Common_NA"]</text>
                                }
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
            
            <div style="margin-bottom: 15px;">
                <h4 style="margin-bottom: 10px;">@L["Customers_Detail_RecentActivity"]</h4>
                <div style="color: var(--muted); font-size: 14px;">
                    <p>@L["Customers_Detail_HistoryPlaceholder"]</p>
                    <p style="margin-top: 10px;">@L["Customers_Detail_HistoryDevNote"]</p>
                </div>
            </div>
            
            <div style="display: flex; gap: 10px;">
                <button type="button" class="btn" onclick="closeHistoryModal()" style="flex: 1;">@L["Common_Close"]</button>
            </div>
        </div>
    </div>
</div>

<script>
function showCreateDealModal() {
    document.getElementById('createDealModal').style.display = 'flex';
}
function closeCreateDealModal() {
    document.getElementById('createDealModal').style.display = 'none';
}
function showHistoryModal() {
    document.getElementById('historyModal').style.display = 'flex';
}
function closeHistoryModal() {
    document.getElementById('historyModal').style.display = 'none';
}
</script>
