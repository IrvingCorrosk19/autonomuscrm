@page "/Customers/Edit/{id:guid}"
@model AutonomusCRM.API.Pages.Customers.EditModel
@using AutonomusCRM.Domain.Customers
@{
    ViewData["Title"] = L["Customers_Edit_Kicker"].Value;
}

@if (Model.Customer == null)
{
    ViewData["EmptyIcon"] = "fas fa-building";
    ViewData["EmptyTitle"] = L["Customers_Edit_NotFound"].Value;
    ViewData["EmptyMessage"] = L["Customers_Edit_NotFoundDesc"].Value;
    ViewData["EmptyActionHtml"] = $"<a href=\"/Customers\" class=\"flow-btn flow-btn-primary\">{L["Customers_Edit_BackTo"].Value}</a>";
    <partial name="Shared/_CrmEmptyState" />
}
else
{
    ViewData["PageTitle"] = Model.Customer.Name;
    ViewData["PageKicker"] = L["Customers_Edit_Kicker"].Value;
    ViewData["PageSubtitle"] = L["Customers_Edit_CardSubtitle"].Value;
    ViewData["PageActionsHtml"] = $"<a href=\"/Customers/Details/{Model.Customer.Id}\" class=\"flow-btn flow-btn-secondary\">{L["Btn_Cancel"].Value}</a>";

    <partial name="Flow/_FlowPageHeader" />
    <partial name="Shared/_FlowFormAlerts" />

    <section class="flow-card flow-form-card">
        <header class="flow-card-header">
            <h2 class="flow-card-title" id="customer-edit-title">@L["Customers_Edit_CardTitle"]</h2>
            <p class="flow-page-subtitle mb-0">@L["Customers_Edit_CardSubtitle"]</p>
        </header>
        <div class="flow-card-body">
            <form method="post" class="flow-form" aria-labelledby="customer-edit-title">
                <div class="flow-form-grid">
                    <div class="flow-form-field">
                        <label class="flow-form-label" for="customer-edit-name">@L["Form_NameRequired"]</label>
                        <input type="text" id="customer-edit-name" name="name" class="flow-form-control" value="@Model.Customer.Name" required autocomplete="name" />
                    </div>
                    <div class="flow-form-field">
                        <label class="flow-form-label" for="customer-edit-email">@L["Common_Email"]</label>
                        <input type="email" id="customer-edit-email" name="email" class="flow-form-control" value="@Model.Customer.Email" autocomplete="email" />
                    </div>
                    <div class="flow-form-field">
                        <label class="flow-form-label" for="customer-edit-phone">@L["Common_Phone"]</label>
                        <input type="tel" id="customer-edit-phone" name="phone" class="flow-form-control" value="@Model.Customer.Phone" autocomplete="tel" />
                    </div>
                    <div class="flow-form-field">
                        <label class="flow-form-label" for="customer-edit-company">@L["Form_Company"]</label>
                        <input type="text" id="customer-edit-company" name="company" class="flow-form-control" value="@Model.Customer.Company" autocomplete="organization" />
                    </div>
                    <div class="flow-form-field">
                        <label class="flow-form-label" for="customer-edit-status">@L["Common_Status"]</label>
                        <select id="customer-edit-status" name="status" class="flow-form-control">
                            <option value="">@L["Form_NoChange"]</option>
                            @foreach (var status in Model.Statuses)
                            {
                                <option value="@status.Value" selected="@status.Selected">@status.Text</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="flow-form-actions">
                    <button type="submit" class="flow-btn flow-btn-primary">@L["Form_SaveChanges"]</button>
                    <a href="/Customers/Details/@Model.Customer.Id" class="flow-btn flow-btn-secondary">@L["Btn_Cancel"]</a>
                </div>
            </form>
        </div>
    </section>

    <p class="flow-form-footer">@L["Customers_Edit_Footer"]</p>
}
