@page
@model AutonomusCRM.API.Pages.WorkflowsModel
@{
    ViewData["Title"] = L["Workflows_PageTitle"].Value;
}

<!-- TOPBAR -->
<header class="topbar">
  <div class="topbar-left">
    <div class="kicker">@L["Workflows_Subtitle"]</div>
    <h2 class="headline">@L["Workflows_PageTitle"]</h2>
  </div>

  <div class="topbar-center">
    <div class="search" role="search">
      <input type="text" placeholder="@L["Btn_Search"]…" aria-label="@L["Btn_Search"]" />
      <span class="chip">@L["Btn_Filter"]</span>
      <span class="chip">@L["Common_Status"]</span>
    </div>
  </div>

  <div class="topbar-right">
    <button class="btn mobile-toggle" type="button" onclick="toggleSidebar()">@L["Common_Menu"]</button>
    <button class="btn" type="button" onclick="showImportModal()">@L["Btn_Import"]</button>
    <a href="/Workflows/Create" class="btn primary crm-link-btn">@L["Workflows_New"]</a>
  </div>
</header>

<!-- STATS -->
<section class="stats" aria-label="@L["Workflows_PageTitle"]">
  <div class="stat">
    <div class="label">@L["Workflows_Active"]</div>
    <div class="value">@Model.Workflows.Count(w => w.IsActive)</div>
    <div class="hint">
      <span>@L["Workflows_Subtitle"]</span>
      <span class="delta up">@Model.Workflows.Count @L["Workflows_PageTitle"]</span>
    </div>
  </div>

  <div class="stat">
    <div class="label">@L["Command_History"]</div>
    <div class="value">@Model.Workflows.Sum(w => w.ExecutionCount)</div>
    <div class="hint">
      <span>@L["Workflows_Subtitle"]</span>
      <span class="delta up">@Model.Workflows.Count(w => w.ExecutionCount > 0)</span>
    </div>
  </div>

  <div class="stat">
    <div class="label">@L["Common_Status"]</div>
    <div class="value">@(Model.Workflows.Any() ? "100%" : "N/A")</div>
    <div class="hint">
      <span>@L["Command_History"]</span>
      <span class="delta up">@Model.Workflows.Count(w => w.IsActive) @L["Workflows_Active"]</span>
    </div>
  </div>

  <div class="stat">
    <div class="label">@L["Command_DecisionDate"]</div>
    <div class="value">@(Model.Workflows.Any(w => w.LastExecutedAt.HasValue) ? Model.Workflows.Where(w => w.LastExecutedAt.HasValue).Max(w => w.LastExecutedAt!.Value).ToString("HH:mm") : "N/A")</div>
    <div class="hint">
      <span>@L["Command_LastPeriod"]</span>
      <span class="delta up">@Model.Workflows.Count(w => w.LastExecutedAt.HasValue) @L["Command_History"]</span>
    </div>
  </div>
</section>

<section class="grid">
  <!-- LEFT: Workflows List -->
  <div class="card">
    <div class="card-h">
      <div>
        <h3 class="title">@L["Workflows_PageTitle"]</h3>
        <p class="subtitle">@L["Workflows_Subtitle"]</p>
      </div>
      <span class="pill">@Model.Workflows.Count @L["Workflows_PageTitle"]</span>
    </div>

    <div class="card-b">
      <table class="table" aria-label="@L["Workflows_PageTitle"]">
        <thead>
          <tr>
            <th>@L["Workflows_PageTitle"]</th>
            <th>@L["Command_DecisionType"]</th>
            <th>@L["Command_History"]</th>
            <th>@L["Common_Status"]</th>
            <th>@L["Common_Actions"]</th>
          </tr>
        </thead>
        <tbody>
          @if (Model.Workflows.Any())
          {
            @foreach (var workflow in Model.Workflows)
            {
              <tr>
                <td>
                  <div class="crm-meta-strong">@workflow.Name</div>
                  <div class="crm-meta-muted">@(workflow.Description ?? L["Common_NoData"].Value)</div>
                </td>
                <td>
                  @if (workflow.Triggers.Any())
                  {
                    <span class="pill">@workflow.Triggers.First().Type</span>
                  }
                  else
                  {
                    <span class="pill">@L["Common_NoData"]</span>
                  }
                </td>
                <td>@workflow.ExecutionCount</td>
                <td><span class="badge @(workflow.IsActive ? "ok" : "")">@(workflow.IsActive ? L["Integrations_Connected"].Value : L["Integrations_Disconnected"].Value)</span></td>
                <td>
                  <a href="/Workflows/Edit/@workflow.Id" class="btn crm-btn-compact crm-link-btn">@L["Btn_Edit"]</a>
                </td>
              </tr>
            }
          }
          else
          {
            <tr>
              <td colspan="5" class="crm-empty-cell">
                @L["Workflows_Empty"] <a href="/Workflows/Create">@L["Btn_Create"]</a>
              </td>
            </tr>
          }
        </tbody>
      </table>

      <div class="crm-toolbar-spacer"></div>

      <div class="crm-toolbar">
        <button class="btn" type="button" onclick="exportWorkflows()">@L["Btn_Export"]</button>
        <a href="/Workflows/Create" class="btn primary crm-link-btn">@L["Btn_Create"]</a>
      </div>
    </div>
  </div>

  <!-- RIGHT: Activity & Stats -->
  <aside class="stack">
    <div class="card">
      <div class="card-h">
        <div>
          <h3 class="title">@L["Command_History"]</h3>
          <p class="subtitle">@L["Command_DecisionOutcome"]</p>
        </div>
        <span class="pill">@L["Command_LiveDecisions"]</span>
      </div>
      <div class="card-b">
        <div class="feed">
          <div class="item">
            <div class="itop">
              <div class="itag">@L["Command_DecisionOutcome"]</div>
              <div class="itime">2 min</div>
            </div>
            <div class="ibody">
              Lead #342 — @L["Btn_Send"]
            </div>
            <div class="ifooter">
              <span class="pill">1.2s</span>
              <span class="pill">@L["Common_Status"]: OK</span>
            </div>
          </div>

          <div class="item">
            <div class="itop">
              <div class="itag">@L["Command_DecisionOutcome"]</div>
              <div class="itime">5 min</div>
            </div>
            <div class="ibody">
              Lead #89 — @L["Agents_Subtitle"]
            </div>
            <div class="ifooter">
              <span class="pill">0.8s</span>
              <span class="pill">@L["Common_Status"]: OK</span>
            </div>
          </div>

          <div class="item">
            <div class="itop">
              <div class="itag">@L["Common_Risk"]</div>
              <div class="itime">12 min</div>
            </div>
            <div class="ibody">
              @L["Command_RevenueAtRisk"] — #23
            </div>
            <div class="ifooter">
              <span class="pill">2.1s</span>
              <span class="pill">@L["Common_Status"]: OK</span>
            </div>
          </div>
        </div>

        <div class="crm-toolbar-spacer"></div>

        <button class="btn primary crm-btn-block" type="button" onclick="alert('@L["Policies_HistorySoon"]');">@L["Command_SeeAll"]</button>
      </div>
    </div>

    <div class="card">
      <div class="card-h">
        <div>
          <h3 class="title">@L["Command_Expansion"]</h3>
          <p class="subtitle">@L["Command_MetricsWillAppear"]</p>
        </div>
        <span class="pill">@L["Agents_Subtitle"]</span>
      </div>
      <div class="card-b">
        <div class="feed">
          <div class="item">
            <div class="itop">
              <div class="itag">@L["Command_Expansion"]</div>
              <div class="itime">1h</div>
            </div>
            <div class="ibody">
              @L["Workflows_Active"] — 23%
            </div>
            <div class="ifooter">
              <span class="pill">@L["Common_Risk"]</span>
              <span class="pill">@L["Btn_Save"]</span>
            </div>
          </div>
        </div>

        <div class="crm-toolbar-spacer"></div>

        <button class="btn primary crm-btn-block" type="button" onclick="alert('@L["Policies_HistorySoon"]');">@L["Command_SeeAll"]</button>
      </div>
    </div>
  </aside>
</section>

<div class="crm-section-gap"></div>

<footer class="crm-footer-note">
  AUTONOMUS CRM · @L["Workflows_Subtitle"]
</footer>

<div id="importModal" class="crm-overlay-modal">
    <div class="card crm-overlay-card">
        <div class="card-h">
            <div>
                <h3 class="title">@L["Btn_Import"] @L["Workflows_PageTitle"]</h3>
            </div>
        </div>
        <div class="card-b">
            <form method="post" action="/Workflows/Import" enctype="multipart/form-data">
                <div class="crm-form-field">
                    <label>@L["Form_JsonRequired"]</label>
                    <input type="file" name="file" accept=".json" required class="crm-form-control" />
                    <div class="crm-form-help">
                        @L["Btn_Import"] JSON
                    </div>
                </div>
                <div class="crm-split-actions">
                    <button type="submit" class="btn primary">@L["Btn_Import"]</button>
                    <button type="button" class="btn" onclick="closeImportModal()">@L["Btn_Cancel"]</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
function exportWorkflows() {
    const workflows = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Workflows.Select(w => new { w.Id, w.Name, w.Description, w.IsActive, w.ExecutionCount })));
    const json = JSON.stringify(workflows, null, 2);
    const blob = new Blob([json], { type: 'application/json' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = 'workflows-' + new Date().toISOString().split('T')[0] + '.json';
    a.click();
    URL.revokeObjectURL(url);
}
function showImportModal() { window.crmModal.open('importModal'); }
function closeImportModal() { window.crmModal.close('importModal'); }
</script>
