@page "/customers/{id:guid}/360"
@model AutonomusCRM.API.Pages.Customer360.DetailModel
@using AutonomusCRM.API.Infrastructure
@{
    var v = Model.View!;
    ViewData["Title"] = v.Profile.Name;
    ViewData["PageTitle"] = v.Profile.Name;
    ViewData["PageKicker"] = L["Customer360_Kicker"].Value;
    ViewData["PageSubtitle"] = v.Profile.Email ?? L["Customer360_SubtitleDefault"].Value;
    ViewData["PageActionsHtml"] = $@"<a href=""/Customers/Details/{v.Profile.CustomerId}"" class=""flow-btn flow-btn-secondary"">CRM</a>";
}
<partial name="Flow/_FlowPageHeader" />

<div class="flow-c360-grid">
  <section class="flow-card">
    <header class="flow-card-header"><h3 class="flow-card-title">@L["Customer360_ExecutiveSummary"]</h3></header>
    <div class="flow-card-body">
      <ul>@foreach (var b in v.ExecutiveSummaryBullets) { <li>@b</li> }</ul>
    </div>
  </section>
  <section class="flow-card">
    <header class="flow-card-header"><h3 class="flow-card-title">@L["Customer360_CustomerHealth"]</h3></header>
    <div class="flow-card-body flow-health-scores">
      <div><span>@L["Customer360_Health"]</span><strong>@v.Health.HealthScore</strong></div>
      <div><span>@L["Customer360_ChurnRisk"]</span><strong>@(v.Health.ChurnRisk?.ToString("F0") ?? "—")%</strong></div>
      <div><span>@L["Customer360_Expansion"]</span><strong>@v.Health.ExpansionReadiness</strong></div>
      <div><span>@L["Customer360_Usage30d"]</span><strong>@v.Health.UsageEvents30d</strong></div>
      <div><span>@L["Customer360_Level"]</span><strong>@v.Health.RiskLevel</strong></div>
    </div>
    @{
      var hasRenewal = v.Journey.Any(j => j.Stage.Contains("Renew", StringComparison.OrdinalIgnoreCase) && j.Status != "completed");
      ViewData["FlowInsightType"] = hasRenewal ? FlowInsightTypes.Renewal : FlowInsightMapper.FromHealth(v.Health);
      ViewData["FlowInsightCustomerId"] = v.Profile.CustomerId;
      ViewData["FlowInsightCustomerName"] = v.Profile.Name;
      ViewData["FlowInsightReturnUrl"] = $"/customers/{v.Profile.CustomerId}/360";
    }
    <footer class="flow-card-footer">
      <partial name="Flow/_FlowInsightActions" />
    </footer>
  </section>
</div>

@if (Model.ActionLearning != null)
{
  var al = Model.ActionLearning;
  <section class="flow-card mt-4">
    <header class="flow-card-header">
      <h3 class="flow-card-title">@L["Customer360_AbosTitle"]</h3>
      <span class="flow-text-muted-sm">@L["Customer360_AbosSubtitle"]</span>
    </header>
    <div class="flow-card-body">
      <div class="flow-revenue-grid">
        <div>
          <h4 class="flow-subsection-title">@string.Format(L["Customer360_SuccessfulActions"].Value, al.Worked.Count)</h4>
          @if (al.Worked.Count == 0) { <p class="flow-text-muted-sm">@L["Customer360_NoPositiveOutcomes"]</p> }
          else {
            <ul class="flow-list-minimal">
              @foreach (var w in al.Worked.Take(6)) {
                <li><strong>@w.Action</strong> · @w.Recommendation<br /><span class="text-muted">@w.Outcome · $@w.RevenueDelta.ToString("N0")</span></li>
              }
            </ul>
          }
        </div>
        <div>
          <h4 class="flow-subsection-title">@string.Format(L["Customer360_UnsuccessfulActions"].Value, al.Failed.Count)</h4>
          @if (al.Failed.Count == 0) { <p class="flow-text-muted-sm">@L["Customer360_NoFailedActions"]</p> }
          else {
            <ul class="flow-list-minimal">
              @foreach (var f in al.Failed.Take(6)) {
                <li><strong>@f.Action</strong> · @f.Recommendation<br /><span class="text-muted">@f.Outcome</span></li>
              }
            </ul>
          }
        </div>
      </div>
      @if (al.BestActions.Count > 0)
      {
        <h4 class="flow-subsection-title">@L["Customer360_BestActionsForProfile"]</h4>
        <table class="flow-table-minimal">
          <thead><tr><th>@L["Common_Action"]</th><th>@L["Common_Success"]</th><th>@L["Common_Attempts"]</th></tr></thead>
          <tbody>
            @foreach (var b in al.BestActions) {
              <tr><td>@b.Label</td><td>@b.SuccessRate.ToString("F0")%</td><td>@b.TotalAttempts</td></tr>
            }
          </tbody>
        </table>
      }
    </div>
  </section>
}

@if (v.CustomerSuccess != null)
{
  var cs = v.CustomerSuccess;
  <section class="flow-card mt-4">
    <header class="flow-card-header">
      <h3 class="flow-card-title">@L["Customer360_CustomerSuccess"]</h3>
      <a href="/customer-success" class="flow-btn flow-btn-secondary flow-btn-sm">@L["Customer360_OpenCsOs"]</a>
    </header>
    <div class="flow-card-body">
      <div class="flow-revenue-grid">
        <div>
          <h4 class="flow-subsection-title">@string.Format(L["Customer360_OpenTickets"].Value, cs.OpenTickets.Count)</h4>
          @if (cs.OpenTickets.Count == 0) { <p class="flow-text-muted-sm">@L["Common_None"]</p> }
          <ul class="flow-list-minimal">
            @foreach (var t in cs.OpenTickets) { <li><strong>@t.Subject</strong> · @t.Priority</li> }
          </ul>
        </div>
        <div>
          <h4 class="flow-subsection-title">@string.Format(L["Customer360_ClosedTickets"].Value, cs.ClosedTickets.Count)</h4>
          @if (cs.ClosedTickets.Count == 0) { <p class="flow-text-muted-sm">@L["Common_None"]</p> }
          <ul class="flow-list-minimal">
            @foreach (var t in cs.ClosedTickets) { <li>@t.Subject</li> }
          </ul>
        </div>
      </div>
      <h4 class="flow-subsection-title">@L["Customer360_RecentCases"]</h4>
      @if (cs.RecentCases.Count == 0) { <p class="flow-text-muted-sm">@L["Customer360_NoCsCases"]</p> }
      else {
        <table class="flow-table-minimal">
          <thead><tr><th>@L["Common_Type"]</th><th>@L["Common_Title"]</th><th>@L["Common_Status"]</th></tr></thead>
          <tbody>
            @foreach (var c in cs.RecentCases) {
              <tr><td>@c.CaseTypeLabel</td><td>@c.Title</td><td>@c.Status</td></tr>
            }
          </tbody>
        </table>
      }
    </div>
  </section>
}

<section class="flow-card mt-4">
  <header class="flow-card-header"><h3 class="flow-card-title">@L["Customer360_CustomerJourney"]</h3></header>
  <div class="flow-card-body flow-journey">
    @foreach (var s in v.Journey)
    {
      <div class="flow-journey-stage @(s.Status == "completed" ? "is-done" : "")">
        <strong>@s.Stage</strong>
        <span>@s.Status</span>
        <small>@(s.OccurredAt?.ToString("d") ?? "—")</small>
      </div>
    }
  </div>
</section>

<section class="flow-card mt-4">
  <header class="flow-card-header"><h3 class="flow-card-title">@L["Customer360_TimelineUnified"]</h3></header>
  <div class="flow-card-body">
    @if (v.Timeline.Count == 0)
    {
      ViewData["FlowEmptyTitle"] = L["Customer360_NoEvents"].Value;
      ViewData["FlowEmptyMessage"] = L["Customer360_NoEventsMessage"].Value;
      <partial name="Flow/_FlowEmptyState" />
    }
    else
    {
      <div class="flow-timeline">
        @foreach (var e in v.Timeline)
        {
          <div class="flow-timeline-item sev-@e.Severity">
            <time>@e.OccurredAt.ToString("g")</time>
            <span class="flow-timeline-cat">@e.Category</span>
            <strong>@e.Title</strong>
            <p>@e.Detail</p>
          </div>
        }
      </div>
    }
  </div>
</section>

<section class="flow-card mt-4">
  <header class="flow-card-header"><h3 class="flow-card-title">@L["Customer360_CommunicationTimeline"]</h3></header>
  <div class="flow-card-body">
    @if (v.Communications.Count == 0)
    {
      <p class="flow-text-muted-sm">@L["Customer360_NoCommunications"]</p>
    }
    else
    {
      <div class="flow-timeline flow-timeline--compact">
        @foreach (var e in v.Communications)
        {
          <div class="flow-timeline-item sev-@e.Severity">
            <time>@e.OccurredAt.ToString("g")</time>
            <span class="flow-timeline-cat">@e.Category</span>
            <strong>@e.Title</strong>
            <p>@e.Detail</p>
          </div>
        }
      </div>
    }
  </div>
</section>

<section class="flow-card mt-4">
  <header class="flow-card-header"><h3 class="flow-card-title">@L["Customer360_RelationshipGraph"]</h3></header>
  <div class="flow-card-body">
    <partial name="Flow/_FlowRelationshipGraph" model="(v.RelationshipNodes, v.RelationshipEdges)" />
  </div>
</section>

<section class="flow-card mt-4">
  <header class="flow-card-header">
    <h3 class="flow-card-title">@L["Customer360_WhyAtRisk"]</h3>
    <span class="flow-text-muted-sm">@L["Customer360_DecisionIntelligence"]</span>
  </header>
  <div class="flow-card-body">
    <partial name="Flow/_FlowExplainability" model="Model.Explainability" />
  </div>
</section>

@if (v.KnowledgeGraph != null)
{
  var kg = v.KnowledgeGraph;
  <section class="flow-card mt-4">
    <header class="flow-card-header">
      <h3 class="flow-card-title">@L["Customer360_KnowledgeGraph"]</h3>
      <span class="flow-text-muted-sm">@L["Customer360_KnowledgeGraphSubtitle"]</span>
    </header>
    <div class="flow-card-body">
      <div class="flow-metric-grid flow-metric-grid--compact">
        <div><span class="text-muted">@L["Customer360_Nodes"]</span><strong>@kg.Nodes.Count</strong></div>
        <div><span class="text-muted">@L["Customer360_Edges"]</span><strong>@kg.Edges.Count</strong></div>
        <div><span class="text-muted">@L["Customer360_RevenueLinks"]</span><strong>@kg.RevenueLinks.Count</strong></div>
        <div><span class="text-muted">@L["Customer360_Risks"]</span><strong>@kg.RiskSignals.Count</strong></div>
      </div>
      @if (kg.Exploration.Answers.Count > 0)
      {
        <h4 class="flow-subsection-title">@L["Customer360_Exploration"]</h4>
        <ul class="flow-list-minimal">
          @foreach (var a in kg.Exploration.Answers)
          {
            <li><strong>@a.Question</strong><br /><span class="text-muted">@a.Answer</span></li>
          }
        </ul>
      }
      @if (kg.Nodes.Count > 0)
      {
        <div class="flow-rel-graph" role="img" aria-label="@L["Customer360_KnowledgeGraphAria"]">
          @foreach (var n in kg.Nodes.Take(12))
          {
            <div class="flow-rel-node" title="@n.NodeType">
              <div>@n.Label</div>
              <small>@n.NodeType</small>
            </div>
          }
        </div>
      }
    </div>
  </section>
}

<section class="flow-card mt-4">
  <div class="flow-card-body">
    <a href="/Customer360" class="flow-btn flow-btn-secondary">@L["Customer360_BackToDirectory"]</a>
  </div>
</section>
