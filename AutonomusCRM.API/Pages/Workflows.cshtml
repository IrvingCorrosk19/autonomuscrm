@page
@model AutonomusCRM.API.Pages.WorkflowsModel
@{
    ViewData["Title"] = "Workflows - AUTONOMUS CRM";
}

<!-- TOPBAR -->
<header class="topbar">
  <div class="topbar-left">
    <div class="kicker">Automatización</div>
    <h2 class="headline">Workflows y procesos automáticos</h2>
  </div>

  <div class="topbar-center">
    <div class="search" role="search">
      <input type="text" placeholder="Buscar workflows..." aria-label="Buscar" />
      <span class="chip">Filtros</span>
      <span class="chip">Estado</span>
    </div>
  </div>

  <div class="topbar-right">
    <button class="btn mobile-toggle" type="button" onclick="toggleSidebar()">Menú</button>
    <button class="btn" type="button" onclick="showImportModal()">Importar</button>
    <a href="/Workflows/Create" class="btn primary crm-link-btn">Nuevo Workflow</a>
  </div>
</header>

<!-- STATS -->
<section class="stats" aria-label="Métricas de workflows">
  <div class="stat">
    <div class="label">Workflows activos</div>
    <div class="value">@Model.Workflows.Count(w => w.IsActive)</div>
    <div class="hint">
      <span>En ejecución</span>
      <span class="delta up">@Model.Workflows.Count total</span>
    </div>
  </div>

  <div class="stat">
    <div class="label">Ejecuciones totales</div>
    <div class="value">@Model.Workflows.Sum(w => w.ExecutionCount)</div>
    <div class="hint">
      <span>Acciones automáticas</span>
      <span class="delta up">@Model.Workflows.Count(w => w.ExecutionCount > 0) con ejecuciones</span>
    </div>
  </div>

  <div class="stat">
    <div class="label">Tasa de éxito</div>
    <div class="value">@(Model.Workflows.Any() ? "100%" : "N/A")</div>
    <div class="hint">
      <span>Completados</span>
      <span class="delta up">@Model.Workflows.Count(w => w.IsActive) activos</span>
    </div>
  </div>

  <div class="stat">
    <div class="label">Última ejecución</div>
    <div class="value">@(Model.Workflows.Any(w => w.LastExecutedAt.HasValue) ? Model.Workflows.Where(w => w.LastExecutedAt.HasValue).Max(w => w.LastExecutedAt!.Value).ToString("HH:mm") : "N/A")</div>
    <div class="hint">
      <span>Hoy</span>
      <span class="delta up">@Model.Workflows.Count(w => w.LastExecutedAt.HasValue) con historial</span>
    </div>
  </div>
</section>

<section class="grid">
  <!-- LEFT: Workflows List -->
  <div class="card">
    <div class="card-h">
      <div>
        <h3 class="title">Workflows configurados</h3>
        <p class="subtitle">
          Procesos automáticos con triggers, condiciones y acciones definidas.
        </p>
      </div>
      <span class="pill">@Model.Workflows.Count workflows</span>
    </div>

    <div class="card-b">
      <table class="table" aria-label="Lista de workflows">
        <thead>
          <tr>
            <th>Workflow</th>
            <th>Trigger</th>
            <th>Ejecuciones</th>
            <th>Estado</th>
            <th>Acciones</th>
          </tr>
        </thead>
        <tbody>
          @if (Model.Workflows.Any())
          {
            @foreach (var workflow in Model.Workflows)
            {
              <tr>
                <td>
                  <div class="crm-meta-strong">@workflow.Name</div>
                  <div class="crm-meta-muted">@(workflow.Description ?? "Sin descripción")</div>
                </td>
                <td>
                  @if (workflow.Triggers.Any())
                  {
                    <span class="pill">@workflow.Triggers.First().Type</span>
                  }
                  else
                  {
                    <span class="pill">Sin trigger</span>
                  }
                </td>
                <td>@workflow.ExecutionCount</td>
                <td><span class="badge @(workflow.IsActive ? "ok" : "")">@(workflow.IsActive ? "Activo" : "Inactivo")</span></td>
                <td>
                  <a href="/Workflows/Edit/@workflow.Id" class="btn crm-btn-compact crm-link-btn">Editar</a>
                </td>
              </tr>
            }
          }
          else
          {
            <tr>
              <td colspan="5" class="crm-empty-cell">
                No hay workflows configurados. <a href="/Workflows/Create">Crea tu primer workflow</a>
              </td>
            </tr>
          }
        </tbody>
      </table>

      <div class="crm-toolbar-spacer"></div>

      <div class="crm-toolbar">
        <button class="btn" type="button" onclick="exportWorkflows()">Exportar</button>
        <a href="/Workflows/Create" class="btn primary crm-link-btn">Crear workflow</a>
      </div>
    </div>
  </div>

  <!-- RIGHT: Activity & Stats -->
  <aside class="stack">
    <div class="card">
      <div class="card-h">
        <div>
          <h3 class="title">Ejecuciones recientes</h3>
          <p class="subtitle">Últimas ejecuciones de workflows y su resultado.</p>
        </div>
        <span class="pill">Tiempo real</span>
      </div>
      <div class="card-b">
        <div class="feed">
          <div class="item">
            <div class="itop">
              <div class="itag">ÉXITO</div>
              <div class="itime">Hace 2 min</div>
            </div>
            <div class="ibody">
              "Seguimiento automático de leads" ejecutado para Lead #342. Email enviado correctamente.
            </div>
            <div class="ifooter">
              <span class="pill">Tiempo: 1.2s</span>
              <span class="pill">Estado: OK</span>
            </div>
          </div>

          <div class="item">
            <div class="itop">
              <div class="itag">ÉXITO</div>
              <div class="itime">Hace 5 min</div>
            </div>
            <div class="ibody">
              "Calificación de leads" ejecutado. Lead #89 asignado a vendedor senior automáticamente.
            </div>
            <div class="ifooter">
              <span class="pill">Tiempo: 0.8s</span>
              <span class="pill">Estado: OK</span>
            </div>
          </div>

          <div class="item">
            <div class="itop">
              <div class="itag">ALERTA</div>
              <div class="itime">Hace 12 min</div>
            </div>
            <div class="ibody">
              "Alerta de churn" ejecutado. Cliente #23 en riesgo detectado, notificación enviada.
            </div>
            <div class="ifooter">
              <span class="pill">Tiempo: 2.1s</span>
              <span class="pill">Estado: OK</span>
            </div>
          </div>
        </div>

        <div class="crm-toolbar-spacer"></div>

        <button class="btn primary crm-btn-block" type="button" onclick="alert('Funcionalidad de historial completo próximamente disponible');">Ver historial completo</button>
      </div>
    </div>

    <div class="card">
      <div class="card-h">
        <div>
          <h3 class="title">Optimizaciones sugeridas</h3>
          <p class="subtitle">Recomendaciones de la IA para mejorar workflows.</p>
        </div>
        <span class="pill">IA Optimizer</span>
      </div>
      <div class="card-b">
        <div class="feed">
          <div class="item">
            <div class="itop">
              <div class="itag">OPTIMIZACIÓN</div>
              <div class="itime">Hace 1h</div>
            </div>
            <div class="ibody">
              Workflow "Seguimiento de leads" puede reducir tiempo 23% combinando condiciones.
            </div>
            <div class="ifooter">
              <span class="pill">Impacto: Alto</span>
              <span class="pill">Aplicar</span>
            </div>
          </div>
        </div>

        <div class="crm-toolbar-spacer"></div>

        <button class="btn primary crm-btn-block" type="button" onclick="alert('Funcionalidad de optimizaciones próximamente disponible');">Ver todas las optimizaciones</button>
      </div>
    </div>
  </aside>
</section>

<div class="crm-section-gap"></div>

<footer class="crm-footer-note">
  AUTONOMUS CRM · Automatización inteligente con workflows configurables.
</footer>

<div id="importModal" class="crm-overlay-modal">
    <div class="card crm-overlay-card">
        <div class="card-h">
            <div>
                <h3 class="title">Importar Workflows</h3>
            </div>
        </div>
        <div class="card-b">
            <form method="post" action="/Workflows/Import" enctype="multipart/form-data">
                <div class="crm-form-field">
                    <label>Archivo JSON *</label>
                    <input type="file" name="file" accept=".json" required class="crm-form-control" />
                    <div class="crm-form-help">
                        Selecciona un archivo JSON exportado previamente.
                    </div>
                </div>
                <div class="crm-split-actions">
                    <button type="submit" class="btn primary">Importar</button>
                    <button type="button" class="btn" onclick="closeImportModal()">Cancelar</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
function exportWorkflows() {
    const workflows = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Workflows.Select(w => new { w.Id, w.Name, w.Description, w.IsActive, w.ExecutionCount })));
    const json = JSON.stringify(workflows, null, 2);
    const blob = new Blob([json], { type: 'application/json' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = 'workflows-' + new Date().toISOString().split('T')[0] + '.json';
    a.click();
    URL.revokeObjectURL(url);
}
function showImportModal() {
    document.getElementById('importModal').style.display = 'flex';
}
function closeImportModal() {
    document.getElementById('importModal').style.display = 'none';
}
</script>

