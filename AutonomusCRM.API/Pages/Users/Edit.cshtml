@page "/Users/Edit/{id:guid}"
@model AutonomusCRM.API.Pages.Users.EditModel
@{
    ViewData["Title"] = L["Users_Edit_Kicker"].Value;
}

@if (Model.User == null)
{
    ViewData["EmptyIcon"] = "fas fa-user-slash";
    ViewData["EmptyTitle"] = L["Users_Edit_NotFound"].Value;
    ViewData["EmptyMessage"] = L["Users_Edit_NotFoundDesc"].Value;
    ViewData["EmptyActionHtml"] = $"<a href=\"/Users\" class=\"flow-btn flow-btn-primary\">{L["Users_Edit_BackTo"].Value}</a>";
    <partial name="Shared/_CrmEmptyState" />
}
else
{
    ViewData["PageTitle"] = Model.User.Email;
    ViewData["PageKicker"] = L["Users_Edit_Kicker"].Value;
    ViewData["PageSubtitle"] = L["Users_Edit_CardSubtitle"].Value;
    ViewData["PageActionsHtml"] = $"<a href=\"/Users\" class=\"flow-btn flow-btn-secondary\">{L["Common_Back"].Value}</a>";

    <partial name="Flow/_FlowPageHeader" />
    <partial name="Shared/_FlowFormAlerts" />

    <div class="flow-grid flow-grid--sidebar">
        <section class="flow-card flow-form-card">
            <header class="flow-card-header">
                <h2 class="flow-card-title" id="user-edit-title">@L["Users_Edit_CardTitle"]</h2>
                <p class="flow-page-subtitle mb-0">@L["Users_Edit_CardSubtitle"]</p>
            </header>
            <div class="flow-card-body">
                <form method="post" class="flow-form" aria-labelledby="user-edit-title">
                    <input type="hidden" asp-for="Command.UserId" />
                    <input type="hidden" asp-for="Command.TenantId" />
                    <div class="flow-form-grid">
                        <div class="flow-form-field flow-form-field--full">
                            <label class="flow-form-label" for="user-edit-email">@L["Common_Email"] @L["Common_RequiredStar"]</label>
                            <input type="email" id="user-edit-email" asp-for="Command.Email" class="flow-form-control" required autocomplete="email" aria-describedby="user-edit-email-error" />
                            <span id="user-edit-email-error" asp-validation-for="Command.Email" class="flow-form-help flow-form-help--error"></span>
                        </div>
                        <div class="flow-form-field">
                            <label class="flow-form-label" for="user-edit-first">@L["Form_FirstName"]</label>
                            <input type="text" id="user-edit-first" asp-for="Command.FirstName" class="flow-form-control" autocomplete="given-name" />
                        </div>
                        <div class="flow-form-field">
                            <label class="flow-form-label" for="user-edit-last">@L["Form_LastName"]</label>
                            <input type="text" id="user-edit-last" asp-for="Command.LastName" class="flow-form-control" autocomplete="family-name" />
                        </div>
                    </div>
                    <div class="flow-form-actions">
                        <button type="submit" class="flow-btn flow-btn-primary">@L["Form_SaveChanges"]</button>
                        <a href="/Users" class="flow-btn flow-btn-secondary">@L["Btn_Cancel"]</a>
                    </div>
                </form>
            </div>
        </section>

        <aside class="flow-grid-stack">
            <section class="flow-card">
                <header class="flow-card-header">
                    <h3 class="flow-card-title" id="user-edit-roles-title">@L["Users_Edit_Roles"]</h3>
                    <p class="flow-page-subtitle mb-0">@L["Users_Edit_RolesSubtitle"]</p>
                </header>
                <div class="flow-card-body">
                    <h4 class="flow-form-section-title">@L["Users_Edit_AssignedRoles"]</h4>
                    @if (Model.User.Roles != null && Model.User.Roles.Any())
                    {
                        <ul class="flow-list flow-list--actions" aria-labelledby="user-edit-roles-title">
                            @foreach (var role in Model.User.Roles)
                            {
                                <li class="flow-list-item">
                                    <span class="flow-badge">@role</span>
                                    <form method="post" asp-page-handler="RemoveRole" class="flow-inline-form">
                                        <input type="hidden" name="id" value="@Model.User.Id" />
                                        <input type="hidden" name="role" value="@role" />
                                        <button type="submit" class="flow-btn flow-btn-sm flow-btn-danger">@L["Users_Edit_Remove"]</button>
                                    </form>
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <p class="flow-form-help">@L["Users_Edit_NoRolesAssigned"]</p>
                    }

                    <div class="flow-form-divider" role="separator"></div>

                    <h4 class="flow-form-section-title">@L["Users_Edit_AssignNewRole"]</h4>
                    <form method="post" asp-page-handler="AssignRole" class="flow-form">
                        <input type="hidden" name="id" value="@Model.User.Id" />
                        <div class="flow-form-field">
                            <label class="flow-form-label" for="user-edit-role-select">@L["Users_Edit_SelectRole"]</label>
                            <select id="user-edit-role-select" name="role" class="flow-form-control" required>
                                <option value="">@L["Users_Edit_SelectRole"]</option>
                                @foreach (var role in Model.AvailableRoles)
                                {
                                    @if (Model.User.Roles == null || !Model.User.Roles.Contains(role))
                                    {
                                        <option value="@role">@role</option>
                                    }
                                }
                            </select>
                        </div>
                        <button type="submit" class="flow-btn flow-btn-primary flow-btn-block">@L["Users_Edit_Assign"]</button>
                    </form>
                </div>
            </section>

            <section class="flow-card">
                <header class="flow-card-header">
                    <h3 class="flow-card-title">@L["Users_Edit_Status"]</h3>
                    <p class="flow-page-subtitle mb-0">@L["Users_Edit_StatusSubtitle"]</p>
                </header>
                <div class="flow-card-body">
                    <p>
                        @L["Users_Edit_CurrentStatus"]
                        @if (Model.User.IsActive)
                        {
                            <span class="flow-badge flow-badge--ok">@L["Common_Active"]</span>
                        }
                        else
                        {
                            <span class="flow-badge flow-badge--warn">@L["Common_Inactive"]</span>
                        }
                    </p>
                    <form method="post" asp-page-handler="ToggleStatus">
                        <input type="hidden" name="id" value="@Model.User.Id" />
                        <input type="hidden" name="isActive" value="@(!Model.User.IsActive)" />
                        <button type="submit" class="flow-btn flow-btn-block @(Model.User.IsActive ? "flow-btn-danger" : "flow-btn-primary")">
                            @(Model.User.IsActive ? L["Users_Edit_Deactivate"].Value : L["Users_Edit_Activate"].Value)
                        </button>
                    </form>
                </div>
            </section>
        </aside>
    </div>

    <p class="flow-form-footer">@L["Users_Edit_Footer"]</p>
}
