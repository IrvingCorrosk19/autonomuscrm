@page "/customer-success"
@model AutonomusCRM.API.Pages.CustomerSuccessModel
@using AutonomusCRM.Application.CustomerSuccess
@using AutonomusCRM.API.Infrastructure
@{
    ViewData["Title"] = L["CustomerSuccess_PageTitle"].Value;
    ViewData["PageTitle"] = L["CustomerSuccess_PageTitle"].Value;
    ViewData["PageKicker"] = L["Nav_Section_Customers"].Value;
    ViewData["PageSubtitle"] = L["CustomerSuccess_Subtitle"].Value;
    var h = Model.Home;
}
<partial name="Flow/_FlowPageHeader" />

@if (!string.IsNullOrEmpty(Model.Message)) { <div class="flow-comms-banner flow-comms-banner--ok">@Model.Message</div> }
@if (!string.IsNullOrEmpty(Model.Error)) { <div class="flow-comms-banner flow-comms-banner--warn">@Model.Error</div> }

@if (h == null)
{
  ViewData["FlowEmptyTitle"] = L["CustomerSuccess_PageTitle"].Value;
  ViewData["FlowEmptyMessage"] = L["Command_LoginPrompt"].Value;
  <partial name="Flow/_FlowEmptyState" />
}
else
{
  <section class="flow-revenue-hero">
    <h2>@L["CustomerSuccess_Subtitle"]</h2>
    <div class="flow-metric-grid">
      @{ ViewData["FlowMetricLabel"] = L["CustomerSuccess_AvgHealth"].Value; ViewData["FlowMetricValue"] = h.Kpis.AvgHealthScore.ToString("F0"); ViewData["FlowMetricVariant"] = "success"; }
      <partial name="Flow/_FlowMetricCard" />
      @{ ViewData["FlowMetricLabel"] = L["CustomerSuccess_AtRisk"].Value; ViewData["FlowMetricValue"] = h.Kpis.CustomersAtRisk.ToString(); ViewData["FlowMetricVariant"] = "warning"; }
      <partial name="Flow/_FlowMetricCard" />
      @{ ViewData["FlowMetricLabel"] = L["Tasks_Open"].Value; ViewData["FlowMetricValue"] = h.OpenTicketCount.ToString(); ViewData["FlowMetricVariant"] = "info"; }
      <partial name="Flow/_FlowMetricCard" />
      @{ ViewData["FlowMetricLabel"] = L["Common_Pending"].Value; ViewData["FlowMetricValue"] = h.OpenCaseCount.ToString(); ViewData["FlowMetricVariant"] = "neutral"; }
      <partial name="Flow/_FlowMetricCard" />
      @{ ViewData["FlowMetricLabel"] = L["Command_Renewals"].Value; ViewData["FlowMetricValue"] = h.Kpis.RenewalRatePercent.ToString("F0") + "%"; ViewData["FlowMetricVariant"] = "ai"; }
      <partial name="Flow/_FlowMetricCard" />
    </div>
  </section>

  <div class="flow-revenue-grid">
    <section class="flow-card">
      <header class="flow-card-header"><h3 class="flow-card-title">@L["CustomerSuccess_AtRisk"]</h3></header>
      <div class="flow-card-body">
        @if (h.AtRiskCustomers.Count == 0) { <p class="text-muted">@L["Command_NoAtRiskAccounts"]</p> }
        @foreach (var c in h.AtRiskCustomers.Take(8))
        {
          <div class="flow-insight-row">
            <div class="flow-insight-row-head">
              <span><strong>@c.CustomerName</strong><br/><small>@c.Description</small></span>
              <span class="flow-revenue-priority">@c.Severity</span>
            </div>
            @{
              ViewData["FlowInsightType"] = FlowInsightTypes.Risk;
              ViewData["FlowInsightCustomerId"] = c.CustomerId;
              ViewData["FlowInsightCustomerName"] = c.CustomerName;
              ViewData["FlowInsightReturnUrl"] = "/customer-success";
              ViewData["FlowInsightCompact"] = true;
            }
            <partial name="Flow/_FlowInsightActions" />
            <form method="post" asp-page-handler="RunPlaybook" class="flow-insight-action-form mt-1">
              <input type="hidden" name="customerId" value="@c.CustomerId" />
              <input type="hidden" name="playbookType" value="@CustomerSuccessOsConstants.PlaybookAtRisk" />
              @Html.AntiForgeryToken()
              <button type="submit" class="flow-btn flow-btn-secondary flow-btn-sm">@L["CustomerSuccess_Playbooks"]</button>
            </form>
          </div>
        }
      </div>
    </section>

    <section class="flow-card">
      <header class="flow-card-header"><h3 class="flow-card-title">@L["Command_Renewals"]</h3></header>
      <div class="flow-card-body">
        @if (h.Renewals.Count == 0) { <p class="text-muted">@L["Command_NoTargets"]</p> }
        @foreach (var r in h.Renewals.Take(8))
        {
          <div class="flow-insight-row">
            <div class="flow-insight-row-head">
              <span><strong>@r.CustomerName</strong><br/><small>@r.DaysUntilRenewal d · $@r.AnnualValue.ToString("N0")</small></span>
              <span class="flow-revenue-priority">@r.Window</span>
            </div>
            @{
              ViewData["FlowInsightType"] = FlowInsightTypes.Renewal;
              ViewData["FlowInsightCustomerId"] = r.CustomerId;
              ViewData["FlowInsightCustomerName"] = r.CustomerName;
              ViewData["FlowInsightReturnUrl"] = "/customer-success";
              ViewData["FlowInsightCompact"] = true;
            }
            <partial name="Flow/_FlowInsightActions" />
            <form method="post" asp-page-handler="RunPlaybook" class="flow-insight-action-form mt-1">
              <input type="hidden" name="customerId" value="@r.CustomerId" />
              <input type="hidden" name="playbookType" value="@CustomerSuccessConstants.PlaybookRenewal" />
              @Html.AntiForgeryToken()
              <button type="submit" class="flow-btn flow-btn-secondary flow-btn-sm">@L["CustomerSuccess_Playbooks"]</button>
            </form>
          </div>
        }
      </div>
    </section>
  </div>

  <div class="flow-revenue-grid mt-4">
    <section class="flow-card">
      <header class="flow-card-header">
        <h3 class="flow-card-title">@L["Tasks_Open"]</h3>
        <span class="text-muted" style="font-size:12px;">@h.OpenTicketCount @L["Tasks_Open"]</span>
      </header>
      <div class="flow-card-body">
        <form method="post" asp-page-handler="CreateTicket" class="flow-filters mb-3" style="flex-wrap:wrap;">
          <select name="NewTicketCustomerId" required aria-label="@L["Common_Customer"]">
            <option value="">@L["Common_Customer"]…</option>
            @foreach (var c in Model.Customers) { <option value="@c.Id">@c.Name</option> }
          </select>
          <input name="NewTicketSubject" placeholder="@L["CustomerSuccess_TicketSubject"]" required aria-label="@L["CustomerSuccess_TicketSubject"]" />
          <select name="NewTicketPriority" aria-label="@L["Common_Priority"]">
            <option value="Normal">@L["Priority_Normal"]</option>
            <option value="High">@L["Priority_High"]</option>
            <option value="Urgent">@L["Priority_Urgent"]</option>
          </select>
          @Html.AntiForgeryToken()
          <button type="submit" class="flow-btn flow-btn-primary flow-btn-sm">@L["Btn_Create"]</button>
        </form>
        @if (h.OpenTickets.Count == 0) { <p class="text-muted">@L["Common_NoData"]</p> }
        <table class="flow-table-minimal">
          <thead><tr><th>@L["Common_Customer"]</th><th>@L["Common_Subject"]</th><th>@L["Common_Risk"]</th><th>@L["Command_DecisionDate"]</th><th></th></tr></thead>
          <tbody>
            @foreach (var t in h.OpenTickets.Take(12))
            {
              <tr class="@(t.IsOverdue ? "flow-row-warn" : "")">
                <td><a href="/customers/@t.CustomerId/360">@t.CustomerName</a></td>
                <td>@t.Subject</td>
                <td>@LocalizedLabels.Priority(L, t.Priority)</td>
                <td>@(t.DueDate?.ToString("d") ?? "—")</td>
                <td>
                  <form method="post" asp-page-handler="CloseTicket" class="d-inline">
                    <input type="hidden" name="ticketId" value="@t.Id" />
                    @Html.AntiForgeryToken()
                    <button type="submit" class="flow-btn flow-btn-secondary flow-btn-sm">@L["Common_Close"]</button>
                  </form>
                </td>
              </tr>
            }
          </tbody>
        </table>
        @if (h.ClosedTickets.Any())
        {
          <h4 style="font-size:13px;margin:16px 0 8px;">@L["Command_History"]</h4>
          <ul class="flow-list-minimal">
            @foreach (var t in h.ClosedTickets.Take(5)) { <li>@t.CustomerName — @t.Subject</li> }
          </ul>
        }
      </div>
    </section>

    <section class="flow-card">
      <header class="flow-card-header"><h3 class="flow-card-title">@L["Command_Expansion"]</h3></header>
      <div class="flow-card-body">
        @if (h.Expansions.Count == 0) { <p class="text-muted">@L["Command_NoTargets"]</p> }
        @foreach (var e in h.Expansions.Take(8))
        {
          <div class="flow-insight-row">
            <div class="flow-insight-row-head">
              <span><strong>@e.CustomerName</strong><br/><small>@e.Recommendation</small></span>
              <span class="flow-revenue-priority">@e.OpportunityType</span>
            </div>
            @{
              ViewData["FlowInsightType"] = FlowInsightTypes.Expansion;
              ViewData["FlowInsightCustomerId"] = e.CustomerId;
              ViewData["FlowInsightCustomerName"] = e.CustomerName;
              ViewData["FlowInsightReturnUrl"] = "/customer-success";
              ViewData["FlowInsightCompact"] = true;
            }
            <partial name="Flow/_FlowInsightActions" />
            <form method="post" asp-page-handler="RunPlaybook" class="flow-insight-action-form mt-1">
              <input type="hidden" name="customerId" value="@e.CustomerId" />
              <input type="hidden" name="playbookType" value="@CustomerSuccessConstants.PlaybookExpansion" />
              @Html.AntiForgeryToken()
              <button type="submit" class="flow-btn flow-btn-secondary flow-btn-sm">@L["CustomerSuccess_Playbooks"]</button>
            </form>
          </div>
        }
      </div>
    </section>
  </div>

  <section class="flow-card mt-4">
    <header class="flow-card-header"><h3 class="flow-card-title">@L["CustomerSuccess_Playbooks"]</h3></header>
    <div class="flow-card-body">
      <p class="text-muted" style="font-size:13px;margin-bottom:12px;">@L["Command_PlaybooksTitle"]</p>
      <div class="flow-insight-actions">
        @foreach (var pb in new[] {
          (CustomerSuccessConstants.PlaybookRenewal, L["Command_Renewals"].Value),
          (CustomerSuccessConstants.PlaybookRescue, L["Command_Protected"].Value),
          (CustomerSuccessConstants.PlaybookExpansion, L["Command_Expansion"].Value),
          (CustomerSuccessOsConstants.PlaybookAtRisk, L["CustomerSuccess_AtRisk"].Value)
        })
        {
          <details class="flow-insight-email">
            <summary class="flow-btn flow-btn-secondary flow-btn-sm">@pb.Item2</summary>
            <form method="post" asp-page-handler="RunPlaybook" class="flow-insight-email-form">
              <select name="customerId" required aria-label="@L["Common_Customer"]">
                <option value="">@L["Common_Customer"]…</option>
                @foreach (var c in Model.Customers) { <option value="@c.Id">@c.Name</option> }
              </select>
              <input type="hidden" name="playbookType" value="@pb.Item1" />
              @Html.AntiForgeryToken()
              <button type="submit" class="flow-btn flow-btn-primary flow-btn-sm">@L["Btn_Create"]</button>
            </form>
          </details>
        }
      </div>
    </div>
  </section>

  @if (h.OpenCases.Any())
  {
    <section class="flow-card mt-4">
      <header class="flow-card-header"><h3 class="flow-card-title">@L["Common_Pending"]</h3></header>
      <div class="flow-card-body" style="padding:0;">
        <table class="flow-table-minimal">
          <thead><tr><th>@L["Command_DecisionType"]</th><th>@L["Common_Customer"]</th><th>@L["Common_Subject"]</th><th>@L["Common_Risk"]</th></tr></thead>
          <tbody>
            @foreach (var c in h.OpenCases)
            {
              <tr>
                <td><span class="flow-revenue-priority">@c.CaseTypeLabel</span></td>
                <td><a href="/customers/@c.CustomerId/360">@c.CustomerName</a></td>
                <td>@c.Title</td>
                <td>@c.Priority</td>
              </tr>
            }
          </tbody>
        </table>
      </div>
    </section>
  }

  <section class="flow-card mt-4">
    <header class="flow-card-header"><h3 class="flow-card-title">@L["CustomerSuccess_AvgHealth"]</h3></header>
    <div class="flow-card-body" style="padding:0;">
      <table class="flow-table-minimal">
        <thead><tr><th>@L["Common_Customer"]</th><th>@L["CustomerSuccess_AvgHealth"]</th><th>@L["Command_Expansion"]</th><th>@L["Command_LiveDecisions"]</th><th>@L["Command_DecisionType"]</th></tr></thead>
        <tbody>
          @foreach (var x in h.HealthSummary.Take(15))
          {
            <tr>
              <td><a href="/customers/@x.CustomerId/360">@x.CustomerName</a></td>
              <td>@x.HealthScore</td>
              <td>@x.AdoptionScore</td>
              <td>@x.EngagementScore</td>
              <td>@x.Classification</td>
            </tr>
          }
        </tbody>
      </table>
    </div>
  </section>
}
