@model IReadOnlyList<AutonomusCRM.Application.Autonomous.FlowSparklinePoint>
@{
    var label = ViewData["FlowSparklineLabel"] as string ?? "";
    var values = Model?.Select(p => p.Value).ToList() ?? new List<decimal>();
    if (values.Count == 0) values = Enumerable.Repeat(0m, 7).ToList();
    var max = values.Max();
    if (max <= 0) max = 1;
    var w = 120;
    var h = 32;
    var step = values.Count > 1 ? (decimal)w / (values.Count - 1) : 0m;
    var points = new List<string>();
    for (var i = 0; i < values.Count; i++)
    {
        var x = (int)(i * step);
        var y = h - (int)((double)(values[i] / max) * (h - 4)) - 2;
        points.Add($"{x},{y}");
    }
    var polyline = string.Join(" ", points);
    var last = values.LastOrDefault();
}
<div class="flow-sparkline" aria-label="@label sparkline">
  <div class="flow-sparkline-header">
    <span class="flow-sparkline-label">@label</span>
    <span class="flow-sparkline-value">@last.ToString("N0")</span>
  </div>
  <svg width="@w" height="@h" viewBox="0 0 @w @h" role="img" aria-hidden="true">
    <polyline fill="none" stroke="currentColor" stroke-width="2" points="@polyline" />
  </svg>
</div>
