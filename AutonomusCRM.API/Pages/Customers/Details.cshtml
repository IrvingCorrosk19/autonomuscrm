@page "/Customers/Details/{id:guid}"
@model AutonomusCRM.API.Pages.Customers.DetailsModel
@using AutonomusCRM.Application.Customers.Queries
@using AutonomusCRM.Domain.Customers
@{
    ViewData["Title"] = L["Customers_Detail_Kicker"].Value;
}

@if (Model.Customer == null)
{
    ViewData["EmptyIcon"] = "fas fa-building";
    ViewData["EmptyTitle"] = L["Customers_Detail_NotFound"].Value;
    ViewData["EmptyMessage"] = L["Customers_Edit_NotFoundDesc"].Value;
    ViewData["EmptyActionHtml"] = $"<a href=\"/Customers\" class=\"flow-btn flow-btn-primary\">{L["Customers_Edit_BackTo"].Value}</a>";
    <partial name="Shared/_CrmEmptyState" />
}
else
{
    ViewData["PageTitle"] = Model.Customer.Name;
    ViewData["PageKicker"] = L["Customers_Detail_Kicker"].Value;
    ViewData["PageSubtitle"] = L["Customers_Detail_CardSubtitle"].Value;
    var backLabel = L["Customers_Detail_BackTo"].Value;
    var newLabel = L["Customers_Detail_NewCustomer"].Value;
    ViewData["PageActionsHtml"] = $"<a href=\"/Customers\" class=\"flow-btn flow-btn-secondary\">{backLabel}</a> <a href=\"/Customers/Create\" class=\"flow-btn flow-btn-primary\">{newLabel}</a>";

    <partial name="Flow/_FlowPageHeader" />

    <div class="flow-grid flow-grid--sidebar">
        <section class="flow-card">
            <header class="flow-card-header">
                <h2 class="flow-card-title" id="customer-detail-title">@L["Customers_Detail_CardTitle"]</h2>
                <p class="flow-page-subtitle mb-0">@L["Customers_Detail_CardSubtitle"]</p>
                <span class="flow-badge">@L["Common_IdLabel"] @(Model.Customer.Id.ToString()[..8])…</span>
            </header>
            <div class="flow-card-body">
                <table class="flow-detail-table" aria-labelledby="customer-detail-title">
                    <tbody>
                        <tr>
                            <th scope="row">@L["Common_Name"]</th>
                            <td>@Model.Customer.Name</td>
                        </tr>
                        <tr>
                            <th scope="row">@L["Common_Email"]</th>
                            <td>@(Model.Customer.Email ?? L["Common_NA"].Value)</td>
                        </tr>
                        <tr>
                            <th scope="row">@L["Common_Phone"]</th>
                            <td>@(Model.Customer.Phone ?? L["Common_NA"].Value)</td>
                        </tr>
                        <tr>
                            <th scope="row">@L["Form_Company"]</th>
                            <td>@(Model.Customer.Company ?? L["Common_NA"].Value)</td>
                        </tr>
                        <tr>
                            <th scope="row">@L["Common_Status"]</th>
                            <td><span class="flow-badge flow-badge--ok">@Model.Customer.Status</span></td>
                        </tr>
                        <tr>
                            <th scope="row">@L["Common_LTV"]</th>
                            <td>
                                @if (Model.Customer.LifetimeValue.HasValue)
                                {
                                    <span class="flow-badge @(Model.Customer.LifetimeValue > 20000 ? "flow-badge--ok" : Model.Customer.LifetimeValue > 10000 ? "flow-badge--warn" : "")">$ @(Model.Customer.LifetimeValue.Value.ToString("N0"))</span>
                                }
                                else
                                {
                                    <span class="flow-badge">@L["Common_NA"]</span>
                                }
                            </td>
                        </tr>
                        <tr>
                            <th scope="row">@L["Common_Risk"]</th>
                            <td>
                                @if (Model.Customer.RiskScore.HasValue)
                                {
                                    <span class="flow-badge @(Model.Customer.RiskScore < 30 ? "flow-badge--ok" : Model.Customer.RiskScore < 70 ? "flow-badge--warn" : "flow-badge--danger")">@(Model.Customer.RiskScore < 30 ? L["Common_RiskLow"].Value : Model.Customer.RiskScore < 70 ? L["Common_RiskMedium"].Value : L["Common_RiskHigh"].Value)</span>
                                }
                                else
                                {
                                    <span class="flow-badge">@L["Common_NA"]</span>
                                }
                            </td>
                        </tr>
                        <tr>
                            <th scope="row">@L["Common_Created"]</th>
                            <td><time datetime="@Model.Customer.CreatedAt.ToString("o")">@(Model.Customer.CreatedAt.ToString("dd/MM/yyyy HH:mm"))</time></td>
                        </tr>
                    </tbody>
                </table>

                <div class="flow-form-actions">
                    <a href="/Customers" class="flow-btn flow-btn-secondary">@L["Common_BackToList"]</a>
                    <a href="/Customers/Edit/@Model.Customer.Id" class="flow-btn flow-btn-primary">@L["Btn_Edit"]</a>
                    <a href="/customers/@Model.Customer.Id/360" class="flow-btn flow-btn-secondary">@L["Customer360_Kicker"]</a>
                </div>
            </div>
        </section>

        <aside class="flow-grid-stack">
            <section class="flow-card">
                <header class="flow-card-header">
                    <h3 class="flow-card-title">@L["Customers_Detail_QuickActions"]</h3>
                    <p class="flow-page-subtitle mb-0">@L["Customers_Detail_QuickActionsSubtitle"]</p>
                </header>
                <div class="flow-card-body flow-stack-actions">
                    <button class="flow-btn flow-btn-secondary flow-btn-block" type="button" onclick="showCreateDealModal()">@L["Customers_Detail_CreateDeal"]</button>
                    <button class="flow-btn flow-btn-secondary flow-btn-block" type="button" onclick="showHistoryModal()">@L["Customers_Detail_ViewHistory"]</button>
                    <form method="post" asp-page-handler="RecordContact" class="flow-inline-form">
                        <input type="hidden" name="id" value="@Model.Customer.Id" />
                        <button class="flow-btn flow-btn-secondary flow-btn-block" type="submit">@L["Customers_Detail_Contact"]</button>
                    </form>
                </div>
            </section>

            <section class="flow-card">
                <header class="flow-card-header">
                    <h3 class="flow-card-title">@L["Common_DangerZone"]</h3>
                </header>
                <div class="flow-card-body">
                    <form method="post" asp-page-handler="Delete" onsubmit="return confirm(this.dataset.msg)" data-msg="@L["Customers_Detail_DeleteConfirm"]">
                        <input type="hidden" name="id" value="@Model.Customer.Id" />
                        <button type="submit" class="flow-btn flow-btn-danger flow-btn-block">@L["Customers_Detail_DeleteCustomer"]</button>
                    </form>
                </div>
            </section>
        </aside>
    </div>

    <p class="flow-form-footer">@L["Customers_Detail_Footer"]</p>

    <div id="createDealModal" class="crm-overlay-modal" role="dialog" aria-modal="true" aria-labelledby="create-deal-title" aria-hidden="true">
        <div class="crm-overlay-card flow-card">
            <header class="flow-card-header">
                <h3 class="flow-card-title" id="create-deal-title">@L["Customers_Detail_CreateDealForCustomer"]</h3>
            </header>
            <div class="flow-card-body">
                <form method="post" asp-page-handler="CreateDeal" class="flow-form">
                    <input type="hidden" name="id" value="@Model.Customer.Id" />
                    <div class="flow-form-field">
                        <label class="flow-form-label" for="deal-modal-title">@L["Form_TitleRequired"]</label>
                        <input type="text" id="deal-modal-title" name="title" class="flow-form-control" required />
                    </div>
                    <div class="flow-form-field">
                        <label class="flow-form-label" for="deal-modal-amount">@L["Form_AmountRequired"]</label>
                        <input type="number" id="deal-modal-amount" name="amount" class="flow-form-control" required step="0.01" min="0" />
                    </div>
                    <div class="flow-form-field">
                        <label class="flow-form-label" for="deal-modal-description">@L["Form_Description"]</label>
                        <textarea id="deal-modal-description" name="description" class="flow-form-control" rows="3"></textarea>
                    </div>
                    <div class="flow-form-actions">
                        <button type="submit" class="flow-btn flow-btn-primary">@L["Customers_Detail_CreateDeal"]</button>
                        <button type="button" class="flow-btn flow-btn-secondary" onclick="closeCreateDealModal()">@L["Btn_Cancel"]</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div id="historyModal" class="crm-overlay-modal" role="dialog" aria-modal="true" aria-labelledby="history-modal-title" aria-hidden="true">
        <div class="crm-overlay-card flow-card">
            <header class="flow-card-header">
                <h3 class="flow-card-title" id="history-modal-title">@L["Customers_Detail_HistoryTitle"]</h3>
                <p class="flow-page-subtitle mb-0">@Model.Customer.Name</p>
            </header>
            <div class="flow-card-body">
                <h4 class="flow-subsection-title">@L["Customers_Detail_CardTitle"]</h4>
                <table class="flow-detail-table">
                    <tbody>
                        <tr>
                            <th scope="row">@L["Customers_Detail_CustomerSince"]</th>
                            <td>@(Model.Customer.CreatedAt.ToString("dd/MM/yyyy HH:mm"))</td>
                        </tr>
                        <tr>
                            <th scope="row">@L["Customers_Detail_CurrentStatus"]</th>
                            <td><span class="flow-badge flow-badge--ok">@Model.Customer.Status</span></td>
                        </tr>
                        <tr>
                            <th scope="row">@L["Common_LTV"]</th>
                            <td>@(Model.Customer.LifetimeValue?.ToString("C") ?? L["Common_NA"].Value)</td>
                        </tr>
                        <tr>
                            <th scope="row">@L["Common_Risk"]</th>
                            <td>
                                @if (Model.Customer.RiskScore.HasValue)
                                {
                                    <span class="flow-badge @(Model.Customer.RiskScore < 30 ? "flow-badge--ok" : Model.Customer.RiskScore < 70 ? "flow-badge--warn" : "flow-badge--danger")">
                                        @(Model.Customer.RiskScore < 30 ? L["Common_RiskLow"].Value : Model.Customer.RiskScore < 70 ? L["Common_RiskMedium"].Value : L["Common_RiskHigh"].Value)
                                    </span>
                                }
                                else
                                {
                                    @L["Common_NA"]
                                }
                            </td>
                        </tr>
                    </tbody>
                </table>

                <h4 class="flow-subsection-title">@L["Customers_Detail_RecentActivity"]</h4>
                <p class="flow-text-muted-sm">@L["Customers_Detail_HistoryPlaceholder"]</p>
                <p class="flow-text-muted-sm">@L["Customers_Detail_HistoryDevNote"]</p>

                <div class="flow-form-actions">
                    <button type="button" class="flow-btn flow-btn-secondary" onclick="closeHistoryModal()">@L["Common_Close"]</button>
                </div>
            </div>
        </div>
    </div>

    <script>
    function showCreateDealModal() { window.crmModal.open('createDealModal'); }
    function closeCreateDealModal() { window.crmModal.close('createDealModal'); }
    function showHistoryModal() { window.crmModal.open('historyModal'); }
    function closeHistoryModal() { window.crmModal.close('historyModal'); }
    </script>
}
