@{
    var icon = ViewData["EmptyIcon"] as string ?? "fas fa-inbox";
    var title = ViewData["EmptyTitle"] as string ?? L["Shared_EmptyTitle"].Value;
    var message = ViewData["EmptyMessage"] as string ?? L["Shared_EmptyMessage"].Value;
    var actionHtml = ViewData["EmptyActionHtml"] as string;
}
<div class="crm-empty-state" role="status" aria-live="polite">
  <div>
    <span class="icon"><i class="@icon"></i></span>
    <h4>@title</h4>
    <p>@message</p>
    @if (!string.IsNullOrWhiteSpace(actionHtml))
    {
      <div class="mt-3">@Html.Raw(actionHtml)</div>
    }
  </div>
</div>
