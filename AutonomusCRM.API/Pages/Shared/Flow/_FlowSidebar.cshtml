@model int
@{
    var currentPage = ViewContext.RouteData.Values["page"]?.ToString() ?? "";
    bool Active(string path) =>
        !string.IsNullOrEmpty(path) && (
            currentPage.Equals(path, StringComparison.OrdinalIgnoreCase)
            || currentPage.StartsWith(path + "/", StringComparison.OrdinalIgnoreCase));
    bool ActiveAny(params string[] paths) => paths.Any(Active);
    var trustPending = Model;
}
<aside class="flow-sidebar" id="flow-sidebar" aria-label="@L["Shell_NavAria"]">
  <a href="/" class="flow-sidebar-brand">
    <span class="flow-sidebar-brand-mark" aria-hidden="true">AF</span>
    <span class="flow-sidebar-brand-text">Autonomus<span>Flow</span></span>
  </a>
  <div class="flow-sidebar-user">
    <a href="/Settings">@ViewData["FlowUserEmail"]</a>
    <small>@ViewData["FlowUserRoles"]</small>
  </div>
  <nav class="flow-sidebar-nav">
    <div class="flow-nav-section">@L["Nav_Section_Command"]</div>
    <a href="/" class="flow-nav-item @(Active("/Index") || currentPage == "/" ? "is-active" : "")">
      <span class="flow-nav-icon" aria-hidden="true">⌘</span>
      <span class="flow-nav-text">@L["Nav_Command"]</span>
    </a>
    <a href="/TrustInbox" class="flow-nav-item @(Active("/TrustInbox") ? "is-active" : "")">
      <span class="flow-nav-icon" aria-hidden="true">✓</span>
      <span class="flow-nav-text">@L["Nav_TrustStudio"]</span>
      @if (trustPending > 0)
      {
        <span class="flow-nav-badge" aria-label="@L["Shell_PendingBadgeAria", trustPending]">@trustPending</span>
      }
    </a>
    <a href="/Agents" class="flow-nav-item @(Active("/Agents") ? "is-active" : "")">
      <span class="flow-nav-icon" aria-hidden="true">◎</span>
      <span class="flow-nav-text">@L["Nav_Workforce"]</span>
    </a>

    <div class="flow-nav-section">@L["Nav_Section_Revenue"]</div>
    <a href="/revenue" class="flow-nav-item @(Active("/Revenue") ? "is-active" : "")">
      <span class="flow-nav-icon" aria-hidden="true">💰</span>
      <span class="flow-nav-text">@L["Nav_RevenueOs"]</span>
    </a>
    <a href="/executive" class="flow-nav-item @(Active("/Executive") ? "is-active" : "")">
      <span class="flow-nav-icon" aria-hidden="true">★</span>
      <span class="flow-nav-text">@L["Nav_Executive"]</span>
    </a>
    <a href="/Deals" class="flow-nav-item @(ActiveAny("/Deals") ? "is-active" : "")">
      <span class="flow-nav-icon" aria-hidden="true">$</span>
      <span class="flow-nav-text">@L["Nav_Pipeline"]</span>
    </a>

    <div class="flow-nav-section">@L["Nav_Section_Customers"]</div>
    <a href="/Customers" class="flow-nav-item @(Active("/Customers") ? "is-active" : "")">
      <span class="flow-nav-icon" aria-hidden="true">◇</span>
      <span class="flow-nav-text">@L["Nav_Directory"]</span>
    </a>
    <a href="/Customer360" class="flow-nav-item @(Active("/Customer360") ? "is-active" : "")">
      <span class="flow-nav-icon" aria-hidden="true">360</span>
      <span class="flow-nav-text">@L["Nav_Customer360"]</span>
    </a>
    <a href="/customer-success" class="flow-nav-item @(Active("/CustomerSuccess") || Active("/customer-success") ? "is-active" : "")">
      <span class="flow-nav-icon" aria-hidden="true">♥</span>
      <span class="flow-nav-text">@L["Nav_CustomerSuccess"]</span>
    </a>

    <div class="flow-nav-section">@L["Nav_Section_Commerce"]</div>
    <a href="/Leads" class="flow-nav-item @(Active("/Leads") ? "is-active" : "")">
      <span class="flow-nav-icon" aria-hidden="true">+</span>
      <span class="flow-nav-text">@L["Nav_Leads"]</span>
    </a>

    <div class="flow-nav-section">@L["Nav_Section_Intelligence"]</div>
    <a href="/Memory" class="flow-nav-item @(Active("/Memory") ? "is-active" : "")">
      <span class="flow-nav-icon" aria-hidden="true">🧠</span>
      <span class="flow-nav-text">@L["Nav_Memory"]</span>
    </a>

    <div class="flow-nav-section">@L["Nav_Section_Learning"]</div>
    <a href="/University" class="flow-nav-item @(Active("/University") ? "is-active" : "")">
      <span class="flow-nav-icon" aria-hidden="true">🎓</span>
      <span class="flow-nav-text">@L["Nav_University"]</span>
    </a>

    <div class="flow-nav-section">@L["Nav_Section_Operation"]</div>
    <a href="/Tasks" class="flow-nav-item @(Active("/Tasks") ? "is-active" : "")">
      <span class="flow-nav-icon" aria-hidden="true">☑</span>
      <span class="flow-nav-text">@L["Nav_Tasks"]</span>
    </a>

    <div class="flow-nav-section">@L["Nav_Section_Platform"]</div>
    <a href="/Integrations" class="flow-nav-item @(Active("/Integrations") ? "is-active" : "")">
      <span class="flow-nav-icon" aria-hidden="true">⎔</span>
      <span class="flow-nav-text">@L["Nav_Integrations"]</span>
    </a>
    <a href="/DataHub" class="flow-nav-item @(Active("/DataHub") ? "is-active" : "")">
      <span class="flow-nav-icon" aria-hidden="true">⬡</span>
      <span class="flow-nav-text">Data Hub</span>
    </a>
    <a href="/DatabaseIntelligence" class="flow-nav-item @(Active("/DatabaseIntelligence") ? "is-active" : "")">
      <span class="flow-nav-icon" aria-hidden="true">◈</span>
      <span class="flow-nav-text">Database Intelligence</span>
