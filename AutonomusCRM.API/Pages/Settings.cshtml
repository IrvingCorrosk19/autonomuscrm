@page
@model AutonomusCRM.API.Pages.SettingsModel
@{
    ViewData["Title"] = "Configuración";
    ViewData["PageTitle"] = "Workspace Settings";
    ViewData["PageKicker"] = "Platform";
    ViewData["PageSubtitle"] = "Tenant, IA, seguridad y comunicaciones — datos reales del espacio de trabajo.";
    var activeAgents = Model.SystemSettings.GetValueOrDefault("ActiveAgents")?.ToString() ?? "—";
    var totalAgents = Model.SystemSettings.GetValueOrDefault("TotalAgents")?.ToString() ?? "—";
}
<partial name="Flow/_FlowPageHeader" />

<div class="flow-settings-sections">
  <section class="flow-card">
    <header class="flow-card-header"><h3 class="flow-card-title">General</h3></header>
    <div class="flow-card-body flow-settings-row">
      <dl class="flow-settings-kv"><dt>Tenant</dt><dd>@(Model.CurrentTenant?.Name ?? "—")</dd></dl>
      <dl class="flow-settings-kv"><dt>Email</dt><dd>@(Model.CurrentTenant?.Settings?.GetValueOrDefault("Email") ?? "—")</dd></dl>
      <dl class="flow-settings-kv"><dt>Región</dt><dd>@(Model.SystemSettings.GetValueOrDefault("Region") ?? "—")</dd></dl>
      <dl class="flow-settings-kv"><dt>Zona horaria</dt><dd>@(Model.SystemSettings.GetValueOrDefault("TimeZone") ?? "—")</dd></dl>
    </div>
  </section>

  <section class="flow-card">
    <header class="flow-card-header"><h3 class="flow-card-title">IA y autonomía</h3></header>
    <div class="flow-card-body flow-settings-row">
      <dl class="flow-settings-kv"><dt>Modo</dt><dd>@(Model.SystemSettings.GetValueOrDefault("OperationMode") ?? "—")</dd></dl>
      <dl class="flow-settings-kv"><dt>Confianza mínima</dt><dd>@(Model.SystemSettings.GetValueOrDefault("MinConfidence") ?? "—")</dd></dl>
      <dl class="flow-settings-kv"><dt>Agentes</dt><dd>@activeAgents / @totalAgents</dd></dl>
    </div>
  </section>

  <section class="flow-card">
    <header class="flow-card-header"><h3 class="flow-card-title">Seguridad</h3></header>
    <div class="flow-card-body flow-settings-row">
      <dl class="flow-settings-kv"><dt>MFA</dt><dd>@((Model.SystemSettings.GetValueOrDefault("MfaRequired")?.ToString() == "True") ? "Requerido" : "Opcional")</dd></dl>
      <dl class="flow-settings-kv"><dt>SCIM</dt><dd><code>/api/enterprise/scim/v2</code></dd></dl>
      <dl class="flow-settings-kv"><dt>SAML</dt><dd>Metadata disponible · ACS login en roadmap ops</dd></dl>
    </div>
  </section>

  <section class="flow-card">
    <header class="flow-card-header"><h3 class="flow-card-title">Acciones</h3></header>
    <div class="flow-card-body" style="display:flex;gap:8px;flex-wrap:wrap;">
      <button class="flow-btn flow-btn-secondary" type="button" onclick="showImportConfigModal()">Importar configuración</button>
      <button class="flow-btn flow-btn-primary" type="button" onclick="saveAllSettings()">Guardar (API)</button>
      <a href="/Integrations" class="flow-btn flow-btn-secondary">Integraciones</a>
    </div>
  </section>
</div>

<div id="importConfigModal" class="crm-modal-backdrop">
  <div class="crm-modal">
    <div class="crm-modal-header"><h3>Importar configuración</h3></div>
    <div class="crm-modal-body">
      <form method="post" asp-page-handler="ImportConfig" enctype="multipart/form-data">
        <input type="file" name="file" class="form-control" accept=".json" required />
        @Html.AntiForgeryToken()
        <div class="crm-modal-footer px-0 pb-0">
          <button type="button" class="flow-btn flow-btn-secondary" onclick="closeImportConfigModal()">Cancelar</button>
          <button type="submit" class="flow-btn flow-btn-primary">Importar</button>
        </div>
      </form>
    </div>
  </div>
</div>

@section Scripts {
<script>
function showImportConfigModal() { document.getElementById('importConfigModal')?.classList.add('show'); }
function closeImportConfigModal() { document.getElementById('importConfigModal')?.classList.remove('show'); }
function saveAllSettings() { alert('Use la API de settings o formularios de tenant para persistir cambios.'); }
</script>
}
