@page "/Workflows/Edit/{id:guid}"
@model AutonomusCRM.API.Pages.Workflows.EditModel
@{
    ViewData["Title"] = L["Workflows_Edit_Kicker"].Value;
}

@if (Model.Workflow == null)
{
    ViewData["EmptyIcon"] = "fas fa-project-diagram";
    ViewData["EmptyTitle"] = L["Workflows_Edit_NotFound"].Value;
    ViewData["EmptyMessage"] = L["Workflows_Edit_NotFoundDesc"].Value;
    ViewData["EmptyActionHtml"] = $"<a href=\"/Workflows\" class=\"flow-btn flow-btn-primary\">{L["Workflows_Edit_BackTo"].Value}</a>";
    <partial name="Shared/_CrmEmptyState" />
}
else
{
    ViewData["PageTitle"] = Model.Workflow.Name;
    ViewData["PageKicker"] = L["Workflows_Edit_Kicker"].Value;
    ViewData["PageSubtitle"] = L["Workflows_Edit_CardSubtitle"].Value;
    ViewData["PageActionsHtml"] = $"<a href=\"/Workflows\" class=\"flow-btn flow-btn-secondary\">{L["Btn_Cancel"].Value}</a>";

    <partial name="Flow/_FlowPageHeader" />
    <partial name="Shared/_FlowFormAlerts" />

    <section class="flow-card flow-form-card">
        <header class="flow-card-header">
            <h2 class="flow-card-title" id="workflow-edit-title">@L["Workflows_Edit_CardTitle"]</h2>
            <p class="flow-page-subtitle mb-0">@L["Workflows_Edit_CardSubtitle"]</p>
        </header>
        <div class="flow-card-body">
            <form method="post" class="flow-form" aria-labelledby="workflow-edit-title">
                <div class="flow-form-grid">
                    <div class="flow-form-field flow-form-field--full">
                        <label class="flow-form-label" for="workflow-edit-name">@L["Form_NameRequired"]</label>
                        <input type="text" id="workflow-edit-name" name="name" class="flow-form-control" value="@Model.Workflow.Name" required />
                    </div>
                    <div class="flow-form-field flow-form-field--full">
                        <label class="flow-form-label" for="workflow-edit-description">@L["Form_Description"]</label>
                        <textarea id="workflow-edit-description" name="description" class="flow-form-control" rows="4">@Model.Workflow.Description</textarea>
                    </div>
                    <div class="flow-form-field">
                        <label class="flow-form-label" for="workflow-edit-status">@L["Common_Status"]</label>
                        <select id="workflow-edit-status" name="isActive" class="flow-form-control">
                            <option value="true" selected="@Model.Workflow.IsActive">@L["Common_Active"]</option>
                            <option value="false" selected="@(!Model.Workflow.IsActive)">@L["Common_Inactive"]</option>
                        </select>
                    </div>
                </div>

                <div class="flow-comms-banner flow-comms-banner--ok" role="note">
                    <strong>@L["Workflows_Edit_StatsInfo"]</strong>
                    <ul class="flow-form-help mb-0 mt-2">
                        <li><strong>@L["Workflows_Edit_Executions"]</strong> @Model.Workflow.ExecutionCount</li>
                        <li><strong>@L["Workflows_Edit_LastExecution"]</strong> @(Model.Workflow.LastExecutedAt?.ToString("dd/MM/yyyy HH:mm") ?? L["Workflows_Edit_Never"].Value)</li>
                        <li><strong>@L["Workflows_Edit_Triggers"]:</strong> @Model.Workflow.Triggers.Count</li>
                        <li><strong>@L["Workflows_Edit_Conditions"]:</strong> @Model.Workflow.Conditions.Count</li>
                        <li><strong>@L["Workflows_Edit_Actions"]:</strong> @Model.Workflow.Actions.Count</li>
                    </ul>
                </div>

                <div class="flow-form-actions">
                    <button type="submit" class="flow-btn flow-btn-primary">@L["Form_SaveChanges"]</button>
                    <a href="/Workflows" class="flow-btn flow-btn-secondary">@L["Btn_Cancel"]</a>
                </div>
            </form>

            <div class="flow-form-divider" role="separator"></div>

            <section aria-labelledby="workflow-triggers-heading">
                <h3 class="flow-form-section-title" id="workflow-triggers-heading">@L["Workflows_Edit_Triggers"]</h3>
                @if (Model.Workflow.Triggers != null && Model.Workflow.Triggers.Any())
                {
                    @foreach (var trigger in Model.Workflow.Triggers)
                    {
                        <div class="flow-item-card">
                            <div class="flow-item-card__title">@trigger.Type</div>
                            <div class="flow-item-card__meta">@trigger.EventType</div>
                        </div>
                    }
                }
                <button type="button" class="flow-btn flow-btn-secondary flow-btn-block" onclick="showAddTriggerModal()">@L["Workflows_Edit_AddTrigger"]</button>

                <h3 class="flow-subsection-title" id="workflow-conditions-heading">@L["Workflows_Edit_Conditions"]</h3>
                @if (Model.Workflow.Conditions != null && Model.Workflow.Conditions.Any())
                {
                    @foreach (var condition in Model.Workflow.Conditions)
                    {
                        <div class="flow-item-card">
                            <div class="flow-item-card__title">@condition.Type</div>
                            <div class="flow-item-card__meta">@condition.Expression</div>
                        </div>
                    }
                }
                <button type="button" class="flow-btn flow-btn-secondary flow-btn-block" onclick="showAddConditionModal()">@L["Workflows_Edit_AddCondition"]</button>

                <h3 class="flow-subsection-title" id="workflow-actions-heading">@L["Workflows_Edit_Actions"]</h3>
                @if (Model.Workflow.Actions != null && Model.Workflow.Actions.Any())
                {
                    @foreach (var action in Model.Workflow.Actions)
                    {
                        <div class="flow-item-card">
                            <div class="flow-item-card__title">@action.Type</div>
                            <div class="flow-item-card__meta">@action.Target</div>
                        </div>
                    }
                }
                <button type="button" class="flow-btn flow-btn-secondary flow-btn-block" onclick="showAddActionModal()">@L["Workflows_Edit_AddAction"]</button>

                    <div class="flow-form-divider" role="separator"></div>
                    <div class="flow-form-actions flow-form-actions--stack">
                        <form method="post" asp-page-handler="Duplicate">
                            <input type="hidden" name="id" value="@Model.Workflow.Id" />
                            <button type="submit" class="flow-btn flow-btn-secondary flow-btn-block">@L["Workflows_Edit_DuplicateWorkflow"]</button>
                        </form>
                        <form method="post" asp-page-handler="Delete" onsubmit="return confirm(this.dataset.msg)" data-msg="@L["Common_DeleteConfirm"]">
                            <input type="hidden" name="id" value="@Model.Workflow.Id" />
                            <button type="submit" class="flow-btn flow-btn-danger flow-btn-block">@L["Workflows_Edit_DeleteWorkflow"]</button>
                        </form>
                    </div>
            </section>
        </div>
    </section>

    <p class="flow-form-footer">@L["Workflows_Edit_Footer"]</p>
}

<partial name="Workflows/_WorkflowEditModals" />

