@page "/command/decisions"
@model AutonomusCRM.API.Pages.Command.DecisionsModel
@{
    ViewData["Title"] = L["Command_DecisionsTitle"].Value;
    ViewData["PageTitle"] = L["Command_DecisionsTitle"].Value;
    ViewData["PageKicker"] = L["Nav_Section_Command"].Value;
    ViewData["PageSubtitle"] = L["Command_Subtitle"].Value;
}
<partial name="Flow/_FlowPageHeader" />

<form method="get" class="flow-filters">
  <select name="status" aria-label="@L["Common_Status"]">
    <option value="">@L["Common_All"] @L["Common_Status"]</option>
    <option value="Pending" selected="@(Model.Status == "Pending")">@L["Status_Pending"]</option>
    <option value="Executed" selected="@(Model.Status == "Executed")">@L["Status_Executed"]</option>
    <option value="Failed" selected="@(Model.Status == "Failed")">@L["Status_Failed"]</option>
  </select>
  <input type="text" name="agent" value="@Model.Agent" placeholder="@L["Agents_PageTitle"]" aria-label="@L["Agents_PageTitle"]" />
  <input type="number" name="minScore" value="@Model.MinScore" placeholder="@L["Common_Score"]" min="0" max="100" aria-label="@L["Common_Score"]" />
  <button type="submit" class="flow-btn flow-btn-primary">@L["Btn_Filter"]</button>
</form>

@if (Model.Rows.Count == 0)
{
  ViewData["FlowEmptyTitle"] = L["Command_DecisionsEmpty"].Value;
  ViewData["FlowEmptyMessage"] = string.Format(L["Command_NoDecisionsYet"].Value, L["Command_Period7Days"].Value);
  <partial name="Flow/_FlowEmptyState" />
}
else
{
  <section class="flow-card">
    <div class="flow-card-body" style="padding:0;">
      <table class="flow-table-minimal">
        <thead><tr><th>@L["Command_DecisionDate"]</th><th>@L["Command_DecisionType"]</th><th>@L["Agents_PageTitle"]</th><th>@L["Command_DecisionAction"]</th><th>@L["Common_Score"]</th><th>@L["Common_Status"]</th><th>@L["Command_OutcomesGenerated"]</th><th>@L["Common_Customer"]</th></tr></thead>
        <tbody>
          @foreach (var r in Model.Rows)
          {
            <tr>
              <td>@r.CreatedAt.ToString("g")</td>
              <td>@r.DecisionType</td>
              <td>@(r.AgentName ?? "—")</td>
              <td>@r.Action</td>
              <td>@r.Score</td>
              <td>@r.Status</td>
              <td>@(r.RevenueImpact.HasValue ? $"${r.RevenueImpact:N0}" : "—")</td>
              <td>@(r.CustomerName ?? "—")</td>
            </tr>
          }
        </tbody>
      </table>
    </div>
  </section>
}
