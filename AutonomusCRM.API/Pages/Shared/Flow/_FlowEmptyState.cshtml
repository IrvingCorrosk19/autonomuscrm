@{
    var title = ViewData["FlowEmptyTitle"] as string ?? L["Shared_FlowEmptyTitle"].Value;
    var message = ViewData["FlowEmptyMessage"] as string ?? L["Shared_FlowEmptyMessage"].Value;
    var ctaText = ViewData["FlowEmptyCta"] as string;
    var ctaHref = ViewData["FlowEmptyCtaHref"] as string ?? "/TrustInbox";
    var icon = ViewData["FlowEmptyIcon"] as string ?? "◎";
}
<div class="flow-empty-state" role="status">
  <div class="flow-empty-icon" aria-hidden="true">@icon</div>
  <h3 class="flow-empty-title">@title</h3>
  <p class="flow-empty-message">@message</p>
  @if (!string.IsNullOrWhiteSpace(ctaText))
  {
    <a href="@ctaHref" class="flow-btn flow-btn-primary">@ctaText</a>
  }
</div>
