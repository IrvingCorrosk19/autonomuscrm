@page "/DatabaseIntelligence/Graph"
@model AutonomusCRM.API.Pages.DatabaseIntelligence.GraphModel
@{
    ViewData["Title"] = "Business graph";
    ViewData["PageTitle"] = "Business graph";
    ViewData["PageKicker"] = "Database Intelligence";
    ViewData["PageSubtitle"] = "See how your business flows — customers, sales, invoices and payments";
}
<partial name="Flow/_FlowPageHeader" />

<div class="flow-card" style="margin-bottom:var(--flow-space-4);">
  <div class="flow-card-body">
    <form method="get" class="form-inline flex-wrap" style="gap:var(--flow-space-2);">
      <label for="connectionId">Connection</label>
      <select id="connectionId" name="connectionId" class="form-control" onchange="this.form.submit()">
        @foreach (var c in Model.Connections)
        {
          <option value="@c.Id" selected="@(Model.SelectedConnectionId == c.Id)">@c.Name</option>
        }
      </select>
      <input type="search" id="graphSearch" class="form-control" placeholder="Search business areas…" aria-label="Search graph nodes" />
      <label class="ml-2"><input type="checkbox" id="filterProducts" checked /> Products</label>
      <label class="ml-2"><input type="checkbox" id="filterActivities" checked /> Activities</label>
      @if (Model.SelectedConnectionId != Guid.Empty && (User.IsInRole("Admin") || User.IsInRole("Owner")))
      {
        <button type="submit" formaction="?handler=Build" class="btn btn-primary">Build graph</button>
      }
    </form>
    @if (Model.StatusMessage != null)
    {
      <div class="alert alert-info mt-3" role="alert">@Model.StatusMessage</div>
    }
    <p style="margin:var(--flow-space-2) 0 0;font-size:13px;color:var(--flow-text-muted);">
      We show how your business works — not database tables.
    </p>
  </div>
</div>

@if (Model.Graph != null)
{
  <div class="flow-card-grid" style="display:grid;grid-template-columns:1fr 320px;gap:var(--flow-space-4);">
    <section class="flow-card" style="overflow:hidden;">
      <header class="flow-card-header" style="display:flex;justify-content:space-between;align-items:center;">
        <h3 class="flow-card-title" style="margin:0;">Business flow</h3>
        <span class="badge badge-secondary">Score @Model.Graph.Summary.GlobalHealthScore — @Model.Graph.Summary.GlobalHealthBand</span>
      </header>
      <div class="flow-card-body" style="padding:0;">
        <div id="graphViewport" style="height:480px;overflow:hidden;cursor:grab;background:var(--flow-bg-subtle,#f8fafc);position:relative;">
          <svg id="businessGraph" width="100%" height="100%" role="img" aria-label="Interactive business graph"></svg>
        </div>
        <div style="padding:var(--flow-space-2);font-size:12px;color:var(--flow-text-muted);">
          Scroll to zoom · Drag to pan · Click a node for details
        </div>
      </div>
    </section>

    <aside class="flow-card" id="nodeDetail" aria-live="polite">
      <header class="flow-card-header"><h3 class="flow-card-title">Details</h3></header>
      <div class="flow-card-body" id="nodeDetailBody">
        <p style="color:var(--flow-text-muted);margin:0;">Select a business area to see health, sources and findings.</p>
      </div>
    </aside>
  </div>

  <script type="application/json" id="graphData">@Html.Raw(Model.GraphJson)</script>
  <script>
    (function () {
      const raw = document.getElementById('graphData');
      if (!raw) return;
      const graph = JSON.parse(raw.textContent);
      const svg = document.getElementById('businessGraph');
      const viewport = document.getElementById('graphViewport');
      const detail = document.getElementById('nodeDetailBody');
      const search = document.getElementById('graphSearch');
      const filterProducts = document.getElementById('filterProducts');
      const filterActivities = document.getElementById('filterActivities');

      let scale = 1, tx = 40, ty = 40, dragging = false, lastX = 0, lastY = 0;
      const g = document.createElementNS('http://www.w3.org/2000/svg', 'g');
      svg.appendChild(g);

      function entityHidden(type) {
        const t = (type || '').toLowerCase();
        if (t === 'product' && filterProducts && !filterProducts.checked) return true;
        if (t === 'activity' && filterActivities && !filterActivities.checked) return true;
        return false;
      }

      function filteredNodes() {
        const q = (search?.value || '').toLowerCase();
        return graph.nodes.filter(n => !entityHidden(n.entityType) && (!q || (n.label || '').toLowerCase().includes(q)));
      }

      function render() {
        while (g.firstChild) g.removeChild(g.firstChild);
        const nodes = filteredNodes();
        const ids = new Set(nodes.map(n => n.id));
        const edges = graph.edges.filter(e => ids.has(e.fromNodeId) && ids.has(e.toNodeId));
        const pos = {};
        nodes.forEach((n, i) => { pos[n.id] = { x: 80, y: 60 + i * 90 }; });

        edges.forEach(e => {
          const a = pos[e.fromNodeId], b = pos[e.toNodeId];
          if (!a || !b) return;
          const line = document.createElementNS('http://www.w3.org/2000/svg', 'line');
          line.setAttribute('x1', a.x + 140); line.setAttribute('y1', a.y + 24);
          line.setAttribute('x2', b.x); line.setAttribute('y2', b.y + 24);
          line.setAttribute('stroke', '#94a3b8'); line.setAttribute('stroke-width', '2');
          g.appendChild(line);
          const lbl = document.createElementNS('http://www.w3.org/2000/svg', 'text');
          lbl.setAttribute('x', (a.x + b.x) / 2 + 70); lbl.setAttribute('y', (a.y + b.y) / 2 + 18);
          lbl.setAttribute('fill', '#64748b'); lbl.setAttribute('font-size', '11');
          lbl.textContent = e.businessLabel || '';
          g.appendChild(lbl);
        });

        nodes.forEach(n => {
          const p = pos[n.id];
          const rect = document.createElementNS('http://www.w3.org/2000/svg', 'rect');
          const color = n.healthScore >= 75 ? '#dcfce7' : n.healthScore >= 50 ? '#fef9c3' : '#fee2e2';
          const stroke = n.healthScore >= 75 ? '#16a34a' : n.healthScore >= 50 ? '#ca8a04' : '#dc2626';
          rect.setAttribute('x', p.x); rect.setAttribute('y', p.y);
          rect.setAttribute('width', '140'); rect.setAttribute('height', '48');
          rect.setAttribute('rx', '8'); rect.setAttribute('fill', color);
          rect.setAttribute('stroke', stroke); rect.setAttribute('stroke-width', '2');
          rect.style.cursor = 'pointer';
          rect.addEventListener('click', () => showDetail(n));
          g.appendChild(rect);
          const t1 = document.createElementNS('http://www.w3.org/2000/svg', 'text');
          t1.setAttribute('x', p.x + 10); t1.setAttribute('y', p.y + 20);
          t1.setAttribute('font-weight', 'bold'); t1.setAttribute('font-size', '13');
          t1.textContent = n.label;
          g.appendChild(t1);
          const t2 = document.createElementNS('http://www.w3.org/2000/svg', 'text');
          t2.setAttribute('x', p.x + 10); t2.setAttribute('y', p.y + 36);
          t2.setAttribute('font-size', '11'); t2.setAttribute('fill', '#64748b');
          t2.textContent = 'Health ' + n.healthScore + ' — ' + n.healthBand;
          g.appendChild(t2);
        });
        g.setAttribute('transform', 'translate(' + tx + ',' + ty + ') scale(' + scale + ')');
      }

      function showDetail(n) {
        const sources = (n.sources || []).map(s => '<li>' + (s.businessName || '') + ' (' + s.confidencePercent + '%)</li>').join('');
        const findings = (n.topFindings || []).slice(0, 3).map(f =>
          '<li><strong>' + f.title + '</strong> — ' + f.explanation + '</li>').join('') || '<li>No quality issues in this area.</li>';
        detail.innerHTML = '<h4 style="margin:0 0 8px;">' + n.label + '</h4>' +
          '<p><strong>Health:</strong> ' + n.healthScore + ' (' + n.healthBand + ')<br>' +
          '<strong>Risk:</strong> ' + n.riskLevel + '<br>' +
          '<strong>Records:</strong> ' + n.recordCount + '<br>' +
          '<strong>Confidence:</strong> ' + n.confidencePercent + '%</p>' +
          '<p style="font-size:12px;color:var(--flow-text-muted);">Data sources (business names)</p><ul>' + sources + '</ul>' +
          '<p style="font-size:12px;">Quality findings</p><ul style="font-size:13px;">' + findings + '</ul>';
      }

      viewport.addEventListener('wheel', e => {
        e.preventDefault();
        scale = Math.min(2.5, Math.max(0.4, scale + (e.deltaY < 0 ? 0.1 : -0.1)));
        render();
      });
      viewport.addEventListener('mousedown', e => { dragging = true; lastX = e.clientX; lastY = e.clientY; viewport.style.cursor = 'grabbing'; });
      window.addEventListener('mouseup', () => { dragging = false; viewport.style.cursor = 'grab'; });
      window.addEventListener('mousemove', e => {
        if (!dragging) return;
        tx += e.clientX - lastX; ty += e.clientY - lastY;
        lastX = e.clientX; lastY = e.clientY;
        render();
      });
      search?.addEventListener('input', render);
      filterProducts?.addEventListener('change', render);
      filterActivities?.addEventListener('change', render);
      render();
    })();
  </script>
}
else if (Model.SelectedConnectionId != Guid.Empty)
{
  <div class="flow-card"><div class="flow-card-body">
    <p style="color:var(--flow-text-muted);margin:0;">No business graph yet. Run business discovery and health scan, then build the graph.</p>
  </div></div>
}
