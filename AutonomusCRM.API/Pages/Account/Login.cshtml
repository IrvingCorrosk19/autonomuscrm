@page
@model AutonomusCRM.API.Pages.Account.LoginModel
@using System.Globalization
@{
    ViewData["Title"] = L["Account_LoginTitle"].Value;
    Layout = null;
    var uiCulture = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
    var returnUrl = $"{Request.Path}{Request.QueryString}";
}
<!DOCTYPE html>
<html lang="@uiCulture">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>@L["Account_LoginTitle"] — @L["AppName"]</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="~/css/flow-tokens.css" asp-append-version="true" />
  <link rel="stylesheet" href="~/css/flow-shell.css" asp-append-version="true" />
  <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
<a class="flow-skip-link" href="#flow-login-form">@L["Account_SkipToForm"]</a>
<div class="flow-auth-page">
  <div class="flow-auth-brand-panel" aria-hidden="false">
    <h1>Autonomus<span style="color:#5eead4">Flow</span></h1>
    <p>@L["Account_BrandTagline"]</p>
    <ul class="flow-auth-trust-list">
      <li>@L["Account_TrustHitl"]</li>
      <li>@L["Account_TrustMultiTenant"]</li>
      <li>@L["Account_TrustImpact"]</li>
    </ul>
  </div>
  <div class="flow-auth-form-panel">
    <div class="flow-auth-card">
      <div style="display:flex;justify-content:flex-end;margin-bottom:12px;">
        <partial name="_LanguageSelector" />
      </div>
      <h2>@L["Account_SecureAccess"]</h2>
      <p class="flow-auth-sub">@L["Account_LoginSubtitle"]</p>

      @if (Model.SsoEnabled)
      {
        <p style="font-size:13px;color:var(--flow-text-muted);margin-bottom:12px;">@L["Account_SsoPreferred"]</p>
        <a asp-page-handler="ExternalLogin" asp-route-returnUrl="@returnUrl" class="flow-btn flow-btn-secondary" style="width:100%;margin-bottom:16px;text-align:center;display:block;">
          @L["Account_SsoContinue"]
        </a>
        <p style="text-align:center;font-size:12px;color:var(--flow-text-muted);margin:16px 0;">@L["Account_OrEmail"]</p>
      }

      @if (!string.IsNullOrEmpty(Model.ErrorMessage))
      {
        <div class="flow-alert-error" role="alert">@Model.ErrorMessage</div>
      }

      @if (Model.ShowMfaStep)
      {
        <form method="post" asp-page-handler="VerifyMfa" id="flow-mfa-form">
          <input type="hidden" asp-for="MfaTempToken" />
          <input type="hidden" asp-for="TenantId" />
          <input type="hidden" asp-for="Email" />
          <div class="flow-field">
            <label asp-for="MfaCode">@L["Account_MfaCode"]</label>
            <input asp-for="MfaCode" inputmode="numeric" autocomplete="one-time-code" maxlength="8" required aria-required="true" />
          </div>
          <button type="submit" class="flow-btn flow-btn-primary" style="width:100%;margin-top:8px;">
            @L["Account_VerifyMfa"]
          </button>
        </form>
        <p style="font-size:12px;color:var(--flow-text-muted);margin-top:12px;">
          <a asp-page="/Account/Login">@L["Account_BackToLogin"]</a>
        </p>
      }
      else
      {
      <form method="post" id="flow-login-form">
        @if (Model.ShowTenantField)
        {
          <div class="flow-field">
            <label asp-for="TenantId">@L["Account_TenantId"]</label>
            <input asp-for="TenantId" required aria-required="true" />
          </div>
        }
        else
        {
          <input type="hidden" asp-for="TenantId" />
        }
        <div class="flow-field">
          <label asp-for="Email">@L["Account_Email"]</label>
          <input asp-for="Email" type="email" autocomplete="username" required aria-required="true" />
        </div>
        <div class="flow-field">
          <label asp-for="Password">@L["Account_Password"]</label>
          <input asp-for="Password" type="password" autocomplete="current-password" required aria-required="true" />
        </div>
        <button type="submit" class="flow-btn flow-btn-primary" style="width:100%;margin-top:8px;">
          @L["Account_Enter"]
        </button>
      </form>
      }

      @if (Model.ShowDemoAccounts && Model.DemoAccounts.Count > 0)
      {
        <details class="flow-auth-demo">
          <summary>@L["Account_DemoAccounts"]</summary>
          <div class="flow-auth-demo-body">
            @if (!string.IsNullOrEmpty(Model.DemoTenantName))
            {
              <p><strong>@L["Account_Tenant"]</strong> @Model.DemoTenantName</p>
            }
            <ul style="margin:0;padding-left:16px;">
              @foreach (var account in Model.DemoAccounts)
              {
                <li><strong>@account.Role</strong> — <code>@account.Email</code></li>
              }
            </ul>
          </div>
        </details>
      }
      <p style="font-size:13px;color:var(--flow-text-muted);margin-top:20px;text-align:center;">
        <a href="/landing">@L["Account_DiscoverProduct"]</a> · <a href="/demo">@L["Account_DemoCeo"]</a> · <a href="/pricing">@L["Account_Pricing"]</a>
      </p>
    </div>
  </div>
</div>
</body>
</html>
