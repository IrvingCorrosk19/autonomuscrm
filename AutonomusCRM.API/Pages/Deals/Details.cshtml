@page "/Deals/Details/{id:guid}"
@model AutonomusCRM.API.Pages.Deals.DetailsModel
@using AutonomusCRM.Application.Deals.Queries
@using AutonomusCRM.Domain.Deals
@using AutonomusCRM.API.Infrastructure
@{
    ViewData["Title"] = L["Deals_Detail_Kicker"].Value;
}

@if (TempData["ErrorMessage"] != null)
{
  <div class="flow-comms-banner flow-comms-banner--warn" role="alert">
    <strong>@L["Common_Error"]</strong> @TempData["ErrorMessage"]
  </div>
}

@if (Model.Deal == null)
{
    ViewData["EmptyIcon"] = "fas fa-handshake";
    ViewData["EmptyTitle"] = L["Deals_Detail_NotFound"].Value;
    ViewData["EmptyMessage"] = L["Deals_Edit_NotFoundDesc"].Value;
    ViewData["EmptyActionHtml"] = $"<a href=\"/Deals\" class=\"flow-btn flow-btn-primary\">{L["Deals_Edit_BackTo"].Value}</a>";
    <partial name="Shared/_CrmEmptyState" />
}
else
{
    var dealBackLabel = L["Common_Back"].Value;
    var dealNewLabel = L["Deals_Detail_NewDeal"].Value;
    ViewData["PageTitle"] = Model.Deal.Title;
    ViewData["PageKicker"] = L["Deals_Detail_Kicker"].Value;
    ViewData["PageSubtitle"] = $"${Model.Deal.Amount:N0} · {Model.Deal.Stage}";
    ViewData["PageActionsHtml"] = $@"<a href=""/Deals"" class=""flow-btn flow-btn-secondary"">{dealBackLabel}</a>
        <a href=""/Deals/Create"" class=""flow-btn flow-btn-primary"">{dealNewLabel}</a>";

    <partial name="Flow/_FlowPageHeader" />

    <div class="flow-grid flow-grid--sidebar">
        <section class="flow-card">
            <header class="flow-card-header">
                <h2 class="flow-card-title" id="deal-detail-title">@L["Deals_Detail_CardTitle"]</h2>
                <p class="flow-page-subtitle mb-0">@L["Deals_Detail_CardSubtitle"]</p>
                <span class="flow-badge">@L["Common_IdLabel"] @(Model.Deal.Id.ToString()[..8])…</span>
            </header>
            <div class="flow-card-body">
                <table class="flow-detail-table" aria-labelledby="deal-detail-title">
                    <tbody>
                        <tr>
                            <th scope="row">@L["Form_Title"]</th>
                            <td>@Model.Deal.Title</td>
                        </tr>
                        <tr>
                            <th scope="row">@L["Form_Amount"]</th>
                            <td><strong>$ @(Model.Deal.Amount.ToString("N0"))</strong></td>
                        </tr>
                        <tr>
                            <th scope="row">@L["Form_Stage"]</th>
                            <td><span class="flow-badge">@Model.Deal.Stage</span></td>
                        </tr>
                        <tr>
                            <th scope="row">@L["Common_Status"]</th>
                            <td><span class="flow-badge">@Model.Deal.Status</span></td>
                        </tr>
                        <tr>
                            <th scope="row">@L["Form_Probability"]</th>
                            <td>
                                @if (Model.Deal.Probability.HasValue)
                                {
                                    <span class="flow-badge @(Model.Deal.Probability >= 70 ? "flow-badge--ok" : Model.Deal.Probability >= 50 ? "flow-badge--warn" : "flow-badge--danger")">@(Model.Deal.Probability)%</span>
                                }
                                else
                                {
                                    <span class="flow-badge">@L["Common_NA"]</span>
                                }
                            </td>
                        </tr>
                        <tr>
                            <th scope="row">@L["Form_ExpectedCloseDate"]</th>
                            <td>@(Model.Deal.ExpectedCloseDate?.ToString("dd/MM/yyyy") ?? L["Common_NA"].Value)</td>
                        </tr>
                        <tr>
                            <th scope="row">@L["Common_Created"]</th>
                            <td><time datetime="@Model.Deal.CreatedAt.ToString("o")">@(Model.Deal.CreatedAt.ToString("dd/MM/yyyy HH:mm"))</time></td>
                        </tr>
                    </tbody>
                </table>

                <div class="flow-form-actions">
                    <a href="/Deals" class="flow-btn flow-btn-secondary">@L["Common_BackToList"]</a>
                    <a href="/Deals/Edit/@Model.Deal.Id" class="flow-btn flow-btn-primary">@L["Btn_Edit"]</a>
                </div>
            </div>
        </section>

        <aside class="flow-grid-stack">
            <section class="flow-card">
                <header class="flow-card-header">
                    <h3 class="flow-card-title">@L["Deals_Detail_QuickActions"]</h3>
                    <p class="flow-page-subtitle mb-0">@L["Deals_Detail_QuickActionsSubtitle"]</p>
                </header>
                <div class="flow-card-body flow-stack-actions">
                    <button class="flow-btn flow-btn-secondary flow-btn-block" type="button" onclick="showUpdateProbabilityModal()">@L["Deals_Detail_UpdateProbability"]</button>
                    <button class="flow-btn flow-btn-secondary flow-btn-block" type="button" onclick="showUpdateStageModal()">@L["Deals_Detail_ChangeStage"]</button>
                    <button class="flow-btn flow-btn-primary flow-btn-block" type="button" onclick="showCloseDealModal()">@L["Deals_Detail_CloseWon"]</button>
                    <button class="flow-btn flow-btn-danger flow-btn-block" type="button" onclick="showLoseDealModal()">@L["Deals_Detail_MarkLost"]</button>
                </div>
            </section>

            <section class="flow-card">
                <header class="flow-card-header">
                    <h3 class="flow-card-title">@L["Common_DangerZone"]</h3>
                </header>
                <div class="flow-card-body">
                    <form method="post" asp-page-handler="Delete" onsubmit="return confirm(this.dataset.msg)" data-msg="@L["Deals_Detail_DeleteConfirm"]">
                        <input type="hidden" name="id" value="@Model.Deal.Id" />
                        <button type="submit" class="flow-btn flow-btn-danger flow-btn-block">@L["Deals_Detail_DeleteDeal"]</button>
                    </form>
                </div>
            </section>
        </aside>
    </div>

    <p class="flow-form-footer">@L["Deals_Detail_Footer"]</p>

    <div id="updateProbabilityModal" class="crm-overlay-modal" role="dialog" aria-modal="true" aria-labelledby="prob-modal-title" aria-hidden="true">
        <div class="crm-overlay-card flow-card">
            <header class="flow-card-header">
                <h3 class="flow-card-title" id="prob-modal-title">@L["Deals_Detail_UpdateProbabilityTitle"]</h3>
            </header>
            <div class="flow-card-body">
                <form method="post" asp-page-handler="UpdateProbability" class="flow-form">
                    <input type="hidden" name="id" value="@Model.Deal.Id" />
                    <div class="flow-form-field">
                        <label class="flow-form-label" for="deal-probability">@L["Form_Probability"] @L["Common_RequiredStar"]</label>
                        <input type="number" id="deal-probability" name="probability" class="flow-form-control" required min="0" max="100" value="@(Model.Deal.Probability ?? 0)" aria-describedby="deal-probability-hint" />
                        <span id="deal-probability-hint" class="flow-form-help">@L["Deals_Detail_ProbabilityRange"]</span>
                    </div>
                    <div class="flow-form-actions">
                        <button type="submit" class="flow-btn flow-btn-primary">@L["Common_Update"]</button>
                        <button type="button" class="flow-btn flow-btn-secondary" onclick="closeUpdateProbabilityModal()">@L["Btn_Cancel"]</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div id="updateStageModal" class="crm-overlay-modal" role="dialog" aria-modal="true" aria-labelledby="stage-modal-title" aria-hidden="true">
        <div class="crm-overlay-card flow-card">
            <header class="flow-card-header">
                <h3 class="flow-card-title" id="stage-modal-title">@L["Deals_Detail_ChangeStageTitle"]</h3>
            </header>
            <div class="flow-card-body">
                <form method="post" asp-page-handler="UpdateStage" class="flow-form">
                    <input type="hidden" name="id" value="@Model.Deal.Id" />
                    <div class="flow-form-field">
                        <label class="flow-form-label" for="deal-stage">@L["Form_Stage"] @L["Common_RequiredStar"]</label>
                        <select id="deal-stage" name="stage" class="flow-form-control" required>
                            <option value="0" selected="@(Model.Deal.Stage == DealStage.Prospecting)">@L["DealStage_Prospecting"]</option>
                            <option value="1" selected="@(Model.Deal.Stage == DealStage.Qualification)">@L["DealStage_Qualification"]</option>
                            <option value="2" selected="@(Model.Deal.Stage == DealStage.Proposal)">@L["DealStage_Proposal"]</option>
                            <option value="3" selected="@(Model.Deal.Stage == DealStage.Negotiation)">@L["DealStage_Negotiation"]</option>
                            <option value="4" selected="@(Model.Deal.Stage == DealStage.ClosedWon)">@L["DealStage_ClosedWon"]</option>
                            <option value="5" selected="@(Model.Deal.Stage == DealStage.ClosedLost)">@L["DealStage_ClosedLost"]</option>
                        </select>
                    </div>
                    <div class="flow-form-field">
                        <label class="flow-form-label" for="deal-stage-probability">@L["Form_Probability"]</label>
                        <input type="number" id="deal-stage-probability" name="probability" class="flow-form-control" min="0" max="100" value="@Model.Deal.Probability" />
                    </div>
                    <div class="flow-form-actions">
                        <button type="submit" class="flow-btn flow-btn-primary">@L["Common_Update"]</button>
                        <button type="button" class="flow-btn flow-btn-secondary" onclick="closeUpdateStageModal()">@L["Btn_Cancel"]</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div id="loseDealModal" class="crm-overlay-modal" role="dialog" aria-modal="true" aria-labelledby="lose-modal-title" aria-hidden="true">
        <div class="crm-overlay-card flow-card">
            <header class="flow-card-header">
                <h3 class="flow-card-title" id="lose-modal-title">@L["Deals_Detail_MarkLostTitle"]</h3>
            </header>
            <div class="flow-card-body">
                <form method="post" asp-page-handler="LoseDeal" class="flow-form">
                    <input type="hidden" name="id" value="@Model.Deal.Id" />
                    <div class="flow-form-field">
                        <label class="flow-form-label" for="deal-loss-reason">@L["Deals_Detail_LossReason"]</label>
                        <textarea id="deal-loss-reason" name="reason" class="flow-form-control" rows="3" placeholder="@L["Deals_Detail_LossReasonPlaceholder"]"></textarea>
                    </div>
                    <div class="flow-form-actions">
                        <button type="submit" class="flow-btn flow-btn-danger">@L["Deals_Detail_ConfirmLoss"]</button>
                        <button type="button" class="flow-btn flow-btn-secondary" onclick="closeLoseDealModal()">@L["Btn_Cancel"]</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div id="closeDealModal" class="crm-overlay-modal" role="dialog" aria-modal="true" aria-labelledby="close-modal-title" aria-hidden="true">
        <div class="crm-overlay-card flow-card">
            <header class="flow-card-header">
                <h3 class="flow-card-title" id="close-modal-title">@L["Deals_Detail_CloseDealTitle"]</h3>
            </header>
            <div class="flow-card-body">
                <form method="post" asp-page-handler="CloseDeal" class="flow-form" onsubmit="return confirm(this.dataset.msg)" data-msg="@L["Deals_Detail_CloseDealConfirm"]">
                    <input type="hidden" name="id" value="@Model.Deal.Id" />
                    <div class="flow-form-field">
                        <label class="flow-form-label" for="deal-final-amount">@L["Deals_Detail_FinalAmount"]</label>
                        <input type="number" id="deal-final-amount" name="finalAmount" class="flow-form-control" step="0.01" min="0" value="@Model.Deal.Amount" aria-describedby="deal-final-hint" />
                        <span id="deal-final-hint" class="flow-form-help">@(L["Deals_Detail_FinalAmountHint", Model.Deal.Amount.ToString("C")])</span>
                    </div>
                    <div class="flow-form-actions">
                        <button type="submit" class="flow-btn flow-btn-primary">@L["Deals_Detail_CloseDealBtn"]</button>
                        <button type="button" class="flow-btn flow-btn-secondary" onclick="closeCloseDealModal()">@L["Btn_Cancel"]</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script>
    function showUpdateProbabilityModal() { window.crmModal.open('updateProbabilityModal'); }
    function closeUpdateProbabilityModal() { window.crmModal.close('updateProbabilityModal'); }
    function showUpdateStageModal() { window.crmModal.open('updateStageModal'); }
    function closeUpdateStageModal() { window.crmModal.close('updateStageModal'); }
    function showCloseDealModal() { window.crmModal.open('closeDealModal'); }
    function closeCloseDealModal() { window.crmModal.close('closeDealModal'); }
    function showLoseDealModal() { window.crmModal.open('loseDealModal'); }
    function closeLoseDealModal() { window.crmModal.close('loseDealModal'); }
    </script>
}
