@page
@model AutonomusCRM.API.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Iniciar sesión";
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Iniciar sesión - Autonomus CRM</title>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css?family=Source+Sans+Pro:300,400,400i,600,700&display=swap" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" crossorigin="anonymous" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/admin-lte@3.2/dist/css/adminlte.min.css" crossorigin="anonymous" />
  <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="hold-transition login-page crm-login-page">
<div class="login-box crm-login-box">
  <div class="login-logo">
    <a href="/"><b>Autonomus</b> CRM</a>
  </div>
  <div class="card login-card-body crm-login-card">
    <div class="card-body login-card-body">
      <p class="login-box-msg">Acceso seguro al sistema</p>

      @if (Model.DemoAccounts.Count > 0)
      {
        <div class="callout callout-info text-sm">
          <strong><i class="fas fa-info-circle mr-1"></i>Usuarios demo</strong>
          @if (!string.IsNullOrEmpty(Model.DemoTenantName))
          {
            <p class="mb-1">Tenant: <b>@Model.DemoTenantName</b></p>
          }
          <table class="table table-sm table-bordered mb-2">
            <thead><tr><th>Rol</th><th>Email</th><th>Pass</th></tr></thead>
            <tbody>
              @foreach (var account in Model.DemoAccounts)
              {
                <tr>
                  <td>@account.Role</td>
                  <td><code>@account.Email</code></td>
                  <td><code>@account.Password</code></td>
                </tr>
              }
            </tbody>
          </table>
          <small class="text-muted">Tenant ID: <code>@Model.TenantId</code></small>
        </div>
      }

      @if (!string.IsNullOrEmpty(Model.ErrorMessage))
      {
        <div class="alert alert-danger" role="alert"><i class="fas fa-exclamation-triangle mr-1"></i>@Model.ErrorMessage</div>
      }

      <form method="post">
        <div class="input-group mb-3">
          <input asp-for="TenantId" class="form-control" placeholder="Tenant ID" required />
          <div class="input-group-append">
            <div class="input-group-text"><i class="fas fa-building"></i></div>
          </div>
        </div>
        <div class="input-group mb-3">
          <input asp-for="Email" type="email" class="form-control" placeholder="Email" value="@Model.DemoEmail" required />
          <div class="input-group-append">
            <div class="input-group-text"><i class="fas fa-envelope"></i></div>
          </div>
        </div>
        <div class="input-group mb-3">
          <input asp-for="Password" type="password" class="form-control" placeholder="Contraseña" required />
          <div class="input-group-append">
            <div class="input-group-text"><i class="fas fa-lock"></i></div>
          </div>
        </div>
        <div class="row">
          <div class="col-12">
            <button type="submit" class="btn btn-primary btn-block">
              <i class="fas fa-sign-in-alt mr-1"></i> Entrar
            </button>
          </div>
        </div>
      </form>
      <p class="mt-3 mb-0 text-center text-muted text-sm">
        Contraseña: nombre del rol + <code>123!</code> (ej. <code>Manager123!</code>)
      </p>
    </div>
  </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
