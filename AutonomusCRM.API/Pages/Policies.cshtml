@page
@model AutonomusCRM.API.Pages.PoliciesModel
@{
    ViewData["Title"] = "Políticas - AUTONOMUS CRM";
}

<!-- TOPBAR -->
<header class="topbar">
  <div class="topbar-left">
    <div class="kicker">Políticas y reglas</div>
    <h2 class="headline">Control y límites del sistema autónomo</h2>
  </div>

  <div class="topbar-center">
    <div class="search" role="search">
      <input type="text" placeholder="Buscar políticas..." aria-label="Buscar" />
      <span class="chip">Filtros</span>
      <span class="chip">Categoría</span>
    </div>
  </div>

  <div class="topbar-right">
    <button class="btn mobile-toggle" type="button" onclick="toggleSidebar()">Menú</button>
    <button class="btn" type="button" onclick="showImportModal()">Importar</button>
    <a href="/Policies/Create" class="btn primary crm-link-btn">Nueva Política</a>
  </div>
</header>

<!-- STATS -->
<section class="stats" aria-label="Métricas de políticas">
  <div class="stat">
    <div class="label">Políticas activas</div>
    <div class="value">@Model.Policies.Count(p => p.IsActive)</div>
    <div class="hint">
      <span>En vigor</span>
      <span class="delta up">@Model.Policies.Count total</span>
    </div>
  </div>

  <div class="stat">
    <div class="label">Políticas totales</div>
    <div class="value">@Model.Policies.Count</div>
    <div class="hint">
      <span>Configuradas</span>
      <span class="delta up">@Model.Policies.Count(p => p.IsActive) activas</span>
    </div>
  </div>

  <div class="stat">
    <div class="label">Cumplimiento</div>
    <div class="value">@(Model.Policies.Count > 0 ? "—" : "N/A")</div>
    <div class="hint">
      <span>Sin evaluaciones automáticas</span>
    </div>
  </div>

  <div class="stat">
    <div class="label">Violaciones</div>
    <div class="value">0</div>
    <div class="hint">
      <span>Bloqueadas</span>
      <span class="delta ok">✓</span>
    </div>
  </div>
</section>

<section class="grid">
  <!-- LEFT: Policies List -->
  <div class="card">
    <div class="card-h">
      <div>
        <h3 class="title">Políticas configuradas</h3>
        <p class="subtitle">
          Reglas de negocio, límites y controles que gobiernan el comportamiento autónomo del sistema.
        </p>
      </div>
      <span class="pill">@Model.Policies.Count políticas</span>
    </div>

    <div class="card-b">
      <table class="table" aria-label="Lista de políticas">
        <thead>
          <tr>
            <th>Política</th>
            <th>Categoría</th>
            <th>Evaluaciones</th>
            <th>Estado</th>
            <th>Acciones</th>
          </tr>
        </thead>
        <tbody>
          @if (Model.Policies.Any())
          {
            @foreach (var policy in Model.Policies)
            {
              <tr>
                <td>
                  <div class="crm-meta-strong">@policy.Name</div>
                  <div class="crm-meta-muted">@(policy.Description ?? "Sin descripción")</div>
                </td>
                <td>
                  @{
                    var category = policy.Expression.Contains("email", StringComparison.OrdinalIgnoreCase) ? "Comunicación" :
                                   policy.Expression.Contains("deal", StringComparison.OrdinalIgnoreCase) || policy.Expression.Contains("amount", StringComparison.OrdinalIgnoreCase) ? "Ventas" :
                                   policy.Expression.Contains("data", StringComparison.OrdinalIgnoreCase) || policy.Expression.Contains("retention", StringComparison.OrdinalIgnoreCase) ? "Compliance" :
                                   "General";
                  }
                  <span class="pill">@category</span>
                </td>
                <td>N/A</td>
                <td><span class="badge @(policy.IsActive ? "ok" : "")">@(policy.IsActive ? "Activa" : "Inactiva")</span></td>
                <td>
                  <a href="/Policies/Edit/@policy.Id" class="btn crm-btn-compact crm-link-btn">Editar</a>
                </td>
              </tr>
            }
          }
          else
          {
            <tr>
              <td colspan="5" class="crm-empty-cell">
                No hay políticas configuradas. <a href="/Policies/Create">Crea tu primera política</a>
              </td>
            </tr>
          }
        </tbody>
      </table>

      <div class="crm-toolbar-spacer"></div>

      <div class="crm-toolbar">
        <button class="btn" type="button" onclick="exportPolicies()">Exportar</button>
        <a href="/Policies/Create" class="btn primary crm-link-btn">Crear política</a>
      </div>
    </div>
  </div>

  <!-- RIGHT: Policy Activity -->
  <aside class="stack">
    <div class="card">
      <div class="card-h">
        <div>
          <h3 class="title">Evaluaciones recientes</h3>
          <p class="subtitle">Últimas evaluaciones de políticas y su resultado.</p>
        </div>
        <span class="pill">Tiempo real</span>
      </div>
      <div class="card-b">
        <div class="feed">
          <div class="item">
            <div class="itop">
              <div class="itag">CUMPLIDA</div>
              <div class="itime">Hace 1 min</div>
            </div>
            <div class="ibody">
              Política "Límite de envíos" evaluada. 45 emails enviados (bajo límite de 50).
            </div>
            <div class="ifooter">
              <span class="pill">Resultado: OK</span>
              <span class="pill">Acción: Permitida</span>
            </div>
          </div>

          <div class="item">
            <div class="itop">
              <div class="itag">BLOQUEADA</div>
              <div class="itime">Hace 8 min</div>
            </div>
            <div class="ibody">
              Política "Aprobación deals > $100K" evaluada. Deal de $125K requiere aprobación.
            </div>
            <div class="ifooter">
              <span class="pill">Resultado: Bloqueado</span>
              <span class="pill">Acción: Pendiente</span>
            </div>
          </div>

          <div class="item">
            <div class="itop">
              <div class="itag">CUMPLIDA</div>
              <div class="itime">Hace 15 min</div>
            </div>
            <div class="ibody">
              Política "Retención de datos" evaluada. Datos conservados según regla.
            </div>
            <div class="ifooter">
              <span class="pill">Resultado: OK</span>
              <span class="pill">Acción: Automática</span>
            </div>
          </div>
        </div>

        <div class="crm-toolbar-spacer"></div>

        <button class="btn primary crm-btn-block" type="button" onclick="alert('Funcionalidad de historial completo próximamente disponible');">Ver historial completo</button>
      </div>
    </div>

    <div class="card">
      <div class="card-h">
        <div>
          <h3 class="title">Categorías</h3>
          <p class="subtitle">Políticas agrupadas por categoría.</p>
        </div>
        <span class="pill">Resumen</span>
      </div>
      <div class="card-b">
        <table class="table" aria-label="Políticas por categoría">
          <thead>
            <tr>
              <th>Categoría</th>
              <th>Políticas</th>
              <th>Estado</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>Comunicación</td>
              <td>5</td>
              <td><span class="badge ok">Activas</span></td>
            </tr>
            <tr>
              <td>Ventas</td>
              <td>4</td>
              <td><span class="badge ok">Activas</span></td>
            </tr>
            <tr>
              <td>Compliance</td>
              <td>6</td>
              <td><span class="badge ok">Activas</span></td>
            </tr>
            <tr>
              <td>Seguridad</td>
              <td>3</td>
              <td><span class="badge ok">Activas</span></td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </aside>
</section>

<div class="crm-section-gap"></div>

<footer class="crm-footer-note">
  AUTONOMUS CRM · Políticas y reglas que gobiernan el sistema autónomo.
</footer>

<div id="importModal" class="crm-overlay-modal">
    <div class="card crm-overlay-card">
        <div class="card-h">
            <div>
                <h3 class="title">Importar Políticas</h3>
            </div>
        </div>
        <div class="card-b">
            <form method="post" action="/Policies/Import" enctype="multipart/form-data">
                <div class="crm-form-field">
                    <label>Archivo JSON *</label>
                    <input type="file" name="file" accept=".json" required class="crm-form-control" />
                    <div class="crm-form-help">
                        Selecciona un archivo JSON exportado previamente.
                    </div>
                </div>
                <div class="crm-split-actions">
                    <button type="submit" class="btn primary">Importar</button>
                    <button type="button" class="btn" onclick="closeImportModal()">Cancelar</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
function exportPolicies() {
    const policies = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Policies.Select(p => new { p.Id, p.Name, p.Description, p.Expression, p.IsActive })));
    const json = JSON.stringify(policies, null, 2);
    const blob = new Blob([json], { type: 'application/json' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = 'policies-' + new Date().toISOString().split('T')[0] + '.json';
    a.click();
    URL.revokeObjectURL(url);
}
function showImportModal() {
    document.getElementById('importModal').style.display = 'flex';
}
function closeImportModal() {
    document.getElementById('importModal').style.display = 'none';
}
</script>

