@page
@model AutonomusCRM.API.Pages.AuditModel
@{
    ViewData["Title"] = "Auditoría - AUTONOMUS CRM";
}

<!-- TOPBAR -->
<header class="topbar">
  <div class="topbar-left">
    <div class="kicker">Auditoría y trazabilidad</div>
    <h2 class="headline">Registro inmutable de todas las acciones</h2>
  </div>

  <div class="topbar-center">
    <form method="get" class="crm-filter-bar">
      <select name="eventType" class="crm-filter-control">
        <option value="">Todos los eventos</option>
        @foreach (var eventType in Model.EventTypes)
        {
          <option value="@eventType.Value" selected="@eventType.Selected">@eventType.Text</option>
        }
      </select>
      <input type="date" name="from" value="@Model.FilterFrom?.ToString("yyyy-MM-dd")" placeholder="Desde" class="crm-filter-control" />
      <input type="date" name="to" value="@Model.FilterTo?.ToString("yyyy-MM-dd")" placeholder="Hasta" class="crm-filter-control" />
      <button type="submit" class="btn crm-text-nowrap">Filtrar</button>
    </form>
  </div>

  <div class="topbar-right">
    <button class="btn mobile-toggle" type="button" onclick="toggleSidebar()">Menú</button>
    <form method="post" asp-page-handler="Export" class="crm-inline-form">
      <button type="submit" class="btn">Exportar</button>
    </form>
    <button class="btn primary" type="button" disabled title="Exportación JSON disponible; reportes PDF en roadmap">Generar reporte</button>
  </div>
</header>

<!-- STATS -->
<section class="stats" aria-label="Métricas de auditoría">
  <div class="stat">
    <div class="label">Eventos registrados</div>
    <div class="value">@Model.TotalEventsCount.ToString("N0")</div>
    <div class="hint">
      <span>Total tenant actual</span>
    </div>
  </div>

  <div class="stat">
    <div class="label">Eventos hoy (UTC)</div>
    <div class="value">@Model.TodayEventsCount.ToString("N0")</div>
    <div class="hint">
      <span>Desde medianoche UTC</span>
    </div>
  </div>

  <div class="stat">
    <div class="label">En vista filtrada</div>
    <div class="value">@Model.Events.Count.ToString("N0")</div>
    <div class="hint">
      <span>Máx. 1000 filas</span>
    </div>
  </div>

  <div class="stat">
    <div class="label">Tipos distintos</div>
    <div class="value">@Model.EventTypes.Count</div>
    <div class="hint">
      <span>Event store</span>
    </div>
  </div>
</section>

<section class="grid">
  <!-- LEFT: Audit Log -->
  <div class="card">
    <div class="card-h">
      <div>
        <h3 class="title">Registro de auditoría</h3>
        <p class="subtitle">
          Historial completo e inmutable de todas las acciones, decisiones y eventos del sistema.
        </p>
      </div>
      <span class="pill">Event Sourcing</span>
    </div>

    <div class="card-b">
      <table class="table" aria-label="Registro de auditoría">
        <thead>
          <tr>
            <th>Timestamp</th>
            <th>Evento</th>
            <th>Usuario/Agente</th>
            <th>Entidad</th>
            <th>Acciones</th>
          </tr>
        </thead>
        <tbody>
          @if (Model.Events.Any())
          {
            @foreach (var evt in Model.Events.OrderByDescending(e => e.OccurredOn).Take(100))
            {
              <tr>
                <td>@evt.OccurredOn.ToString("yyyy-MM-dd HH:mm:ss")</td>
                <td>
                  <div class="crm-meta-strong">@evt.EventType</div>
                  <div class="crm-meta-muted">ID: @evt.Id.ToString().Substring(0, 8)...</div>
                </td>
                <td>
                  @if (evt.CorrelationId.HasValue)
                  {
                    <span class="pill">@evt.CorrelationId.Value.ToString().Substring(0, 8)...</span>
                  }
                  else
                  {
                    <span class="pill">System</span>
                  }
                </td>
                <td><span class="badge">@evt.TenantId.ToString().Substring(0, 8)...</span></td>
                <td>
                  <button class="btn crm-btn-compact" type="button" onclick="showEventDetails('@evt.Id', '@evt.EventType', '@evt.OccurredOn', '@System.Text.Json.JsonSerializer.Serialize(evt).Replace("'", "\\'")');">Ver</button>
                </td>
              </tr>
            }
          }
          else
          {
            <tr>
              <td colspan="5" class="crm-empty-cell">
                No hay eventos de auditoría registrados aún.
              </td>
            </tr>
          }
        </tbody>
      </table>

      <div class="crm-toolbar-spacer"></div>

      <div class="crm-toolbar">
        <button class="btn" type="button">Exportar</button>
        <button class="btn" type="button">Filtrar</button>
        <button class="btn primary" type="button">Generar reporte</button>
      </div>
    </div>
  </div>

  <!-- RIGHT: Event Details -->
  <aside class="stack">
    <div class="card">
      <div class="card-h">
        <div>
          <h3 class="title">Eventos por tipo</h3>
          <p class="subtitle">Distribución de eventos registrados en el sistema.</p>
        </div>
        <span class="pill">Últimos 7 días</span>
      </div>
      <div class="card-b">
        <table class="table" aria-label="Eventos por tipo">
          <thead>
            <tr>
              <th>Tipo de evento</th>
              <th>Cantidad</th>
              <th>Tendencia</th>
            </tr>
          </thead>
          <tbody>
            @if (Model.EventsByType.Any())
            {
              @foreach (var kv in Model.EventsByType.OrderByDescending(x => x.Value).Take(15))
              {
                <tr>
                  <td>@kv.Key</td>
                  <td>@kv.Value</td>
                  <td><span class="badge ok">—</span></td>
                </tr>
              }
            }
            else
            {
              <tr>
                <td colspan="3" class="crm-empty-cell">Sin datos en el filtro actual</td>
              </tr>
            }
          </tbody>
        </table>
      </div>
    </div>

    <div class="card">
      <div class="card-h">
        <div>
          <h3 class="title">Trazabilidad completa</h3>
          <p class="subtitle">Cada acción puede ser reconstruida y explicada.</p>
        </div>
        <span class="pill">Event Sourcing</span>
      </div>
      <div class="card-b">
        <div class="feed">
          <div class="item">
            <div class="itop">
              <div class="itag">INFO</div>
              <div class="itime">Sistema</div>
            </div>
            <div class="ibody">
              Todos los eventos se almacenan de forma inmutable. El estado completo del sistema puede reconstruirse desde cero.
            </div>
            <div class="ifooter">
              <span class="pill">Event Store</span>
              <span class="pill">Snapshots</span>
            </div>
          </div>
        </div>

        <div class="crm-toolbar-spacer"></div>

        <button class="btn primary crm-btn-block" type="button">Ver documentación</button>
      </div>
    </div>
  </aside>
</section>

<div class="crm-section-gap"></div>

<footer class="crm-footer-note">
  AUTONOMUS CRM · Auditoría completa con Event Sourcing y trazabilidad absoluta.
</footer>

<div id="eventDetailsModal" class="crm-overlay-modal">
    <div class="card crm-overlay-card crm-overlay-card-lg">
        <div class="card-h">
            <div>
                <h3 class="title" id="eventDetailsTitle">Detalles del Evento</h3>
            </div>
        </div>
        <div class="card-b">
            <div id="eventDetailsContent" class="crm-json-preview"></div>
            <div class="crm-form-field">
                <button type="button" class="btn crm-btn-block" onclick="closeEventDetailsModal()">Cerrar</button>
            </div>
        </div>
    </div>
</div>

<script>
function showEventDetails(id, eventType, occurredOn, eventData) {
    document.getElementById('eventDetailsTitle').textContent = eventType;
    try {
        const data = JSON.parse(eventData);
        document.getElementById('eventDetailsContent').textContent = JSON.stringify(data, null, 2);
    } catch {
        document.getElementById('eventDetailsContent').textContent = eventData;
    }
    document.getElementById('eventDetailsModal').style.display = 'flex';
}
function closeEventDetailsModal() {
    document.getElementById('eventDetailsModal').style.display = 'none';
}
</script>

