@page "/Customers/Create"
@model AutonomusCRM.API.Pages.Customers.CreateModel
@{
    ViewData["Title"] = L["Customers_Create_Title"].Value;
    ViewData["PageTitle"] = L["Customers_Create_Title"].Value;
    ViewData["PageKicker"] = L["Customers_Create_Kicker"].Value;
    ViewData["PageSubtitle"] = L["Customers_Create_CardSubtitle"].Value;
    ViewData["PageActionsHtml"] = $"<a href=\"/Customers\" class=\"flow-btn flow-btn-secondary\">{L["Btn_Cancel"].Value}</a>";
    ViewData["FormErrorMessage"] = Model.ErrorMessage;
    ViewData["FormSuccessMessage"] = Model.SuccessMessage;
}

<partial name="Flow/_FlowPageHeader" />
<partial name="Shared/_FlowFormAlerts" />

<section class="flow-card flow-form-card">
  <header class="flow-card-header">
    <h2 class="flow-card-title" id="customer-create-title">@L["Customers_Create_CardTitle"]</h2>
    <p class="flow-page-subtitle mb-0">@L["Customers_Create_CardSubtitle"]</p>
  </header>
  <div class="flow-card-body">
    <form method="post" asp-page-handler="Create" class="flow-form" aria-labelledby="customer-create-title">
      <div class="flow-form-grid">
        <div class="flow-form-field">
          <label class="flow-form-label" for="customer-name">@L["Form_FullNameRequired"]</label>
          <input type="text" id="customer-name" name="name" class="flow-form-control" required value="@Model.Name" placeholder="@L["Customers_Create_PlaceholderName"]" autocomplete="name" />
        </div>
        <div class="flow-form-field">
          <label class="flow-form-label" for="customer-email">@L["Common_Email"]</label>
          <input type="email" id="customer-email" name="email" class="flow-form-control" value="@Model.Email" placeholder="@L["Customers_Create_PlaceholderEmail"]" autocomplete="email" />
        </div>
        <div class="flow-form-field">
          <label class="flow-form-label" for="customer-phone">@L["Common_Phone"]</label>
          <input type="tel" id="customer-phone" name="phone" class="flow-form-control" value="@Model.Phone" placeholder="@L["Customers_Create_PlaceholderPhone"]" autocomplete="tel" />
        </div>
        <div class="flow-form-field">
          <label class="flow-form-label" for="customer-company">@L["Form_Company"]</label>
          <input type="text" id="customer-company" name="company" class="flow-form-control" value="@Model.Company" placeholder="@L["Customers_Create_PlaceholderCompany"]" autocomplete="organization" />
        </div>
      </div>
      <div class="flow-form-actions">
        <button type="submit" class="flow-btn flow-btn-primary">@L["Customers_Create_Submit"]</button>
        <a href="/Customers" class="flow-btn flow-btn-secondary">@L["Btn_Cancel"]</a>
      </div>
    </form>
  </div>
</section>

<p class="flow-form-footer">@L["Customers_Create_Footer"]</p>
