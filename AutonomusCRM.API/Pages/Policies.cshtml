@page
@model AutonomusCRM.API.Pages.PoliciesModel
@{
    ViewData["Title"] = L["Policies_PageTitle"].Value;
}

<!-- TOPBAR -->
<header class="topbar">
  <div class="topbar-left">
    <div class="kicker">@L["Policies_Subtitle"]</div>
    <h2 class="headline">@L["Policies_PageTitle"]</h2>
  </div>

  <div class="topbar-center">
    <div class="search" role="search">
      <input type="text" placeholder="@L["Btn_Search"]…" aria-label="@L["Btn_Search"]" />
      <span class="chip">@L["Btn_Filter"]</span>
      <span class="chip">@L["Command_DecisionType"]</span>
    </div>
  </div>

  <div class="topbar-right">
    <button class="btn mobile-toggle" type="button" onclick="toggleSidebar()">@L["Common_Menu"]</button>
    <button class="btn" type="button" onclick="showImportModal()">@L["Btn_Import"]</button>
    <a href="/Policies/Create" class="btn primary crm-link-btn">@L["Policies_New"]</a>
  </div>
</header>

<!-- STATS -->
<section class="stats" aria-label="@L["Policies_PageTitle"]">
  <div class="stat">
    <div class="label">@L["Policies_PageTitle"]</div>
    <div class="value">@Model.Policies.Count(p => p.IsActive)</div>
    <div class="hint">
      <span>@L["Common_Status"]</span>
      <span class="delta up">@Model.Policies.Count @L["Policies_PageTitle"]</span>
    </div>
  </div>

  <div class="stat">
    <div class="label">@L["Policies_PageTitle"]</div>
    <div class="value">@Model.Policies.Count</div>
    <div class="hint">
      <span>@L["Btn_Create"]</span>
      <span class="delta up">@Model.Policies.Count(p => p.IsActive) @L["Integrations_Connected"]</span>
    </div>
  </div>

  <div class="stat">
    <div class="label">@L["Policies_Compliance"]</div>
    <div class="value">@(Model.Policies.Count > 0 ? "—" : "N/A")</div>
    <div class="hint">
      <span>@L["Command_MetricsWillAppear"]</span>
    </div>
  </div>

  <div class="stat">
    <div class="label">@L["Policies_Blocked"]</div>
    <div class="value">0</div>
    <div class="hint">
      <span>@L["Policies_Blocked"]</span>
      <span class="delta ok">✓</span>
    </div>
  </div>
</section>

<section class="grid">
  <!-- LEFT: Policies List -->
  <div class="card">
    <div class="card-h">
      <div>
        <h3 class="title">@L["Policies_PageTitle"]</h3>
        <p class="subtitle">@L["Policies_Subtitle"]</p>
      </div>
      <span class="pill">@Model.Policies.Count @L["Policies_PageTitle"]</span>
    </div>

    <div class="card-b">
      <table class="table" aria-label="@L["Policies_PageTitle"]">
        <thead>
          <tr>
            <th>@L["Policies_PageTitle"]</th>
            <th>@L["Command_DecisionType"]</th>
            <th>@L["Command_History"]</th>
            <th>@L["Common_Status"]</th>
            <th>@L["Common_Actions"]</th>
          </tr>
        </thead>
        <tbody>
          @if (Model.Policies.Any())
          {
            @foreach (var policy in Model.Policies)
            {
              <tr>
                <td>
                  <div class="crm-meta-strong">@policy.Name</div>
                  <div class="crm-meta-muted">@(policy.Description ?? L["Common_NoData"].Value)</div>
                </td>
                <td>
                  @{
                    var category = policy.Expression.Contains("email", StringComparison.OrdinalIgnoreCase) ? L["Policies_Communication"].Value :
                                   policy.Expression.Contains("deal", StringComparison.OrdinalIgnoreCase) || policy.Expression.Contains("amount", StringComparison.OrdinalIgnoreCase) ? L["Policies_Sales"].Value :
                                   policy.Expression.Contains("data", StringComparison.OrdinalIgnoreCase) || policy.Expression.Contains("retention", StringComparison.OrdinalIgnoreCase) ? L["Policies_Compliance"].Value :
                                   L["Common_Status"].Value;
                  }
                  <span class="pill">@category</span>
                </td>
                <td>N/A</td>
                <td><span class="badge @(policy.IsActive ? "ok" : "")">@(policy.IsActive ? L["Integrations_Connected"].Value : L["Integrations_Disconnected"].Value)</span></td>
                <td>
                  <a href="/Policies/Edit/@policy.Id" class="btn crm-btn-compact crm-link-btn">@L["Btn_Edit"]</a>
                </td>
              </tr>
            }
          }
          else
          {
            <tr>
              <td colspan="5" class="crm-empty-cell">
                @L["Common_NoData"] <a href="/Policies/Create">@L["Btn_Create"]</a>
              </td>
            </tr>
          }
        </tbody>
      </table>

      <div class="crm-toolbar-spacer"></div>

      <div class="crm-toolbar">
        <button class="btn" type="button" onclick="exportPolicies()">@L["Btn_Export"]</button>
        <a href="/Policies/Create" class="btn primary crm-link-btn">@L["Btn_Create"]</a>
      </div>
    </div>
  </div>

  <!-- RIGHT: Policy Activity -->
  <aside class="stack">
    <div class="card">
      <div class="card-h">
        <div>
          <h3 class="title">@L["Command_History"]</h3>
          <p class="subtitle">@L["Command_DecisionOutcome"]</p>
        </div>
        <span class="pill">@L["Command_LiveDecisions"]</span>
      </div>
      <div class="card-b">
        <div class="feed">
          <div class="item">
            <div class="itop">
              <div class="itag">@L["Policies_Compliant"]</div>
              <div class="itime">1 min</div>
            </div>
            <div class="ibody">
              @L["Policies_Communication"] — 45 / 50
            </div>
            <div class="ifooter">
              <span class="pill">@L["Command_DecisionOutcome"]: OK</span>
              <span class="pill">@L["Btn_Approve"]</span>
            </div>
          </div>

          <div class="item">
            <div class="itop">
              <div class="itag">@L["Policies_Blocked"]</div>
              <div class="itime">8 min</div>
            </div>
            <div class="ibody">
              @L["Policies_Sales"] — $125K
            </div>
            <div class="ifooter">
              <span class="pill">@L["Policies_Blocked"]</span>
              <span class="pill">@L["Common_Pending"]</span>
            </div>
          </div>

          <div class="item">
            <div class="itop">
              <div class="itag">@L["Policies_Compliant"]</div>
              <div class="itime">15 min</div>
            </div>
            <div class="ibody">
              @L["Policies_Compliance"]
            </div>
            <div class="ifooter">
              <span class="pill">@L["Command_DecisionOutcome"]: OK</span>
              <span class="pill">@L["Workflows_Subtitle"]</span>
            </div>
          </div>
        </div>

        <div class="crm-toolbar-spacer"></div>

        <button class="btn primary crm-btn-block" type="button" onclick="alert('@L["Policies_HistorySoon"]');">@L["Command_SeeAll"]</button>
      </div>
    </div>

    <div class="card">
      <div class="card-h">
        <div>
          <h3 class="title">@L["Command_DecisionType"]</h3>
          <p class="subtitle">@L["Policies_Subtitle"]</p>
        </div>
        <span class="pill">@L["Command_History"]</span>
      </div>
      <div class="card-b">
        <table class="table" aria-label="@L["Policies_PageTitle"]">
          <thead>
            <tr>
              <th>@L["Command_DecisionType"]</th>
              <th>@L["Policies_PageTitle"]</th>
              <th>@L["Common_Status"]</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>@L["Policies_Communication"]</td>
              <td>5</td>
              <td><span class="badge ok">@L["Integrations_Connected"]</span></td>
            </tr>
            <tr>
              <td>@L["Policies_Sales"]</td>
              <td>4</td>
              <td><span class="badge ok">@L["Integrations_Connected"]</span></td>
            </tr>
            <tr>
              <td>@L["Policies_Compliance"]</td>
              <td>6</td>
              <td><span class="badge ok">@L["Integrations_Connected"]</span></td>
            </tr>
            <tr>
              <td>@L["Settings_Security"]</td>
              <td>3</td>
              <td><span class="badge ok">@L["Integrations_Connected"]</span></td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </aside>
</section>

<div class="crm-section-gap"></div>

<footer class="crm-footer-note">
  AUTONOMUS CRM · @L["Policies_Subtitle"]
</footer>

<div id="importModal" class="crm-overlay-modal">
    <div class="card crm-overlay-card">
        <div class="card-h">
            <div>
                <h3 class="title">@L["Btn_Import"] @L["Policies_PageTitle"]</h3>
            </div>
        </div>
        <div class="card-b">
            <form method="post" action="/Policies/Import" enctype="multipart/form-data">
                <div class="crm-form-field">
                    <label>@L["Form_JsonRequired"]</label>
                    <input type="file" name="file" accept=".json" required class="crm-form-control" />
                    <div class="crm-form-help">
                        @L["Btn_Import"] JSON
                    </div>
                </div>
                <div class="crm-split-actions">
                    <button type="submit" class="btn primary">@L["Btn_Import"]</button>
                    <button type="button" class="btn" onclick="closeImportModal()">@L["Btn_Cancel"]</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
function exportPolicies() {
    const policies = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Policies.Select(p => new { p.Id, p.Name, p.Description, p.Expression, p.IsActive })));
    const json = JSON.stringify(policies, null, 2);
    const blob = new Blob([json], { type: 'application/json' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = 'policies-' + new Date().toISOString().split('T')[0] + '.json';
    a.click();
    URL.revokeObjectURL(url);
}
function showImportModal() { window.crmModal.open('importModal'); }
function closeImportModal() { window.crmModal.close('importModal'); }
</script>
