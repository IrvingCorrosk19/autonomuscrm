@page "/Workflows/Create"
@model AutonomusCRM.API.Pages.Workflows.CreateModel
@{
    ViewData["Title"] = L["Workflows_Create_Title"].Value;
    ViewData["PageTitle"] = L["Workflows_Create_Title"].Value;
    ViewData["PageKicker"] = L["Workflows_Create_Kicker"].Value;
    ViewData["PageSubtitle"] = L["Workflows_Create_CardSubtitle"].Value;
    ViewData["PageActionsHtml"] = $"<a href=\"/Workflows\" class=\"flow-btn flow-btn-secondary\">{L["Btn_Cancel"].Value}</a>";
}

<partial name="Flow/_FlowPageHeader" />
<partial name="Shared/_FlowFormAlerts" />

<section class="flow-card flow-form-card">
    <header class="flow-card-header">
        <h2 class="flow-card-title" id="workflow-create-title">@L["Workflows_Create_CardTitle"]</h2>
        <p class="flow-page-subtitle mb-0">@L["Workflows_Create_CardSubtitle"]</p>
    </header>
    <div class="flow-card-body">
        <form method="post" class="flow-form" aria-labelledby="workflow-create-title">
            <div class="flow-form-grid">
                <div class="flow-form-field flow-form-field--full">
                    <label class="flow-form-label" for="workflow-create-name">@L["Form_NameRequired"]</label>
                    <input type="text" id="workflow-create-name" name="name" class="flow-form-control" required placeholder="@L["Workflows_Create_PlaceholderName"]" />
                </div>
                <div class="flow-form-field flow-form-field--full">
                    <label class="flow-form-label" for="workflow-create-description">@L["Form_Description"]</label>
                    <textarea id="workflow-create-description" name="description" class="flow-form-control" rows="4" placeholder="@L["Workflows_Create_PlaceholderDesc"]"></textarea>
                </div>
            </div>
            <div class="flow-comms-banner flow-comms-banner--warn" role="note">
                <strong>@L["Common_Note"]</strong> @L["Workflows_Create_Note"]
            </div>
            <div class="flow-form-actions">
                <button type="submit" class="flow-btn flow-btn-primary">@L["Workflows_Create_Submit"]</button>
                <a href="/Workflows" class="flow-btn flow-btn-secondary">@L["Btn_Cancel"]</a>
            </div>
        </form>
    </div>
</section>

<p class="flow-form-footer">@L["Workflows_Create_Footer"]</p>
