@page "/demo"
@model AutonomusCRM.API.Pages.DemoModel
@{
    Layout = "Shared/Marketing/_MarketingLayout";
    ViewData["Title"] = L["Marketing_Demo_PageTitle"].Value;
}
<section class="marketing-hero" style="padding-bottom:24px;">
  <h1>@L["Marketing_Demo_HeroTitle"]</h1>
  <p class="lead">@L["Marketing_Demo_HeroLead"]</p>
</section>

<section class="marketing-section" style="padding-top:0;">
  <div class="marketing-demo-steps">
    <article class="marketing-demo-step">
      <div class="marketing-demo-step-num">1</div>
      <div>
        <h3 style="margin:0 0 8px;">@L["Marketing_Demo_Step1Title"]</h3>
        <p style="margin:0 0 12px;font-size:14px;color:var(--flow-text-secondary);">
          @L["Marketing_Demo_Step1Desc"]
        </p>
        <p style="font-size:13px;background:var(--flow-bg-subtle);padding:12px;border-radius:8px;margin:0;">
          <strong>@L["Marketing_Demo_CeoAdmin"]</strong> admin@autonomuscrm.local · Admin123!<br/>
          <strong>@L["Marketing_Demo_CroSales"]</strong> sales@autonomuscrm.local · Sales123!<br/>
          <strong>@L["Marketing_Demo_CcoCs"]</strong> manager@autonomuscrm.local · Manager123!
        </p>
        <p style="margin-top:12px;"><a href="/Account/Login" class="flow-btn flow-btn-primary flow-btn-sm">@L["Marketing_Demo_Step1Login"]</a></p>
      </div>
    </article>

    <article class="marketing-demo-step">
      <div class="marketing-demo-step-num">2</div>
      <div>
        <h3 style="margin:0 0 8px;">@L["Marketing_Demo_Step2Title"]</h3>
        <p style="margin:0;font-size:14px;color:var(--flow-text-secondary);">
          @L["Marketing_Demo_Step2Desc"]
        </p>
        <p style="margin-top:10px;"><a href="/executive" class="flow-btn flow-btn-secondary flow-btn-sm">@L["Marketing_Demo_Step2Open"]</a> <span class="text-muted" style="font-size:12px;">@L["Marketing_Demo_RequiresLogin"]</span></p>
      </div>
    </article>

    <article class="marketing-demo-step">
      <div class="marketing-demo-step-num">3</div>
      <div>
        <h3 style="margin:0 0 8px;">@L["Marketing_Demo_Step3Title"]</h3>
        <p style="margin:0;font-size:14px;color:var(--flow-text-secondary);">
          @L["Marketing_Demo_Step3Desc"]
        </p>
        <p style="margin-top:10px;"><a href="/revenue" class="flow-btn flow-btn-secondary flow-btn-sm">@L["Marketing_Demo_Step3Open"]</a></p>
      </div>
    </article>

    <article class="marketing-demo-step">
      <div class="marketing-demo-step-num">4</div>
      <div>
        <h3 style="margin:0 0 8px;">@L["Marketing_Demo_Step4Title"]</h3>
        <p style="margin:0;font-size:14px;color:var(--flow-text-secondary);">
          @L["Marketing_Demo_Step4DescLine1"]<br/>
          @L["Marketing_Demo_Step4DescLine2"]
        </p>
        <p style="margin-top:10px;">
          <a href="/" class="flow-btn flow-btn-secondary flow-btn-sm">@L["Marketing_Demo_Step4Command"]</a>
          <a href="/TrustInbox" class="flow-btn flow-btn-secondary flow-btn-sm">@L["Marketing_Demo_Step4Trust"]</a>
        </p>
      </div>
    </article>

    <article class="marketing-demo-step">
      <div class="marketing-demo-step-num">5</div>
      <div>
        <h3 style="margin:0 0 8px;">@L["Marketing_Demo_Step5Title"]</h3>
        <p style="margin:0;font-size:14px;color:var(--flow-text-secondary);">
          @L["Marketing_Demo_Step5DescLine1"]<br/>
          @L["Marketing_Demo_Step5DescLine2"]
        </p>
        <p style="margin-top:10px;">
          <a href="/Customer360" class="flow-btn flow-btn-secondary flow-btn-sm">@L["Marketing_Demo_Step5C360"]</a>
          <a href="/customer-success" class="flow-btn flow-btn-secondary flow-btn-sm">@L["Marketing_Demo_Step5CsOs"]</a>
        </p>
      </div>
    </article>
  </div>

  <div class="marketing-card" style="max-width:720px;margin:32px auto 0;text-align:center;">
    <h3 style="margin:0 0 8px;">@L["Marketing_Demo_ChecklistTitle"]</h3>
    <p style="font-size:14px;color:var(--flow-text-secondary);margin:0;">
      @L["Marketing_Demo_Checklist"]
    </p>
  </div>
</section>
