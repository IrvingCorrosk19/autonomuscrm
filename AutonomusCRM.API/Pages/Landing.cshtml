@page "/landing"
@model AutonomusCRM.API.Pages.LandingModel
@{
    Layout = "Shared/Marketing/_MarketingLayout";
    ViewData["Title"] = L["Marketing_Landing_PageTitle"].Value;
    ViewData["MetaDescription"] = L["Marketing_Landing_MetaDescription"].Value;
}

<section class="marketing-hero">
  <h1>@L["Marketing_Landing_HeroPrefix"]<span style="color:var(--flow-brand-primary)">@L["Marketing_Landing_HeroHighlight"]</span>@L["Marketing_Landing_HeroSuffix"]</h1>
  <p class="lead">@L["Marketing_Landing_Lead"]</p>
  <div class="marketing-hero-actions">
    <a href="/demo" class="flow-btn flow-btn-primary">@L["Marketing_Landing_CeoDemo"]</a>
    <a href="/roi" class="flow-btn flow-btn-secondary">@L["Marketing_Landing_CalcRoi"]</a>
  </div>
</section>

<section class="marketing-section">
  <h2>@L["Marketing_Landing_WhatIs"]</h2>
  <div class="marketing-grid-3">
    <article class="marketing-card">
      <h3>@L["Marketing_Landing_Tagline"]</h3>
      <p>@L["Marketing_Landing_TaglineDesc"]</p>
    </article>
    <article class="marketing-card">
      <h3>@L["Marketing_Landing_ExecutiveNative"]</h3>
      <p>@L["Marketing_Landing_ExecutiveNativeDesc"]</p>
    </article>
    <article class="marketing-card">
      <h3>@L["Marketing_Landing_Actionable"]</h3>
      <p>@L["Marketing_Landing_ActionableDesc"]</p>
    </article>
  </div>
</section>

<section class="marketing-section" style="background:var(--flow-bg-subtle);max-width:none;">
  <div style="max-width:1080px;margin:0 auto;padding:0 24px;">
    <h2>@L["Marketing_Landing_WhyDifferent"]</h2>
    <div class="marketing-value-grid">
      <div class="marketing-value-item">
        <strong>@L["Marketing_Landing_VsCrmBi"]</strong>
        @L["Marketing_Landing_VsCrmBiDesc"]
      </div>
      <div class="marketing-value-item">
        <strong>@L["Marketing_Landing_VsCopilots"]</strong>
        @L["Marketing_Landing_VsCopilotsDesc"]
      </div>
      <div class="marketing-value-item">
        <strong>@L["Marketing_Landing_VsCsTools"]</strong>
        @L["Marketing_Landing_VsCsToolsDesc"]
      </div>
      <div class="marketing-value-item">
        <strong>@L["Marketing_Landing_VsConsulting"]</strong>
        @L["Marketing_Landing_VsConsultingDesc"]
      </div>
    </div>
  </div>
</section>

<section class="marketing-section">
  <h2>@L["Marketing_Landing_MoneyRiskTitle"]</h2>
  <div class="marketing-grid-3">
    <article class="marketing-card">
      <h3>@L["Marketing_Landing_MakesMoney"]</h3>
      <p><strong>@L["Marketing_Landing_ExpansionLabel"]</strong> @L["Marketing_Landing_ExpansionDesc"]<br/>
      <strong>@L["Marketing_Landing_RenewalsLabel"]</strong> @L["Marketing_Landing_RenewalsDesc"]<br/>
      <strong>@L["Marketing_Landing_AiRevenueLabel"]</strong> @L["Marketing_Landing_AiRevenueDesc"]</p>
    </article>
    <article class="marketing-card">
      <h3>@L["Marketing_Landing_ReducesRisk"]</h3>
      <p><strong>@L["Marketing_Landing_ChurnLabel"]</strong> @L["Marketing_Landing_ChurnDesc"]<br/>
      <strong>@L["Marketing_Landing_RevenueAtRiskLabel"]</strong> @L["Marketing_Landing_RevenueAtRiskDesc"]<br/>
      <strong>@L["Marketing_Landing_AiGovernanceLabel"]</strong> @L["Marketing_Landing_AiGovernanceDesc"]</p>
    </article>
    <article class="marketing-card">
      <h3>@L["Marketing_Landing_TypicalResult"]</h3>
      <p>@L["Marketing_Landing_TypicalResultDesc"]</p>
      <p style="margin-top:12px;"><a href="/stories">@L["Marketing_Landing_SeeFullStory"]</a></p>
    </article>
  </div>
  <p style="text-align:center;margin-top:32px;">
    <a href="/Account/Login" class="flow-btn flow-btn-primary">@L["Marketing_Landing_AccessProduct"]</a>
  </p>
</section>
