@page
@model AutonomusCRM.API.Pages.CustomersModel
@using AutonomusCRM.Application.Customers.Queries
@using AutonomusCRM.Domain.Customers
@{
    ViewData["Title"] = L["Customers_PageTitle"].Value;
    ViewData["PageTitle"] = L["Customers_PageTitle"].Value;
    ViewData["PageKicker"] = L["Nav_Section_Customers"].Value;
    ViewData["PageSubtitle"] = L["Customers_Subtitle"].Value;
    ViewData["PageActionsHtml"] = "<a href=\"/Customers/Create\" class=\"btn btn-primary\"><i class=\"fas fa-plus mr-1\"></i>" + L["Customers_NewCustomer"].Value + "</a>";
}

<partial name="Flow/_FlowPageHeader" />

<div class="crm-filter-card">
  <form method="get" class="crm-filter-form">
    <div class="form-group" style="flex:2 1 200px;">
      <label for="search">@L["Btn_Search"]</label>
      <input type="text" id="search" name="search" class="form-control" value="@Model.SearchTerm" placeholder="@L["Customers_SearchPlaceholder"]" />
    </div>
    <div class="form-group">
      <label for="status">@L["Common_Status"]</label>
      <select id="status" name="status" class="form-control">
        <option value="">@L["Common_All"]</option>
        @foreach (var status in Enum.GetValues<AutonomusCRM.Domain.Customers.CustomerStatus>())
        {
          <option value="@((int)status)" selected="@(Model.FilterStatus == status)">@status</option>
        }
      </select>
    </div>
    <div class="crm-filter-actions">
      <button type="submit" class="btn btn-primary">@L["Btn_Filter"]</button>
      @if (!string.IsNullOrWhiteSpace(Model.SearchTerm) || Model.FilterStatus.HasValue)
      {
        <a href="/Customers" class="btn btn-outline-secondary">@L["Btn_Clear"]</a>
      }
      <button type="button" class="btn btn-outline-secondary" onclick="exportCustomers()">@L["Btn_Export"]</button>
    </div>
  </form>
</div>

@if (Model.Created == true)
{
  <div class="alert alert-success alert-dismissible fade show" role="alert">
    <i class="fas fa-check mr-1"></i> @L["Customers_CreatedSuccess"]
    <button type="button" class="close" data-dismiss="alert"><span>&times;</span></button>
  </div>
}
@if (TempData["Message"] != null)
{
  <div class="alert alert-success alert-dismissible fade show" role="alert">
    @TempData["Message"]
    <button type="button" class="close" data-dismiss="alert"><span>&times;</span></button>
  </div>
}

<section class="flow-metric-grid" aria-label="@L["Customers_MetricsAria"]">
  @{ var cSummary = Model.Summary; ViewData["FlowMetricLabel"] = L["Customers_MetricTotal"].Value; ViewData["FlowMetricValue"] = cSummary.TotalCount.ToString(); ViewData["FlowMetricHint"] = string.Format(L["Pagination_Records"].Value, Model.FilteredCustomers.Count, cSummary.TotalCount); ViewData["FlowMetricVariant"] = "info"; }
  <partial name="Flow/_FlowMetricCard" />
  @{ ViewData["FlowMetricLabel"] = L["Customers_MetricAvgLtv"].Value; ViewData["FlowMetricValue"] = "$" + cSummary.AvgLtv.ToString("N0"); ViewData["FlowMetricHint"] = $"{cSummary.HighLtvCount} {L["Customers_MetricHighLtv"].Value}"; ViewData["FlowMetricVariant"] = "success"; }
  <partial name="Flow/_FlowMetricCard" />
  @{ ViewData["FlowMetricLabel"] = L["Customers_MetricHighRisk"].Value; ViewData["FlowMetricValue"] = cSummary.HighRiskCount.ToString(); ViewData["FlowMetricHint"] = L["Customers_MetricHighRiskHint"].Value; ViewData["FlowMetricVariant"] = "warning"; }
  <partial name="Flow/_FlowMetricCard" />
  @{ ViewData["FlowMetricLabel"] = L["Customers_MetricAvgRisk"].Value; ViewData["FlowMetricValue"] = cSummary.AvgRisk.HasValue ? cSummary.AvgRisk.Value.ToString("F0") : "N/A"; ViewData["FlowMetricHint"] = $"{cSummary.LowRiskCount} {L["Customers_MetricLowRisk"].Value}"; ViewData["FlowMetricVariant"] = "neutral"; }
  <partial name="Flow/_FlowMetricCard" />
</section>

<section class="flow-revenue-grid mt-4">
  <section class="flow-card" data-flow-datatable>
    <header class="flow-card-header">
      <div>
        <h3 class="flow-card-title">@L["Customers_Base"]</h3>
        <p class="text-muted mb-0" style="font-size:13px;">@string.Format(L["Pagination_Records"].Value, Model.FilteredCustomers.Count, Model.TotalCount)</p>
      </div>
    </header>
    <div class="flow-datatable-toolbar">
      <input type="search" class="flow-datatable-search" placeholder="@L["Btn_Search"]…" aria-label="@L["Btn_Search"]" />
    </div>
    <div class="flow-card-body flow-crm-table-wrap" style="padding:0;">
      <table class="flow-table-minimal flow-datatable" aria-label="@L["Customers_ListAria"]">
        <thead>
          <tr>
            <th>@L["Table_Customer"]</th>
            <th>@L["Customer360_Health"]</th>
            <th>@L["Customers_ExpansionColumn"]</th>
            <th>@L["Common_LTV"]</th>
            <th>@L["Common_Risk"]</th>
            <th>@L["Common_Status"]</th>
            <th>@L["Common_Actions"]</th>
          </tr>
        </thead>
        <tbody>
          @if (Model.FilteredCustomers.Any())
          {
            @foreach (var customer in Model.FilteredCustomers)
            {
              var healthScore = customer.RiskScore.HasValue ? Math.Clamp(100 - (int)customer.RiskScore.Value, 0, 100) : (customer.LifetimeValue > 0 ? 65 : 50);
              var expansionScore = customer.LifetimeValue switch { > 20000 => 90, > 10000 => 75, > 5000 => 55, _ => 30 };
              var search = $"{customer.Name} {customer.Company} {customer.Email}".ToLowerInvariant();
              var drawerBody = string.Format(L["Customers_DrawerBodyFormat"].Value, healthScore, expansionScore, customer.LifetimeValue?.ToString("N0") ?? "—", customer.RiskScore?.ToString() ?? "—");
              <tr data-search="@search" data-drawer-title="@customer.Name" data-drawer-body="@drawerBody" data-drawer-href="/customers/@customer.Id/360">
                <td>
                  <div style="font-weight:600;font-size:13px;">@customer.Name</div>
                  <div style="color:var(--flow-text-muted);font-size:12px;">
                    @if (!string.IsNullOrEmpty(customer.Company))
                    {
                      <text>@customer.Company</text>
                    }
                    @if (!string.IsNullOrEmpty(customer.Email))
                    {
                      <text> · @customer.Email</text>
                    }
                  </div>
                </td>
                <td><span class="flow-score-pill @(healthScore >= 70 ? "flow-score-pill--ok" : healthScore >= 45 ? "flow-score-pill--warn" : "flow-score-pill--danger")">@healthScore</span></td>
                <td><span class="flow-score-pill @(expansionScore >= 70 ? "flow-score-pill--ok" : expansionScore >= 45 ? "flow-score-pill--warn" : "")">@expansionScore</span></td>
                <td>@(customer.LifetimeValue.HasValue ? "$" + customer.LifetimeValue.Value.ToString("N0") : "—")</td>
                <td>@(customer.RiskScore?.ToString() ?? "—")</td>
                <td>@customer.Status</td>
                <td class="flow-row-actions">
                  <a href="/customers/@customer.Id/360" class="flow-btn flow-btn-secondary" style="font-size:11px;padding:4px 8px;" onclick="event.stopPropagation();">360</a>
                  <a href="/Customers/Details/@customer.Id" class="flow-btn flow-btn-secondary" style="font-size:11px;padding:4px 8px;" onclick="event.stopPropagation();">CRM</a>
                </td>
              </tr>
            }
          }
          else
          {
            <tr>
              <td colspan="7" class="text-muted" style="text-align:center;padding:20px;">
                @if (!string.IsNullOrWhiteSpace(Model.SearchTerm) || Model.FilterStatus.HasValue)
                {
                  <text>@L["Common_NoResults"] <a href="/Customers" style="color: var(--primary);">@L["Btn_Clear"]</a></text>
                }
                else
                {
                  <text>@L["Customers_NoCustomers"] <a href="/Customers/Create" style="color: var(--primary);">@L["Customers_NewCustomer"]</a></text>
                }
              </td>
            </tr>
          }
        </tbody>
      </table>
    </div>
    <footer class="flow-card-body" style="border-top:1px solid var(--flow-border-default); display:flex; gap:8px; flex-wrap:wrap; justify-content:space-between; align-items:center;">
      <div style="display:flex; gap:8px; flex-wrap:wrap;">
        <button class="flow-btn flow-btn-secondary" type="button" onclick="exportCustomers()">@L["Btn_Export"]</button>
        <button class="flow-btn flow-btn-secondary" type="button" onclick="showBulkActionsModal()">@L["Customers_BulkActions"]</button>
      </div>
      <partial name="Shared/_CrmPagination" model='new AutonomusCRM.API.Pages.Shared.CrmPaginationModel { Page = Model.PageIndex, PageSize = Model.PageSize, TotalCount = Model.TotalCount, ShownCount = Model.FilteredCustomers.Count, RecordsFormat = L["Pagination_Records"].Value, PageFormat = L["Pagination_Page"].Value, BuildUrl = Model.BuildPageUrl }' />
    </footer>
  </section>

  <aside class="flow-card">
    <header class="flow-card-header"><h3 class="flow-card-title">@L["Customers_MetricHighRisk"]</h3></header>
    <div class="flow-card-body">
      <p class="text-muted mb-2" style="font-size:13px;">@cSummary.HighRiskCount @L["Customers_MetricHighRisk"].Value · @cSummary.HighLtvCount @L["Customers_MetricHighLtv"].Value</p>
      <p class="text-muted mb-0" style="font-size:13px;">@L["Customers_MetricAvgLtv"]: $@cSummary.AvgLtv.ToString("N0")</p>
    </div>
  </aside>
</section>

<!-- CREATE CUSTOMER FORM -->
<div id="create-customer-form" style="display:none; position:fixed; top:0; left:0; right:0; bottom:0; background:rgba(0,0,0,0.8); z-index:1000; padding:40px; overflow:auto;">
  <div style="max-width:600px; margin:0 auto; background:var(--bg-card); padding:30px; border-radius:8px;">
    <h2 style="margin:0 0 20px 0;">@L["Customers_CreateTitle"]</h2>
    <form method="post" asp-page-handler="Create">
      <div style="margin-bottom:15px;">
        <label style="display:block; margin-bottom:5px; font-weight:600;">@L["Form_NameRequired"]</label>
        <input type="text" name="name" required style="width:100%; padding:10px; border:1px solid rgba(255,255,255,0.1); background:var(--bg); color:var(--text); border-radius:4px;" />
      </div>
      <div style="margin-bottom:15px;">
        <label style="display:block; margin-bottom:5px; font-weight:600;">@L["Common_Email"]</label>
        <input type="email" name="email" style="width:100%; padding:10px; border:1px solid rgba(255,255,255,0.1); background:var(--bg); color:var(--text); border-radius:4px;" />
      </div>
      <div style="margin-bottom:15px;">
        <label style="display:block; margin-bottom:5px; font-weight:600;">@L["Common_Phone"]</label>
        <input type="tel" name="phone" style="width:100%; padding:10px; border:1px solid rgba(255,255,255,0.1); background:var(--bg); color:var(--text); border-radius:4px;" />
      </div>
      <div style="margin-bottom:20px;">
        <label style="display:block; margin-bottom:5px; font-weight:600;">@L["Form_Company"]</label>
        <input type="text" name="company" style="width:100%; padding:10px; border:1px solid rgba(255,255,255,0.1); background:var(--bg); color:var(--text); border-radius:4px;" />
      </div>
      <div style="display:flex; gap:10px;">
        <button type="submit" class="btn primary" style="flex:1;">@L["Btn_Create"]</button>
        <button type="button" class="btn" onclick="document.getElementById('create-customer-form').style.display='none'" style="flex:1;">@L["Btn_Cancel"]</button>
      </div>
    </form>
  </div>
</div>

<div id="importModal" class="crm-overlay-modal" role="dialog" aria-modal="true" aria-hidden="true">
    <div class="card crm-overlay-card">
        <div class="card-h">
            <div>
                <h3 class="title">@L["Customers_ImportTitle"]</h3>
            </div>
        </div>
        <div class="card-b">
            <form method="post" action="/Customers/Import" enctype="multipart/form-data">
                <div style="margin-bottom: 15px;">
                    <label style="display: block; margin-bottom: 5px; font-weight: 600;">@L["Customers_ImportFileLabel"]</label>
                    <input type="file" name="file" accept=".json,.csv" required style="width: 100%; padding: 10px; border: 1px solid rgba(255,255,255,0.1); background: var(--bg); color: var(--text); border-radius: 4px;" />
                    <div style="margin-top: 5px; font-size: 12px; color: var(--muted);">
                        @L["Import_CsvFormatCustomers"]
                    </div>
                </div>
                <div style="display: flex; gap: 10px;">
                    <button type="submit" class="btn primary" style="flex: 1;">@L["Btn_Import"]</button>
                    <button type="button" class="btn" onclick="closeImportModal()" style="flex: 1;">@L["Btn_Cancel"]</button>
                </div>
            </form>
        </div>
    </div>
</div>

<partial name="Flow/_FlowDrawer" />

@section Scripts {
<script src="~/js/flow-worldclass.js" asp-append-version="true"></script>
<script>
function showImportModal() { window.crmModal.open('importModal'); }
function closeImportModal() { window.crmModal.close('importModal'); }
function exportCustomers() {
    const customers = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.FilteredCustomers.Select(c => new { c.Id, c.Name, c.Email, c.Phone, c.Company, Status = c.Status.ToString(), c.LifetimeValue, c.RiskScore, CreatedAt = c.CreatedAt.ToString("yyyy-MM-dd HH:mm") })));
    const json = JSON.stringify(customers, null, 2);
    const blob = new Blob([json], { type: 'application/json' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = 'customers-' + new Date().toISOString().split('T')[0] + '.json';
    a.click();
    URL.revokeObjectURL(url);
}
</script>
}

