@page "/flow/components"
@{
    ViewData["Title"] = L["FlowComponents_Title"].Value;
    ViewData["PageTitle"] = L["FlowComponents_Title"].Value;
    ViewData["PageKicker"] = L["FlowComponents_Title"].Value;
    ViewData["PageSubtitle"] = L["FlowComponents_Subtitle"].Value;
}
<partial name="Flow/_FlowPageHeader" />

<div class="flow-catalog-grid">
  <div class="flow-catalog-item">
    <div class="flow-metric-label">@L["FlowComponents_MetricCard"]</div>
    @{ ViewData["FlowMetricLabel"] = L["Executive_Revenue"].Value; ViewData["FlowMetricValue"] = "$124K"; ViewData["FlowMetricVariant"] = "success"; }
    <partial name="Flow/_FlowMetricCard" />
  </div>
  <div class="flow-catalog-item">
    <div class="flow-metric-label">@L["FlowComponents_Buttons"]</div>
    <div style="display:flex;gap:8px;flex-wrap:wrap;margin-top:8px;">
      <button type="button" class="flow-btn flow-btn-primary">@L["FlowComponents_Primary"]</button>
      <button type="button" class="flow-btn flow-btn-secondary">@L["FlowComponents_Secondary"]</button>
      <button type="button" class="flow-btn flow-btn-danger">@L["FlowComponents_Danger"]</button>
    </div>
  </div>
  <div class="flow-catalog-item">
    <div class="flow-metric-label">@L["FlowComponents_EmptyState"]</div>
    @{ ViewData["FlowEmptyTitle"] = L["Common_NoData"].Value; ViewData["FlowEmptyMessage"] = L["FlowComponents_EmptyMessage"].Value; }
    <partial name="Flow/_FlowEmptyState" />
  </div>
  <div class="flow-catalog-item">
    <div class="flow-metric-label">@L["FlowComponents_Skeleton"]</div>
    <div class="flow-skeleton" style="height:40px;margin-top:8px;"></div>
    <div class="flow-skeleton" style="height:12px;width:70%;margin-top:8px;"></div>
  </div>
  <div class="flow-catalog-item">
    <div class="flow-metric-label">@L["FlowComponents_ScorePills"]</div>
    <div style="display:flex;gap:6px;margin-top:8px;">
      <span class="flow-score-pill flow-score-pill--ok">88</span>
      <span class="flow-score-pill flow-score-pill--warn">52</span>
      <span class="flow-score-pill flow-score-pill--danger">21</span>
    </div>
  </div>
  <div class="flow-catalog-item" style="grid-column:1/-1;">
    <div class="flow-metric-label">@L["FlowComponents_KanbanCard"]</div>
    <article class="flow-kanban-card" style="max-width:240px;margin-top:8px;">
      <div class="flow-kanban-card-title">@L["FlowComponents_SampleDeal"]</div>
      <div class="flow-kanban-card-meta"><span>$48,000</span><span>72%</span></div>
      <div class="flow-kanban-prob"><span style="width:72%"></span></div>
    </article>
  </div>
</div>
