@page
@model AutonomusCRM.API.Pages.UsersModel
@{
    ViewData["Title"] = L["Users_PageTitle"].Value;
}

<!-- TOPBAR -->
<header class="topbar">
  <div class="topbar-left">
    <div class="kicker">@L["Users_Subtitle"]</div>
    <h2 class="headline">@L["Users_Headline"]</h2>
  </div>

  <div class="topbar-center">
    <form method="get" class="crm-filter-bar crm-filter-bar-full">
      <div class="search crm-grow" role="search">
        <input type="text" name="search" value="@Model.SearchTerm" placeholder="@L["Btn_Search"]…" aria-label="@L["Btn_Search"]" />
      </div>
      <button type="submit" class="btn crm-text-nowrap">@L["Btn_Search"]</button>
      @if (!string.IsNullOrWhiteSpace(Model.SearchTerm))
      {
        <a href="/Users" class="btn crm-text-nowrap crm-link-btn">@L["Btn_Clear"]</a>
      }
    </form>
  </div>

  <div class="topbar-right">
    <button class="btn mobile-toggle" type="button" onclick="toggleSidebar()">@L["Common_Menu"]</button>
    <button class="btn" type="button" onclick="showImportModal()">@L["Btn_Import"]</button>
    <a href="/Users/Create" class="btn primary crm-link-btn">@L["Users_NewUser"]</a>
  </div>
</header>

<!-- STATS -->
<section class="stats" aria-label="@L["Users_PageTitle"]">
  <div class="stat">
    <div class="label">@L["Users_Total"]</div>
    <div class="value">@Model.Summary.TotalCount</div>
    <div class="hint">
      <span>@L["Users_Registered"]</span>
      <span class="delta up">@Model.Summary.ActiveCount @L["Users_Active"]</span>
    </div>
  </div>

  <div class="stat">
    <div class="label">@L["Users_MfaEnabled"]</div>
    <div class="value">@Model.Summary.MfaCount</div>
    <div class="hint">
      <span>@(Model.Summary.TotalCount > 0 ? (Model.Summary.MfaCount * 100 / Model.Summary.TotalCount) : 0)%</span>
      <span class="delta up">@Model.Summary.MfaCount</span>
    </div>
  </div>

  <div class="stat">
    <div class="label">@L["Users_Active"]</div>
    <div class="value">@Model.Summary.ActiveCount</div>
    <div class="hint">
      <span>@L["Users_SystemList"]</span>
      <span class="delta up">@Model.Summary.TotalCount @L["Users_Total"]</span>
    </div>
  </div>

  <div class="stat">
    <div class="label">@L["Common_Role"]</div>
    <div class="value">@Model.Summary.WithRolesCount</div>
    <div class="hint">
      <span>@L["Users_Assigned"]</span>
      <span class="delta ok">✓</span>
    </div>
  </div>
</section>

<section class="grid">
  <!-- LEFT: Users Table -->
  <div class="card">
    <div class="card-h">
      <div>
        <h3 class="title">@L["Users_SystemList"]</h3>
        <p class="subtitle">@L["Users_Subtitle"]</p>
      </div>
      <span class="pill">@string.Format(L["Pagination_Records"].Value, Model.FilteredUsers.Count, Model.TotalCount)</span>
    </div>

    <div class="card-b">
      <table class="table" aria-label="@L["Users_SystemList"]">
        <thead>
          <tr>
            <th><input type="checkbox" id="selectAll" onclick="toggleSelectAll()" /></th>
            <th>@L["Users_ColumnUser"]</th>
            <th>@L["Common_Role"]</th>
            <th>@L["Users_MfaEnabled"]</th>
            <th>@L["Users_ColumnState"]</th>
            <th>@L["Common_Actions"]</th>
          </tr>
        </thead>
        <tbody>
          @if (Model.FilteredUsers.Any())
          {
            @foreach (var user in Model.FilteredUsers)
            {
              <tr>
                <td><input type="checkbox" name="userIds" value="@user.Id" /></td>
                <td>
                  <div class="crm-meta-strong">@user.Email</div>
                  <div class="crm-meta-muted">
                    @if (!string.IsNullOrEmpty(user.FirstName) || !string.IsNullOrEmpty(user.LastName))
                    {
                      <text>@($"{user.FirstName} {user.LastName}".Trim())</text>
                    }
                    else
                    {
                      <text>@L["Users_ColumnUser"]</text>
                    }
                  </div>
                </td>
                <td>
                  @if (user.Roles != null && user.Roles.Any())
                  {
                    <span class="badge @(user.Roles.Contains("Admin") ? "danger" : user.Roles.Contains("Manager") ? "warn" : "")">@string.Join(", ", user.Roles)</span>
                  }
                  else
                  {
                    <span class="badge">@L["Users_NoRole"]</span>
                  }
                </td>
                <td>
                  @if (user.MfaEnabled)
                  {
                    <span class="badge ok">@L["Integrations_Connected"]</span>
                  }
                  else
                  {
                    <span class="badge warn">@L["Integrations_Disconnected"]</span>
                  }
                </td>
                <td>
                  @if (user.IsActive)
                  {
                    <span class="badge ok">@L["Integrations_Connected"]</span>
                  }
                  else
                  {
                    <span class="badge">@L["Integrations_Disconnected"]</span>
                  }
                </td>
                <td>
                  <a href="/Users/Edit/@user.Id" class="btn crm-btn-compact crm-link-btn">@L["Btn_Edit"]</a>
                </td>
              </tr>
            }
          }
          else
          {
            <tr>
              <td colspan="5" class="crm-empty-cell">
                @if (!string.IsNullOrWhiteSpace(Model.SearchTerm))
                {
                  <text>@L["Common_NoResults"] <a href="/Users">@L["Btn_Clear"]</a></text>
                }
                else
                {
                  <text>@L["Common_NoData"] <a href="/Users/Create">@L["Btn_Create"]</a></text>
                }
              </td>
            </tr>
          }
        </tbody>
      </table>

      <div class="crm-toolbar-spacer"></div>

      <div class="crm-toolbar" style="justify-content:space-between; align-items:center; flex-wrap:wrap; gap:12px;">
        <div style="display:flex; gap:8px; flex-wrap:wrap;">
          <button class="btn" type="button" onclick="exportUsers()">@L["Btn_Export"]</button>
          <button class="btn" type="button" onclick="showBulkActionsModal()">@L["Users_BulkActions"]</button>
          <a href="/Users/Create" class="btn primary crm-link-btn">@L["Btn_Create"]</a>
        </div>
        <partial name="Shared/_CrmPagination" model='new AutonomusCRM.API.Pages.Shared.CrmPaginationModel { Page = Model.PageIndex, PageSize = Model.PageSize, TotalCount = Model.TotalCount, ShownCount = Model.FilteredUsers.Count, RecordsFormat = L["Pagination_Records"].Value, PageFormat = L["Pagination_Page"].Value, BuildUrl = Model.BuildPageUrl }' />
      </div>
    </div>
  </div>

  <!-- RIGHT: Roles & Permissions -->
  <aside class="stack">
    <div class="card">
      <div class="card-h">
        <div>
          <h3 class="title">@L["Users_Headline"]</h3>
          <p class="subtitle">@L["Users_Subtitle"]</p>
        </div>
        <span class="pill">@L["Users_RbacAbac"]</span>
      </div>
      <div class="card-b">
        <table class="table" aria-label="@L["Common_Role"]">
          <thead>
            <tr>
              <th>@L["Common_Role"]</th>
              <th>@L["Users_ColumnUser"]</th>
              <th>@L["Common_Actions"]</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>@L["Role_Admin"]</td>
              <td>3</td>
              <td><span class="badge ok">@L["Btn_View"]</span></td>
            </tr>
            <tr>
              <td>@L["Role_Manager"]</td>
              <td>8</td>
              <td><span class="badge warn">@L["Common_Actions"]</span></td>
            </tr>
            <tr>
              <td>@L["Role_Sales"]</td>
              <td>24</td>
              <td><span class="badge">@L["Policies_Sales"]</span></td>
            </tr>
            <tr>
              <td>@L["Role_Viewer"]</td>
              <td>12</td>
              <td><span class="badge">@L["Btn_View"]</span></td>
            </tr>
          </tbody>
        </table>

        <div class="crm-toolbar-spacer"></div>

        <a href="/Users/Roles" class="btn primary crm-btn-block">@L["Common_Role"]</a>
      </div>
    </div>

    <div class="card">
      <div class="card-h">
        <div>
          <h3 class="title">@L["Command_History"]</h3>
          <p class="subtitle">@L["Users_Subtitle"]</p>
        </div>
        <span class="pill">@string.Format(L["Command_LastPeriod"].Value, "24h")</span>
      </div>
      <div class="card-b">
        <div class="feed">
          <div class="item">
            <div class="itop">
              <div class="itag">@L["Command_History"]</div>
              <div class="itime">2 min</div>
            </div>
            <div class="ibody">
              admin@autonomuscrm.com — 192.168.1.100
            </div>
            <div class="ifooter">
              <span class="pill">MFA: ✓</span>
              <span class="pill">@L["Common_Status"]: OK</span>
            </div>
          </div>

          <div class="item">
            <div class="itop">
              <div class="itag">@L["Common_Actions"]</div>
              <div class="itime">8 min</div>
            </div>
            <div class="ibody">
              manager@autonomuscrm.com — Lead #342
            </div>
            <div class="ifooter">
              <span class="pill">@L["Common_Actions"]: ✓</span>
              <span class="pill">@L["Audit_PageTitle"]</span>
            </div>
          </div>
        </div>

        <div class="crm-toolbar-spacer"></div>

        <a href="/Audit" class="btn primary crm-btn-block crm-link-btn">@L["Audit_PageTitle"]</a>
      </div>
    </div>
  </aside>
</section>

<div class="crm-section-gap"></div>

<footer class="crm-footer-note">
  AUTONOMUS CRM · @L["Users_Subtitle"]
</footer>

<div id="importModal" class="crm-overlay-modal">
    <div class="card crm-overlay-card">
        <div class="card-h">
            <div>
                <h3 class="title">@L["Btn_Import"] @L["Users_PageTitle"]</h3>
            </div>
        </div>
        <div class="card-b">
            <form method="post" action="/Users/Import" enctype="multipart/form-data">
                <div class="crm-form-field">
                    <label>@L["Users_ImportFileLabel"]</label>
                    <input type="file" name="file" accept=".json,.csv" required class="crm-form-control" />
                    <div class="crm-form-help">
                        CSV: @L["Common_Email"], @L["Common_Name"]<br/>
                        @L["Users_ImportJsonHelp"]
                    </div>
                </div>
                <div class="crm-split-actions">
                    <button type="submit" class="btn primary">@L["Btn_Import"]</button>
                    <button type="button" class="btn" onclick="closeImportModal()">@L["Btn_Cancel"]</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
function exportUsers() {
    const users = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.FilteredUsers.Select(u => new { u.Id, u.Email, u.FirstName, u.LastName, Roles = u.Roles != null ? string.Join(", ", u.Roles) : "", u.MfaEnabled, u.IsActive })));
    const json = JSON.stringify(users, null, 2);
    const blob = new Blob([json], { type: 'application/json' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = 'users-' + new Date().toISOString().split('T')[0] + '.json';
    a.click();
    URL.revokeObjectURL(url);
}
function showImportModal() { window.crmModal.open('importModal'); }
function closeImportModal() { window.crmModal.close('importModal'); }
function showBulkActionsModal() {
    const selected = Array.from(document.querySelectorAll('input[type="checkbox"][name="userIds"]:checked')).map(cb => cb.value);
    if (selected.length === 0) {
        alert('@L["Users_BulkActions"]');
        return;
    }
    window.crmModal.open('bulkActionsModal');
    document.getElementById('selectedUserIds').value = selected.join(',');
}
function closeBulkActionsModal() {
    window.crmModal.close('bulkActionsModal');
}
function toggleSelectAll() {
    const selectAll = document.getElementById('selectAll');
    const checkboxes = document.querySelectorAll('input[type="checkbox"][name="userIds"]');
    checkboxes.forEach(cb => cb.checked = selectAll.checked);
}
</script>

<div id="bulkActionsModal" class="crm-overlay-modal">
    <div class="card crm-overlay-card">
        <div class="card-h">
            <div>
                <h3 class="title">@L["Users_BulkActions"]</h3>
            </div>
        </div>
        <div class="card-b">
            <form method="post" action="/Users/BulkActions">
                <input type="hidden" id="selectedUserIds" name="userIds" />
                <div class="crm-form-field">
                    <label>@L["Common_Actions"] *</label>
                    <select name="action" required class="crm-form-control">
                        <option value="activate">@L["Users_Active"]</option>
                        <option value="deactivate">@L["Integrations_Disconnected"]</option>
                    </select>
                </div>
                <div class="crm-split-actions">
                    <button type="submit" class="btn primary">@L["Btn_Save"]</button>
                    <button type="button" class="btn" onclick="closeBulkActionsModal()">@L["Btn_Cancel"]</button>
                </div>
            </form>
        </div>
    </div>
</div>
