@page "/FailedEvents"
@model AutonomusCRM.API.Pages.FailedEventsModel
@{
    ViewData["Title"] = L["Ops_FailedEvents_Title"].Value;
    ViewData["PageTitle"] = L["Ops_FailedEvents_Title"].Value;
    ViewData["PageKicker"] = L["Ops_FailedEvents_Kicker"].Value;
    ViewData["PageSubtitle"] = L["Ops_FailedEvents_Subtitle"].Value;
}
<partial name="Flow/_FlowPageHeader" />
@if (!string.IsNullOrEmpty(Model.Message)) { <div class="alert alert-success">@Model.Message</div> }

<section class="flow-card">
  <header class="flow-card-header"><h3 class="flow-card-title">@L["Ops_FailedEvents_MessagesTitle"]</h3></header>
  <div class="flow-card-body">
    @if (Model.Items.Count == 0)
    {
      <p class="text-muted">@L["Ops_FailedEvents_Empty"]</p>
    }
    else
    {
      <table class="flow-table">
        <thead><tr><th>@L["Ops_FailedEvents_Type"]</th><th>@L["Ops_FailedEvents_MessageId"]</th><th>@L["Ops_FailedEvents_Retries"]</th><th>@L["Ops_FailedEvents_FailedAt"]</th><th>@L["Ops_FailedEvents_Error"]</th><th></th></tr></thead>
        <tbody>
        @foreach (var e in Model.Items)
        {
          <tr>
            <td>@e.EventType</td>
            <td><code>@e.MessageId</code></td>
            <td>@e.RetryCount</td>
            <td>@e.FailedAt.ToString("g")</td>
            <td style="max-width:280px;font-size:12px;">@(e.LastError ?? "—")</td>
            <td>
              <form method="post" asp-page-handler="Replay" style="display:inline;">
                <input type="hidden" name="id" value="@e.Id" />
                <button type="submit" class="flow-btn flow-btn-secondary">@L["Ops_FailedEvents_Replay"]</button>
              </form>
            </td>
          </tr>
        }
        </tbody>
      </table>
    }
    <p class="text-muted" style="font-size:12px;margin-top:12px;">API: <code>/api/ops/failed-events</code></p>
  </div>
</section>
