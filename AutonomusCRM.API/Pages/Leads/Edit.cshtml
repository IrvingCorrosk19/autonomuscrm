@page "/Leads/Edit/{id:guid}"
@model AutonomusCRM.API.Pages.Leads.EditModel
@using AutonomusCRM.Domain.Leads
@{
    ViewData["Title"] = L["Leads_Edit_Kicker"].Value;
}

@if (Model.Lead == null)
{
    ViewData["EmptyIcon"] = "fas fa-user-slash";
    ViewData["EmptyTitle"] = L["Leads_Edit_NotFound"].Value;
    ViewData["EmptyMessage"] = L["Leads_Edit_NotFoundDesc"].Value;
    ViewData["EmptyActionHtml"] = $"<a href=\"/Leads\" class=\"flow-btn flow-btn-primary\">{L["Leads_Edit_BackTo"].Value}</a>";
    <partial name="Shared/_CrmEmptyState" />
}
else
{
    ViewData["PageTitle"] = Model.Lead.Name;
    ViewData["PageKicker"] = L["Leads_Edit_Kicker"].Value;
    ViewData["PageSubtitle"] = L["Leads_Edit_CardSubtitle"].Value;
    ViewData["PageActionsHtml"] = $"<a href=\"/Leads/Details/{Model.Lead.Id}\" class=\"flow-btn flow-btn-secondary\">{L["Btn_Cancel"].Value}</a>";

    <partial name="Flow/_FlowPageHeader" />
    <partial name="Shared/_FlowFormAlerts" />

    <section class="flow-card flow-form-card">
        <header class="flow-card-header">
            <h2 class="flow-card-title" id="lead-edit-title">@L["Leads_Edit_CardTitle"]</h2>
            <p class="flow-page-subtitle mb-0">@L["Leads_Edit_CardSubtitle"]</p>
        </header>
        <div class="flow-card-body">
            <form method="post" class="flow-form" aria-labelledby="lead-edit-title">
                <div class="flow-form-grid">
                    <div class="flow-form-field">
                        <label class="flow-form-label" for="lead-edit-name">@L["Form_NameRequired"]</label>
                        <input type="text" id="lead-edit-name" name="name" class="flow-form-control" value="@Model.Lead.Name" required autocomplete="name" />
                    </div>
                    <div class="flow-form-field">
                        <label class="flow-form-label" for="lead-edit-email">@L["Common_Email"]</label>
                        <input type="email" id="lead-edit-email" name="email" class="flow-form-control" value="@Model.Lead.Email" autocomplete="email" />
                    </div>
                    <div class="flow-form-field">
                        <label class="flow-form-label" for="lead-edit-phone">@L["Common_Phone"]</label>
                        <input type="tel" id="lead-edit-phone" name="phone" class="flow-form-control" value="@Model.Lead.Phone" autocomplete="tel" />
                    </div>
                    <div class="flow-form-field">
                        <label class="flow-form-label" for="lead-edit-company">@L["Form_Company"]</label>
                        <input type="text" id="lead-edit-company" name="company" class="flow-form-control" value="@Model.Lead.Company" autocomplete="organization" />
                    </div>
                    <div class="flow-form-field">
                        <label class="flow-form-label" for="lead-edit-source">@L["Form_SourceRequired"]</label>
                        <select id="lead-edit-source" name="source" class="flow-form-control" required>
                            @foreach (var source in Model.Sources)
                            {
                                <option value="@source.Value" selected="@source.Selected">@source.Text</option>
                            }
                        </select>
                    </div>
                    <div class="flow-form-field">
                        <label class="flow-form-label" for="lead-edit-status">@L["Common_Status"]</label>
                        <select id="lead-edit-status" name="status" class="flow-form-control">
                            <option value="">@L["Form_NoChange"]</option>
                            @foreach (var status in Model.Statuses)
                            {
                                <option value="@status.Value" selected="@status.Selected">@status.Text</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="flow-form-actions">
                    <button type="submit" class="flow-btn flow-btn-primary">@L["Form_SaveChanges"]</button>
                    <a href="/Leads/Details/@Model.Lead.Id" class="flow-btn flow-btn-secondary">@L["Btn_Cancel"]</a>
                </div>
            </form>
        </div>
    </section>

    <p class="flow-form-footer">@L["Leads_Edit_Footer"]</p>
}
