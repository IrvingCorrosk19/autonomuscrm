@page "/Leads/Details/{id:guid}"
@model AutonomusCRM.API.Pages.Leads.DetailsModel
@using AutonomusCRM.Domain.Leads
@{
    ViewData["Title"] = Model.Lead?.Name ?? "Lead";
    var statusClass = Model.Lead?.Status switch {
        LeadStatus.New => "status-new",
        LeadStatus.Contacted => "status-contacted",
        LeadStatus.Qualified => "status-qualified",
        LeadStatus.Converted => "status-converted",
        LeadStatus.Lost => "status-lost",
        _ => "status-unqualified"
    };
}

@if (Model.Lead == null)
{
  <div class="card">
    <div class="card-b text-center py-5">
      <h2 class="h4">Lead no encontrado</h2>
      <p class="text-muted">El registro no existe o fue eliminado.</p>
      <a href="/Leads" class="btn btn-primary mt-2">Volver a leads</a>
    </div>
  </div>
}
else
{
  ViewData["PageTitle"] = Model.Lead.Name;
  ViewData["PageKicker"] = "Detalle del lead";
  ViewData["PageSubtitle"] = Model.Lead.Company ?? Model.Lead.Email ?? "Sin empresa";
  ViewData["PageActionsHtml"] = $@"<a href=""/Leads"" class=""btn btn-outline-secondary""><i class=""fas fa-arrow-left mr-1""></i>Lista</a>
      <a href=""/Leads/Edit/{Model.Lead.Id}"" class=""btn btn-primary""><i class=""fas fa-edit mr-1""></i>Editar</a>";

  <partial name="_PageHeader" />

  <div class="row">
    <div class="col-lg-8">
      <div class="card">
        <div class="card-h">
          <h3 class="title">Información</h3>
          <span class="badge @statusClass">@Model.Lead.Status</span>
        </div>
        <div class="card-b">
          <dl class="crm-dl">
            <div class="row">
              <div class="col-sm-4"><dt>Email</dt></div>
              <div class="col-sm-8"><dd>@(Model.Lead.Email ?? "—")</dd></div>
            </div>
            <div class="row">
              <div class="col-sm-4"><dt>Teléfono</dt></div>
              <div class="col-sm-8"><dd>@(Model.Lead.Phone ?? "—")</dd></div>
            </div>
            <div class="row">
              <div class="col-sm-4"><dt>Empresa</dt></div>
              <div class="col-sm-8"><dd>@(Model.Lead.Company ?? "—")</dd></div>
            </div>
            <div class="row">
              <div class="col-sm-4"><dt>Fuente</dt></div>
              <div class="col-sm-8"><dd><span class="pill">@Model.Lead.Source</span></dd></div>
            </div>
            <div class="row">
              <div class="col-sm-4"><dt>Score</dt></div>
              <div class="col-sm-8">
                <dd>
                  @if (Model.Lead.Score.HasValue)
                  {
                    <span class="badge @(Model.Lead.Score >= 70 ? "ok" : Model.Lead.Score >= 50 ? "warn" : "danger")">@Model.Lead.Score</span>
                  }
                  else { <span class="text-muted">Sin puntuación</span> }
                </dd>
              </div>
            </div>
            <div class="row">
              <div class="col-sm-4"><dt>Creado</dt></div>
              <div class="col-sm-8"><dd>@Model.Lead.CreatedAt.ToString("dd/MM/yyyy HH:mm")</dd></div>
            </div>
            <div class="row">
              <div class="col-sm-4"><dt>ID</dt></div>
              <div class="col-sm-8"><dd><code class="small">@Model.Lead.Id</code></dd></div>
            </div>
          </dl>
        </div>
      </div>
    </div>

    <div class="col-lg-4">
      <div class="card">
        <div class="card-h"><h3 class="title">Acciones</h3></div>
        <div class="card-b">
          <form method="post" asp-page-handler="Qualify" class="mb-2">
            <input type="hidden" name="id" value="@Model.Lead.Id" />
            <button class="btn btn-success btn-block" type="submit" @(Model.Lead.Status == LeadStatus.Qualified ? "disabled" : null)>
              <i class="fas fa-check mr-1"></i> Calificar
            </button>
          </form>
          <form method="post" asp-page-handler="ConvertToCustomer" class="mb-2" onsubmit="return confirm('¿Convertir este lead a cliente?');">
            <input type="hidden" name="id" value="@Model.Lead.Id" />
            <button class="btn btn-primary btn-block" type="submit"><i class="fas fa-building mr-1"></i> Convertir a cliente</button>
          </form>
          <button class="btn btn-outline-secondary btn-block" type="button" onclick="showCreateDealModal()"><i class="fas fa-handshake mr-1"></i> Crear deal</button>
        </div>
      </div>

      <div class="card border-danger">
        <div class="card-h"><h3 class="title text-danger">Zona de peligro</h3></div>
        <div class="card-b">
          <form method="post" asp-page-handler="Delete" onsubmit="return confirm('¿Eliminar este lead? No se puede deshacer.');">
            <input type="hidden" name="id" value="@Model.Lead.Id" />
            <button type="submit" class="btn btn-danger btn-block"><i class="fas fa-trash mr-1"></i> Eliminar</button>
          </form>
        </div>
      </div>
    </div>
  </div>

  <div id="createDealModal" class="crm-modal-backdrop">
    <div class="crm-modal">
      <div class="crm-modal-header"><h3>Crear deal desde lead</h3></div>
      <div class="crm-modal-body">
        <form method="post" asp-page-handler="CreateDeal">
          <input type="hidden" name="id" value="@Model.Lead.Id" />
          <label class="form-label-crm">Título *</label>
          <input type="text" name="title" class="form-control mb-3" required />
          <label class="form-label-crm">Monto *</label>
          <input type="number" name="amount" class="form-control mb-3" required step="0.01" min="0" />
          <label class="form-label-crm">Descripción</label>
          <textarea name="description" class="form-control mb-3" rows="3"></textarea>
          <div class="crm-modal-footer px-0 pb-0">
            <button type="button" class="btn btn-outline-secondary" onclick="closeCreateDealModal()">Cancelar</button>
            <button type="submit" class="btn btn-primary">Crear deal</button>
          </div>
        </form>
      </div>
    </div>
  </div>
}

@section Scripts {
<script>
function showCreateDealModal() { document.getElementById('createDealModal')?.classList.add('show'); }
function closeCreateDealModal() { document.getElementById('createDealModal')?.classList.remove('show'); }
document.getElementById('createDealModal')?.addEventListener('click', e => { if (e.target.id === 'createDealModal') closeCreateDealModal(); });
</script>
}
