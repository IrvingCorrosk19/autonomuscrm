@page "/executive"
@model AutonomusCRM.API.Pages.ExecutiveModel
@{
    ViewData["Title"] = "Executive Intelligence";
    ViewData["PageTitle"] = "Executive Intelligence Center";
    ViewData["PageKicker"] = "CEO";
    ViewData["PageSubtitle"] = "¿Dónde pierdo y gano dinero? ¿Qué clientes y agentes generan valor?";
    var ai = Model.AiDashboard;
    var rev = Model.Revenue;
}
<partial name="Flow/_FlowPageHeader" />

@if (ai == null)
{
  <partial name="Flow/_FlowEmptyState" />
}
else
{
  <section class="flow-revenue-hero">
    <h2>Intelligence ejecutiva</h2>
    <div class="flow-metric-grid">
      @{ ViewData["FlowMetricLabel"] = "Clientes en riesgo"; ViewData["FlowMetricValue"] = ai.AtRiskCustomers.ToString(); ViewData["FlowMetricVariant"] = "warning"; }
      <partial name="Flow/_FlowMetricCard" />
      @{ ViewData["FlowMetricLabel"] = "Listos expansión"; ViewData["FlowMetricValue"] = ai.ExpansionReady.ToString(); ViewData["FlowMetricVariant"] = "success"; }
      <partial name="Flow/_FlowMetricCard" />
      @{ ViewData["FlowMetricLabel"] = "Decisiones pendientes"; ViewData["FlowMetricValue"] = ai.PendingDecisions.ToString(); ViewData["FlowMetricVariant"] = "danger"; }
      <partial name="Flow/_FlowMetricCard" />
      @{ ViewData["FlowMetricLabel"] = "Ejecutadas hoy"; ViewData["FlowMetricValue"] = ai.ExecutedToday.ToString(); ViewData["FlowMetricVariant"] = "ai"; }
      <partial name="Flow/_FlowMetricCard" />
      @if (rev != null) {
        ViewData["FlowMetricLabel"] = "Revenue generado (90d)"; ViewData["FlowMetricValue"] = "$" + rev.Overview.RevenueGenerated.ToString("N0"); ViewData["FlowMetricVariant"] = "success";
        <partial name="Flow/_FlowMetricCard" />
      }
    </div>
  </section>

  <div class="flow-revenue-grid">
    <section class="flow-card">
      <header class="flow-card-header"><h3 class="flow-card-title">¿Dónde pierdo dinero?</h3></header>
      <div class="flow-card-body">
        @if (rev != null && rev.WinLoss.Any())
        {
          <ul class="flow-revenue-list">@foreach (var w in rev.WinLoss.Take(5)) { <li><span>@w.Key</span><span>$@w.TotalAmount.ToString("N0")</span></li> }</ul>
        }
        else { <p class="text-muted">Sin pérdidas categorizadas aún.</p> }
      </div>
    </section>
    <section class="flow-card">
      <header class="flow-card-header"><h3 class="flow-card-title">¿Dónde gano dinero?</h3></header>
      <div class="flow-card-body">
        @if (rev != null)
        {
          <p>Revenue cerrado: <strong>$@rev.Kpis.RevenueClosed.ToString("N0")</strong></p>
          <p>Generado por IA: <strong>$@rev.Overview.RevenueGenerated.ToString("N0")</strong></p>
        }
      </div>
    </section>
    <section class="flow-card">
      <header class="flow-card-header"><h3 class="flow-card-title">Decisiones IA recientes</h3></header>
      <div class="flow-card-body flow-decision-feed">
        @foreach (var dec in ai.RecentDecisions.Take(8)) {
          ViewData["FlowDecisionType"] = dec.DecisionType;
          ViewData["FlowDecisionAction"] = dec.Action;
          ViewData["FlowDecisionScore"] = dec.Score;
          ViewData["FlowDecisionStatus"] = "executed";
          ViewData["FlowDecisionAt"] = DateTime.UtcNow;
          <partial name="Flow/_FlowDecisionCard" />
        }
      </div>
    </section>
    <section class="flow-card">
      <header class="flow-card-header"><h3 class="flow-card-title">Next Best Actions</h3></header>
      <div class="flow-card-body">
        <ul class="flow-revenue-list">
          @foreach (var n in ai.NextBestActions.Take(6)) {
            <li><span><strong>@n.EntityName</strong> — @n.RecommendedAction</span><span>@n.PriorityScore</span></li>
          }
        </ul>
      </div>
    </section>
  </div>
  <p class="mt-3"><a href="/revenue" class="flow-btn flow-btn-primary">Abrir Revenue OS</a> <a href="/TrustInbox" class="flow-btn flow-btn-secondary">Trust Studio</a></p>
}
