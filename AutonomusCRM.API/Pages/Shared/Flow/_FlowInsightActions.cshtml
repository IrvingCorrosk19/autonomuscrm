@using AutonomusCRM.API.Infrastructure
@{
    var insightType = ViewData["FlowInsightType"] as string ?? FlowInsightTypes.Risk;
    var customerId = ViewData["FlowInsightCustomerId"] as Guid?;
    var customerName = ViewData["FlowInsightCustomerName"] as string ?? "Cliente";
    var returnUrl = ViewData["FlowInsightReturnUrl"] as string ?? "/";
    var compact = ViewData["FlowInsightCompact"] as bool? ?? false;
    var recommendation = ViewData["FlowInsightRecommendation"] as string ?? FlowInsightTypes.DefaultRecommendation(insightType);
    var rationale = ViewData["FlowInsightRationale"] as string ?? "Insight ABOS — acción recomendada";
    var hasCustomer = customerId is Guid cid && cid != Guid.Empty;
}
<div class="flow-insight-actions @(compact ? "flow-insight-actions--compact" : "")" role="group" aria-label="Acciones para @customerName">
  @if (insightType == FlowInsightTypes.Risk && hasCustomer)
  {
    <form method="post" asp-page="/FlowActions" asp-page-handler="CreateTask" class="flow-insight-action-form">
      <input type="hidden" name="customerId" value="@customerId" />
      <input type="hidden" name="title" value="Retener: @customerName" />
      <input type="hidden" name="taskType" value="Retention" />
      <input type="hidden" name="returnUrl" value="@returnUrl" />
      <input type="hidden" name="insightType" value="@insightType" />
      <input type="hidden" name="recommendation" value="@recommendation" />
      <input type="hidden" name="rationale" value="@rationale" />
      @Html.AntiForgeryToken()
      <button type="submit" class="flow-btn flow-btn-primary flow-btn-sm">Crear tarea</button>
    </form>
    <details class="flow-insight-email">
      <summary class="flow-btn flow-btn-secondary flow-btn-sm">Enviar email</summary>
      <form method="post" asp-page="/FlowActions" asp-page-handler="SendEmail" class="flow-insight-email-form">
        <input type="hidden" name="customerId" value="@customerId" />
        <input type="hidden" name="returnUrl" value="@returnUrl" />
      <input type="hidden" name="insightType" value="@insightType" />
      <input type="hidden" name="recommendation" value="@recommendation" />
      <input type="hidden" name="rationale" value="@rationale" />
        <input type="text" name="subject" value="Seguimiento — @customerName" required aria-label="Asunto" />
        <textarea name="body" rows="2" required aria-label="Mensaje">Hola @customerName, queremos asegurarnos de que todo vaya bien con su cuenta.</textarea>
        @Html.AntiForgeryToken()
        <button type="submit" class="flow-btn flow-btn-primary flow-btn-sm">Enviar</button>
      </form>
    </details>
    <form method="post" asp-page="/FlowActions" asp-page-handler="CreateTask" class="flow-insight-action-form">
      <input type="hidden" name="customerId" value="@customerId" />
      <input type="hidden" name="title" value="Llamada de retención: @customerName" />
      <input type="hidden" name="taskType" value="Call" />
      <input type="hidden" name="returnUrl" value="@returnUrl" />
      <input type="hidden" name="insightType" value="@insightType" />
      <input type="hidden" name="recommendation" value="@recommendation" />
      <input type="hidden" name="rationale" value="@rationale" />
      @Html.AntiForgeryToken()
      <button type="submit" class="flow-btn flow-btn-secondary flow-btn-sm">Programar llamada</button>
    </form>
    <a href="/Deals/Create?customerId=@customerId&amp;title=@Uri.EscapeDataString($"Retención — {customerName}")&amp;amount=10000" class="flow-btn flow-btn-secondary flow-btn-sm">Crear oportunidad de retención</a>
    <form method="post" asp-page="/FlowActions" asp-page-handler="RequestApproval" class="flow-insight-action-form">
      <input type="hidden" name="customerId" value="@customerId" />
      <input type="hidden" name="returnUrl" value="@returnUrl" />
      <input type="hidden" name="insightType" value="@insightType" />
      <input type="hidden" name="recommendation" value="@recommendation" />
      <input type="hidden" name="rationale" value="@rationale" />
      @Html.AntiForgeryToken()
      <button type="submit" class="flow-btn flow-btn-secondary flow-btn-sm">Solicitar aprobación</button>
    </form>
  }
  else if (insightType == FlowInsightTypes.Expansion && hasCustomer)
  {
    <a href="/Deals/Create?customerId=@customerId&amp;title=@Uri.EscapeDataString($"Expansión — {customerName}")&amp;amount=25000" class="flow-btn flow-btn-primary flow-btn-sm">Crear oportunidad</a>
    <form method="post" asp-page="/FlowActions" asp-page-handler="CreateTask" class="flow-insight-action-form">
      <input type="hidden" name="customerId" value="@customerId" />
      <input type="hidden" name="title" value="Generar propuesta: @customerName" />
      <input type="hidden" name="taskType" value="Proposal" />
      <input type="hidden" name="returnUrl" value="@returnUrl" />
      <input type="hidden" name="insightType" value="@insightType" />
      <input type="hidden" name="recommendation" value="@recommendation" />
      <input type="hidden" name="rationale" value="@rationale" />
      @Html.AntiForgeryToken()
      <button type="submit" class="flow-btn flow-btn-secondary flow-btn-sm">Generar propuesta</button>
    </form>
    <form method="post" asp-page="/FlowActions" asp-page-handler="CreateTask" class="flow-insight-action-form">
      <input type="hidden" name="customerId" value="@customerId" />
      <input type="hidden" name="title" value="Reunión de expansión: @customerName" />
      <input type="hidden" name="taskType" value="Meeting" />
      <input type="hidden" name="returnUrl" value="@returnUrl" />
      <input type="hidden" name="insightType" value="@insightType" />
      <input type="hidden" name="recommendation" value="@recommendation" />
      <input type="hidden" name="rationale" value="@rationale" />
      @Html.AntiForgeryToken()
      <button type="submit" class="flow-btn flow-btn-secondary flow-btn-sm">Programar reunión</button>
    </form>
    <details class="flow-insight-email">
      <summary class="flow-btn flow-btn-secondary flow-btn-sm">Enviar email</summary>
      <form method="post" asp-page="/FlowActions" asp-page-handler="SendEmail" class="flow-insight-email-form">
        <input type="hidden" name="customerId" value="@customerId" />
        <input type="hidden" name="returnUrl" value="@returnUrl" />
      <input type="hidden" name="insightType" value="@insightType" />
      <input type="hidden" name="recommendation" value="@recommendation" />
      <input type="hidden" name="rationale" value="@rationale" />
        <input type="text" name="subject" value="Oportunidad de expansión — @customerName" required aria-label="Asunto" />
        <textarea name="body" rows="2" required aria-label="Mensaje">Hola @customerName, identificamos oportunidades para ampliar su plan.</textarea>
        @Html.AntiForgeryToken()
        <button type="submit" class="flow-btn flow-btn-primary flow-btn-sm">Enviar</button>
      </form>
    </details>
  }
  else if (insightType == FlowInsightTypes.Renewal && hasCustomer)
  {
    <form method="post" asp-page="/FlowActions" asp-page-handler="CreateTask" class="flow-insight-action-form">
      <input type="hidden" name="customerId" value="@customerId" />
      <input type="hidden" name="title" value="Preparar renovación: @customerName" />
      <input type="hidden" name="taskType" value="Renewal" />
      <input type="hidden" name="returnUrl" value="@returnUrl" />
      <input type="hidden" name="insightType" value="@insightType" />
      <input type="hidden" name="recommendation" value="@recommendation" />
      <input type="hidden" name="rationale" value="@rationale" />
      @Html.AntiForgeryToken()
      <button type="submit" class="flow-btn flow-btn-primary flow-btn-sm">Crear tarea</button>
    </form>
    <a href="/Deals/Create?customerId=@customerId&amp;title=@Uri.EscapeDataString($"Renovación — {customerName}")&amp;amount=15000" class="flow-btn flow-btn-secondary flow-btn-sm">Crear renovación</a>
    <details class="flow-insight-email">
      <summary class="flow-btn flow-btn-secondary flow-btn-sm">Contactar cliente</summary>
      <form method="post" asp-page="/FlowActions" asp-page-handler="SendEmail" class="flow-insight-email-form">
        <input type="hidden" name="customerId" value="@customerId" />
        <input type="hidden" name="returnUrl" value="@returnUrl" />
      <input type="hidden" name="insightType" value="@insightType" />
      <input type="hidden" name="recommendation" value="@recommendation" />
      <input type="hidden" name="rationale" value="@rationale" />
        <input type="text" name="subject" value="Renovación próxima — @customerName" required aria-label="Asunto" />
        <textarea name="body" rows="2" required aria-label="Mensaje">Hola @customerName, su contrato se acerca a renovación. ¿Agendamos una llamada?</textarea>
        @Html.AntiForgeryToken()
        <button type="submit" class="flow-btn flow-btn-primary flow-btn-sm">Enviar</button>
      </form>
    </details>
    <form method="post" asp-page="/FlowActions" asp-page-handler="RequestApproval" class="flow-insight-action-form">
      <input type="hidden" name="customerId" value="@customerId" />
      <input type="hidden" name="returnUrl" value="@returnUrl" />
      <input type="hidden" name="insightType" value="@insightType" />
      <input type="hidden" name="recommendation" value="@recommendation" />
      <input type="hidden" name="rationale" value="@rationale" />
      @Html.AntiForgeryToken()
      <button type="submit" class="flow-btn flow-btn-secondary flow-btn-sm">Solicitar aprobación</button>
    </form>
  }
  else if (insightType == FlowInsightTypes.RevenueAtRisk)
  {
    <a href="/Customer360" class="flow-btn flow-btn-primary flow-btn-sm">Ver clientes afectados</a>
    <form method="post" asp-page="/FlowActions" asp-page-handler="CreatePlan" class="flow-insight-action-form">
      <input type="hidden" name="title" value="Plan de recuperación de revenue" />
      <input type="hidden" name="returnUrl" value="@returnUrl" />
      <input type="hidden" name="insightType" value="@insightType" />
      <input type="hidden" name="recommendation" value="@recommendation" />
      <input type="hidden" name="rationale" value="@rationale" />
      @Html.AntiForgeryToken()
      <button type="submit" class="flow-btn flow-btn-secondary flow-btn-sm">Crear plan</button>
    </form>
    <a href="/Tasks" class="flow-btn flow-btn-secondary flow-btn-sm">Asignar responsable</a>
  }
</div>
