@model AutonomusCRM.Application.KnowledgeGraph.DecisionIntelligenceResultDto?
@if (Model == null)
{
  <p class="text-muted" style="font-size:13px;">@L["Explain_NoAnalysis"]</p>
}
else
{
  <div class="flow-explainability">
    <p><strong>@L["Explain_WhatHappened"]</strong> @Model.WhatHappened</p>
    <p><strong>@L["Explain_Why"]</strong> @Model.WhyItHappened</p>
    <p><strong>@L["Explain_RecommendedAction"]</strong> @Model.RecommendedAction</p>
    <p><strong>@L["Explain_Risk"]</strong> @Model.RiskAssessment · <strong>@L["Explain_Impact"]</strong> @Model.EconomicImpactEstimate</p>
    <p><strong>@L["Explain_HitlRequired"]</strong> @(Model.RequiresHumanApproval ? L["Explain_Yes"].Value : L["Explain_No"].Value)</p>
    @if (Model.Evidence.Count > 0)
    {
      <ul class="flow-list-minimal">
        @foreach (var e in Model.Evidence.Take(6))
        {
          <li>@e</li>
        }
      </ul>
    }
  </div>
}
