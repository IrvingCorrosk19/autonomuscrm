@page
@model AutonomusCRM.API.Pages.DealsModel
@using AutonomusCRM.Domain.Deals
@{
    ViewData["Title"] = L["Deals_PageTitle"].Value;
    ViewData["PageTitle"] = L["Deals_PageTitle"].Value;
    ViewData["PageKicker"] = L["Nav_Section_Revenue"].Value;
    ViewData["PageSubtitle"] = L["Deals_Subtitle"].Value;
    ViewData["PageActionsHtml"] = "<a href=\"/Deals/Create\" class=\"flow-btn flow-btn-primary\">" + L["Deals_NewDeal"].Value + "</a>";

    var openStages = new[] { DealStage.Prospecting, DealStage.Qualification, DealStage.Proposal, DealStage.Negotiation };
    var closedStages = new[] { DealStage.ClosedWon, DealStage.ClosedLost };
    var pipelineOpen = Model.FilteredDeals.Where(d => d.Status == DealStatus.Open).Sum(d => d.Amount);
}

<partial name="Flow/_FlowPageHeader" />

@if (TempData["Message"] != null)
{
  <div class="alert alert-success">@TempData["Message"]</div>
}

<div class="crm-filter-card">
  <form method="get" class="crm-filter-form">
    <div class="form-group" style="flex:2 1 200px;">
      <label for="search">@L["Btn_Search"]</label>
      <input type="text" id="search" name="search" class="form-control" value="@Model.SearchTerm" placeholder="Título del deal..." />
    </div>
    <div class="form-group">
      <label for="status">@L["Common_Status"]</label>
      <select id="status" name="status" class="form-control">
        <option value="">@L["Common_All"]</option>
        @foreach (var status in Enum.GetValues<DealStatus>())
        {
          <option value="@((int)status)" selected="@(Model.FilterStatus == status)">@status</option>
        }
      </select>
    </div>
    <div class="crm-filter-actions">
      <button type="submit" class="flow-btn flow-btn-primary">@L["Btn_Filter"]</button>
      @if (!string.IsNullOrWhiteSpace(Model.SearchTerm) || Model.FilterStatus.HasValue)
      {
        <a href="/Deals" class="flow-btn flow-btn-secondary">@L["Btn_Clear"]</a>
      }
    </div>
  </form>
</div>

<section class="flow-metric-grid" aria-label="Forecast pipeline">
  @{ ViewData["FlowMetricLabel"] = L["Deals_OpenPipeline"].Value; ViewData["FlowMetricValue"] = "$" + pipelineOpen.ToString("N0"); ViewData["FlowMetricHint"] = $"{Model.FilteredDeals.Count(d => d.Status == DealStatus.Open)} deals"; ViewData["FlowMetricVariant"] = "info"; }
  <partial name="Flow/_FlowMetricCard" />
  @{ ViewData["FlowMetricLabel"] = "Forecast 30d"; ViewData["FlowMetricValue"] = "$" + Model.Forecast30.ToString("N0"); ViewData["FlowMetricVariant"] = "ai"; }
  <partial name="Flow/_FlowMetricCard" />
  @{ ViewData["FlowMetricLabel"] = "Forecast 60d"; ViewData["FlowMetricValue"] = "$" + Model.Forecast60.ToString("N0"); ViewData["FlowMetricVariant"] = "neutral"; }
  <partial name="Flow/_FlowMetricCard" />
  @{ ViewData["FlowMetricLabel"] = "Win rate"; ViewData["FlowMetricValue"] = Model.WinRate.ToString("F1") + "%"; ViewData["FlowMetricHint"] = "Revenue cerrado $" + Model.RevenueClosed.ToString("N0"); ViewData["FlowMetricVariant"] = "success"; }
  <partial name="Flow/_FlowMetricCard" />
</section>

@if (!Model.Deals.Any())
{
  ViewData["FlowEmptyTitle"] = L["Deals_EmptyPipeline"].Value;
  ViewData["FlowEmptyMessage"] = L["Shared_FlowEmptyMessage"].Value;
  ViewData["FlowEmptyCta"] = L["Deals_NewDeal"].Value;
  ViewData["FlowEmptyCtaHref"] = "/Deals/Create";
  <partial name="Flow/_FlowEmptyState" />
}
else if (!Model.FilteredDeals.Any())
{
  ViewData["FlowEmptyTitle"] = L["Common_NoResults"].Value;
  ViewData["FlowEmptyMessage"] = L["Leads_NoResults"].Value;
  ViewData["FlowEmptyCta"] = L["Btn_Clear"].Value;
  ViewData["FlowEmptyCtaHref"] = "/Deals";
  <partial name="Flow/_FlowEmptyState" />
}
else
{
  <section class="flow-card mt-4">
    <header class="flow-card-header">
      <h3 class="flow-card-title">@L["Deals_Kanban"]</h3>
      <p class="text-muted mb-0" style="font-size:13px;">Arrastra deals entre etapas · @Model.FilteredDeals.Count registros</p>
    </header>
    <div class="flow-card-body" style="padding:var(--flow-space-3);">
      <div class="flow-kanban" id="flow-deals-kanban" data-tenant-id="@Model.TenantId" aria-label="Pipeline kanban">
        @foreach (var stage in openStages)
        {
          var stageDeals = Model.FilteredDeals.Where(d => d.Stage == stage && d.Status == DealStatus.Open).ToList();
          var sum = stageDeals.Sum(d => d.Amount);
          <div class="flow-kanban-column">
            <div class="flow-kanban-column-header">
              @stage
              <small>$@sum.ToString("N0") · @stageDeals.Count deals</small>
            </div>
            <div class="flow-kanban-dropzone" data-stage="@((int)stage)">
              @foreach (var deal in stageDeals)
              {
                var prob = deal.Probability ?? 0;
                <article class="flow-kanban-card" data-deal-id="@deal.Id" data-probability="@prob">
                  <div class="flow-kanban-card-title"><a href="/Deals/Details/@deal.Id">@deal.Title</a></div>
                  <div class="flow-kanban-card-meta"><span>$@deal.Amount.ToString("N0")</span><span>@prob%</span></div>
                  <div class="flow-kanban-prob"><span style="width:@prob%"></span></div>
                </article>
              }
            </div>
          </div>
        }
        @foreach (var stage in closedStages)
        {
          var stageDeals = Model.FilteredDeals.Where(d => d.Stage == stage).Take(12).ToList();
          <div class="flow-kanban-column">
            <div class="flow-kanban-column-header">
              @stage
              <small>@stageDeals.Count deals</small>
            </div>
            <div class="flow-kanban-dropzone" data-stage="@((int)stage)">
              @foreach (var deal in stageDeals)
              {
                <article class="flow-kanban-card" style="cursor:default;" data-deal-id="@deal.Id">
                  <div class="flow-kanban-card-title"><a href="/Deals/Details/@deal.Id">@deal.Title</a></div>
                  <div class="flow-kanban-card-meta"><span>$@deal.Amount.ToString("N0")</span></div>
                </article>
              }
            </div>
          </div>
        }
      </div>
    </div>
  </section>

  <section class="flow-card mt-4" data-flow-datatable>
    <header class="flow-card-header"><h3 class="flow-card-title">@L["Deals_PageTitle"]</h3></header>
    <div class="flow-datatable-toolbar">
      <input type="search" class="flow-datatable-search" placeholder="@L["Btn_Search"]…" aria-label="@L["Btn_Search"]" />
    </div>
    <div class="flow-card-body flow-crm-table-wrap" style="padding:0;">
      <table class="flow-table-minimal flow-datatable" aria-label="Deals">
        <thead><tr><th>Deal</th><th>Stage</th><th>Amount</th><th>Prob.</th><th>@L["Common_Status"]</th></tr></thead>
        <tbody>
          @foreach (var deal in Model.FilteredDeals.OrderByDescending(d => d.Amount))
          {
            var search = $"{deal.Title} {deal.Stage} {deal.Status}".ToLowerInvariant();
            var body = $"Monto ${deal.Amount:N0} · {deal.Stage} · Prob {deal.Probability ?? 0}% · {deal.Status}";
            <tr data-search="@search" data-drawer-title="@deal.Title" data-drawer-body="@body" data-drawer-href="/Deals/Details/@deal.Id">
              <td><a href="/Deals/Details/@deal.Id">@deal.Title</a></td>
              <td>@deal.Stage</td>
              <td>$@deal.Amount.ToString("N0")</td>
              <td>@(deal.Probability ?? 0)%</td>
              <td>@deal.Status</td>
            </tr>
          }
        </tbody>
      </table>
    </div>
  </section>
}

@section Scripts {
<script src="~/js/flow-worldclass.js" asp-append-version="true"></script>
}
