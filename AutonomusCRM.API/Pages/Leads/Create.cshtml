@page "/Leads/Create"
@model AutonomusCRM.API.Pages.Leads.CreateModel
@{
    ViewData["Title"] = L["Leads_Create_Title"].Value;
    Layout = "~/Pages/Shared/_Layout.cshtml";
}

<header class="topbar">
  <div class="topbar-left">
    <div class="kicker">@L["Leads_Create_Kicker"]</div>
    <h2 class="headline">@L["Leads_Create_Title"]</h2>
  </div>

  <div class="topbar-right">
    <button class="btn mobile-toggle" type="button" onclick="toggleSidebar()">@L["Common_Menu"]</button>
    <a href="/Leads" class="btn">@L["Btn_Cancel"]</a>
  </div>
</header>

<section class="grid">
  <div class="card" style="max-width: 800px; margin: 0 auto;">
    <div class="card-h">
      <div>
        <h3 class="title">@L["Leads_Create_CardTitle"]</h3>
        <p class="subtitle">@L["Leads_Create_CardSubtitle"]</p>
      </div>
    </div>

    <div class="card-b">
      @if (!string.IsNullOrEmpty(Model.ErrorMessage))
      {
        <div style="background: rgba(255, 0, 0, 0.1); border: 1px solid rgba(255, 0, 0, 0.3); padding: 15px; border-radius: 4px; margin-bottom: 20px; color: #ff6b6b;">
          <strong>@L["Common_Error"]</strong> @Model.ErrorMessage
        </div>
      }

      @if (Model.SuccessMessage != null)
      {
        <div class="alert alert-success"><i class="fas fa-check mr-1"></i>@Model.SuccessMessage</div>
      }

      <form method="post" asp-page-handler="Create">
        <div style="margin-bottom: 20px;">
          <label style="display: block; margin-bottom: 8px; font-weight: 600; color: var(--text);">
            @L["Form_FullNameRequired"]
          </label>
          <input 
            type="text" 
            name="name" 
            required 
            value="@Model.Name"
            placeholder="@L["Leads_Create_PlaceholderName"]"
            style="width: 100%; padding: 12px; border: 1px solid rgba(255,255,255,0.1); background: var(--bg); color: var(--text); border-radius: 4px; font-size: 14px;" 
          />
        </div>

        <div style="margin-bottom: 20px;">
          <label style="display: block; margin-bottom: 8px; font-weight: 600; color: var(--text);">
            @L["Common_Email"]
          </label>
          <input 
            type="email" 
            name="email" 
            value="@Model.Email"
            placeholder="@L["Leads_Create_PlaceholderEmail"]"
            style="width: 100%; padding: 12px; border: 1px solid rgba(255,255,255,0.1); background: var(--bg); color: var(--text); border-radius: 4px; font-size: 14px;" 
          />
        </div>

        <div style="margin-bottom: 20px;">
          <label style="display: block; margin-bottom: 8px; font-weight: 600; color: var(--text);">
            @L["Common_Phone"]
          </label>
          <input 
            type="tel" 
            name="phone" 
            value="@Model.Phone"
            placeholder="@L["Leads_Create_PlaceholderPhone"]"
            style="width: 100%; padding: 12px; border: 1px solid rgba(255,255,255,0.1); background: var(--bg); color: var(--text); border-radius: 4px; font-size: 14px;" 
          />
        </div>

        <div style="margin-bottom: 20px;">
          <label style="display: block; margin-bottom: 8px; font-weight: 600; color: var(--text);">
            @L["Form_Company"]
          </label>
          <input 
            type="text" 
            name="company" 
            value="@Model.Company"
            placeholder="@L["Leads_Create_PlaceholderCompany"]"
            style="width: 100%; padding: 12px; border: 1px solid rgba(255,255,255,0.1); background: var(--bg); color: var(--text); border-radius: 4px; font-size: 14px;" 
          />
        </div>

        <div style="margin-bottom: 25px;">
          <label style="display: block; margin-bottom: 8px; font-weight: 600; color: var(--text);">
            @L["Form_SourceRequired"]
          </label>
          <select 
            name="source" 
            required 
            style="width: 100%; padding: 12px; border: 1px solid rgba(255,255,255,0.1); background: var(--bg); color: var(--text); border-radius: 4px; font-size: 14px;"
          >
            <option value="">@L["Form_SelectSource"]</option>
            <option value="Website" selected="@(Model.Source == "Website")">@L["LeadSource_Website"]</option>
            <option value="Referral" selected="@(Model.Source == "Referral")">@L["LeadSource_Referral"]</option>
            <option value="SocialMedia" selected="@(Model.Source == "SocialMedia")">@L["LeadSource_SocialMedia"]</option>
            <option value="EmailCampaign" selected="@(Model.Source == "EmailCampaign")">@L["LeadSource_EmailCampaign"]</option>
            <option value="ColdCall" selected="@(Model.Source == "ColdCall")">@L["LeadSource_ColdCall"]</option>
            <option value="Partner" selected="@(Model.Source == "Partner")">@L["LeadSource_Partner"]</option>
            <option value="Event" selected="@(Model.Source == "Event")">@L["LeadSource_Event"]</option>
            <option value="Other" selected="@(Model.Source == "Other")">@L["LeadSource_Other"]</option>
          </select>
        </div>

        <div style="display: flex; gap: 12px; margin-top: 30px;">
          <button type="submit" class="btn primary" style="flex: 1; padding: 12px;">
            @L["Leads_Create_Submit"]
          </button>
          <a href="/Leads" class="btn" style="flex: 1; padding: 12px; text-align: center; text-decoration: none;">
            @L["Btn_Cancel"]
          </a>
        </div>
      </form>
    </div>
  </div>
</section>

<div style="height: 14px"></div>

<footer style="color: rgba(255,255,255,0.55); font-size: 12px; padding: 8px 2px;">
  @L["Leads_Create_Footer"]
</footer>
