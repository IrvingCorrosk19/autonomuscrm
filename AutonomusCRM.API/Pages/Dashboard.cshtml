@page
@model AutonomusCRM.API.Pages.DashboardModel
@{
    ViewData["Title"] = L["Dashboard_PageTitle"].Value;
}

<header class="topbar crm-dashboard-toolbar">
  <div class="topbar-left">
    <div class="kicker">@L["Dashboard_Kicker"]</div>
    <h2 class="headline">@L["Dashboard_Title"]</h2>
  </div>

  <div class="topbar-center">
    <div class="search" role="search">
      <input type="text" placeholder="@L["Dashboard_SearchPlaceholder"]" aria-label="@L["Dashboard_SearchAria"]" />
      <span class="chip">@L["Dashboard_Filters"]</span>
      <span class="chip">@L["Dashboard_Segments"]</span>
    </div>
  </div>

  <div class="topbar-right">
    <button class="btn mobile-toggle" type="button" onclick="toggleSidebar()">@L["Common_Menu"]</button>
    <button class="btn" type="button">@L["Dashboard_ApproveActions"]</button>
    <a href="/Leads/Create" class="btn primary">@L["Leads_NewLead"]</a>
  </div>
</header>

<section class="stats" aria-label="@L["Dashboard_KeyMetricsAria"]">
  <div class="stat">
    <div class="label">@L["Dashboard_NewLeads"]</div>
    <div class="value">128</div>
    <div class="hint">
      <span>@L["Dashboard_Last24h"]</span>
      <span class="delta up">+18%</span>
    </div>
  </div>

  <div class="stat">
    <div class="label">@L["Dashboard_Conversion"]</div>
    <div class="value">14.2%</div>
    <div class="hint">
      <span>@L["Dashboard_CurrentWeek"]</span>
      <span class="delta up">+2.1%</span>
    </div>
  </div>

  <div class="stat">
    <div class="label">@L["Dashboard_RiskDeals"]</div>
    <div class="value">9</div>
    <div class="hint">
      <span>@L["Dashboard_DetectedByAi"]</span>
      <span class="delta down">+3</span>
    </div>
  </div>

  <div class="stat">
    <div class="label">@L["Dashboard_EstimatedRevenue"]</div>
    <div class="value">$ 84,900</div>
    <div class="hint">
      <span>@L["Dashboard_CurrentMonth"]</span>
      <span class="delta up">+12%</span>
    </div>
  </div>
</section>

<section class="grid">
  <div class="card">
    <div class="card-h">
      <div>
        <h3 class="title">@L["Dashboard_SmartPipeline"]</h3>
        <p class="subtitle">@L["Dashboard_PipelineSubtitle"]</p>
      </div>
      <span class="pill">@L["Dashboard_UpdatedAgo"]</span>
    </div>

    <div class="card-b">
      <div class="pipeline" aria-label="@L["Dashboard_PipelineStagesAria"]">
        <div class="stage">
          <div class="head">
            <div class="name">@L["Dashboard_StageProspecting"]</div>
            <div class="sum">$ 22,400</div>
          </div>
          <div class="deal">
            <div class="dtitle">Canal B2B · 15 cuentas</div>
            <div class="dmeta"><span>Prioridad: Alta</span><span>IA: Seguimiento</span></div>
            <div class="bar"><span style="width:62%"></span></div>
          </div>
        </div>

        <div class="stage">
          <div class="head">
            <div class="name">@L["Dashboard_StageQualification"]</div>
            <div class="sum">$ 18,200</div>
          </div>
          <div class="deal">
            <div class="dtitle">Empresa: Comercio X</div>
            <div class="dmeta"><span>Riesgo: Bajo</span><span>IA: Propuesta</span></div>
            <div class="bar"><span style="width:58%"></span></div>
          </div>
        </div>

        <div class="stage">
          <div class="head">
            <div class="name">@L["Dashboard_StageProposal"]</div>
            <div class="sum">$ 28,700</div>
          </div>
          <div class="deal">
            <div class="dtitle">Renovación anual</div>
            <div class="dmeta"><span>Riesgo: Medio</span><span>IA: Ajustar precio</span></div>
            <div class="bar"><span style="width:71%"></span></div>
          </div>
        </div>

        <div class="stage">
          <div class="head">
            <div class="name">@L["Dashboard_StageClosing"]</div>
            <div class="sum">$ 15,600</div>
          </div>
          <div class="deal">
            <div class="dtitle">Contrato listo</div>
            <div class="dmeta"><span>Riesgo: Bajo</span><span>IA: Enviar</span></div>
            <div class="bar"><span style="width:82%"></span></div>
          </div>
        </div>
      </div>

      <div class="crm-section-gap"></div>

      <table class="table" aria-label="@L["Dashboard_AiActionsAria"]">
        <thead>
          <tr>
            <th>@L["Dashboard_Recommendation"]</th>
            <th>@L["Dashboard_Entity"]</th>
            <th>@L["Dashboard_Impact"]</th>
            <th>@L["Common_Status"]</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>Enviar propuesta personalizada con objeciones resueltas</td>
            <td>Deal · Renovación anual</td>
            <td><span class="badge ok">@L["Dashboard_High"]</span></td>
            <td><span class="badge">@L["Dashboard_Pending"]</span></td>
          </tr>
          <tr>
            <td>Agendar llamada de calificación (15 min) con preguntas clave</td>
            <td>Lead · Inbound</td>
            <td><span class="badge warn">@L["Dashboard_Medium"]</span></td>
            <td><span class="badge">@L["Dashboard_Pending"]</span></td>
          </tr>
        </tbody>
      </table>

      <div style="height:12px"></div>

      <div class="crm-toolbar">
        <button class="btn" type="button">@L["Dashboard_ViewDetails"]</button>
        <button class="btn" type="button">@L["Dashboard_SimulateActions"]</button>
        <button class="btn primary" type="button">@L["Dashboard_ApproveBatch"]</button>
        <span class="crm-density-toggle" role="group" aria-label="@L["Dashboard_DensityAria"]">
          <button type="button" class="active">@L["Dashboard_DensityCompact"]</button>
          <button type="button">@L["Dashboard_DensityComfortable"]</button>
        </span>
      </div>
    </div>
  </div>

  <aside class="stack">
    <div class="card">
      <div class="card-h">
        <div>
          <h3 class="title">@L["Dashboard_AiControlCenter"]</h3>
          <p class="subtitle">@L["Dashboard_AiControlSubtitle"]</p>
        </div>
        <span class="pill">@L["Dashboard_ModeSupervised"]</span>
      </div>
      <div class="card-b">
        <div class="feed">
          <div class="item">
            <div class="itop">
              <div class="itag">DECISIÓN</div>
              <div class="itime">Hace 3 min</div>
            </div>
            <div class="ibody">
              Se priorizó "Renovación anual" por alta probabilidad de cierre y alto impacto mensual.
            </div>
            <div class="ifooter">
              <span class="pill">Confianza: 0.82</span>
              <span class="pill">Motivo: historial + timing</span>
            </div>
          </div>

          <div class="item">
            <div class="itop">
              <div class="itag">ALERTA</div>
              <div class="itime">Hace 8 min</div>
            </div>
            <div class="ibody">
              "Pago pendiente" presenta riesgo alto por ausencia de respuesta y plazo cercano.
            </div>
            <div class="ifooter">
              <span class="pill">Confianza: 0.77</span>
              <span class="pill">Acción: recordatorio</span>
            </div>
          </div>
        </div>

        <div class="crm-toolbar-spacer"></div>

        <div class="crm-toolbar">
          <button class="btn" type="button">@L["Dashboard_ChangeMode"]</button>
          <button class="btn" type="button">@L["Dashboard_ViewAudit"]</button>
          <button class="btn primary" type="button">@L["Dashboard_AdjustPolicies"]</button>
        </div>
      </div>
    </div>

    <div class="card">
      <div class="card-h">
        <div>
          <h3 class="title">@L["Dashboard_CustomerExperience"]</h3>
          <p class="subtitle">@L["Dashboard_CustomerExperienceSubtitle"]</p>
        </div>
        <span class="pill">@L["Dashboard_Last7Days"]</span>
      </div>
      <div class="card-b">
        <table class="table" aria-label="@L["Dashboard_CustomerExperience"]">
          <thead>
            <tr>
              <th>@L["Dashboard_Indicator"]</th>
              <th>@L["Dashboard_Value"]</th>
              <th>@L["Common_Status"]</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>@L["Dashboard_ResponseTime"]</td>
              <td>12 min</td>
              <td><span class="badge ok">@L["Dashboard_Good"]</span></td>
            </tr>
            <tr>
              <td>@L["Dashboard_EstimatedSatisfaction"]</td>
              <td>4.6 / 5</td>
              <td><span class="badge ok">@L["Dashboard_Good"]</span></td>
            </tr>
            <tr>
              <td>@L["Dashboard_ReopenedTickets"]</td>
              <td>3</td>
              <td><span class="badge warn">@L["Dashboard_Attention"]</span></td>
            </tr>
          </tbody>
        </table>

        <div class="crm-toolbar-spacer"></div>

        <button class="btn primary crm-btn-block" type="button">@L["Dashboard_AutoImprovementPlan"]</button>
      </div>
    </div>
  </aside>
</section>

<div class="crm-section-gap"></div>

<footer class="crm-footer-note">
  @L["Dashboard_Footer"]
</footer>
