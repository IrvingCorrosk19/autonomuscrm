@page
@model IndexModel
@using AutonomusCRM.API.Infrastructure
@{
    ViewData["Title"] = "Flow Command";
    ViewData["PageTitle"] = "Flow Command";
    ViewData["PageKicker"] = "Command";
    ViewData["PageSubtitle"] = "Supervise ingresos, decisiones autónomas y workforce en tiempo real.";
    var f = Model.Flow;
    var d = f?.Dashboard;
    var periodLabel = f?.PeriodDays == 30 ? "30 días" : "7 días";
}
<partial name="Flow/_FlowPageHeader" />

@if (f == null || d == null)
{
  ViewData["FlowEmptyTitle"] = "Espacio de trabajo no configurado";
  ViewData["FlowEmptyMessage"] = "Inicie sesión con un tenant válido para ver Flow Command.";
  <partial name="Flow/_FlowEmptyState" />
}
else if (!f.HasData)
{
  <section class="flow-command-hero">
    <h2>AutonomusFlow está listo para operar</h2>
    <p>Aún no hay decisiones autónomas en los últimos @periodLabel.</p>
    <div class="flow-command-hero-actions">
      @if (d.PendingApprovals > 0)
      {
        <a href="/TrustInbox" class="flow-btn flow-btn-primary">Revisar @d.PendingApprovals decisiones</a>
      }
      <a href="/Agents" class="flow-btn flow-btn-secondary">Workforce</a>
    </div>
  </section>
  ViewData["FlowEmptyTitle"] = "Sin actividad autónoma";
  ViewData["FlowEmptyMessage"] = "Las métricas aparecerán cuando el motor autónomo registre auditorías.";
  ViewData["FlowEmptyCta"] = "Trust Studio";
  ViewData["FlowEmptyCtaHref"] = "/TrustInbox";
  <partial name="Flow/_FlowEmptyState" />
}
else
{
  <section class="flow-command-hero" aria-labelledby="flow-hero-title">
    <form method="get" style="margin-bottom:12px;">
      <select name="period" class="flow-period-select" onchange="this.form.submit()">
        @if (f.PeriodDays == 7) { <option value="7" selected>7 días</option> } else { <option value="7">7 días</option> }
        @if (f.PeriodDays == 30) { <option value="30" selected>30 días</option> } else { <option value="30">30 días</option> }
      </select>
    </form>
    <h2 id="flow-hero-title">
      Generó <span class="flow-hero-amount">$@f.RevenueGeneratedPeriod.ToString("N0")</span>
      · Protegió <span class="flow-hero-amount">$@f.RevenueProtectedPeriod.ToString("N0")</span>
      <small style="display:block;font-weight:500;opacity:0.85;margin-top:6px;">Últimos @periodLabel</small>
    </h2>
    <p>@d.DecisionsLast24h decisiones (24h) · @d.BusinessOutcomesLast7d outcomes (7d)
      @(d.PendingApprovals > 0 ? $" · {d.PendingApprovals} pendientes" : "")</p>
    <div class="flow-command-hero-actions">
      @if (d.PendingApprovals > 0) { <a href="/TrustInbox" class="flow-btn flow-btn-primary">Revisar decisiones</a> }
      <a href="/command/decisions" class="flow-btn flow-btn-secondary">Historial</a>
      <a href="/command/outcomes" class="flow-btn flow-btn-secondary">Outcomes</a>
    </div>
  </section>

  <div class="flow-command-grid">
    <div class="flow-command-left">
      <section class="flow-card">
        <header class="flow-card-header"><div><h3 class="flow-card-title">Ingresos en riesgo</h3></div></header>
        <div class="flow-card-body">
          <partial name="Flow/_FlowSparkline" model="f.ChurnSparkline" view-data="@(new ViewDataDictionary(ViewData) { { "FlowSparklineLabel", "Churn" } })" />
          @if (d.AtRiskCustomers.Count == 0) { <p class="text-muted mb-0">Sin cuentas en riesgo.</p> }
          else {
            @foreach (var c in d.AtRiskCustomers) {
              <div class="flow-insight-row">
                <div class="flow-insight-row-head">
                  <span><strong>@c.Name</strong><br/><small>@c.Reason</small></span>
                  <span class="flow-revenue-priority">@c.PriorityScore</span>
                </div>
                @{
                  ViewData["FlowInsightType"] = FlowInsightTypes.Risk;
                  ViewData["FlowInsightCustomerId"] = c.CustomerId;
                  ViewData["FlowInsightCustomerName"] = c.Name;
                  ViewData["FlowInsightReturnUrl"] = "/";
                  ViewData["FlowInsightCompact"] = true;
                }
                <partial name="Flow/_FlowInsightActions" />
              </div>
            }
          }
        </div>
      </section>
      <section class="flow-card">
        <header class="flow-card-header"><h3 class="flow-card-title">Expansión</h3></header>
        <div class="flow-card-body">
          <partial name="Flow/_FlowSparkline" model="f.ExpansionSparkline" view-data="@(new ViewDataDictionary(ViewData) { { "FlowSparklineLabel", "Expansion" } })" />
          @if (d.ExpansionTargets.Count == 0) { <p class="text-muted mb-0">Sin targets.</p> }
          else {
            @foreach (var c in d.ExpansionTargets) {
              <div class="flow-insight-row">
                <div class="flow-insight-row-head">
                  <span><strong>@c.Name</strong></span>
                  <span class="flow-revenue-priority">@c.PriorityScore</span>
                </div>
                @{
                  ViewData["FlowInsightType"] = FlowInsightTypes.Expansion;
                  ViewData["FlowInsightCustomerId"] = c.CustomerId;
                  ViewData["FlowInsightCustomerName"] = c.Name;
                  ViewData["FlowInsightReturnUrl"] = "/";
                  ViewData["FlowInsightCompact"] = true;
                }
                <partial name="Flow/_FlowInsightActions" />
              </div>
            }
          }
        </div>
      </section>
      <section class="flow-card">
        <header class="flow-card-header"><h3 class="flow-card-title">Renovaciones</h3></header>
        <div class="flow-card-body">
          <partial name="Flow/_FlowSparkline" model="f.RenewalSparkline" view-data="@(new ViewDataDictionary(ViewData) { { "FlowSparklineLabel", "Renewals" } })" />
          @if (d.RenewalTargets.Count == 0) { <p class="text-muted mb-0">Sin renovaciones.</p> }
          else {
            @foreach (var c in d.RenewalTargets) {
              <div class="flow-insight-row">
                <div class="flow-insight-row-head">
                  <span><strong>@c.Name</strong></span>
                  <span class="flow-revenue-priority">@c.PriorityScore</span>
                </div>
                @{
                  ViewData["FlowInsightType"] = FlowInsightTypes.Renewal;
                  ViewData["FlowInsightCustomerId"] = c.CustomerId;
                  ViewData["FlowInsightCustomerName"] = c.Name;
                  ViewData["FlowInsightReturnUrl"] = "/";
                  ViewData["FlowInsightCompact"] = true;
                }
                <partial name="Flow/_FlowInsightActions" />
              </div>
            }
          }
        </div>
      </section>
    </div>

    <div class="flow-command-right">
      <section class="flow-card">
        <header class="flow-card-header">
          <div><h3 class="flow-card-title">Workforce</h3><p class="flow-card-subtitle">6 agentes · datos reales</p></div>
          <a href="/Agents" class="flow-btn flow-btn-secondary" style="font-size:12px;">Ver todo</a>
        </header>
        <div class="flow-card-body">
          <div class="flow-workforce-grid">
            @foreach (var agent in f.Workforce) { <partial name="Flow/_FlowAgentCard" model="agent" /> }
          </div>
        </div>
      </section>
      <section class="flow-card">
        <header class="flow-card-header"><h3 class="flow-card-title">Decisiones en vivo</h3></header>
        <div class="flow-card-body">
          <div class="flow-decision-feed">
            @if (d.RecentDecisions.Count == 0) { <p class="text-muted">Sin decisiones.</p> }
            @foreach (var dec in d.RecentDecisions) {
              ViewData["FlowDecisionType"] = dec.DecisionType;
              ViewData["FlowDecisionAction"] = dec.Action;
              ViewData["FlowDecisionScore"] = dec.Score;
              ViewData["FlowDecisionStatus"] = dec.Status;
              ViewData["FlowDecisionAt"] = dec.CreatedAt;
              <partial name="Flow/_FlowDecisionCard" />
            }
          </div>
        </div>
      </section>
    </div>
  </div>

  <div class="flow-command-bottom">
    <section class="flow-card">
      <header class="flow-card-header"><h3 class="flow-card-title">Pipeline snapshot</h3></header>
      <div class="flow-card-body">
        @if (f.PipelineSnapshot.Count == 0) { <p class="text-muted">Sin pipeline abierto.</p> }
        else {
          <div class="flow-pipeline-mini">
            @foreach (var s in f.PipelineSnapshot) {
              <div class="flow-pipeline-col"><strong>@s.StageName</strong>@s.DealCount deals · $@s.Amount.ToString("N0")</div>
            }
          </div>
        }
      </div>
    </section>
    <section class="flow-card">
      <header class="flow-card-header">
        <div><h3 class="flow-card-title">Outcome Fabric</h3><p class="flow-card-subtitle">@d.IncompleteOutcomeFabric incompletas</p></div>
        <a href="/command/outcomes">Ver</a>
      </header>
      <div class="flow-card-body">
        <partial name="Flow/_FlowSparkline" model="f.RevenueSparkline" view-data="@(new ViewDataDictionary(ViewData) { { "FlowSparklineLabel", "Revenue" } })" />
        @if (f.IncompleteOutcomes.Count == 0) { <p class="text-muted">Sin cadenas pendientes.</p> }
        @foreach (var chain in f.IncompleteOutcomes.Take(3)) { <partial name="Flow/_FlowOutcomeChain" model="chain" /><hr style="margin:12px 0;border:0;border-top:1px solid var(--flow-border-subtle);" /> }
      </div>
    </section>
  </div>
}
