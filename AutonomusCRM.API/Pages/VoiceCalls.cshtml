@page
@model AutonomusCRM.API.Pages.VoiceCallsModel
@{
    ViewData["Title"] = L["VoiceCalls_PageTitle"].Value;
    ViewData["PageTitle"] = L["VoiceCalls_PageTitle"].Value;
    ViewData["PageKicker"] = L["Nav_Section_Platform"].Value;
    ViewData["PageSubtitle"] = L["Voice_RegisterCall"].Value;
}
<partial name="Flow/_FlowPageHeader" />

<section class="flow-card">
  <header class="flow-card-header"><h3 class="flow-card-title">@L["Voice_RegisterCall"]</h3></header>
  <div class="flow-card-body">
    <form method="post" asp-page-handler="LogCall" class="flow-settings-row">
      @Html.AntiForgeryToken()
      <div><label>@L["Voice_Phone"]</label><input asp-for="PhoneNumber" class="form-control" required /></div>
      <div><label>@L["Voice_Direction"]</label><select asp-for="Direction" class="form-control"><option>outbound</option><option>inbound</option></select></div>
      <div><label>@L["Voice_Duration"]</label><input asp-for="DurationSeconds" type="number" class="form-control" /></div>
      <div><label>@L["Command_DecisionOutcome"]</label><select asp-for="Outcome" class="form-control"><option>connected</option><option>voicemail</option><option>no_answer</option><option>failed</option></select></div>
      <div style="grid-column:1/-1;"><label>@L["Common_Message"]</label><input asp-for="Notes" class="form-control" /></div>
      <div><button type="submit" class="flow-btn flow-btn-primary">@L["Voice_RegisterCall"]</button></div>
    </form>
  </div>
</section>

<section class="flow-card mt-4" data-flow-datatable>
  <header class="flow-card-header">
    <h3 class="flow-card-title">@L["Voice_History"]</h3>
    <p class="text-muted mb-0" style="font-size:13px;">@Model.Calls.Count</p>
  </header>
  @if (!Model.Calls.Any())
  {
    ViewData["FlowEmptyTitle"] = L["Voice_NoCalls"].Value;
    ViewData["FlowEmptyMessage"] = L["Voice_RegisterCall"].Value;
    <partial name="Flow/_FlowEmptyState" />
  }
  else
  {
    <div class="flow-datatable-toolbar">
      <input type="search" class="flow-datatable-search" placeholder="@L["Voice_SearchPlaceholder"]" aria-label="@L["Voice_SearchPlaceholder"]" />
    </div>
    <div class="flow-card-body flow-crm-table-wrap" style="padding:0;">
      <table class="flow-table-minimal flow-datatable">
        <thead><tr><th>@L["Voice_Phone"]</th><th>@L["Voice_Direction"]</th><th>@L["Voice_Duration"]</th><th>@L["Command_DecisionOutcome"]</th><th>@L["Common_Customer"]</th><th>@L["Command_DecisionDate"]</th><th>@L["Common_Details"]</th><th>@L["Agents_Subtitle"]</th></tr></thead>
        <tbody>
          @foreach (var c in Model.Calls)
          {
            var search = $"{c.PhoneNumber} {c.CustomerName} {c.DealTitle} {c.Outcome}".ToLowerInvariant();
            <tr data-search="@search">
              <td>@c.PhoneNumber</td>
              <td>@c.Direction</td>
              <td>@c.DurationSeconds s</td>
              <td>@c.Outcome</td>
              <td>@(c.CustomerName ?? "—")</td>
              <td>@c.StartedAt.ToString("g")</td>
              <td>@c.TranscriptStatus</td>
              <td>@(string.IsNullOrWhiteSpace(c.AiSummary) ? "—" : c.AiSummary)</td>
            </tr>
          }
        </tbody>
      </table>
    </div>
  }
</section>

@section Scripts {
<script src="~/js/flow-worldclass.js" asp-append-version="true"></script>
}
