@page "/Deals/Create"
@model AutonomusCRM.API.Pages.Deals.CreateModel
@using AutonomusCRM.Application.Customers.Queries
@{
    ViewData["Title"] = L["Deals_Create_Title"].Value;
    Layout = "~/Pages/Shared/_Layout.cshtml";
}

<header class="topbar">
  <div class="topbar-left">
    <div class="kicker">@L["Deals_Create_Kicker"]</div>
    <h2 class="headline">@L["Deals_Create_Title"]</h2>
  </div>

  <div class="topbar-right">
    <button class="btn mobile-toggle" type="button" onclick="toggleSidebar()">@L["Common_Menu"]</button>
    <a href="/Deals" class="btn">@L["Btn_Cancel"]</a>
  </div>
</header>

<section class="grid">
  <div class="card" style="max-width: 800px; margin: 0 auto;">
    <div class="card-h">
      <div>
        <h3 class="title">@L["Deals_Create_CardTitle"]</h3>
        <p class="subtitle">@L["Deals_Create_CardSubtitle"]</p>
      </div>
    </div>

    <div class="card-b">
      @if (!string.IsNullOrEmpty(Model.ErrorMessage))
      {
        <div style="background: rgba(255, 0, 0, 0.1); border: 1px solid rgba(255, 0, 0, 0.3); padding: 15px; border-radius: 4px; margin-bottom: 20px; color: #ff6b6b;">
          <strong>@L["Common_Error"]</strong> @Model.ErrorMessage
        </div>
      }

      @if (Model.SuccessMessage != null)
      {
        <div class="alert alert-success"><i class="fas fa-check mr-1"></i>@Model.SuccessMessage</div>
      }

      <form method="post" asp-page-handler="Create">
        <div style="margin-bottom: 20px;">
          <label style="display: block; margin-bottom: 8px; font-weight: 600; color: var(--text);">
            @L["Common_Customer"] *
          </label>
          <select 
            name="customerId" 
            required 
            style="width: 100%; padding: 12px; border: 1px solid rgba(255,255,255,0.1); background: var(--bg); color: var(--text); border-radius: 4px; font-size: 14px;"
          >
            <option value="">@L["Form_SelectCustomer"]</option>
            @foreach (var customer in Model.Customers)
            {
              <option value="@customer.Id" selected="@(Model.CustomerId == customer.Id)">@customer.Name @(!string.IsNullOrEmpty(customer.Company) ? $"({customer.Company})" : "")</option>
            }
          </select>
          @if (!Model.Customers.Any())
          {
            <p style="color: var(--muted); font-size: 12px; margin-top: 5px;">
              @L["Deals_Create_NoCustomers"] <a href="/Customers/Create" style="color: var(--primary);">@L["Deals_Create_CreateCustomerFirst"]</a>
            </p>
          }
        </div>

        <div style="margin-bottom: 20px;">
          <label style="display: block; margin-bottom: 8px; font-weight: 600; color: var(--text);">
            @L["Form_TitleRequired"]
          </label>
          <input 
            type="text" 
            name="title" 
            required 
            value="@Model.Title"
            placeholder="@L["Deals_Create_PlaceholderTitle"]"
            style="width: 100%; padding: 12px; border: 1px solid rgba(255,255,255,0.1); background: var(--bg); color: var(--text); border-radius: 4px; font-size: 14px;" 
          />
        </div>

        <div style="margin-bottom: 20px;">
          <label style="display: block; margin-bottom: 8px; font-weight: 600; color: var(--text);">
            @L["Form_AmountRequired"]
          </label>
          <input 
            type="number" 
            name="amount" 
            step="0.01" 
            min="0" 
            required 
            value="@Model.Amount"
            placeholder="@L["Deals_Create_PlaceholderAmount"]"
            style="width: 100%; padding: 12px; border: 1px solid rgba(255,255,255,0.1); background: var(--bg); color: var(--text); border-radius: 4px; font-size: 14px;" 
          />
        </div>

        <div style="margin-bottom: 25px;">
          <label style="display: block; margin-bottom: 8px; font-weight: 600; color: var(--text);">
            @L["Form_Description"]
          </label>
          <textarea 
            name="description" 
            rows="4" 
            placeholder="@L["Deals_Create_PlaceholderDesc"]"
            style="width: 100%; padding: 12px; border: 1px solid rgba(255,255,255,0.1); background: var(--bg); color: var(--text); border-radius: 4px; font-size: 14px; resize: vertical;"
          >@Model.Description</textarea>
        </div>

        <div style="display: flex; gap: 12px; margin-top: 30px;">
          <button type="submit" class="btn primary" style="flex: 1; padding: 12px;" @(!Model.Customers.Any() ? "disabled" : "")>
            @L["Deals_Create_Submit"]
          </button>
          <a href="/Deals" class="btn" style="flex: 1; padding: 12px; text-align: center; text-decoration: none;">
            @L["Btn_Cancel"]
          </a>
        </div>
      </form>
    </div>
  </div>
</section>

<div style="height: 14px"></div>

<footer style="color: rgba(255,255,255,0.55); font-size: 12px; padding: 8px 2px;">
  @L["Deals_Create_Footer"]
</footer>
