@page "/Users/Create"
@model AutonomusCRM.API.Pages.Users.CreateModel
@{
    ViewData["Title"] = L["Users_Create_Title"].Value;
    ViewData["PageTitle"] = L["Users_Create_Title"].Value;
    ViewData["PageKicker"] = L["Users_Create_Kicker"].Value;
    ViewData["PageSubtitle"] = L["Users_Create_CardSubtitle"].Value;
    ViewData["PageActionsHtml"] = $"<a href=\"/Users\" class=\"flow-btn flow-btn-secondary\">{L["Btn_Cancel"].Value}</a>";
}

<partial name="Flow/_FlowPageHeader" />
<partial name="Shared/_FlowFormAlerts" />

<section class="flow-card flow-form-card">
    <header class="flow-card-header">
        <h2 class="flow-card-title" id="user-create-title">@L["Users_Create_CardTitle"]</h2>
        <p class="flow-page-subtitle mb-0">@L["Users_Create_CardSubtitle"]</p>
    </header>
    <div class="flow-card-body">
        <form method="post" class="flow-form" aria-labelledby="user-create-title">
            <div class="flow-form-grid">
                <div class="flow-form-field flow-form-field--full">
                    <label class="flow-form-label" for="user-create-email">@L["Common_Email"] @L["Common_RequiredStar"]</label>
                    <input type="email" id="user-create-email" name="email" class="flow-form-control" required placeholder="@L["Users_Create_PlaceholderEmail"]" autocomplete="email" />
                </div>
                <div class="flow-form-field flow-form-field--full">
                    <label class="flow-form-label" for="user-create-password">@L["Form_PasswordRequired"]</label>
                    <input type="password" id="user-create-password" name="password" class="flow-form-control" required minlength="8" placeholder="@L["Form_PasswordMin"]" autocomplete="new-password" aria-describedby="user-create-password-hint" />
                    <span id="user-create-password-hint" class="flow-form-help">@L["Form_PasswordMin"]</span>
                </div>
                <div class="flow-form-field">
                    <label class="flow-form-label" for="user-create-first">@L["Form_FirstName"]</label>
                    <input type="text" id="user-create-first" name="firstName" class="flow-form-control" placeholder="@L["Form_FirstName"]" autocomplete="given-name" />
                </div>
                <div class="flow-form-field">
                    <label class="flow-form-label" for="user-create-last">@L["Form_LastName"]</label>
                    <input type="text" id="user-create-last" name="lastName" class="flow-form-control" placeholder="@L["Form_LastName"]" autocomplete="family-name" />
                </div>
            </div>
            <div class="flow-comms-banner flow-comms-banner--ok" role="note">
                <strong>@L["Common_Note"]</strong> @L["Users_Create_Note"]
            </div>
            <div class="flow-form-actions">
                <button type="submit" class="flow-btn flow-btn-primary">@L["Users_Create_Submit"]</button>
                <a href="/Users" class="flow-btn flow-btn-secondary">@L["Btn_Cancel"]</a>
            </div>
        </form>
    </div>
</section>

<p class="flow-form-footer">@L["Users_Create_Footer"]</p>
