@page "/revenue"
@model AutonomusCRM.API.Pages.RevenueModel
@{
    ViewData["Title"] = "Revenue OS";
    ViewData["PageTitle"] = "Revenue OS";
    ViewData["PageKicker"] = "Revenue Intelligence";
    ViewData["PageSubtitle"] = "Ingresos generados, protegidos, en riesgo y predicción ejecutiva.";
    var d = Model.Dashboard;
    var o = d?.Overview;
}
<partial name="Flow/_FlowPageHeader" />

@if (d == null || o == null)
{
  <partial name="Flow/_FlowEmptyState" />
}
else if (!d.HasData)
{
  ViewData["FlowEmptyTitle"] = "Revenue OS en espera de datos";
  ViewData["FlowEmptyMessage"] = "Conecte integraciones y deje que los agentes autónomos registren outcomes para ver inteligencia de ingresos.";
  ViewData["FlowEmptyCta"] = "Flow Command";
  ViewData["FlowEmptyCtaHref"] = "/";
  <partial name="Flow/_FlowEmptyState" />
}
else
{
  <section class="flow-revenue-hero">
    <h2>Executive Revenue Overview</h2>
    <div class="flow-metric-grid">
      @{ ViewData["FlowMetricLabel"] = "Generado"; ViewData["FlowMetricValue"] = "$" + o.RevenueGenerated.ToString("N0"); ViewData["FlowMetricVariant"] = "success"; }
      <partial name="Flow/_FlowMetricCard" />
      @{ ViewData["FlowMetricLabel"] = "Protegido"; ViewData["FlowMetricValue"] = "$" + o.RevenueProtected.ToString("N0"); ViewData["FlowMetricVariant"] = "info"; }
      <partial name="Flow/_FlowMetricCard" />
      @{ ViewData["FlowMetricLabel"] = "En riesgo"; ViewData["FlowMetricValue"] = "$" + o.RevenueAtRisk.ToString("N0"); ViewData["FlowMetricVariant"] = "warning"; }
      <partial name="Flow/_FlowMetricCard" />
      @{ ViewData["FlowMetricLabel"] = "Expansión"; ViewData["FlowMetricValue"] = "$" + o.RevenueExpansion.ToString("N0"); ViewData["FlowMetricVariant"] = "ai"; }
      <partial name="Flow/_FlowMetricCard" />
      @{ ViewData["FlowMetricLabel"] = "Renovaciones"; ViewData["FlowMetricValue"] = "$" + o.RevenueRenewals.ToString("N0"); ViewData["FlowMetricVariant"] = "neutral"; }
      <partial name="Flow/_FlowMetricCard" />
      @{ ViewData["FlowMetricLabel"] = "Perdido"; ViewData["FlowMetricValue"] = "$" + o.RevenueLost.ToString("N0"); ViewData["FlowMetricVariant"] = "danger"; }
      <partial name="Flow/_FlowMetricCard" />
      @{ ViewData["FlowMetricLabel"] = "Recuperado"; ViewData["FlowMetricValue"] = "$" + o.RevenueRecovered.ToString("N0"); ViewData["FlowMetricVariant"] = "success"; }
      <partial name="Flow/_FlowMetricCard" />
    </div>
  </section>

  <div class="flow-revenue-grid">
    <section class="flow-card">
      <header class="flow-card-header"><h3 class="flow-card-title">Revenue Health</h3></header>
      <div class="flow-card-body flow-health-scores">
        <div><span>Health</span><strong>@d.Health.HealthScore</strong></div>
        <div><span>Stability</span><strong>@d.Health.StabilityScore</strong></div>
        <div><span>Risk Index</span><strong>@d.Health.RiskIndex</strong></div>
        <div><span>Expansion</span><strong>@d.Health.ExpansionIndex</strong></div>
        <div><span>Renewal confidence</span><strong>@d.Health.RenewalConfidence</strong></div>
      </div>
    </section>

    <section class="flow-card">
      <header class="flow-card-header"><h3 class="flow-card-title">Forecasting</h3></header>
      <div class="flow-card-body">
        <p class="text-muted" style="font-size:13px;">Confianza modelo: @d.Forecast.ConfidencePercent%</p>
        <table class="flow-table-minimal">
          <thead><tr><th>Horizonte</th><th>Revenue</th><th>Renewals</th><th>Churn</th><th>Expansion</th></tr></thead>
          <tbody>
            @foreach (var h in d.Forecast.Horizons)
            {
              <tr>
                <td>@h.HorizonDays d</td>
                <td>$@h.PredictedRevenue.ToString("N0")</td>
                <td>$@h.PredictedRenewals.ToString("N0")</td>
                <td>@h.PredictedChurnCount</td>
                <td>$@h.PredictedExpansion.ToString("N0")</td>
              </tr>
            }
          </tbody>
        </table>
      </div>
    </section>
  </div>

  <section class="flow-card mt-4">
    <header class="flow-card-header"><h3 class="flow-card-title">Executive Insights</h3></header>
    <div class="flow-card-body">
      @if (d.Insights.Count == 0) { <p class="text-muted">Sin insights prioritarios.</p> }
      <ul class="flow-revenue-list">
        @foreach (var i in d.Insights)
        {
          <li><span><span class="flow-revenue-priority">@i.Category</span> <strong>@i.Title</strong><br/><small>@i.Detail</small></span><span>@i.Priority</span></li>
        }
      </ul>
    </div>
  </section>

  <section class="flow-card mt-4">
    <header class="flow-card-header"><h3 class="flow-card-title">Outcome Fabric — Attribution</h3></header>
    <div class="flow-card-body" style="padding:0;">
      @if (d.AttributionChains.Count == 0) { <p class="p-4 text-muted">Sin cadenas de outcome.</p> }
      else {
        <table class="flow-table-minimal">
          <thead><tr><th>Fecha</th><th>Decision</th><th>Action</th><th>Estado</th><th>Revenue</th><th>Learning</th></tr></thead>
          <tbody>
            @foreach (var a in d.AttributionChains)
            {
              <tr>
                <td>@a.CreatedAt.ToString("g")</td>
                <td>@a.DecisionType</td>
                <td>@a.Action</td>
                <td>@a.Status</td>
                <td>@(a.RevenueImpact.HasValue ? $"${a.RevenueImpact:N0}" : "—")</td>
                <td>@a.LearningStatus</td>
              </tr>
            }
          </tbody>
        </table>
      }
    </div>
  </section>

  <div class="flow-revenue-grid mt-4">
    <section class="flow-card">
      <header class="flow-card-header"><h3 class="flow-card-title">Win / Loss Center</h3></header>
      <div class="flow-card-body">
        <p><strong>Ganados:</strong> @d.WinBreakdown.Sum(w => w.Count) deals · $@d.Kpis.RevenueClosed.ToString("N0")</p>
        @if (d.WinLoss.Count == 0) { <p class="text-muted">Sin pérdidas registradas.</p> }
        else {
          <table class="flow-table-minimal">
            <thead><tr><th>Razón</th><th>Count</th><th>Monto</th><th>%</th></tr></thead>
            <tbody>
              @foreach (var w in d.WinLoss) {
                <tr><td>@w.Key</td><td>@w.Count</td><td>$@w.TotalAmount.ToString("N0")</td><td>@w.PercentOfLosses.ToString("F1")%</td></tr>
              }
            </tbody>
          </table>
        }
      </div>
    </section>
    <section class="flow-card">
      <header class="flow-card-header"><h3 class="flow-card-title">KPIs Revenue</h3></header>
      <div class="flow-card-body flow-health-scores">
        <div><span>Win rate</span><strong>@d.Kpis.WinRate%</strong></div>
        <div><span>Deal size</span><strong>$@d.Kpis.AverageDealSize.ToString("N0")</strong></div>
        <div><span>Coverage</span><strong>@d.Kpis.PipelineCoveragePercent%</strong></div>
        <div><span>Conversión</span><strong>@d.Kpis.ConversionRate%</strong></div>
      </div>
    </section>
  </div>

  @if (Model.RevenueExplanation != null)
  {
    <section class="flow-card mt-4">
      <header class="flow-card-header">
        <h3 class="flow-card-title">¿Por qué sube/baja el revenue?</h3>
        <span class="text-muted" style="font-size:12px;">Graph reasoning — @Model.RevenueExplanation.ProviderBadge</span>
      </header>
      <div class="flow-card-body">
        <p>@Model.RevenueExplanation.Summary</p>
        @if (Model.RevenueExplanation.Evidence.Count > 0)
        {
          <ul class="flow-list-minimal">
            @foreach (var e in Model.RevenueExplanation.Evidence.Take(8)) { <li>@e</li> }
          </ul>
        }
        <p class="text-muted" style="font-size:12px;">API: <code>/api/reasoning/revenue/leak</code></p>
      </div>
    </section>
  }
}
