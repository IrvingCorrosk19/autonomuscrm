@page
@model AutonomusCRM.API.Pages.TrustInboxModel
@{
    ViewData["Title"] = "Trust";
    ViewData["PageTitle"] = "Trust Inbox";
    ViewData["PageKicker"] = "Command";
    ViewData["PageSubtitle"] = "Human-in-the-loop: aprueba, rechaza o revierte decisiones autónomas antes de impacto real.";
}
<partial name="Flow/_FlowPageHeader" />
<div class="flow-page-body">
    @if (!string.IsNullOrEmpty(Model.Message)) { <div class="alert alert-success">@Model.Message</div> }
    @if (!string.IsNullOrEmpty(Model.Error)) { <div class="alert alert-danger">@Model.Error</div> }

    @if (Model.Metrics != null)
    {
      <div class="flow-metric-grid mb-3">
        @{
          ViewData["FlowMetricLabel"] = "Pendientes";
          ViewData["FlowMetricValue"] = Model.Metrics.PendingApprovals.ToString();
          ViewData["FlowMetricVariant"] = "warning";
        }
        <partial name="Flow/_FlowMetricCard" />
        @{
          ViewData["FlowMetricLabel"] = "Aprobados (7d)";
          ViewData["FlowMetricValue"] = Model.Metrics.ApprovedLast7Days.ToString();
          ViewData["FlowMetricVariant"] = "success";
        }
        <partial name="Flow/_FlowMetricCard" />
        @{
          ViewData["FlowMetricLabel"] = "Rechazados (7d)";
          ViewData["FlowMetricValue"] = Model.Metrics.RejectedLast7Days.ToString();
          ViewData["FlowMetricVariant"] = "danger";
        }
        <partial name="Flow/_FlowMetricCard" />
      </div>
      <form method="post" asp-page-handler="SetThreshold" class="form-inline mb-3">
        @Html.AntiForgeryToken()
        <label class="mr-2">Umbral HITL (50-95):</label>
        <input type="number" name="threshold" value="@Model.ApprovalThreshold" min="50" max="95" class="form-control form-control-sm w-auto mr-2" />
        <button type="submit" class="btn btn-sm btn-secondary">Guardar política</button>
      </form>
    }

    @if (Model.Items.Count == 0)
    {
      <div class="card"><div class="card-body text-center text-muted py-5">
        <i class="fas fa-inbox fa-3x mb-3"></i><p>No hay decisiones pendientes de aprobación.</p>
      </div></div>
    }
    else
    {
      foreach (var item in Model.Items)
      {
        <div class="card card-outline card-warning mb-3">
          <div class="card-header">
            <strong>@item.DecisionType</strong>
            <span class="badge badge-@(item.RiskLevel == "Alto" ? "danger" : item.RiskLevel == "Medio" ? "warning" : "secondary") float-right">Riesgo @item.RiskLevel · Score @item.DecisionScore</span>
          </div>
          <div class="card-body">
            <p><strong>Acción propuesta:</strong> @item.RecommendedAction</p>
            <p><strong>Explicación:</strong> @item.Explanation</p>
            @if (item.CustomerName != null) { <p><i class="fas fa-building"></i> Cliente: <strong>@item.CustomerName</strong></p> }
            @if (item.DealTitle != null) { <p><i class="fas fa-handshake"></i> Deal: <strong>@item.DealTitle</strong></p> }
            <small class="text-muted">@item.CreatedAt.ToString("u") UTC</small>
          </div>
          <div class="card-footer d-flex flex-wrap gap-2">
            <form method="post" asp-page-handler="Approve" class="mr-2">
              <input type="hidden" name="approvalId" value="@item.Id" />
              @Html.AntiForgeryToken()
              <button type="submit" class="btn btn-success btn-sm"><i class="fas fa-check"></i> Aprobar y ejecutar</button>
            </form>
            <form method="post" asp-page-handler="Reject" class="mr-2">
              <input type="hidden" name="approvalId" value="@item.Id" />
              <input type="text" name="note" class="form-control form-control-sm d-inline-block w-auto" placeholder="Motivo rechazo" />
              @Html.AntiForgeryToken()
              <button type="submit" class="btn btn-outline-danger btn-sm"><i class="fas fa-times"></i> Rechazar</button>
            </form>
            <form method="post" asp-page-handler="Rollback">
              <input type="hidden" name="approvalId" value="@item.Id" />
              <input type="text" name="note" class="form-control form-control-sm d-inline-block w-auto" placeholder="Motivo rollback" required />
              @Html.AntiForgeryToken()
              <button type="submit" class="btn btn-outline-secondary btn-sm"><i class="fas fa-undo"></i> Rollback</button>
            </form>
          </div>
        </div>
      }
    }
</div>
