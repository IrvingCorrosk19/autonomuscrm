@page
@model AutonomusCRM.API.Pages.Account.LoginModel
@using Microsoft.Extensions.Options
@{
    ViewData["Title"] = "Iniciar sesión";
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Iniciar sesión — AutonomusFlow</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="~/css/flow-tokens.css" asp-append-version="true" />
  <link rel="stylesheet" href="~/css/flow-shell.css" asp-append-version="true" />
</head>
<body>
<a class="flow-skip-link" href="#flow-login-form">Saltar al formulario</a>
<div class="flow-auth-page">
  <div class="flow-auth-brand-panel" aria-hidden="false">
    <h1>Autonomus<span style="color:#5eead4">Flow</span></h1>
    <p>Autonomous Business Operating System — detecta, decide, actúa y aprende con supervisión humana y trazabilidad completa.</p>
    <ul class="flow-auth-trust-list">
      <li>Human-in-the-loop y auditoría de decisiones IA</li>
      <li>Multi-tenant enterprise con gobernanza</li>
      <li>Impacto de negocio medible en cada acción autónoma</li>
    </ul>
  </div>
  <div class="flow-auth-form-panel">
    <div class="flow-auth-card">
      <h2>Acceso seguro</h2>
      <p class="flow-auth-sub">Inicie sesión en su espacio de trabajo.</p>

      @if (Model.SsoEnabled)
      {
        <p style="font-size:13px;color:var(--flow-text-muted);margin-bottom:12px;">Preferido para equipos enterprise:</p>
        <a asp-page-handler="ExternalLogin" class="flow-btn flow-btn-secondary" style="width:100%;margin-bottom:16px;text-align:center;display:block;">
          Continuar con SSO corporativo
        </a>
        <p style="text-align:center;font-size:12px;color:var(--flow-text-muted);margin:16px 0;">o con email</p>
      }

      @if (!string.IsNullOrEmpty(Model.ErrorMessage))
      {
        <div class="flow-alert-error" role="alert">@Model.ErrorMessage</div>
      }

      @if (Model.ShowMfaStep)
      {
        <form method="post" asp-page-handler="VerifyMfa" id="flow-mfa-form">
          <input type="hidden" asp-for="MfaTempToken" />
          <input type="hidden" asp-for="TenantId" />
          <input type="hidden" asp-for="Email" />
          <div class="flow-field">
            <label asp-for="MfaCode">Código autenticador (6 dígitos)</label>
            <input asp-for="MfaCode" inputmode="numeric" autocomplete="one-time-code" maxlength="8" required aria-required="true" />
          </div>
          <button type="submit" class="flow-btn flow-btn-primary" style="width:100%;margin-top:8px;">
            Verificar MFA
          </button>
        </form>
        <p style="font-size:12px;color:var(--flow-text-muted);margin-top:12px;">
          <a asp-page="/Account/Login">Volver al inicio de sesión</a>
        </p>
      }
      else
      {
      <form method="post" id="flow-login-form">
        @if (Model.ShowTenantField)
        {
          <div class="flow-field">
            <label asp-for="TenantId">Espacio de trabajo (Tenant ID)</label>
            <input asp-for="TenantId" required aria-required="true" />
          </div>
        }
        else
        {
          <input type="hidden" asp-for="TenantId" />
        }
        <div class="flow-field">
          <label asp-for="Email">Email</label>
          <input asp-for="Email" type="email" autocomplete="username" required aria-required="true" />
        </div>
        <div class="flow-field">
          <label asp-for="Password">Contraseña</label>
          <input asp-for="Password" type="password" autocomplete="current-password" required aria-required="true" />
        </div>
        <button type="submit" class="flow-btn flow-btn-primary" style="width:100%;margin-top:8px;">
          Entrar
        </button>
      </form>
      }

      @if (Model.ShowDemoAccounts && Model.DemoAccounts.Count > 0)
      {
        <details class="flow-auth-demo">
          <summary>Cuentas demo (solo desarrollo)</summary>
          <div class="flow-auth-demo-body">
            @if (!string.IsNullOrEmpty(Model.DemoTenantName))
            {
              <p><strong>Tenant:</strong> @Model.DemoTenantName</p>
            }
            <ul style="margin:0;padding-left:16px;">
              @foreach (var account in Model.DemoAccounts)
              {
                <li><strong>@account.Role</strong> — <code>@account.Email</code></li>
              }
            </ul>
          </div>
        </details>
      }
      <p style="font-size:13px;color:var(--flow-text-muted);margin-top:20px;text-align:center;">
        <a href="/landing">Conocer AutonomusFlow</a> · <a href="/demo">Demo CEO 5 min</a> · <a href="/pricing">Pricing</a>
      </p>
    </div>
  </div>
</div>
</body>
</html>
