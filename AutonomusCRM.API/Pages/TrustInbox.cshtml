@page
@model AutonomusCRM.API.Pages.TrustInboxModel
@using AutonomusCRM.API.Infrastructure
@{
    ViewData["Title"] = L["Trust_PageTitle"].Value;
    ViewData["PageTitle"] = L["Trust_PageTitle"].Value;
    ViewData["PageKicker"] = L["Nav_Section_Command"].Value;
    ViewData["PageSubtitle"] = L["Trust_Subtitle"].Value;
}
<partial name="Flow/_FlowPageHeader" />

@if (!string.IsNullOrEmpty(Model.Message)) { <div class="alert alert-success">@Model.Message</div> }
@if (!string.IsNullOrEmpty(Model.Error)) { <div class="alert alert-danger">@Model.Error</div> }

@if (Model.SimulateMode && Model.Selected != null)
{
  <div class="alert alert-info" role="status">
    <strong>@L["Trust_SimulateMode"]</strong> @L["Trust_SimulateHint"]
  </div>
}

<div class="flow-trust-studio">
  <aside class="flow-trust-queue" aria-label="@L["Trust_QueueAria"]">
    <h3 class="flow-card-title" style="margin-bottom:12px;">@L["Trust_QueueTitle"]</h3>
    @if (Model.Queue.Count == 0)
    {
      ViewData["FlowEmptyTitle"] = L["Trust_QueueEmpty"].Value;
      ViewData["FlowEmptyMessage"] = L["Trust_QueueEmptyMessage"].Value;
      ViewData["FlowEmptyCta"] = null;
      <partial name="Flow/_FlowEmptyState" />
    }
    else
    {
      @foreach (var q in Model.Queue)
      {
        var sel = Model.Selected?.Id == q.Item.Id;
        <a href="/TrustInbox?id=@q.Item.Id" class="flow-trust-queue-item sev-@q.Severity @(sel ? "is-selected" : "")">
          <strong>@q.Item.DecisionType</strong>
          <div style="font-size:12px;color:var(--flow-text-muted);">@q.Item.RecommendedAction</div>
          <div style="font-size:11px;margin-top:4px;">
            <span class="flow-revenue-priority">@q.Severity</span>
            @L["Common_Score"] @q.Item.DecisionScore · @q.Item.CreatedAt.ToString("g")
          </div>
        </a>
      }
    }
  </aside>

  <main class="flow-trust-detail" aria-label="@L["Trust_DetailAria"]">
    @if (Model.Selected == null)
    {
      ViewData["FlowEmptyTitle"] = L["Trust_SelectDecision"].Value;
      ViewData["FlowEmptyMessage"] = L["Trust_SelectHint"].Value;
      <partial name="Flow/_FlowEmptyState" />
    }
    else
    {
      var item = Model.Selected;
      <section class="flow-card">
        <header class="flow-card-header">
          <div>
            <h3 class="flow-card-title">@item.DecisionType</h3>
            <p class="flow-card-subtitle">@L["Common_Risk"] @item.RiskLevel · @L["Common_Score"] @item.DecisionScore</p>
          </div>
        </header>
        <div class="flow-card-body">
          <p><strong>@L["Trust_ProposedAction"]</strong> @item.RecommendedAction</p>
          <p><strong>@L["Trust_Explanation"]</strong> @item.Explanation</p>
          @if (item.CustomerName != null) { <p>@L["Trust_Customer"] <strong>@item.CustomerName</strong></p> }
          @if (item.DealTitle != null) { <p>@L["Trust_Deal"] <strong>@item.DealTitle</strong></p> }
          <p class="text-muted" style="font-size:12px;">@item.CreatedAt.ToString("u") UTC</p>
          <h4 style="font-size:13px;margin-top:16px;">@L["Trust_WhyApproval"]</h4>
          <partial name="Flow/_FlowExplainability" model="Model.TrustExplainability" />
          <h4 style="font-size:13px;margin-top:16px;">@L["Trust_OutcomePreview"]</h4>
          <partial name="Flow/_FlowOutcomeChain" model="Model.SelectedOutcome" />
          @{
            ViewData["TrustApprovalId"] = item.Id;
            ViewData["TrustShowSimulate"] = true;
            ViewData["TrustShowRollback"] = true;
          }
          <partial name="Flow/_FlowTrustActions" />
          @if (item.CustomerId is Guid trustCustomerId)
          {
            ViewData["FlowInsightType"] = FlowInsightTypes.Risk;
            ViewData["FlowInsightCustomerId"] = trustCustomerId;
            ViewData["FlowInsightCustomerName"] = item.CustomerName ?? L["Insight_DefaultCustomer"].Value;
            ViewData["FlowInsightReturnUrl"] = $"/TrustInbox?id={item.Id}";
            ViewData["FlowInsightCompact"] = true;
            <h4 style="font-size:13px;margin-top:16px;">@L["Insight_ActionsFor", item.CustomerName ?? L["Insight_DefaultCustomer"].Value]</h4>
            <partial name="Flow/_FlowInsightActions" />
          }
        </div>
      </section>
    }
  </main>

  <aside class="flow-trust-context" aria-label="@L["Trust_HitlPolicy"]">
    @if (Model.Metrics != null)
    {
      <section class="flow-card flow-policy-panel mb-3">
        <header class="flow-card-header"><h3 class="flow-card-title">@L["Revenue_Health"]</h3></header>
        <div class="flow-card-body">
          <dl>
            <dt>@L["Trust_Pending"]</dt><dd>@Model.Metrics.PendingApprovals</dd>
            <dt>@L["Trust_Approved"] (7d)</dt><dd>@Model.Metrics.ApprovedLast7Days</dd>
            <dt>@L["Trust_Rejected"] (7d)</dt><dd>@Model.Metrics.RejectedLast7Days</dd>
          </dl>
        </div>
      </section>
    }
    <section class="flow-card flow-policy-panel">
      <header class="flow-card-header"><h3 class="flow-card-title">@L["Trust_HitlPolicy"]</h3></header>
      <div class="flow-card-body">
        <form method="post" asp-page-handler="SetThreshold">
          @Html.AntiForgeryToken()
          <label>@L["Trust_Threshold"]</label>
          <input type="range" name="threshold" min="50" max="95" value="@Model.ApprovalThreshold" oninput="this.nextElementSibling.value=this.value" />
          <output>@Model.ApprovalThreshold</output>
          <button type="submit" class="flow-btn flow-btn-secondary" style="margin-top:8px;">@L["Trust_SavePolicy"]</button>
        </form>
      </div>
    </section>
  </aside>
</div>
