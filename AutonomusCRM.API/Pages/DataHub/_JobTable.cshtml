@model IReadOnlyList<AutonomusCRM.Application.DataHub.DataHubJobSummaryDto>
<section class="flow-card">
  <div class="flow-card-body">
    @if (Model.Count == 0)
    {
      <p class="text-muted">No import jobs yet. <a href="/DataHub/Import">Start an import</a>.</p>
    }
    else
    {
      <table class="table table-sm table-hover">
        <thead>
          <tr>
            <th>File</th><th>Entity</th><th>Status</th><th>Rows</th><th>Success</th><th>Failed</th><th>Progress</th><th>Created</th><th></th>
          </tr>
        </thead>
        <tbody>
        @foreach (var job in Model)
        {
          <tr data-dh-job-row="@job.Id">
            <td>@job.FileName</td>
            <td>@job.TargetEntity</td>
            <td><span class="badge badge-@(job.Status.Contains("Completed") ? "success" : job.Status == "Failed" ? "danger" : "secondary")" data-dh-row-status>@job.Status</span></td>
            <td>@job.TotalRows</td>
            <td>@job.SuccessRows</td>
            <td>@job.FailedRows</td>
            <td>
              <div class="progress" style="height:8px;min-width:80px;">
                <div class="progress-bar" data-dh-bar style="width:@(job.ProgressPercent)%"></div>
              </div>
              <small class="text-muted" data-dh-pct>@job.ProgressPercent%</small>
            </td>
            <td>@job.CreatedAt.ToLocalTime().ToString("g")</td>
            <td><a href="/DataHub/Job/@job.Id">Open</a></td>
          </tr>
        }
        </tbody>
      </table>
    }
  </div>
</section>
