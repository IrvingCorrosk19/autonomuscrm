@page "/DataHub/Wizard"
@model AutonomusCRM.API.Pages.DataHub.WizardModel
@{
    ViewData["Title"] = "Import Wizard";
    ViewData["PageTitle"] = "Guided Import";
    ViewData["PageKicker"] = "Data Hub";
    ViewData["PageSubtitle"] = "Import your data in 10 simple steps — no technical knowledge required";
    var steps = new[] { "Upload", "Analyze", "Detect", "Map", "Rules", "Validate", "Preview", "Confirm", "Import", "Done" };
}
<partial name="Flow/_FlowPageHeader" />

<div class="dh-wizard">
  <div class="dh-wizard-steps" role="list" aria-label="Import steps">
    @for (var i = 0; i < steps.Length; i++)
    {
      var n = i + 1;
      var cls = n == Model.CurrentStep ? "is-active" : n < Model.CurrentStep ? "is-done" : "";
      <div class="dh-wizard-step @cls" role="listitem">@n. @steps[i]</div>
    }
  </div>

  @if (!string.IsNullOrEmpty(Model.Message))
  {
    <div class="alert alert-success">@Model.Message</div>
  }
  @if (!string.IsNullOrEmpty(Model.Error))
  {
    <div class="alert alert-danger">@Model.Error</div>
  }

  @* Step 1: Upload *@
  @if (Model.CurrentStep == 1)
  {
    <div class="flow-card"><div class="flow-card-body">
      <h3 class="flow-card-title">Step 1 — Upload your file</h3>
      <p class="text-muted">CSV, Excel, JSON or TXT. We handle the rest.</p>
      <form method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()
        <input type="hidden" name="step" value="1" />
        <div class="form-group">
          <label>What are you importing?</label>
          <select name="targetEntity" class="form-control">
            @foreach (var e in Model.Entities) { <option value="@e">@e</option> }
          </select>
        </div>
        <div class="form-group">
          <label>Load mode</label>
          <select name="loadMode" class="form-control">
            @foreach (var m in Model.LoadModes)
            {
              <option value="@m" selected="@(m == Model.SelectedLoadMode)">@m</option>
            }
          </select>
          <small class="form-text text-muted">Insert Only · Upsert · Skip Duplicates · Dry Run (no writes)</small>
        </div>
        <div class="form-check mb-3">
          <input type="checkbox" name="dryRun" value="true" class="form-check-input" id="dryRunCheck" @(Model.IsDryRun ? "checked" : null) />
          <label class="form-check-label" for="dryRunCheck">Dry run — validate only, do not write to CRM</label>
        </div>
        <div class="dh-dropzone mb-3">
          <input type="file" name="file" required accept=".csv,.json,.xlsx,.xls,.txt" class="form-control-file" />
          <p class="mt-2 mb-0 text-muted">Drag &amp; drop or click to browse (max 100 MB)</p>
        </div>
        <button type="submit" class="flow-btn flow-btn-primary">Upload &amp; Continue</button>
      </form>
    </div></div>
  }

  @* Step 2-3: AI Analysis *@
  @if (Model.CurrentStep is >= 2 and <= 3 && Model.JobId.HasValue)
  {
    <div class="dh-ai-panel">
      <h4>✨ Smart Analysis</h4>
      @if (Model.AiAnalysis != null)
      {
        <p>@Model.AiAnalysis.Summary</p>
        <p><strong>Suggested destination:</strong> @Model.AiAnalysis.SuggestedTargetEntity
          <span class="dh-confidence"><span class="dh-confidence-bar"><span class="dh-confidence-fill" style="width:@(Model.AiAnalysis.OverallConfidencePercent)%"></span></span>@Model.AiAnalysis.OverallConfidencePercent%</span></p>
        @if (Model.AiAnalysis.DetectedContentTypes.Any())
        {
          <p>This file appears to contain: @string.Join(", ", Model.AiAnalysis.DetectedContentTypes.Select(t => "✓ " + t))</p>
        }
        @if (Model.AiAnalysis.DetectedIssues.Any())
        {
          <ul class="text-warning mb-0">@foreach (var issue in Model.AiAnalysis.DetectedIssues) { <li>@issue</li> }</ul>
        }
      }
      else
      {
        <p>Analyzing your file…</p>
      }
    </div>
    @if (Model.ColumnDetections.Any())
    {
      <div class="flow-card"><div class="flow-card-body">
        <h3 class="flow-card-title">Column detection</h3>
        @foreach (var col in Model.ColumnDetections)
        {
          <div class="dh-mapping-row">
            <span>@col.SourceColumn</span>
            <span class="dh-arrow">→</span>
            <span>@(col.SuggestedTargetField ?? col.DetectedType)</span>
            <span class="dh-confidence"><span class="dh-confidence-bar"><span class="dh-confidence-fill" style="width:@(col.ConfidencePercent)%"></span></span>@col.ConfidencePercent%</span>
          </div>
        }
      </div></div>
    }
    <form method="post" class="mt-3">
      @Html.AntiForgeryToken()
      <input type="hidden" name="jobId" value="@Model.JobId" />
      @if (Model.CurrentStep == 2)
      {
        <input type="hidden" name="step" value="2" />
        <button type="submit" class="flow-btn flow-btn-primary">Run Smart Analysis</button>
      }
      else
      {
        <input type="hidden" name="step" value="3" />
        <a href="/DataHub/Wizard?jobId=@Model.JobId&amp;step=4" class="flow-btn flow-btn-primary">Continue to Mapping</a>
      }
    </form>
  }

  @* Step 4: Mapping *@
  @if (Model.CurrentStep == 4 && Model.JobId.HasValue)
  {
    <div class="flow-card"><div class="flow-card-body">
      <h3 class="flow-card-title">Step 4 — Map your columns</h3>
      <form method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" name="step" value="4" />
        <input type="hidden" name="jobId" value="@Model.JobId" />
        @for (var i = 0; i < Model.Mappings.Count; i++)
        {
          <div class="dh-mapping-row">
            <input name="Mappings[@i].SourceColumn" value="@Model.Mappings[i].SourceColumn" class="form-control form-control-sm" readonly />
            <span class="dh-arrow">→</span>
            <select name="Mappings[@i].TargetField" class="form-control form-control-sm">
              @foreach (var f in Model.TargetFields) { <option value="@f.Name" selected="@(f.Name == Model.Mappings[i].TargetField)">@f.Label</option> }
            </select>
            <input type="hidden" name="Mappings[@i].IsRequired" value="@Model.Mappings[i].IsRequired" />
          </div>
        }
        <button type="submit" class="flow-btn flow-btn-primary mt-3">Save &amp; Continue</button>
      </form>
    </div></div>
  }

  @* Step 5: Rules *@
  @if (Model.CurrentStep == 5 && Model.JobId.HasValue)
  {
    <div class="flow-card"><div class="flow-card-body">
      <h3 class="flow-card-title">Step 5 — Cleaning rules</h3>
      <p class="text-muted">These rules run automatically — no code required.</p>
      <ul>
        @foreach (var rule in Model.VisualRules)
        {
          <li><strong>@rule.Name</strong> — @rule.ActionType @(rule.ActionValue != null ? $"→ {rule.ActionValue}" : "")</li>
        }
      </ul>
      <a href="/DataHub/Wizard?jobId=@Model.JobId&amp;step=6" class="flow-btn flow-btn-primary">Continue to Validation</a>
    </div></div>
  }

  @* Step 6-7: Validate & Preview *@
  @if (Model.CurrentStep is >= 6 and <= 7 && Model.JobId.HasValue)
  {
    @if (Model.CleaningSummary != null)
    {
      <div class="dh-stat-grid">
        <div class="dh-stat-card"><small>Total records</small><strong>@Model.CleaningSummary.TotalRows.ToString("N0")</strong></div>
        <div class="dh-stat-card is-valid"><small>Valid</small><strong>@Model.CleaningSummary.ValidRows.ToString("N0")</strong></div>
        <div class="dh-stat-card is-warn"><small>Warnings</small><strong>@Model.CleaningSummary.WarningRows.ToString("N0")</strong></div>
        <div class="dh-stat-card is-error"><small>Errors</small><strong>@Model.CleaningSummary.ErrorRows.ToString("N0")</strong></div>
        <div class="dh-stat-card"><small>Duplicates</small><strong>@Model.CleaningSummary.DuplicateRows.ToString("N0")</strong></div>
      </div>
    }
    <form method="post" class="mb-3">
      @Html.AntiForgeryToken()
      <input type="hidden" name="jobId" value="@Model.JobId" />
      <input type="hidden" name="step" value="6" />
      <button type="submit" name="handler" value="Validate" class="flow-btn flow-btn-primary">Run Validation</button>
      <button type="submit" name="handler" value="AutoFix" class="flow-btn flow-btn-secondary">Fix automatically</button>
    </form>
    @if (Model.CurrentStep == 7)
    {
      <div class="flow-card mt-3"><div class="flow-card-body">
        <h3 class="flow-card-title">Step 7 — Editable preview</h3>
        <p class="text-muted">Fix errors inline, then revalidate without leaving the wizard.</p>
        @if (Model.DuplicateScan?.TotalGroups > 0)
        {
          <div class="alert alert-warning">
            @Model.DuplicateScan.TotalGroups duplicate group(s) detected.
            <a href="/DataHub/Duplicates?jobId=@Model.JobId">Open Duplicate Resolution Center</a>
          </div>
        }
        @if (Model.PreviewRows.Any() && Model.PreviewColumns.Any())
        {
          <form method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="jobId" value="@Model.JobId" />
            <input type="hidden" name="step" value="7" />
            <div class="table-responsive" style="max-height:420px;overflow:auto;">
              <table class="table table-sm table-bordered">
                <thead class="thead-light"><tr>
                  <th>#</th><th>Status</th>
                  @foreach (var col in Model.PreviewColumns) { <th>@col</th> }
                </tr></thead>
                <tbody>
                @for (var i = 0; i < Model.PreviewRows.Count; i++)
                {
                  var row = Model.PreviewRows[i];
                  var data = row.TransformedData.Count > 0 ? row.TransformedData : row.RawData;
                  var statusCls = row.Status == "Invalid" || row.Status == "Failed" ? "table-danger"
                    : row.Status == "Skipped" ? "table-warning" : "";
                  <tr class="@statusCls">
                    <td>
                      @row.RowNumber
                      <input type="hidden" name="PreviewUpdates[@i].RowNumber" value="@row.RowNumber" />
                    </td>
                    <td><span class="badge badge-secondary">@row.Status</span></td>
                    @foreach (var col in Model.PreviewColumns)
                    {
                      <td><input name="PreviewUpdates[@i].Data[@col]" value="@(data.GetValueOrDefault(col) ?? "")" class="form-control form-control-sm" /></td>
                    }
                  </tr>
                }
                </tbody>
              </table>
            </div>
            <div class="mt-3">
              <button type="submit" name="handler" value="SavePreview" class="flow-btn flow-btn-primary">Save edits</button>
              <button type="submit" name="handler" value="Revalidate" class="flow-btn flow-btn-secondary">Revalidate</button>
            </div>
          </form>
        }
        else
        {
          <p class="text-muted">No preview rows available. Run validation first.</p>
        }
      </div></div>
      <a href="/DataHub/Wizard?jobId=@Model.JobId&amp;step=8" class="flow-btn flow-btn-primary mt-3">Continue to Confirm</a>
    }
    else if (Model.CurrentStep == 6)
    {
      <a href="/DataHub/Wizard?jobId=@Model.JobId&amp;step=7" class="flow-btn flow-btn-secondary">Skip to Preview</a>
    }
  }

  @* Step 8-9: Confirm & Import *@
  @if (Model.CurrentStep is >= 8 and <= 9 && Model.JobId.HasValue)
  {
    <div class="flow-card"><div class="flow-card-body">
      <h3 class="flow-card-title">@(Model.CurrentStep == 8 ? "Step 8 — Confirm import" : "Step 9 — Importing…")</h3>
      @if (Model.CurrentStep == 8)
      {
        <form method="post" class="mb-3">
          @Html.AntiForgeryToken()
          <input type="hidden" name="jobId" value="@Model.JobId" />
          <input type="hidden" name="step" value="8" />
          <div class="form-group">
            <label>Load mode</label>
            <select name="loadMode" class="form-control" style="max-width:280px;">
              @foreach (var m in Model.LoadModes)
              {
                <option value="@m" selected="@(m == Model.SelectedLoadMode)">@m</option>
              }
            </select>
          </div>
          <div class="form-check mb-3">
            <input type="checkbox" name="dryRun" value="true" class="form-check-input" id="confirmDryRun" @(Model.IsDryRun ? "checked" : null) />
            <label class="form-check-label" for="confirmDryRun">Dry run</label>
          </div>
          @if (Model.CleaningSummary != null)
          {
            <p class="text-muted">@Model.CleaningSummary.ValidRows valid · @Model.CleaningSummary.ErrorRows errors · @Model.CleaningSummary.DuplicateRows duplicates</p>
          }
          <button type="submit" class="flow-btn flow-btn-primary btn-lg">Confirm &amp; Start Import</button>
        </form>
      }
      @if (Model.CurrentStep == 9)
      {
        <div data-dh-progress data-job-id="@Model.JobId" data-tenant-id="@Model.TenantId" class="mb-3">
          <p>Progress: <strong data-dh-pct>@(Model.Metrics?.ProgressPercent ?? 0)%</strong>
            · <span data-dh-processed>@(Model.Metrics != null ? Model.JobId.HasValue ? "" : "" : "")</span>
            · <span data-dh-rpm>@(Model.Metrics?.RowsPerMinute ?? 0)</span> rows/min
            · ETA <span data-dh-eta>@(Model.Metrics?.EstimatedRemaining?.ToString(@"mm\mss\s") ?? "—")</span>
          </p>
          <div class="progress mb-3" style="height:14px;">
            <div class="progress-bar progress-bar-striped progress-bar-animated" data-dh-bar style="width:@(Model.Metrics?.ProgressPercent ?? 0)%"></div>
          </div>
          <div class="dh-stat-grid">
            <div class="dh-stat-card is-error"><small>Errors</small><strong data-dh-failed>0</strong></div>
            <div class="dh-stat-card"><small>Pending</small><strong data-dh-pending>0</strong></div>
          </div>
        </div>
        <p>Your import is running live. <a href="/DataHub/Job/@Model.JobId">Open job monitor</a></p>
        <a href="/DataHub/Wizard?jobId=@Model.JobId&amp;step=10" class="flow-btn flow-btn-primary">View results</a>
      }
    </div></div>
  }

  @* Step 10: Done *@
  @if (Model.CurrentStep == 10 && Model.JobId.HasValue)
  {
    <div class="flow-card"><div class="flow-card-body py-4">
      @if (Model.ImportSummary != null)
      {
        ViewData["TenantId"] = Model.TenantId;
        <partial name="DataHub/_ImportSummaryDashboard" model="Model.ImportSummary" />
      }
      else
      {
        <p class="text-muted text-center">Import still processing. <a href="/DataHub/Job/@Model.JobId">Check job status</a></p>
      }
      <div class="text-center mt-4">
        <a href="/DataHub/Templates" class="flow-btn flow-btn-secondary">Save as template</a>
        <a href="/DataHub/Wizard" class="flow-btn flow-btn-secondary">New import</a>
      </div>
    </div></div>
  }
</div>

@section Scripts {
  @if (Model.CurrentStep == 9 && Model.JobId.HasValue)
  {
    <script src="https://cdn.jsdelivr.net/npm/@@microsoft/signalr@8.0.7/dist/browser/signalr.min.js" crossorigin="anonymous"></script>
    <script src="~/js/datahub-progress.js" asp-append-version="true"></script>
  }
}
