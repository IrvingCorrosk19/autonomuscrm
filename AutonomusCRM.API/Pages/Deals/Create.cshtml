@page "/Deals/Create"
@model AutonomusCRM.API.Pages.Deals.CreateModel
@using AutonomusCRM.Application.Customers.Queries
@{
    ViewData["Title"] = L["Deals_Create_Title"].Value;
    ViewData["PageTitle"] = L["Deals_Create_Title"].Value;
    ViewData["PageKicker"] = L["Deals_Create_Kicker"].Value;
    ViewData["PageSubtitle"] = L["Deals_Create_CardSubtitle"].Value;
    ViewData["PageActionsHtml"] = $"<a href=\"/Deals\" class=\"flow-btn flow-btn-secondary\">{L["Btn_Cancel"].Value}</a>";
    ViewData["FormErrorMessage"] = Model.ErrorMessage;
    ViewData["FormSuccessMessage"] = Model.SuccessMessage;
}

<partial name="Flow/_FlowPageHeader" />
<partial name="Shared/_FlowFormAlerts" />

<section class="flow-card flow-form-card">
  <header class="flow-card-header">
    <h2 class="flow-card-title" id="deal-create-title">@L["Deals_Create_CardTitle"]</h2>
    <p class="flow-page-subtitle mb-0">@L["Deals_Create_CardSubtitle"]</p>
  </header>
  <div class="flow-card-body">
    <form method="post" asp-page-handler="Create" class="flow-form" aria-labelledby="deal-create-title">
      <div class="flow-form-grid">
        <div class="flow-form-field flow-form-field--full">
          <label class="flow-form-label" for="deal-customer">@L["Common_Customer"] @L["Common_RequiredStar"]</label>
          <select id="deal-customer" name="customerId" class="flow-form-control" required aria-describedby="deal-customer-help">
            <option value="">@L["Form_SelectCustomer"]</option>
            @foreach (var customer in Model.Customers)
            {
              <option value="@customer.Id" selected="@(Model.CustomerId == customer.Id)">@customer.Name @(!string.IsNullOrEmpty(customer.Company) ? $"({customer.Company})" : "")</option>
            }
          </select>
          @if (!Model.Customers.Any())
          {
            <p class="flow-form-help" id="deal-customer-help">
              @L["Deals_Create_NoCustomers"] <a href="/Customers/Create">@L["Deals_Create_CreateCustomerFirst"]</a>
            </p>
          }
        </div>
        <div class="flow-form-field">
          <label class="flow-form-label" for="deal-title">@L["Form_TitleRequired"]</label>
          <input type="text" id="deal-title" name="title" class="flow-form-control" required value="@Model.Title" placeholder="@L["Deals_Create_PlaceholderTitle"]" />
        </div>
        <div class="flow-form-field">
          <label class="flow-form-label" for="deal-amount">@L["Form_AmountRequired"]</label>
          <input type="number" id="deal-amount" name="amount" class="flow-form-control" step="0.01" min="0" required value="@Model.Amount" placeholder="@L["Deals_Create_PlaceholderAmount"]" />
        </div>
        <div class="flow-form-field flow-form-field--full">
          <label class="flow-form-label" for="deal-description">@L["Form_Description"]</label>
          <textarea id="deal-description" name="description" class="flow-form-control" rows="4" placeholder="@L["Deals_Create_PlaceholderDesc"]">@Model.Description</textarea>
        </div>
      </div>
      <div class="flow-form-actions">
        <button type="submit" class="flow-btn flow-btn-primary" @(!Model.Customers.Any() ? "disabled" : "")>@L["Deals_Create_Submit"]</button>
        <a href="/Deals" class="flow-btn flow-btn-secondary">@L["Btn_Cancel"]</a>
      </div>
    </form>
  </div>
</section>

<p class="flow-form-footer">@L["Deals_Create_Footer"]</p>
