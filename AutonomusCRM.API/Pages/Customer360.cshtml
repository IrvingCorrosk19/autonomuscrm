@page
@model AutonomusCRM.API.Pages.Customer360Model
@using AutonomusCRM.API.Infrastructure
@{
    ViewData["Title"] = L["Customer360_PageTitle"].Value;
    ViewData["PageTitle"] = L["Customer360_DirectoryTitle"].Value;
    ViewData["PageKicker"] = L["Nav_Section_Customers"].Value;
    ViewData["PageSubtitle"] = L["Customer360_PageTitle"].Value;
}
<partial name="Flow/_FlowPageHeader" />
<div class="flow-page-body">
  <form method="get" class="flow-filters">
    <input name="q" value="@Model.Q" placeholder="@L["Customer360_SearchPlaceholder"]" aria-label="@L["Btn_Search"]" />
    <button type="submit" class="flow-btn flow-btn-primary">@L["Btn_Search"]</button>
  </form>
  @if (Model.Duplicates.Count > 0)
  {
    <div class="alert alert-warning"><strong>Identity Resolution:</strong> @Model.Duplicates.Count grupo(s) duplicados.</div>
  }
  @if (Model.Results.Count == 0)
  {
    ViewData["FlowEmptyTitle"] = L["Customer360_NoCustomersTitle"].Value;
    ViewData["FlowEmptyMessage"] = L["Customer360_NoCustomersMessage"].Value;
    <partial name="Flow/_FlowEmptyState" />
  }
  else
  {
    <div class="flow-c360-directory">
      @foreach (var c in Model.Results)
      {
        <section class="flow-card">
          <header class="flow-card-header"><h3 class="flow-card-title">@c.Name</h3></header>
          <div class="flow-card-body" style="font-size:13px;">
            <p>@(c.Email ?? "—") · Pipeline @c.OpenPipeline.ToString("C") · Won @c.WonRevenue.ToString("C")</p>
            <p>Uso 30d: @c.UsageEvents30d · Churn: @(c.ChurnRisk?.ToString("0") ?? "—")%</p>
          </div>
          <footer class="flow-card-footer">
            <a href="/customers/@c.CustomerId/360" class="flow-btn flow-btn-primary">@L["Customer360_Enterprise360"]</a>
            <a href="/Customers/Details/@c.CustomerId" class="flow-btn flow-btn-secondary">CRM</a>
          </footer>
          @if (c.ChurnRisk >= 40 || c.WonRevenue >= 10_000m) {
            ViewData["FlowInsightType"] = FlowInsightMapper.FromCustomer360(c);
            ViewData["FlowInsightCustomerId"] = c.CustomerId;
            ViewData["FlowInsightCustomerName"] = c.Name;
            ViewData["FlowInsightReturnUrl"] = "/Customer360";
            ViewData["FlowInsightCompact"] = true;
            <div class="flow-card-body" style="padding-top:0;border-top:1px solid var(--flow-border-subtle);">
              <partial name="Flow/_FlowInsightActions" />
            </div>
          }
        </section>
      }
    </div>
  }
</div>
