@page "/stories"
@model AutonomusCRM.API.Pages.StoriesModel
@{
    Layout = "Shared/Marketing/_MarketingLayout";
    ViewData["Title"] = L["Marketing_Stories_PageTitle"].Value;
}
<section class="marketing-hero" style="padding-bottom:24px;">
  <h1>@L["Marketing_Stories_HeroTitle"]</h1>
  <p class="lead">@L["Marketing_Stories_HeroLead"]</p>
</section>

<section class="marketing-section" style="padding-top:0;">
  <div class="marketing-story-flow">
    <article class="marketing-story-step">
      <h4>@L["Marketing_Stories_Step1Title"]</h4>
      <p>@L["Marketing_Stories_Step1Desc"]</p>
    </article>
    <article class="marketing-story-step">
      <h4>@L["Marketing_Stories_Step2Title"]</h4>
      <p>@L["Marketing_Stories_Step2Desc"]</p>
    </article>
    <article class="marketing-story-step">
      <h4>@L["Marketing_Stories_Step3Title"]</h4>
      <p>@L["Marketing_Stories_Step3Desc"]</p>
    </article>
    <article class="marketing-story-step">
      <h4>@L["Marketing_Stories_Step4Title"]</h4>
      <p>@L["Marketing_Stories_Step4Desc"]</p>
    </article>
    <article class="marketing-story-step" style="border-left-color:var(--flow-success);">
      <h4>@L["Marketing_Stories_Step5Title"]</h4>
      <p>@L["Marketing_Stories_Step5Desc"]</p>
    </article>
  </div>

  <div class="marketing-grid-3" style="margin-top:48px;">
    <article class="marketing-card">
      <h3>@L["Marketing_Stories_BeforeTitle"]</h3>
      <p>@L["Marketing_Stories_BeforeDesc"]</p>
    </article>
    <article class="marketing-card">
      <h3>@L["Marketing_Stories_WithTitle"]</h3>
      <p>@L["Marketing_Stories_WithDesc"]</p>
    </article>
    <article class="marketing-card">
      <h3>@L["Marketing_Stories_MetricsTitle"]</h3>
      <p>@L["Marketing_Stories_MetricsDesc"]</p>
    </article>
  </div>

  <p style="text-align:center;margin-top:32px;">
    <a href="/demo" class="flow-btn flow-btn-primary">@L["Marketing_Stories_CtaDemo"]</a>
    <a href="/roi" class="flow-btn flow-btn-secondary">@L["Marketing_Stories_CtaRoi"]</a>
  </p>
</section>
