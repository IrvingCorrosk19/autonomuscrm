@using System.Globalization
@{
    Layout = null;
    var title = ViewData["Title"]?.ToString() ?? "AutonomusFlow";
    var uiCulture = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
}
<!DOCTYPE html>
<html lang="@uiCulture">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content="@(ViewData["MetaDescription"] ?? L["Marketing_Layout_MetaDefault"].Value)" />
  <title>@title — AutonomusFlow</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="~/css/flow-tokens.css" asp-append-version="true" />
  <link rel="stylesheet" href="~/css/flow-shell.css" asp-append-version="true" />
  <link rel="stylesheet" href="~/css/marketing.css" asp-append-version="true" />
</head>
<body class="marketing-page">
  <header class="marketing-nav">
    <a href="/landing" class="marketing-nav-brand">Autonomus<span>Flow</span></a>
    <nav class="marketing-nav-links" aria-label="Marketing">
      <a href="/landing">@L["Marketing_Layout_Product"]</a>
      <a href="/roi">@L["Marketing_Layout_Roi"]</a>
      <a href="/demo">@L["Marketing_Layout_Demo"]</a>
      <a href="/stories">@L["Marketing_Layout_Stories"]</a>
      <a href="/pricing">@L["Marketing_Layout_Pricing"]</a>
      <partial name="_LanguageSelector" />
      <a href="/Account/Login" class="flow-btn flow-btn-primary" style="padding:8px 16px;font-size:13px;">@L["Marketing_Layout_SignIn"]</a>
    </nav>
  </header>
  @RenderBody()
  <footer class="marketing-footer">
    @L["Marketing_Layout_Footer"] <a href="/demo">@L["Marketing_Layout_TryDemo"]</a>
  </footer>
  @RenderSection("Scripts", required: false)
</body>
</html>
